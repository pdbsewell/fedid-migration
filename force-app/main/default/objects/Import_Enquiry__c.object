    </nameField>
    <pluralLabel>Import Enquiries</pluralLabel>
    <recordTypeTrackHistory>true</recordTypeTrackHistory>
    <recordTypes>
        <fullName>MRO</fullName>
        <active>true</active>
        <description>Monash Research Office</description>
        <label>MRO</label>
        <picklistValues>
            <picklist>Status__c</picklist>
            <values>
                <fullName>Failed</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>In Progress</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>New</fullName>
                <default>true</default>
            </values>
            <values>
                <fullName>Success</fullName>
                <default>false</default>
            </values>
        </picklistValues>
    </recordTypes>
