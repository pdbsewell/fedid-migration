    <label>Import Enquiry</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Batch_Reference__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>Status__c</columns>
        <columns>Record_Log__c</columns>
        <columns>Enquiry_Subject__c</columns>
        <columns>Enquiry_Type__c</columns>
        <columns>Enquiry_Category_Level_1__c</columns>
        <columns>Enquiry_Origin__c</columns>
        <columns>Enquiry_Status__c</columns>
        <columns>Enquiry_Group__c</columns>
        <filterScope>Everything</filterScope>
        <label>All Records</label>
    </listViews>
    <listViews>
        <fullName>MRO_Failed_Records</fullName>
        <columns>NAME</columns>
        <columns>Batch_Reference__c</columns>
        <columns>Status__c</columns>
        <columns>CREATEDBY_USER</columns>
        <columns>CREATED_DATE</columns>
        <columns>Record_Log__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RECORDTYPE</field>
            <operation>equals</operation>
            <value>Import_Enquiry__c.MRO</value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operation>equals</operation>
            <value>Failed</value>
        </filters>
        <label>MRO Failed Records</label>
        <sharedTo>
            <group>Monash_Research_Office</group>
        </sharedTo>
    </listViews>
    <listViews>
        <fullName>test</fullName>
        <columns>NAME</columns>
        <columns>Status__c</columns>
        <columns>CREATEDBY_USER</columns>
        <columns>Batch_Reference__c</columns>
        <columns>Record_Log__c</columns>
        <columns>OBJECT_ID</columns>
        <columns>Enquiry_Subject__c</columns>
        <columns>Enquiry_Owner__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RECORDTYPE</field>
            <operation>equals</operation>
            <value>Import_Enquiry__c.MRO</value>
        </filters>
        <filters>
            <field>CREATED_DATE</field>
            <operation>greaterThan</operation>
            <value>7/1/2024 12:00 AM</value>
        </filters>
        <filters>
            <field>Enquiry_Category_Level_1__c</field>
            <operation>equals</operation>
            <value>Reports</value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operation>notEqual</operation>
            <value>Success</value>
        </filters>
        <label>MRO Import Enquiries - NEW Status</label>
        <sharedTo>
            <group>MRO_Awards</group>
            <group>Sys_Admin</group>
        </sharedTo>
    </listViews>
    <nameField>
        <displayFormat>Imp{00000}</displayFormat>
