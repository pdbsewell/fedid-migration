<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>custom setting for IT Account Disabled field encryption</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Encrypt__c</fullName>
        <defaultValue>true</defaultValue>
        <description>By default it is checked. This drives the encryption of  IT Account Disabled</description>
        <label>Encrypt</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Role__c</fullName>
        <description>This will contain the roles where IT Account Disabled will be masked when displayed.</description>
        <label>Role</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <label>Field Encryption IT Account Disabled</label>
    <visibility>Public</visibility>
</CustomObject>
