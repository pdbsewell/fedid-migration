    <fields>
        <fullName>Work_Experience__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Link to work experience record if relevant</description>
        <inlineHelpText>Link to work experience record if relevant</inlineHelpText>
        <label>Work Experience</label>
        <lookupFilter>
            <active>true</active>
            <errorMessage>No work experience records assigned to the contact.</errorMessage>
            <filterItems>
                <field>$Source.Contact__c</field>
                <operation>equals</operation>
                <valueField>Work_Experience__c.Contact__c</valueField>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Work_Experience__c</referenceTo>
        <relationshipLabel>Contact Documents</relationshipLabel>
        <relationshipName>Contact_Documents</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
