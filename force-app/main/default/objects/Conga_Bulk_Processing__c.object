    </fields>
    <fields>
        <fullName>Full_Address__c</fullName>
        <externalId>false</externalId>
        <formula>Street__c + &apos;, &apos; +  Suburb__c + &apos; &apos; +  State__c + &apos; &apos; +  Postcode__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Full Address</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Full_Name__c</fullName>
        <externalId>false</externalId>
        <formula>IF(NOT(ISBLANK(Title__c)), Title__c + &apos; &apos;, &apos;&apos;) + IF(NOT(ISBLANK(First_name__c)), First_name__c + &apos; &apos;, &apos;&apos;) + IF(NOT(ISBLANK(Last_name__c)), Last_name__c + &apos; &apos;, &apos;&apos;)</formula>
        <label>Full Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Full_Work_Location__c</fullName>
        <externalId>false</externalId>
        <formula>Work_Location_Campus__c + &apos; - &apos; + Work_Location_Address__c</formula>
        <label>Full Work Location</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Generate_Child_Care_Permit_Conga_Trigger__c</fullName>
        <externalId>false</externalId>
        <formula>&quot;&amp;id=&quot; + Id +
&quot;&amp;contactid=&quot; + Contact__r.Id +
&quot;&amp;templateid=&quot; + Conga_Template_Id__c +
&quot;&amp;uf0=1&quot; +
&quot;&amp;mfts0=Status__c&quot; +
&quot;&amp;mftsvalue0=Permit Issued&quot; +
&quot;&amp;PS0=1&amp;PS1=1&quot; +
&quot;&amp;pspw=&quot; + SAP_Staff_Id__c + Date_of_Birth__c +
&quot;&amp;sc0=1&quot; +
&quot;&amp;sc1=SalesforceFile&quot; +
&quot;&amp;qmode=SendEmail&quot; +
&quot;&amp;emailtemplateid=&quot; + Email_Template_Id__c +
&quot;&amp;emailfromid=&quot; + Email_From_Id__c +
&quot;&amp;emailtoid=&quot; + Contact__r.Id +
&quot;&amp;EmailSubject=&quot; + Subject_Content__c + &apos; - &apos; + Full_Name__c +
&quot;&amp;defaultpdf=1&quot; +
&quot;&amp;seti=&quot; + Contact__r.Id +
&quot;&amp;ofn=&quot; + Full_Name__c + &apos; &apos; + Subject_Content__c + &apos; &apos; + TEXT(DAY(TODAY()))+TEXT(MONTH(TODAY()))+TEXT(YEAR(TODAY())) +
&quot;&amp;EmailBCC=&quot; + Email_BCC__c</formula>
        <label>Generate Child Care Permit Conga Trigger</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
