        <description>This field is used to uniquely identify a row</description>
        <externalId>false</externalId>
        <formula>Case(RecordTypeDevName__c, 


&quot;OSHC&quot;,
TEXT(Healthcare_Type__c) &amp; &quot;|&quot; &amp;
TEXT(Period_Cover__c) &amp; &quot;|&quot;
, 
&quot;Other&quot;, &quot;Not defined&quot;, 

