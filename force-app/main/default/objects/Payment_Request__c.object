        <searchResultsAdditionalFields>Requested_Amount__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Calculated_Payable_Amount__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Payable_Amount_Audit__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>CREATED_DATE</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Validation_on_PendingApproval</fullName>
        <active>true</active>
        <description>Validation check on status change to Pending Approval</description>
        <errorConditionFormula>AND(ISCHANGED( Status__c ), TEXT(Status__c) = &apos;Pending Approval&apos;, Students_Verified__c !=  Students_Total__c )</errorConditionFormula>
        <errorMessage>Please make sure all the Payment Request Items have been verified</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
