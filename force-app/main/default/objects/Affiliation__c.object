    <deploymentStatus>Deployed</deploymentStatus>
    <description>Links a person (Contact) with an entity, e.g. company (or organisational unit), club, school etc.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Account_Communications__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Account communication preferences, i.e. whom to reach out to for the particular areas, e.g. tax receipts to be sent or stewardship.</description>
        <inlineHelpText>This field indicates which types of communication are to be received on behalf of the Account</inlineHelpText>
        <label>Account Communications</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MultiselectPicklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Tax receipt</fullName>
                    <default>false</default>
                    <label>Tax receipt</label>
                </value>
                <value>
                    <fullName>Stewardship</fullName>
                    <default>false</default>
                    <label>Stewardship</label>
                </value>
            </valueSetDefinition>
        </valueSet>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>Account__c</fullName>
        <description>The contact (person) of the affiliation to an account (organisation)</description>
        <inlineHelpText>Please provide the account of the affiliation.</inlineHelpText>
        <label>Account</label>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Affiliations</relationshipLabel>
        <relationshipName>Affiliations</relationshipName>
        <relationshipOrder>1</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>true</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Composite_Key__c</fullName>
        <businessStatus>Active</businessStatus>
        <caseSensitive>true</caseSensitive>
        <description>Composite key comprised of Contact Id + Account Id + RecordType ID. Defined as &quot;unique&quot;. Value maintained by trigger. Essentially ensures there can be only one record for the same contact-account-record type combination.</description>
        <externalId>true</externalId>
        <inlineHelpText>Composite key comprised of Contact Id + Account Id + RecordType ID. Defined as &quot;unique&quot;. Value maintained by trigger. Essentially ensures there can be only one record for the same contact-account-record type combination.</inlineHelpText>
        <label>Composite Key</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Contact_Name__c</fullName>
        <description>Contact name as a clickable link on Affiliattion</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&quot;/lightning/r/Contact/&quot;+Contact__r.Id+&quot;/view&quot;, Contact__r.Full_Name__c , &quot;_self&quot;)</formula>
        <inlineHelpText>Click to view contact</inlineHelpText>
        <label>Contact Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
