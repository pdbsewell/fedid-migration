    <fields>
        <fullName>Sharing_Composite_Key__c</fullName>
        <description>Composite key comprised of: Contact Id + Account Id.  Defined as &quot;unique&quot;. Value maintained by trigger. Essentially ensures there can be only one sharing related affilation record for the same contact-account combination. Which would otherwise lead to sharing ambiguities.</description>
        <externalId>false</externalId>
        <inlineHelpText>Composite key comprised of: Contact Id + Account Id.  Defined as &quot;unique&quot;. Value maintained by trigger. Essentially ensures there can be only one sharing related affilation record for the same contact-account combination. Which would otherwise lead to sharing ambiguities.</inlineHelpText>
        <label>Sharing Composite Key</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Start_Date__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>TODAY()</defaultValue>
        <description>The date the email address is valid from.</description>
        <inlineHelpText>Please provide a date indicating the valid from for the affiliation</inlineHelpText>
        <label>Start Date</label>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>isActive__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>indicates if the Affiliation record is active or not, based on the end date.</description>
        <formula>IF( 

AND( 
 NOT(ISNULL(End_Date__c)),
 TODAY() &gt;= End_Date__c
), 

FALSE, 
TRUE)</formula>
        <inlineHelpText>indicates if the Affiliation record is active or not, based on the end date.</inlineHelpText>
        <label>is Active</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <label>Affiliation</label>
    <listViews>
