<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Hierarchy custom settings that controls the specifications/login details to expose faq articles through public site</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Access_Password__c</fullName>
        <description>Password of the user to use in accessing the FAQ Articles</description>
        <externalId>false</externalId>
        <label>Access Password</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Access_Token__c</fullName>
        <description>Security Token of the user to use in accessing the FAQ Articles</description>
        <externalId>false</externalId>
        <label>Access Token</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Access_Username__c</fullName>
        <description>Username of the user to use in accessing the FAQ Articles</description>
        <externalId>false</externalId>
        <label>Access Username</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Client_Id__c</fullName>
        <description>Client Id of the connected app: Web Team Expose FAQ</description>
        <externalId>false</externalId>
        <label>Client Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Client_Secret__c</fullName>
        <description>Client Secret of the connected app: Web Team Expose FAQ</description>
        <externalId>false</externalId>
        <label>Client Secret</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Retrieve_From__c</fullName>
        <description>Salesforce domain where to fetch the articles. Usually the domain of the org you are currently logged into.
Add the domain to remote site settings.</description>
        <externalId>false</externalId>
        <label>Retrieve From</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Expose FAQ Articles</label>
    <visibility>Public</visibility>
</CustomObject>
