    <recordTypes>
        <fullName>CC_Transfer</fullName>
        <active>true</active>
        <compactLayoutAssignment>BDP_Compact_Layout</compactLayoutAssignment>
        <description>Used to create offer request records specific to course and campus transfers</description>
        <label>Course &amp; Campus Transfer</label>
        <picklistValues>
            <picklist>Credit_Duration_Unit__c</picklist>
            <values>
                <fullName>Semesters</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Trimesters</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Years</fullName>
                <default>false</default>
            </values>
        </picklistValues>
        <picklistValues>
            <picklist>Scholarship__c</picklist>
            <values>
                <fullName>No</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Yes</fullName>
                <default>false</default>
            </values>
        </picklistValues>
        <picklistValues>
            <picklist>Signature_Type__c</picklist>
            <values>
                <fullName>Digital Signature</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Wet Signature</fullName>
                <default>true</default>
            </values>
        </picklistValues>
        <picklistValues>
            <picklist>Status__c</picklist>
            <values>
                <fullName>Completed</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Generate Offer</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>New</fullName>
                <default>true</default>
            </values>
            <values>
                <fullName>Offer Created</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Offer Error</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Processing Offer</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Ready for Offer</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Review Required</fullName>
                <default>false</default>
            </values>
        </picklistValues>
        <picklistValues>
            <picklist>Type__c</picklist>
            <values>
                <fullName>Campus Transfer</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Course Transfer</fullName>
                <default>false</default>
            </values>
        </picklistValues>
    </recordTypes>
    <searchLayouts>
        <listViewButtons>Add_Manual_Clause</listViewButtons>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <startsWith>Vowel</startsWith>
    <validationRules>
        <fullName>Transfer_Is_Locked</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
 RecordType.DeveloperName = &quot;CC_Transfer&quot;,
 NOT(ISCHANGED(isLocked__c)),
 OR(
    AND(ISPICKVAL(PRIORVALUE(Status__c),&quot;Processing Offer&quot;), ISCHANGED( Status__c )),
    AND(ISPICKVAL(Status__c,&quot;Processing Offer&quot;),
     OR(
        ISCHANGED( Transfer_Calendar__c ),
        ISCHANGED( Transfer_Course_Campus__c ) ,
        ISCHANGED( Transfer_Course_Code__c ),
        ISCHANGED( Transfer_Course_Specialisation__c ),
        ISCHANGED( Transfer_Course_Title__c ),
        ISCHANGED( Transfer_To__c ),
        ISCHANGED( Credit_Duration__c ),
        ISCHANGED( Credit_Duration_Unit__c ),
        ISCHANGED( Credit_Points__c ),
        ISCHANGED( Person_ID__c ),
        ISCHANGED( Applicant__c )
       )
    )
    
  )
)</errorConditionFormula>
        <errorMessage>Can&apos;t update transfer record at this stage</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Transfer_ready_for_offer</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
ISBLANK(Transfer_To__c),
OR( ISPICKVAL(Status__c, &quot;Ready for Offer&quot;), ISPICKVAL(Status__c, &quot;Generate Offer&quot;) ),
 RecordType.DeveloperName = &quot;CC_Transfer&quot;
 
)</errorConditionFormula>
        <errorMessage>Transfer To is mandatory in order to
make an offer.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>Add_Manual_Clause</fullName>
        <availability>online</availability>
        <displayType>massActionButton</displayType>
        <height>600</height>
        <linkType>page</linkType>
        <masterLabel>Add Manual Clause</masterLabel>
        <openType>noSidebar</openType>
        <page>BulkAddManualClause</page>
        <protected>false</protected>
        <requireRowSelection>true</requireRowSelection>
    </webLinks>
</CustomObject>
