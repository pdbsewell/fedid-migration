<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>If the Web Email specified on the Enquiry is in this list, the &quot;To&quot; address field should pick up the contact&apos;s email address instead</description>
    <enableFeeds>false</enableFeeds>
    <label>Enquiry Email Exclusion List</label>
    <visibility>Protected</visibility>
</CustomObject>
