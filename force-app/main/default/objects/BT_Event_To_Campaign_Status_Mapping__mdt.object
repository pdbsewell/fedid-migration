<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>metadata to help mapping between event registration status and campaign</description>
    <fields>
        <fullName>Campaign_Active__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Describes if the campaign isactive flag is true</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Campaign Active</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Campaign_Status__c</fullName>
        <description>Describes the status of the campaign</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Campaign Status</label>
        <length>40</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Event_Status__c</fullName>
        <description>Describes the status of an event (conference360__Event__c)</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Event Status</label>
        <length>40</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>BT Event To Campaign Status Mapping</label>
    <pluralLabel>BT Event To Campaign Status Mapping</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
