    </fields>
    <fields>
        <fullName>Assessment_Tap_Controller__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Informs the administrator if the tap conditions are being applied. During the development and while we are onboarding courses, teams, etc, this will always be off / on AND off when we are no longer conditionally allowing ACPs to be assessed in UniCRM.</description>
        <inlineHelpText>Will be used during transition phase to check if the tap has been enabled based on criteria</inlineHelpText>
        <label>Assessment Tap - Controller</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Assessment_Tap_Default__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Informs the administrators if the tap is switch on / off. During the development and while we are onboarding courses, teams, etc, this will always be off.</description>
        <inlineHelpText>Will be used before go live and after tap is no longer required to keep the tap always OFF or always ON</inlineHelpText>
        <label>Assessment Tap - Default</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Assessment_Tap_FIT__c</fullName>
