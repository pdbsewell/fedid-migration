<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Allow features to be enabled or disabled based on a Boolean switch</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Align_ACP_Owner__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Change the owner of Agent linked ACP records to the branch manager of the agency. This is to support acai created in Callista that Agent Portal users require access to.</description>
        <inlineHelpText>Change owner of Agent linked ACP records to the branch manager of the agency.</inlineHelpText>
        <label>Align ACP Owner</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Align_Application_Owner__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Change the owner of Agent linked Application records to the branch manager of the agency. This is used to grant access to acai created in Callista to Agent Portal users.</description>
        <inlineHelpText>Change the owner of Agent linked Application records to the branch manager of the agency.</inlineHelpText>
        <label>Align Application Owner</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>AllowOutOfSyncEvents__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Contact events (ibdcontact__e) will skip the API LastModifiedDate check when true</description>
        <label>Allow out of sync events</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Assessment_Tap_Australia__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Assessment tap where campus location is Australia</description>
        <label>Assessment Tap - Australia</label>
        <trackTrending>false</trackTrending>
