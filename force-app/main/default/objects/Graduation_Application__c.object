        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Student_Person_Id__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Contact&apos;s Student ID</description>
        <externalId>false</externalId>
        <formula>Student__r.Person_ID_unique__c</formula>
        <label>Student Person Id</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Student_Personal_Email__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>PII</complianceGroup>
        <description>Personal email of the student as entered on form</description>
        <externalId>false</externalId>
        <label>Student Personal Email</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Student_Testamur_Name_Change_Status__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Current state of the name change request</description>
        <label>Student Testamur Name Change Status</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Approved</fullName>
                    <default>false</default>
                    <label>Approved</label>
                </value>
                <value>
                    <fullName>Pending</fullName>
                    <default>false</default>
                    <label>Pending</label>
                </value>
                <value>
                    <fullName>Rejected</fullName>
                    <default>false</default>
                    <label>Rejected</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Student_Testamur_Name_Reject_Reason__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Reason for rejecting the name change request</description>
        <label>Student Testamur Name Reject Reason</label>
        <length>2048</length>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>Student_Testamur_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>PII</complianceGroup>
        <description>Student name as it will appear on the testamur</description>
        <externalId>false</externalId>
        <label>Student Testamur Name</label>
        <length>80</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Student__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>Restrict</deleteConstraint>
        <description>Student contact associated with the Application</description>
        <label>Student</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Graduation Applications</relationshipLabel>
        <relationshipName>Graduation_Applications</relationshipName>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Unique_Key__c</fullName>
        <businessStatus>Active</businessStatus>
        <caseSensitive>false</caseSensitive>
        <description>Ensure that duplicate applications can&apos;t exist for a student</description>
        <externalId>false</externalId>
        <label>Unique Key</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Writeback_Status_f__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Show a visual &quot;error&quot; or &quot;ok&quot; status depending on presence of writeback errors</description>
        <externalId>false</externalId>
        <formula>IF(
  ISPICKVAL(Status__c, &quot;Applied&quot;) || ISPICKVAL(Status__c, &quot;Cancelled&quot;),
  IF(
    Number_of_Writeback_Errors_f__c &gt; 0,
    IMAGE(&quot;/resource/icon_cross_red&quot;, &quot;Error&quot;, 18, 18),
    IMAGE(&quot;/resource/icon_tick_green&quot;, &quot;OK&quot;, 18, 18)
  ),
  &apos;N/A&apos;
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Writeback Status</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Graduation Application</label>
    <listViews>
        <fullName>All</fullName>
        <columns>CREATED_DATE</columns>
        <columns>Student_Person_Id__c</columns>
        <columns>NAME</columns>
        <columns>Student__c</columns>
        <columns>Graduation_Calendar__c</columns>
        <columns>Attendance_Mode__c</columns>
        <columns>Status__c</columns>
        <columns>Pending_Refunds_f__c</columns>
        <columns>Student_Personal_Email__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>X2024_Calendar_Applications</fullName>
        <columns>CREATED_DATE</columns>
        <columns>NAME</columns>
        <columns>Student__c</columns>
        <columns>Graduation_Calendar__c</columns>
        <columns>Attendance_Mode__c</columns>
        <columns>Status__c</columns>
        <columns>Pending_Refunds_f__c</columns>
        <columns>Student_Personal_Email__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Graduation_Calendar__c</field>
            <operation>contains</operation>
            <value>2024</value>
        </filters>
        <label>2024 Calendar Applications</label>
    </listViews>
    <listViews>
        <fullName>X2025_Calendar_Applications</fullName>
        <columns>CREATED_DATE</columns>
        <columns>Student_Person_Id__c</columns>
        <columns>NAME</columns>
        <columns>Student__c</columns>
        <columns>Graduation_Calendar__c</columns>
        <columns>Attendance_Mode__c</columns>
        <columns>Status__c</columns>
        <columns>Pending_Refunds_f__c</columns>
        <columns>Student_Personal_Email__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Graduation_Calendar__c</field>
            <operation>contains</operation>
            <value>GRAD-MI</value>
        </filters>
        <label>2025 Calendar Applications</label>
    </listViews>
    <nameField>
        <displayFormat>GAPP-{0000000}</displayFormat>
        <label>Graduation Application Number</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Graduation Applications</pluralLabel>
    <searchLayouts>
        <excludedStandardButtons>New</excludedStandardButtons>
        <excludedStandardButtons>OpenListInQuip</excludedStandardButtons>
        <excludedStandardButtons>NewFromDocument</excludedStandardButtons>
        <excludedStandardButtons>Accept</excludedStandardButtons>
        <excludedStandardButtons>ChangeOwner</excludedStandardButtons>
        <excludedStandardButtons>Import</excludedStandardButtons>
        <excludedStandardButtons>MassChangeOwner</excludedStandardButtons>
        <excludedStandardButtons>MassAssignRecordLabel</excludedStandardButtons>
        <listViewButtons>Create_New_Application</listViewButtons>
        <listViewButtons>Upload_Applications</listViewButtons>
        <listViewButtons>Callista_Eligibility_Viewer</listViewButtons>
        <searchResultsAdditionalFields>Student_Person_Id__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Graduation_Calendar__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>CREATED_DATE</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>Applied_App_Cant_Become_Draft</fullName>
        <active>true</active>
        <description>Don&apos;t allow Status to be changed from Applied to Draft</description>
        <errorConditionFormula>NOT($Permission.Graduations_Admin)
&amp;&amp;
ISPICKVAL(PRIORVALUE(Status__c), &apos;Applied&apos;)
&amp;&amp; 
(ISPICKVAL(Status__c, &apos;Draft&apos;) || ISPICKVAL(Status__c, &apos;Internal Draft&apos;))</errorConditionFormula>
        <errorDisplayField>Status__c</errorDisplayField>
        <errorMessage>Application Status can&apos;t be changed from Applied to Draft</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Attendance_Fee_Waivers_Only_Increase</fullName>
        <active>true</active>
        <errorConditionFormula>ISCHANGED(Number_of_Attendance_Fee_Waivers__c)
&amp;&amp;
Number_of_Attendance_Fee_Waivers__c &lt; PRIORVALUE(Number_of_Attendance_Fee_Waivers__c)
&amp;&amp;
ISPICKVAL(Status__c,&quot;Applied&quot;)</errorConditionFormula>
        <errorDisplayField>Number_of_Attendance_Fee_Waivers__c</errorDisplayField>
        <errorMessage>Number of attendance fee waivers can&apos;t be decreased</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Name_Change_Reason_Not_Provided</fullName>
        <active>true</active>
        <errorConditionFormula>ISPICKVAL(Student_Testamur_Name_Change_Status__c, &apos;Rejected&apos;)
&amp;&amp; 
ISBLANK(Student_Testamur_Name_Reject_Reason__c)</errorConditionFormula>
        <errorDisplayField>Student_Testamur_Name_Reject_Reason__c</errorDisplayField>
        <errorMessage>Reject Reason can not be blank</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
