                    <label>977 - ETA BUSINESS ENTRANT SHORT VALIDITY</label>
                </value>
                <value>
                    <fullName>988</fullName>
                    <default>false</default>
                    <label>988 - MARITIME CREW</label>
                </value>
                <value>
                    <fullName>995</fullName>
                    <default>false</default>
                    <label>995 - DIPLOMATIC (TEMPORARY)</label>
                </value>
                <value>
                    <fullName>APP-PORTAL</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
