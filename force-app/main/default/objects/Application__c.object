        <inlineHelpText>Allows for the storage of the Application Checklist Output which is then consumed by marketing cloud. This should not be edited directly.</inlineHelpText>
        <label>Checklist output completed</label>
        <length>10000</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
