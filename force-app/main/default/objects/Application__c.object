    <fields>
        <fullName>Citizenship_Classification__c</fullName>
        <description>Citizenship Classification based on Residency Status and Campus Location (Application fields) 

Please refer to the table here:
https://confluence.apps.monash.edu/pages/viewpage.action?spaceKey=SF&amp;title=Citizenship+Classification+Multi+Campus</description>
        <externalId>false</externalId>
        <formula>IF(ISPICKVAL(Type_of_Study__c, &apos;Graduate Research&apos;),
	IF(ISPICKVAL(Campus_Location__c, &apos;Australia&apos;),
		IF(OR(TEXT(Residency_Status__c)=&apos;DOM-AUS&apos;,TEXT(Residency_Status__c)=&apos;DOM-NZ&apos;,TEXT(Residency_Status__c)=&apos;DOM-PR&apos;),
			&apos;Domestic&apos;,
			IF(OR(TEXT(Residency_Status__c)=&apos;DOM-SUN&apos;,TEXT(Residency_Status__c)=&apos;DOM-IDN&apos;,TEXT(Residency_Status__c)=&apos;DOM-IDN-PR&apos;,TEXT(Residency_Status__c)=&apos;INTRNTNL&apos;),
			&apos;International&apos;,
			&apos;NA&apos;)
		),
		IF(ISPICKVAL(Campus_Location__c, &apos;Malaysia&apos;),
			IF(TEXT(Residency_Status__c)=&apos;DOM-SUN&apos;,
				&apos;Domestic&apos;,
				IF(OR(TEXT(Residency_Status__c)=&apos;DOM-AUS&apos;,TEXT(Residency_Status__c)=&apos;DOM-NZ&apos;,TEXT(Residency_Status__c)=&apos;DOM-PR&apos;,TEXT(Residency_Status__c)=&apos;INTRNTNL&apos;),
					&apos;International&apos;,
					&apos;NA&apos;)
			),
			IF(ISPICKVAL(Campus_Location__c, &apos;Indonesia&apos;),
				IF(OR(TEXT(Residency_Status__c)=&apos;DOM-IDN&apos;, TEXT(Residency_Status__c)=&apos;DOM-IDN-PR&apos;),
					&apos;Domestic&apos;,
					IF(OR(TEXT(Residency_Status__c)=&apos;DOM-AUS&apos;,TEXT(Residency_Status__c)=&apos;DOM-NZ&apos;,TEXT(Residency_Status__c)=&apos;DOM-PR&apos;,TEXT(Residency_Status__c)=&apos;INTRNTNL&apos;),
						&apos;International&apos;,
						&apos;NA&apos;
					)
				),
				&apos;NA&apos;
			)
		)
	)
	,
	IF(ISPICKVAL(Campus_Location__c, &apos;Australia&apos;),
		IF(OR(TEXT(Residency_Status__c)=&apos;DOM-AUS&apos;,TEXT(Residency_Status__c)=&apos;DOM-NZ&apos;,TEXT(Residency_Status__c)=&apos;DOM-PR&apos;,TEXT(Residency_Status__c)=&apos;DOM-HV&apos;),
			&apos;Domestic&apos;,
			IF(OR(TEXT(Residency_Status__c)=&apos;INTRNTNL&apos;,TEXT(Residency_Status__c)=&apos;INT-TEP&apos;),
				&apos;International&apos;,
				&apos;NA&apos;)
		),
		IF(ISPICKVAL(Campus_Location__c, &apos;Malaysia&apos;),
			IF(TEXT(Residency_Status__c)=&apos;DOM-SUN&apos;,
				&apos;Domestic&apos;,
				IF(OR(TEXT(Residency_Status__c)=&apos;INT-SUN-P&apos;,TEXT(Residency_Status__c)=&apos;INT-SUN&apos;),
					&apos;International&apos;,
					&apos;NA&apos;)
			),

			IF(ISPICKVAL(Campus_Location__c, &apos;South Africa&apos;),
				IF(TEXT(Residency_Status__c)=&apos;DOM-SA&apos;,
					&apos;Domestic&apos;,
					IF(TEXT(Residency_Status__c)=&apos;INT-SA&apos;,
						&apos;International&apos;,
						&apos;NA&apos;
					)
				),
				IF(ISPICKVAL(Campus_Location__c, &apos;Indonesia&apos;),
					IF(OR(TEXT(Residency_Status__c)=&apos;DOM-IDN&apos;, TEXT(Residency_Status__c)=&apos;DOM-IDN-PR&apos;),
						&apos;Domestic&apos;,
						IF(OR(TEXT(Residency_Status__c)=&apos;INT-IDN-P&apos;, TEXT(Residency_Status__c)=&apos;INT-IDN&apos;),
							&apos;International&apos;,
							&apos;NA&apos;
						)
					),
					&apos;NA&apos;
				)
			)
		)
	)
)</formula>
        <inlineHelpText>a formula field that holds the Citizenship Classification based on Residency Status and Campus Location</inlineHelpText>
        <label>Citizenship Classification</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
