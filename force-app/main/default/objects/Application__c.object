    <validationRules>
        <fullName>Block_Approved_Status_By_Portal_User</fullName>
        <active>true</active>
        <description>Prevent portal users from updating of Status field to Approved</description>
        <errorConditionFormula>AND(
  ISCHANGED(Status__c),
  ISPICKVAL(Status__c, &apos;Approved&apos;),
  ISPICKVAL($User.UserType, &apos;CspLitePortal&apos;)
)</errorConditionFormula>
        <errorDisplayField>Status__c</errorDisplayField>
        <errorMessage>Requested update on status field not permitted</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>Callista_Sync</fullName>
        <availability>online</availability>
        <displayType>button</displayType>
        <linkType>javascript</linkType>
        <masterLabel>Callista Sync</masterLabel>
        <openType>onClickJavaScript</openType>
        <protected>false</protected>
        <url>{!REQUIRESCRIPT(&apos;/soap/ajax/39.0/connection.js&apos;)}
{!REQUIRESCRIPT(&apos;/soap/ajax/39.0/apex.js&apos;)}
{!REQUIRESCRIPT(&apos;/support/console/41.0/integration.js&apos;)}

if ({!ISBLANK( Application__c.Callista_Student_Id__c )}) { 
    alert(&apos;The person ID does not exist.&apos;);
} 
else { 
   console.log(&apos;The person ID does exist: {!Application__c.Callista_Student_Id__c}&apos;);

   function sendRequest(callback) 
   { 
    // alert(&quot;Your request is now being processed.&quot;); 
      callback(); 
    }

    sendRequest(function (){ 
       var result = 
          sforce.apex.execute(&apos;Callista_Sync_Service&apos;, 
          &apos;initiateSync&apos;, 
          {personId:&apos;{!Application__c.Callista_Student_Id__c}&apos;} 
          );

      console.log(&apos;Response from The Salesforce function:&apos;);
      console.log(result);

//if (result.includes(&apos;{!$Label.Callista_Sync_Failed}&apos;)) {
      //  alert(result);
      //}

    if( result.indexOf(&apos;{!$Label.Callista_Sync_Failed}&apos;) &gt; -1 ) {
        alert(&apos;{!$Label.Callista_Sync_Failed}&apos;);
    } 

        /////////////////////////////////////////////////
        //This section is to refresh the tabs

       var refreshSuccess = function refreshSuccess(result) {
          //Report whether refreshing the subtab was successful
          if (result.success == true) {
             console.log(&apos;Subtab refreshed successfully&apos;);
          } else {
              console.log(&apos;Subtab did not refresh&apos;);
         }
       };
            
       var refreshSubTabsByTheirIds = function refreshSubTabsByTheirIds(result) {
           console.log(&apos;The id of all subtabs: &apos; + result.ids);
           var allOfTheSubTabIds = result.ids;
           var allOfTheSubTabIdsArray = String(allOfTheSubTabIds).split(&apos;,&apos;);
           for(var i = 0; i &lt; allOfTheSubTabIdsArray.length; i++)
           {
              (function()
              {
                   sforce.console.refreshSubtabById(allOfTheSubTabIdsArray[i], false, refreshSuccess);
                   //console.log(&apos;subTabId: &apos; + allOfTheSubTabIdsArray[i]);
              })(i);
          }
       };

       function getCurrentPrimaryTab() {
           //First find the ID of the current primary tab to close it
           try {
                sforce.console.getEnclosingPrimaryTabId(getAllOfTheSubtabs);
           }
           catch(err) {
                console.log(&quot;Probably because you are in the classic view the following error has occured:&quot;);
            console.log(err);
            //refresh the tab
            location.reload();
           }
       }
            
       var getAllOfTheSubtabs = function getAllOfTheSubtabs(result) {
          //Now that we have the primary tab ID, we can get subtabids
          var primaryTabId = result.id;
          console.log(&apos;PrimaryTabID: &apos; + primaryTabId);
          sforce.console.getSubtabIds(primaryTabId, refreshSubTabsByTheirIds);
       };

      getCurrentPrimaryTab();

      //End of section
      ////////////////////////////////////////////////

    });
    
}</url>
    </webLinks>
