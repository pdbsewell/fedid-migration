    <fields>
        <fullName>Age_at_submission__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK(Birthdate__c) ) , 
IF( DATE( 2000 , MONTH(Birthdate__c) , DAY(Birthdate__c) ) &lt;= DATE( 2000 , MONTH(Submitted_Date__c) , DAY(Submitted_Date__c)), 
YEAR (Submitted_Date__c) - YEAR (Birthdate__c), 
YEAR (Submitted_Date__c) - YEAR (Birthdate__c) -1 ), 
null)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Age at submission</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
