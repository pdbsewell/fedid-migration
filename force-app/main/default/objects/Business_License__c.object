        <columns>Total_Active_Licenses__c</columns>
        <columns>Total_Licenses__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <label>Business License Name</label>
        <type>Text</type>
    </nameField>
    <pluralLabel>Business Licenses</pluralLabel>
