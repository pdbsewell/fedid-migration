    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Stores license information grouped by Business Unit. Includes Baseline Licenses for each Business Unit, Paid Licenses and Total Active Licenses.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Baseline_Licenses__c</fullName>
        <description>Centrally funded licenses.</description>
        <externalId>false</externalId>
        <inlineHelpText>Centrally funded licenses.</inlineHelpText>
        <label>Initial Licenses</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Paid_Licenses__c</fullName>
        <description>Stores the number of Paid Licenses for each Business Unit.</description>
        <externalId>false</externalId>
        <label>Paid Licenses</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Total_Active_Licenses__c</fullName>
        <description>Total Active Licenses for each Business Unit</description>
        <label>Total Active Licenses</label>
        <summaryFilterItems>
            <field>Role_License__c.Status__c</field>
            <operation>equals</operation>
            <value>Active</value>
        </summaryFilterItems>
        <summaryForeignKey>Role_License__c.Parent_Business_Unit__c</summaryForeignKey>
        <summaryOperation>count</summaryOperation>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Total_Licenses__c</fullName>
        <externalId>false</externalId>
        <formula>Baseline_Licenses__c  +  Paid_Licenses__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Total Licenses</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Business License</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Baseline_Licenses__c</columns>
