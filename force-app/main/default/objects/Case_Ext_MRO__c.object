    <label>Case Extension - MRO</label>
    <listViews>
        <fullName>Extensions_ARC</fullName>
        <columns>NAME</columns>
        <columns>Pure_Application_Id__c</columns>
        <columns>Primary_Funder__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Primary_Funder__c</field>
            <operation>equals</operation>
            <value>Australian Research Council [ARC]</value>
        </filters>
        <label>Extensions - ARC</label>
        <sharedTo>
            <group>MRO_Monash_Research_Office</group>
        </sharedTo>
    </listViews>
    <nameField>
        <displayFormat>MRO-{00000000}</displayFormat>
        <label>MRO Case Number</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Case Extension - MRO</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>Pure_Application_Id__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Category_Level_1__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Funder_Ref__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Sub_Project_Id__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>CaseOwner__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Date_Enquiry_Opened__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>PUREApplicationID_NumberOnly</fullName>
        <active>true</active>
        <description>Numbers only, no spaces or special characters.</description>
        <errorConditionFormula>!REGEX(Pure_Application_Id__c,&quot;[0-9]*&quot;)</errorConditionFormula>
        <errorDisplayField>Pure_Application_Id__c</errorDisplayField>
        <errorMessage>Please enter a valid PURE Application ID.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PUREAwardID_NumberOnly</fullName>
        <active>true</active>
        <description>Numbers only, no spaces or special characters.</description>
        <errorConditionFormula>!REGEX(Pure_Award_Id__c,&quot;[0-9]*&quot;)</errorConditionFormula>
        <errorDisplayField>Pure_Award_Id__c</errorDisplayField>
        <errorMessage>Please enter a valid PURE Award ID.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>PUREProjectID_NumberOnly</fullName>
        <active>true</active>
        <description>Numbers only, no spaces or special characters.</description>
        <errorConditionFormula>!REGEX(Pure_Project_Id__c,&quot;[0-9]*&quot;)</errorConditionFormula>
        <errorDisplayField>Pure_Project_Id__c</errorDisplayField>
        <errorMessage>Please enter a valid PURE Project ID.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
