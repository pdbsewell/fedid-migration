    <fields>
        <fullName>Primary_Funder__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Primary Funder for Pure Application &amp; Award</description>
        <inlineHelpText>Primary Funder for Pure Application &amp; Award</inlineHelpText>
        <label>Primary Funder</label>
        <lookupFilter>
            <active>true</active>
            <errorMessage>Primary funder needs to be a UniCRM account that is an External Organisation or a Monash Organisation</errorMessage>
            <filterItems>
                <field>Account.RecordTypeId</field>
                <operation>equals</operation>
                <value>External Organisation, Monash Organisation, Faculty</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Case Extension - MRO</relationshipLabel>
        <relationshipName>Case_Extension_MRO</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
