<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Controls behaviour of the OTP widget</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Country_Code_Exclusions__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Comma separated list of international dialling country codes to exclude, including the +. e.g. +86 for China. 
The OTP widget will not list to the agent any mobile number beginning with an excluded prefix.
This is to allow for exclusion of SMS destinations not supported by the SMS service.</description>
        <externalId>false</externalId>
        <inlineHelpText>Comma separated list of international dialling country codes to exclude, including the +. e.g. +86 for China. 
The OTP widget will not list to the agent any mobile number beginning with an excluded prefix.
This is to allow for exclusion of SMS destinations not supported by the SMS service.</inlineHelpText>
        <label>Country Code Exclusions</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>OTP Widget</label>
    <visibility>Public</visibility>
</CustomObject>
