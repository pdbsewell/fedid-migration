    <fields>
        <fullName>Payable_Amount_GST__c</fullName>
        <description>GST Amount for Payable Amount. Current assumption is always 10%</description>
        <formula>IF(Invoice_GST_Inclusive__c , Payable_Amount__c - (Payable_Amount__c / 1.1) , 0)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Payable Amount GST</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
