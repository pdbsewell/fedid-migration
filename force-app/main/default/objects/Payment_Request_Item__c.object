        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Tax_Code__c</fullName>
        <externalId>false</externalId>
        <formula>IF( Invoice_GST_Inclusive__c , &apos;P1&apos;, &apos;P0&apos;)</formula>
        <label>Tax Code</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Payment Request Item</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Payment_Request_Type__c</columns>
        <columns>Invoice_No__c</columns>
        <columns>Student__c</columns>
        <columns>Student_Id__c</columns>
        <columns>Requested_Amount__c</columns>
        <columns>Invoice_GST_Inclusive__c</columns>
        <columns>Payable_Amount__c</columns>
        <columns>Status__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>Ready_for_Submission</fullName>
        <columns>NAME</columns>
        <columns>Payable_Amount__c</columns>
        <columns>Tax_Code__c</columns>
        <columns>SAP_Vendor_Id__c</columns>
        <columns>Invoice_No__c</columns>
        <columns>Payment_Request__c</columns>
        <columns>Student__c</columns>
        <columns>Student_Id__c</columns>
        <filterScope>Everything</filterScope>
        <label>Ready for Submission</label>
    </listViews>
    <nameField>
        <displayFormat>PRI-{000000000}</displayFormat>
        <label>Payment Request Item Name</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Payment Request Items</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>Payment_Request_Type__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Invoice_No__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Student__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Student_Id__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Requested_Amount__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Payable_Amount__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Validation_on_Verify</fullName>
        <active>true</active>
        <errorConditionFormula>AND(ISCHANGED( Status__c ),  TEXT(Status__c) = &apos;Verified&apos;, NOT(Ready_for_Approval__c))</errorConditionFormula>
        <errorMessage>Please check that all the financial code fields have been populated</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
