    <fields>
        <fullName>Stripe_Link__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Link to the Stripe transaction</description>
        <externalId>false</externalId>
        <formula>IF(
	ISBLANK(Transaction_Id__c),
	&apos;&apos;,
	IF(
		TEXT(Type__c) = &apos;Charge&apos;,
		HYPERLINK(
			$Setup.URLs__c.Graduation_Portal_Stripe__c + &apos;/payments/&apos; + Transaction_Id__c, $Setup.URLs__c.Graduation_Portal_Stripe__c + &apos;/payments/&apos; + Transaction_Id__c,
			&apos;_blank&apos;
		),
		HYPERLINK(
			$Setup.URLs__c.Graduation_Portal_Stripe__c + &apos;/refunds/&apos; + Transaction_Id__c, $Setup.URLs__c.Graduation_Portal_Stripe__c + &apos;/refunds/&apos; + Transaction_Id__c,
			&apos;_blank&apos;
		)
	)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Stripe Link</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
