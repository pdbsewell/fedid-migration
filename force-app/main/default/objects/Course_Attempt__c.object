    <fields>
        <fullName>First_Unit_Enrolment_Date__c</fullName>
        <description>First unit enrolment date of the course attempt. 
eg. Getting the earliest enrolment date of all unit attempts related to the course attempt.</description>
        <label>First Unit Enrolment Date</label>
        <summarizedField>Unit_Attempt__c.Enrolment_Date__c</summarizedField>
        <summaryForeignKey>Unit_Attempt__c.Course_Attempt__c</summaryForeignKey>
        <summaryOperation>min</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>GPA__c</fullName>
        <description>A grade point average is a number representing the average value of the accumulated final grades earned in courses over time. More commonly called a GPA, a student&apos;s grade point average is calculated by adding up all accumulated final grades and dividing that figure by the number of grades awarded.
The usual range is 1.0 to 5.0 (with 3 points of precision)</description>
        <externalId>false</externalId>
        <label>GPA</label>
        <precision>4</precision>
        <required>false</required>
        <scale>3</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Granted_Advanced_Standing_Credit_Points__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Advanced standing credit points, granted against this course attempt.

Integrated field.</description>
        <externalId>false</externalId>
        <inlineHelpText>Advanced standing credit points</inlineHelpText>
        <label>Granted Adv Standing CP</label>
        <precision>7</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Initial_Intermit_Start_Date__c</fullName>
        <description>This date will be populated when the intermission start date is updated from Null. This should indicate when Intermission processing commenced.

The original value will be retained if intermission periods are sequential.</description>
        <label>Intermit Processing Start Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
