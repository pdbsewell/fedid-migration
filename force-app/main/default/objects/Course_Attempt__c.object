        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Number_of_Active_Unit_Attempts__c</fullName>
        <description>Count of active unit attempts related to the course attempt. Active unit attempts have a status of &quot;Enrolled&quot;</description>
        <label>Active Unit Attempts</label>
        <summaryFilterItems>
            <field>Unit_Attempt__c.Status__c</field>
            <operation>equals</operation>
            <value>Enrolled</value>
        </summaryFilterItems>
        <summaryForeignKey>Unit_Attempt__c.Course_Attempt__c</summaryForeignKey>
        <summaryOperation>count</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Number_of_Completed_Unit_Attempt__c</fullName>
        <description>Count of completed unit attempts related to the course attempt. Completed unit attempts have a status of &quot;Completed&quot;</description>
        <label>Completed Unit Attempt</label>
        <summaryFilterItems>
            <field>Unit_Attempt__c.Status__c</field>
            <operation>equals</operation>
            <value>Completed</value>
        </summaryFilterItems>
        <summaryForeignKey>Unit_Attempt__c.Course_Attempt__c</summaryForeignKey>
        <summaryOperation>count</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Partner_Faculty_Code__c</fullName>
        <externalId>false</externalId>
        <formula>Course__r.Partner_Faculty_Code__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Partner Faculty Code</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Partner_Faculty_Description__c</fullName>
        <externalId>false</externalId>
        <formula>Course__r.Partner_Faculty_Description__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Partner Faculty</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Person_ID__c</fullName>
        <externalId>false</externalId>
        <label>Person Id</label>
        <length>10</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Portal_Application_Id__c</fullName>
        <externalId>false</externalId>
        <label>Portal Application Id</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Remaining_Credit_Points__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Credit Points remaining for course completion.

Calculated from course total credit, minus the achieved and granted totals.</description>
        <externalId>false</externalId>
        <formula>Course__r.Points__c - Achieved_Credit_Points__c - Granted_Advanced_Standing_Credit_Points__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Credit Points remaining for course completion</inlineHelpText>
        <label>Remaining CP</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Required_Credit_Points__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The total required credit points for course completion</description>
        <externalId>false</externalId>
        <formula>Course__r.Points__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The total required credit points for course completion</inlineHelpText>
        <label>Required CP</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>SS_CourseCodeDescription__c</fullName>
        <externalId>false</externalId>
        <formula>Course__r.Name + &apos; - &apos; + Course__r.Course_Description__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Code Description</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Student_Confirmed__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Student Confirmed</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Student_Type__c</fullName>
        <description>Indicate the type of student of the course attempt. Ie. International, Domestic or Unspecified</description>
        <label>Student Type</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>International</fullName>
                    <default>false</default>
                    <label>International</label>
                </value>
                <value>
                    <fullName>Domestic</fullName>
                    <default>false</default>
                    <label>Domestic</label>
                </value>
                <value>
                    <fullName>Unspecified</fullName>
                    <default>false</default>
                    <label>Unspecified</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>WAM_GPA_Last_Refresh_Date__c</fullName>
        <label>WAM-GPA Last Refresh Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>WAM__c</fullName>
        <description>The Weighted Average Mark (WAM) is a more precise measure of your academic performance than the Grade Point Average. This is because we base the calculation on your actual marks and the year level of each unit. The WAM is the average mark you achieve across all completed units in a course.</description>
        <externalId>false</externalId>
        <label>WAM</label>
        <precision>6</precision>
        <required>false</required>
        <scale>3</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Course Attempt</label>
