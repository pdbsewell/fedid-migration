    <deploymentStatus>Deployed</deploymentStatus>
    <description>Course attempt represents the courses a Contact is related to.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Achieved_Credit_Points__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Total credit points achieved</description>
        <inlineHelpText>Total credit points achieved</inlineHelpText>
        <label>Achieved CP</label>
        <securityClassification>Internal</securityClassification>
        <summarizedField>Unit_Attempt__c.Achieved_Credit_Points__c</summarizedField>
        <summaryFilterItems>
            <field>Unit_Attempt__c.Status__c</field>
            <operation>equals</operation>
            <value>Completed, Duplicate</value>
        </summaryFilterItems>
        <summaryForeignKey>Unit_Attempt__c.Course_Attempt__c</summaryForeignKey>
        <summaryOperation>sum</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Summary</type>
    </fields>
    <fields>
        <fullName>Application_Agent_Code__c</fullName>
        <externalId>false</externalId>
        <formula>Application_Course_Preference__r.Application__r.Agent__r.Callista_Org_Unit_Code__c</formula>
        <label>Application Agent Code</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Application_Course_Preference__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>The application course preference related to this course attempt (eg. Originating ACP)</description>
        <label>Application Course Preference</label>
        <referenceTo>Application_Course_Preference__c</referenceTo>
        <relationshipLabel>Course Attempts</relationshipLabel>
        <relationshipName>Course_Attempts</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Attendance_Mode__c</fullName>
        <label>Attendance Mode</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>IN</fullName>
                    <default>false</default>
                    <label>Internal Mode</label>
                </value>
                <value>
                    <fullName>EX</fullName>
                    <default>false</default>
                    <label>External Mode</label>
                </value>
                <value>
                    <fullName>MM</fullName>
                    <default>false</default>
                    <label>Multi-mode</label>
                </value>
                <value>
                    <fullName>MO</fullName>
                    <default>false</default>
                    <label>Monash Online</label>
                </value>
                <value>
                    <fullName>OL</fullName>
                    <default>false</default>
                    <label>Open Learning</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Attendance_Type__c</fullName>
        <label>Attendance Type</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>FT</fullName>
                    <default>false</default>
                    <label>Full Time</label>
                </value>
                <value>
                    <fullName>PT</fullName>
                    <default>false</default>
                    <label>Part Time</label>
                </value>
                <value>
                    <fullName>OL</fullName>
                    <default>false</default>
                    <label>Open Learning</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Attendance__c</fullName>
        <description>Attendance Mode and Type</description>
        <externalId>false</externalId>
        <formula>CASE(
TEXT(Attendance_Mode__c)
, &apos;EX&apos;, &apos;External Mode&apos;
, &apos;IN&apos;, &apos;Internal Mode&apos;
, &apos;MM&apos;, &apos;Multi-Mode&apos;
, &apos;MO&apos;, &apos;Monash Online&apos;
, &apos;OL&apos;, &apos;Open Learning&apos;
, text(Attendance_Mode__c)
)

+ if(!ISBLANK(TEXT(Attendance_Type__c)), &apos;/&apos;,&apos;&apos;) +

CASE(
TEXT(Attendance_Type__c)
, &apos;FT&apos;, &apos;Full Time&apos;
, &apos;PT&apos;, &apos;Part Time&apos;
, &apos;OL&apos;, &apos;Open Learning&apos;
,TEXT(Attendance_Type__c)
)</formula>
        <inlineHelpText>Attendance Mode and Type</inlineHelpText>
        <label>Attendance</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
