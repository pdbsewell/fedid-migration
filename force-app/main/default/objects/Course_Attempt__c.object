        <externalId>false</externalId>
        <formula>IF (JRG_Ind__c
, IMAGE(&quot;/resource/1500335404000/GraphicsPackNew/fatcow/farmfresh/16/lightbulb.png&quot;, &quot;JRG Student&quot;, 16, 16)
, IMAGE(&quot;/resource/1500335404000/GraphicsPackNew/fatcow/farmfresh/16/lightbulb_off.png&quot;, &quot;Non-JRG Student&quot;, 16, 16)
)</formula>
