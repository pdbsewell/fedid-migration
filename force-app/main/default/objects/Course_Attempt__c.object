    <fields>
        <fullName>Course_Attempt_Status_Ranking__c</fullName>
        <description>System Field. 

The priority order when assigning a primary SCA to a contact. Transferred SCA are considered the least interesting, hence they are relegated to the bottom.</description>
        <externalId>false</externalId>
        <formula>CASE(   UPPER(Text(Course_Attempt_Status__c))  , 
&apos;ENROLLED&apos;,10, 
&apos;INTERMIT&apos;, 20, 
&apos;INACTIVE&apos;, 30, 
&apos;UNCONFIRM&apos;, 40,
&apos;DISCONTIN&apos;, IF(OR(BEGINS(Discontinuation_Reason__c,&apos;31&apos;),BEGINS(Discontinuation_Reason__c,&apos;04&apos;)),70,50),
&apos;COMPLETED&apos;, 60,
999
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Ranking</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
