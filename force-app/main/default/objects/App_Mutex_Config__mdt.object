<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Configuration metadata for features that use Mutex Locking</description>
    <fields>
        <fullName>Batch_Size__c</fullName>
        <description>Indicates the number of records to be processed for each asynchronous transaction</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Batch Size</label>
        <precision>8</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Lock_Duration__c</fullName>
        <description>If set, the scheduled nightly job will unlock the mutex record if not modified within the duration defined here.
Also make sure that if this is left blank, the job wouldn&apos;t release the mutex record</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>If set, the scheduled nightly job will unlock the mutex record if not modified within the duration defined here.
Also make sure that if this is left blank, the job wouldn&apos;t release the mutex record</inlineHelpText>
        <label>Lock Duration(In Hours)</label>
        <precision>2</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>is_Muted__c</fullName>
        <defaultValue>false</defaultValue>
        <description>kill switch for mutex lock implementation of this asynchronous process</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>is Muted</label>
        <type>Checkbox</type>
    </fields>
    <label>App Mutex Config</label>
    <pluralLabel>App Mutex Configs</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
