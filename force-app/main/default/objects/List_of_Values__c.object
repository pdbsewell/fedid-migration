    <listViews>
        <fullName>Outcome</fullName>
        <columns>NAME</columns>
        <columns>Type__c</columns>
        <columns>Value__c</columns>
        <columns>Description__c</columns>
        <columns>System_Code__c</columns>
        <columns>System_Code_Description__c</columns>
        <columns>Is_Active__c</columns>
        <columns>Is_Active_System_Code__c</columns>
        <columns>Applicant_Value__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Type__c</field>
            <operation>equals</operation>
            <value>ADM_OUTCOME_STATUS</value>
        </filters>
        <label>Outcome</label>
    </listViews>
