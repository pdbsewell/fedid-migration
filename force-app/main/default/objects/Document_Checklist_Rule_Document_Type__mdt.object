    </fields>
    <fields>
        <fullName>Rule__c</fullName>
        <description>Parent rule for which this document type can be assigned.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Parent rule for which this document type can be assigned.</inlineHelpText>
        <label>Rule</label>
        <referenceTo>Document_Checklist_Rule__mdt</referenceTo>
        <relationshipLabel>Document Checklist Rule Document Types</relationshipLabel>
        <relationshipName>Document_Checklist_Rule_Document_Types</relationshipName>
        <required>true</required>
        <type>MetadataRelationship</type>
        <unique>false</unique>
    </fields>
    <label>Document Checklist Rule Document Type</label>
    <listViews>
        <fullName>All</fullName>
        <columns>DeveloperName</columns>
        <columns>MasterLabel</columns>
        <columns>Rule__c</columns>
        <columns>Allowed_Document_Types__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>Version_2_Doc_Types</fullName>
        <columns>DeveloperName</columns>
        <columns>MasterLabel</columns>
        <columns>Rule__c</columns>
        <columns>Allowed_Document_Types__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>DeveloperName</field>
            <operation>startsWith</operation>
            <value>V2</value>
        </filters>
        <label>Version 2 Doc Types</label>
    </listViews>
    <pluralLabel>Document Checklist Rule Document Types</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
