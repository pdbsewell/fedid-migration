                <value>
                    <fullName>CV_SUPPDOC</fullName>
                    <default>false</default>
                    <label>Employment: Resume / Curriculum Vitae</label>
                </value>
                <value>
                    <fullName>PRFEMPLMNT</fullName>
                    <default>false</default>
