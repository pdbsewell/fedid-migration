<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Contains the list of applicable document type for each document checklist rule</description>
    <fields>
        <fullName>Allowed_Document_Types__c</fullName>
