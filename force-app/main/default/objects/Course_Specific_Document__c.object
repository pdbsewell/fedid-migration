    <validationRules>
        <fullName>Course_or_Faculty_should_be_populated</fullName>
        <active>true</active>
        <description>Only either Course or Faculty should be populated</description>
        <errorConditionFormula>OR(AND(ISBLANK(Course__c), ISPICKVAL(Faculty_Name__c,&apos;&apos;)), AND(NOT(ISBLANK(Course__c)), NOT(ISPICKVAL(Faculty_Name__c,&apos;&apos;))))</errorConditionFormula>
        <errorMessage>Course or Faculty should be entered but not both.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
