    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>This object is to contain private information such as Activities, and Email content to override out of the box privacy of Activities being controlled by the parent object.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Contact_Birthdate__c</fullName>
        <description>Birthdate of contact. Being used in email template</description>
        <formula>Contact__r.Birthdate</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contact Birthdate</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Contact_Country_of_Birth__c</fullName>
        <description>Country of birth of Contact. Being used in email template</description>
        <externalId>false</externalId>
        <formula>TEXT(Contact__r.Country_Of_Birth__c)</formula>
        <label>Contact Country of Birth</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_Email__c</fullName>
        <description>Email address of contact. Being used in email tempalte</description>
        <externalId>false</externalId>
        <formula>Contact__r.Email</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contact Email</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_First_Name__c</fullName>
        <description>Name of contact associated to record. Being used in email template</description>
        <externalId>false</externalId>
        <formula>Contact__r.FirstName</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contact First Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_Last_Name__c</fullName>
        <description>last name of contact associated to record. being used in email tempalte</description>
        <externalId>false</externalId>
        <formula>Contact__r.LastName</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contact Last Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_Mailing_Address__c</fullName>
        <description>Mailing address of Contact. Being used in email template</description>
        <externalId>false</externalId>
        <formula>if(LEN(Contact__r.MailingStreet) &gt; 0, Contact__r.MailingStreet&amp; &quot; &quot; , &quot;&quot; ) &amp;
if(LEN(Contact__r.MailingCity) &gt; 0, Contact__r.MailingCity&amp; &quot;, &quot; , &quot;&quot; ) &amp;
if(LEN(Contact__r.MailingState ) &gt; 0, Contact__r.MailingState&amp; &quot; &quot; , &quot;&quot; ) &amp;
if(LEN(Contact__r.MailingCountry) &gt; 0, Contact__r.MailingCountry&amp; &quot; &quot;,&quot;&quot;) &amp;
if(LEN(Contact__r.MailingPostalCode) &gt; 0, Contact__r.MailingPostalCode,&quot;&quot;)</formula>
        <label>Contact Mailing Address</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact_Salutation__c</fullName>
        <description>Contact salutation. Being used in email tempalte</description>
        <externalId>false</externalId>
        <formula>TEXT(Contact__r.Salutation)</formula>
        <label>Contact Salutation</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Parent contact of record</description>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Communications / Activities</relationshipLabel>
        <relationshipName>Contact_Communications</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Current_Date__c</fullName>
        <description>gets current date. being used in email template</description>
        <formula>TODAY()</formula>
        <label>Current Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Subject__c</fullName>
        <description>Contains topic of communication</description>
        <externalId>false</externalId>
        <label>Subject</label>
        <length>150</length>
        <required>true</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Contact Communication</label>
    <nameField>
        <displayFormat>CC-{0000}</displayFormat>
        <label>Contact Communication Name</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Contact Communications</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
