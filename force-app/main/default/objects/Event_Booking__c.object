        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>Status__c</fullName>
        <externalId>false</externalId>
        <formula>IF(!ISBLANK(Cancelled_Date_Time__c),&apos;Cancelled&apos;,
  /* Minutes/Minutes In Day for DT addition */
  IF(Start_Date_Time__c+(Duration_In_Minutes__c/1440) &lt; NOW(),&apos;Complete&apos;,
    IF(Start_Date_Time__c &lt; NOW(),&apos;In Progress&apos;,
      &apos;Scheduled&apos;
    )
  )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
