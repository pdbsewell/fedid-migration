    <fields>
        <fullName>DPID__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Verified Delivery Point ID for AU Addresses only.</description>
        <externalId>false</externalId>
        <label>DPID</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>End_Date__c</fullName>
        <description>This defines the date until the address is valid for.</description>
        <inlineHelpText>Please provide the date the address is valid through, or leave it empty if it is not known or not end dated.</inlineHelpText>
        <label>End Date</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>External_System_ID__c</fullName>
        <caseSensitive>true</caseSensitive>
        <description>Unique ID used to identify records in an external system.</description>
        <externalId>true</externalId>
        <inlineHelpText>Unique ID used to identify records in an external system.</inlineHelpText>
        <label>External System ID</label>
        <length>100</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Is_Active__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Indicates whether an address is active, usually when end date is in the past or the start date is in the future. This value Is automatically (by a scheduled process) set to &quot;false&quot; if End_Date__c is populated and in the past or the Start_Date__c is in the future.
If manually set/changed to &quot;True&quot; (&quot;False&quot;), then the End_Date__c is automatically removed (added with the current date).</description>
        <inlineHelpText>Please indicate whether the address is active or not (inactive).</inlineHelpText>
        <label>Active</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Deleted__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>A soft delete flag. An overnight purge process removes these records.</description>
        <inlineHelpText>A soft delete flag, queued for purging</inlineHelpText>
        <label>Deleted</label>
        <securityClassification>Public</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Primary__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Global primary (by Contact), as such only a single Address__c record can be flagged as primary per Contact Lookup.
If selected manually, all other records (for the Contact) will be marked as non-primary (false)
If none are selected, the entry with the latest Start_Date__c will be automatically marked as primary.</description>
        <inlineHelpText>Please indicate whether the address is primary for this Contact.</inlineHelpText>
        <label>Primary</label>
        <securityClassification>Public</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Key_UID__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>System Field - Unique Key Combination field</description>
        <externalId>true</externalId>
        <inlineHelpText>System Field - Unique Key Combination field</inlineHelpText>
        <label>Key UID</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Post_Code__c</fullName>
        <description>Post code of the address</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the post code of the address</inlineHelpText>
        <label>Post Code</label>
        <length>16</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Primary_set_by__c</fullName>
        <description>Use as indicator if the record (only if Is_Primary__c changed) has been modified by user or system.</description>
        <externalId>false</externalId>
        <label>Primary set by</label>
        <length>80</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Source__c</fullName>
        <description>Source of the address.</description>
        <inlineHelpText>Please enter source of the address, i.e. how were the details obtained.</inlineHelpText>
        <label>Source</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Contact_Point_Source</valueSetName>
        </valueSet>
    </fields>
    <fields>
        <fullName>Start_Date__c</fullName>
        <description>The date the address is valid from.</description>
        <inlineHelpText>Please provide a date indicating the valid from for the address.</inlineHelpText>
        <label>Start Date</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>State__c</fullName>
        <description>State of the address</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the state of the address.</inlineHelpText>
        <label>State</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Street_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Name of the street (and type)</description>
        <inlineHelpText>Please provide the street name and type, e.g. Duerdin St, Wellington Road, Margaret Court</inlineHelpText>
        <label>Street Name</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <description>Type of the address.</description>
        <inlineHelpText>Please enter the address type</inlineHelpText>
        <label>Type</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Mailing</fullName>
                    <default>true</default>
                    <label>Mailing</label>
                </value>
                <value>
                    <fullName>Billing</fullName>
                    <default>false</default>
                    <label>Billing</label>
                </value>
                <value>
                    <fullName>Physical</fullName>
                    <default>false</default>
                    <label>Physical</label>
                </value>
                <value>
                    <fullName>Fax</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Fax</label>
                </value>
                <value>
                    <fullName>Landline</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Landline</label>
                </value>
                <value>
                    <fullName>Mobile</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Mobile</label>
                </value>
                <value>
                    <fullName>Postal</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Postal</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Verification_Status__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Verification of Address record inserted into the system</description>
        <label>Verification Status</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Address_Verification_Status</valueSetName>
        </valueSet>
    </fields>
    <label>Address</label>
    <listViews>
        <fullName>Address_audit</fullName>
        <columns>NAME</columns>
        <columns>Street_Name__c</columns>
        <columns>City__c</columns>
        <columns>State__c</columns>
        <columns>Post_Code__c</columns>
        <columns>Country2__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>NAME</field>
            <operation>equals</operation>
            <value>ADR-00075448,ADR-00085682,ADR-00104734,ADR-00128275</value>
        </filters>
        <label>Address audit</label>
    </listViews>
    <listViews>
        <fullName>All_created_today</fullName>
        <columns>NAME</columns>
        <columns>Street_Name__c</columns>
        <columns>State__c</columns>
        <columns>City__c</columns>
        <columns>Country2__c</columns>
        <columns>Post_Code__c</columns>
        <columns>Type__c</columns>
        <columns>Classification__c</columns>
        <columns>Contact__c</columns>
        <columns>Is_Active__c</columns>
        <columns>Is_Primary__c</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>CREATED_DATE</field>
            <operation>equals</operation>
            <value>TODAY</value>
        </filters>
        <label>All created today</label>
    </listViews>
    <listViews>
        <fullName>All_records</fullName>
        <columns>NAME</columns>
