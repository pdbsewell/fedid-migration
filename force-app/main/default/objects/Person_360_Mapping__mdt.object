        <columns>RollUpType__c</columns>
        <columns>RollUpSort__c</columns>
        <columns>RollDirection__c</columns>
        <columns>RollDownBlanks__c</columns>
        <columns>RollUpBlanks__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RollDownSObject__c</field>
            <operation>equals</operation>
            <value>Name</value>
        </filters>
        <label>Name</label>
    </listViews>
    <pluralLabel>Person360 Mappings</pluralLabel>
    <validationRules>
        <fullName>IsPrimaryCheck</fullName>
        <active>true</active>
        <description>Checks if Is Primary</description>
        <errorConditionFormula>AND(
IsPrimary__c,
NOT(ISPICKVAL(RollUpType__c, &apos;PRIMARY&apos;))
)</errorConditionFormula>
        <errorDisplayField>RollUpType__c</errorDisplayField>
        <errorMessage>Set to Primary if IsPrimary is true</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
