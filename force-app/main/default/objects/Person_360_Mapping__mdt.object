<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Mapping matrix for Person 360 roll down logic from Contact</description>
    <fields>
        <fullName>Classification__c</fullName>
        <description>Classification of Rolldown to Classification__c field</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Classification of Rolldown to Classification__c field</inlineHelpText>
        <label>Classification</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Private</fullName>
                    <default>true</default>
                    <label>Private</label>
                </value>
                <value>
                    <fullName>Monash</fullName>
                    <default>false</default>
                    <label>Monash</label>
                </value>
                <value>
                    <fullName>Business</fullName>
                    <default>false</default>
                    <label>Business</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>ContactSourceField__c</fullName>
        <description>Contact Source Field Api Name</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Contact Source Field Api Name</inlineHelpText>
        <label>Contact Source Field</label>
        <length>100</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>IsPrimary__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Field which will be set to the primary context of the person maps to Is_Primary__c</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Field which will be set to the primary context of the person maps to Is_Primary__c</inlineHelpText>
        <label>Is Primary</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>RollDirection__c</fullName>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Roll Direction</label>
        <required>true</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Both</fullName>
                    <default>true</default>
                    <label>Both</label>
                </value>
                <value>
                    <fullName>Down</fullName>
                    <default>false</default>
                    <label>Down</label>
                </value>
                <value>
                    <fullName>Up</fullName>
                    <default>false</default>
                    <label>Up</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>RollDownBlanks__c</fullName>
        <defaultValue>false</defaultValue>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Roll Down Blanks</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>RollDownField__c</fullName>
        <description>Target Field to Map values From Contact</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Target Field to Map values From</inlineHelpText>
        <label>Roll Down Field</label>
        <metadataRelationshipControllingField>Person_360_Mapping__mdt.RollDownSObject__c</metadataRelationshipControllingField>
        <referenceTo>FieldDefinition</referenceTo>
        <relationshipLabel>Person_Roll_Downs</relationshipLabel>
        <relationshipName>Person_Roll_Downs</relationshipName>
        <required>false</required>
        <type>MetadataRelationship</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>RollDownSObject__c</fullName>
        <description>Target SObject to Roll down</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Target SObject to Roll down</inlineHelpText>
        <label>Roll Down SObject</label>
        <referenceTo>EntityDefinition</referenceTo>
        <relationshipLabel>Person_Roll_Downs</relationshipLabel>
        <relationshipName>Person_Roll_Downs</relationshipName>
        <required>true</required>
        <type>MetadataRelationship</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>RollUpBlanks__c</fullName>
        <defaultValue>true</defaultValue>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Roll Up Blanks</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>RollUpSort__c</fullName>
        <defaultValue>false</defaultValue>
        <description>If true this will perform a sorting ORDER BY Start_Date__c DESC, createddate DESC to roll up to Contact</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>If true this will perform a sorting ORDER BY Start_Date__c DESC, createddate DESC to roll up to Contact</inlineHelpText>
        <label>RollUp Sort</label>
        <type>Checkbox</type>
    </fields>
