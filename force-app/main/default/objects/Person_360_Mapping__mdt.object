        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Mapped as Rollup Type identifier</inlineHelpText>
        <label>RollUpType</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>PRIMARY</fullName>
                    <default>true</default>
                    <label>PRIMARY</label>
                </value>
                <value>
                    <fullName>PRIVATE</fullName>
                    <default>false</default>
                    <label>PRIVATE</label>
                </value>
                <value>
                    <fullName>MONASH</fullName>
                    <default>false</default>
                    <label>MONASH</label>
                </value>
                <value>
                    <fullName>BUSINESS</fullName>
                    <default>false</default>
                    <label>BUSINESS</label>
                </value>
                <value>
                    <fullName>MOBILE</fullName>
                    <default>false</default>
                    <label>MOBILE</label>
                </value>
                <value>
                    <fullName>ASSISTANT</fullName>
                    <default>false</default>
                    <label>ASSISTANT</label>
                </value>
                <value>
                    <fullName>FAX</fullName>
                    <default>false</default>
                    <label>FAX</label>
                </value>
                <value>
                    <fullName>LANDLINE</fullName>
                    <default>false</default>
                    <label>LANDLINE</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <description>Phone Type Mapping</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <inlineHelpText>Phone Type Mapping</inlineHelpText>
        <label>Type</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Mobile</fullName>
                    <default>true</default>
                    <label>Mobile</label>
                </value>
                <value>
                    <fullName>Assistant</fullName>
                    <default>false</default>
                    <label>Assistant</label>
                </value>
                <value>
                    <fullName>Fax</fullName>
                    <default>false</default>
                    <label>Fax</label>
                </value>
                <value>
                    <fullName>Undefined</fullName>
                    <default>false</default>
                    <label>Undefined</label>
                </value>
                <value>
                    <fullName>Landline</fullName>
                    <default>false</default>
                    <label>Landline</label>
                </value>
