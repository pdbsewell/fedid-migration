    <label>Person 360 Mapping</label>
    <listViews>
        <fullName>ALLMDT</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>ContactSourceField__c</columns>
        <columns>RollDownSObject__c</columns>
