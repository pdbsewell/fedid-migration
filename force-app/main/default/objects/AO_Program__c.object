    <fields>
        <fullName>Business_Unit__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Business Unit to be captured for Program</description>
        <externalId>false</externalId>
        <formula>CASE(
   TEXT(AO_Program_Type__c),
   &quot;Global Study Tours (GST)&quot;, &quot;Study_Tours_GIG_GST&quot; ,
   &quot;Monash Global Campus Intensives in Malaysia (MGCI)&quot;, &quot;Monash_Led&quot; ,
   &quot;Monash Global Campus Intensives in Prato (MGCI)&quot;, &quot;Monash_Led&quot; ,
   &quot;Global Immersion Guarantee (GIG)&quot;, &quot;Study_Tours_GIG_GST&quot; ,
   &quot;Global Co-Curricular Experience (GCE)&quot;, &quot;Study_Tours_GCE_GWIL&quot; ,
   &quot;Global Work Integrated Learning (GWIL)&quot;, &quot;Study_Tours_GCE_GWIL&quot; ,
   &quot;Global Independent Research (GIR)&quot;, &quot;Partner_Led&quot; ,
   &quot;Independent Study Abroad (ISA)&quot;, &quot;Partner_Led&quot; ,
   &quot;Global Summer and Winter short term programs (GSP/GWP)&quot;, &quot;Partner_Led&quot; ,
   &quot;Global Intercampus Program semester in Australia (GIP)&quot;, &quot;Partner_Led&quot; ,
   &quot;Global Intercampus Program semester in Malaysia (GIP)&quot;, &quot;Partner_Led&quot; ,
   &quot;Semester exchange (EXC)&quot;, &quot;Partner_Led&quot; ,
   &quot;Other&quot;
)</formula>
        <label>Business Unit</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
