    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>AO_VALIDATE_DATES_IN_PAST</fullName>
        <active>false</active>
        <description>Start, End or Deadline Date can&apos;t be in past</description>
        <errorConditionFormula>OR(AND(NOT(ISBLANK(End_Date__c)),End_Date__c &lt;  TODAY())  ,  AND(NOT(ISBLANK(AO_Form_Deadline_Date__c)),AO_Form_Deadline_Date__c &lt; TODAY()) , AND(NOT(ISBLANK(Start_Date__c)), Start_Date__c &lt;  TODAY() ))</errorConditionFormula>
        <errorMessage>Start Date, End Date or Form Deadline Date can&apos;t be in past</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>AO_VALIDATE_END_BEFORE_START_DATE</fullName>
        <active>false</active>
        <description>End and Deadline date can&apos;t be before Start Date</description>
        <errorConditionFormula>OR(End_Date__c &lt; Start_Date__c ,  AO_Form_Deadline_Date__c &lt; Start_Date__c)</errorConditionFormula>
        <errorMessage>Form Deadline Date and End Date can&apos;t be before Start Date</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>AO_VALIDATE_SAME_DEADLINE_END_DATE</fullName>
        <active>false</active>
        <description>End date shouldn&apos;t be before Deadline date</description>
        <errorConditionFormula>End_Date__c &lt;= AO_Form_Deadline_Date__c</errorConditionFormula>
        <errorDisplayField>AO_Form_Deadline_Date__c</errorDisplayField>
        <errorMessage>Form Deadline Date can&apos;t be same or post Program End Date</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>AO_VALIDATE_SAME_START_END_DATE</fullName>
        <active>false</active>
        <description>Start and End date shouldn&apos;t be same</description>
        <errorConditionFormula>End_Date__c =  Start_Date__c</errorConditionFormula>
        <errorDisplayField>End_Date__c</errorDisplayField>
        <errorMessage>Start Date and End Date can&apos;t be same. Please update</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>VALIDATE_PROGRAM_YEAR</fullName>
        <active>true</active>
        <description>Program year should not be past year value</description>
        <errorConditionFormula>VALUE(TEXT(AO_Program_Year__c)) &lt;YEAR(TODAY())</errorConditionFormula>
        <errorDisplayField>AO_Program_Year__c</errorDisplayField>
        <errorMessage>Program Year can&apos;t be a previous year</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
