        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Student owner of the EC</description>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Emergency Contacts</relationshipLabel>
        <relationshipName>Emergency_Contacts</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>true</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Country__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Address Field

ISO Country List for Emergency Contacts</description>
        <label>Country</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Country_List_1</valueSetName>
        </valueSet>
    </fields>
    <fields>
        <fullName>Email_Address__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Primary email address</description>
        <externalId>false</externalId>
        <inlineHelpText>Primary email address</inlineHelpText>
        <label>Email Address</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Emergency_Contact_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The name details received from Callista. You will expect a channel to be linked if this field is populated. The UI will only show this field if it is populated.</description>
        <externalId>false</externalId>
        <inlineHelpText>The name of the emergency contact as supplied from Callista</inlineHelpText>
        <label>Emergency Contact Name</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Emergency_Contact__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Self referencing field for listviews as an alternative to the auto-number</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&apos;/&apos;+Id, IF (ISBLANK( Emergency_Contact_Name__c ), trim(First_Name__c + &apos; &apos; + Last_Name__c),Emergency_Contact_Name__c) + &apos; (&apos; + Relationship__c +&apos;)&apos; ,&apos;_self&apos; )</formula>
        <label>Emergency Contact</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>First_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>First and given names of the EC.

A validation rule ensures that a first or last name is entered, so mononymous names can be entered in either field.</description>
        <externalId>false</externalId>
        <inlineHelpText>First and given names of the EC</inlineHelpText>
        <label>First Name</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Fullname__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The Callista supplied full name or the first &amp; last names concatenated</description>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(Emergency_Contact_Name__c), TRIM(First_Name__c &amp; &apos; &apos; &amp; Last_Name__c), Emergency_Contact_Name__c)</formula>
        <inlineHelpText>EC Full name</inlineHelpText>
        <label>Full Name</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Key_UID__c</fullName>
        <businessStatus>Active</businessStatus>
        <caseSensitive>true</caseSensitive>
        <description>System Field - Unique Key Combination field</description>
        <externalId>true</externalId>
        <inlineHelpText>System Field - Unique Key Combination field</inlineHelpText>
        <label>Key UID</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Last_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The surname or family name of the EC. 

A validation rule ensures that a first or last name is entered, so mononymous names can be entered in either field.</description>
        <externalId>false</externalId>
        <inlineHelpText>The surname or family name of the EC</inlineHelpText>
        <label>Last Name</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Mobile_Phone__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Primary phone number</description>
