        <fullName>Preferred__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>A manually selected field to indicate the preferred emergency contact. There are no restrictions on the number of preferred ECs indicated.</description>
        <inlineHelpText>Indicates a preferred emergency contact</inlineHelpText>
        <label>Preferred</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
