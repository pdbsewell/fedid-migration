    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Active_From__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>TODAY()</defaultValue>
        <description>Start of active date range (used by the active flag)</description>
        <inlineHelpText>The start date from which this emergency contact should be considered</inlineHelpText>
        <label>Active From</label>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Active_To__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>End of active date range (used by the active flag)</description>
        <inlineHelpText>End of active date range</inlineHelpText>
        <label>Active To</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Active__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Active status calculation</description>
        <formula>AND(Active_From__c &lt;= TODAY(), BLANKVALUE(Active_To__c, TODAY()) &gt;= TODAY())</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Calculated status based on the active date range</inlineHelpText>
        <label>Active</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Alternate_Email_Address__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>A secondary email address</description>
        <externalId>false</externalId>
        <inlineHelpText>A secondary email address</inlineHelpText>
        <label>Alternate Email Address</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Alternate_Phone__c</fullName>
