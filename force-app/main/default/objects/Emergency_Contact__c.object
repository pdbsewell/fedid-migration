    <label>Emergency Contact</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>First_Name__c</columns>
        <columns>Last_Name__c</columns>
        <columns>Relationship__c</columns>
        <columns>Mobile_Phone__c</columns>
        <columns>Alternate_Phone__c</columns>
        <columns>Email_Address__c</columns>
        <columns>Alternate_Email_Address__c</columns>
        <columns>Preferred_Language__c</columns>
        <columns>Active__c</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <label>All Emergency Contacts</label>
        <sharedTo>
            <allInternalUsers></allInternalUsers>
        </sharedTo>
    </listViews>
    <listViews>
        <fullName>All_Active_Emergency_Contacts</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>First_Name__c</columns>
        <columns>Last_Name__c</columns>
        <columns>Relationship__c</columns>
        <columns>Mobile_Phone__c</columns>
        <columns>Alternate_Phone__c</columns>
        <columns>Email_Address__c</columns>
        <columns>Alternate_Email_Address__c</columns>
        <columns>Preferred_Language__c</columns>
        <columns>Active__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Active__c</field>
            <operation>equals</operation>
            <value>1</value>
        </filters>
        <label>All Active Emergency Contacts</label>
        <sharedTo>
            <allInternalUsers></allInternalUsers>
        </sharedTo>
    </listViews>
    <nameField>
        <displayFormat>EC-{00000000}</displayFormat>
        <label>Emergency Contact Id</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Emergency Contacts</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>First_Name__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Last_Name__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Relationship__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Mobile_Phone__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Alternate_Phone__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Email_Address__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Alternate_Email_Address__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Preferred_Language__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Active_From__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Enforce_date_range</fullName>
        <active>true</active>
        <description>Ensure that the active dates for a positive range</description>
        <errorConditionFormula>blankvalue(Active_To__c,today()) &lt; Active_From__c</errorConditionFormula>
        <errorMessage>The active to date field must be blank or follow the active from date field</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Enforce_minimum_contact_details</fullName>
        <active>true</active>
        <description>Ensure we have some minimum details for the EC record to be useful</description>
        <errorConditionFormula>AND( 
ISBLANK(Mobile_Phone__c), 
ISBLANK(Alternate_Phone__c),
ISBLANK(Alternate_Email_Address__c),
ISBLANK(Email_Address__c),
OR(ISBLANK(Street_Name__c),ISBLANK(Text(Country__c)))
)</errorConditionFormula>
        <errorMessage>Please supply a phone, email or minimum address details</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Enforce_minimum_name_details</fullName>
        <active>true</active>
        <description>We need a first or last name as a minimum</description>
        <errorConditionFormula>AND(
ISBLANK(First_Name__c),
ISBLANK(Last_Name__c),
ISBLANK(Emergency_Contact_Name__c)
)</errorConditionFormula>
        <errorMessage>Please supply a first or last name</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
