<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Used to filter the number of requests which go to Callista for the Application integration</description>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Defines if the rule is being applied or not</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Defines if the rule is being applied or not</inlineHelpText>
        <label>Active?</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <description>Type of filter which is defined for the rule e.g Channel, Location etc...</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Type of filter which is defined for the rule e.g Channel, Location etc...</inlineHelpText>
        <label>Type</label>
        <required>true</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Channel</fullName>
                    <default>true</default>
                    <label>Channel</label>
                </value>
                <value>
                    <fullName>Count</fullName>
                    <default>false</default>
                    <label>Count</label>
                </value>
                <value>
                    <fullName>Location</fullName>
                    <default>false</default>
                    <label>Location</label>
                </value>
                <value>
                    <fullName>PreviousMonashStudent</fullName>
                    <default>false</default>
                    <label>Previous Monash Student</label>
                </value>
                <value>
                    <fullName>CreditIntention</fullName>
                    <default>false</default>
                    <label>Credit Intention</label>
                </value>
                <value>
                    <fullName>ResidencyStatus</fullName>
                    <default>false</default>
                    <label>Residency Status</label>
                </value>
                <value>
                    <fullName>ACPPreferenceSubType</fullName>
                    <default>false</default>
                    <label>ACP Preference SubType</label>
                </value>
                <value>
                    <fullName>CourseCode</fullName>
                    <default>false</default>
                    <label>CourseCode</label>
                </value>
                <value>
                    <fullName>PreviousStudentCheck</fullName>
                    <default>false</default>
                    <label>PreviousStudentCheck</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Value__c</fullName>
        <description>Defines what the rule is measured against.</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Defines what the rule is measured against.</inlineHelpText>
        <label>Value</label>
        <length>255</length>
        <required>true</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Throttle Setting</label>
    <pluralLabel>Throttle Settings</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
