<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Rules executed to automatically generate document checklists</description>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Defines if the rule can be calculated or not</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Active</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Cancellation_Rule__c</fullName>
        <description>Field used to manage how the checklist is auto-cancelled</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Select &quot;Requested&quot; if auto-cancellation only applies when both applicants and assessors did not worked on the checklist</inlineHelpText>
        <label>Cancellation Rule</label>
        <required>true</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Always</fullName>
                    <default>true</default>
                    <label>Always</label>
                </value>
                <value>
                    <fullName>Never</fullName>
                    <default>false</default>
                    <label>Never</label>
                </value>
                <value>
                    <fullName>Draft Application</fullName>
                    <default>false</default>
                    <label>Draft Application</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Criteria__c</fullName>
        <description>Defines the evaluation criteria for the function, leave blank if should always return as true</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Defines the evaluation criteria for the function, leave blank if should always return as true</inlineHelpText>
        <label>Criteria</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
