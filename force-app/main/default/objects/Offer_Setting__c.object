    <fields>
        <fullName>Enable_Specialist_Review__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Enables the specialist review functionality for offers when a product, course fee and/or clause has been identified as something that could be reviewed by a CPQ admin before allowing the assessor to publish the offer. When this value is unchecked, opportunities generated for Offers will allow the assessor to publish the offer without further review from a CPQ Admin, regardless of whether a potential review for course fee, product and/or clause has been identified.</description>
        <label>Enable Specialist Review</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
