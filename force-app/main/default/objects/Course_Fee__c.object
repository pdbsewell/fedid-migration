    <fields>
        <fullName>Diploma_Accelerated_Deposit__c</fullName>
        <formula>Course_Deposit_Amount__c / 2</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Diploma Accelerated Deposit</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Diploma_Accelerated_Total_Fee__c</fullName>
        <description>Tactical field system. Used in CPQ Price rule &apos;ISCA Accelerated diploma&apos; field used to pre-calculate a 50% discount for specific diploma as the base value before any RPL. Once source callista data is rectified this field is no longer necessary.</description>
        <formula>Year_One_Fee__c / 2</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Diploma Accelerated Total Fee</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
