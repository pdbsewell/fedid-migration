    <fields>
        <fullName>Course_Fee_Identifier__c</fullName>
        <description>This field is used to match quote line information to the corresponding course fee</description>
        <externalId>false</externalId>
        <formula>IF(Product__r.Product_Bundle__r.ProductCode = &quot;BUNUNI&quot;, 
Course_Code__c &amp; &quot;|&quot; &amp; 
TEXT(Course_Code_Version__c) &amp; &quot;|&quot; &amp;  
Fee_Category__c,
Course_Code__c &amp; &quot;|&quot; &amp; 
TEXT(Course_Code_Version__c) &amp; &quot;|&quot; &amp; 
Unit_Set_Code__c &amp; &quot;|&quot; &amp; 
Fee_Category__c)</formula>
        <label>Course Fee Identifier</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
