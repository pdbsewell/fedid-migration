<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Configuration used to manage the connection to the MIX api</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Base_Url__c</fullName>
        <description>The base url which is used for connection to the environment.</description>
        <label>Base Url</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Client_Id__c</fullName>
        <description>The client ID which is used to connect to the MIX gateway.</description>
        <externalId>false</externalId>
        <label>Client Id</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Client_Secret__c</fullName>
        <description>The secret key used to access the API</description>
        <externalId>false</externalId>
        <label>Client Secret</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>MIX API Config</label>
    <visibility>Public</visibility>
</CustomObject>
