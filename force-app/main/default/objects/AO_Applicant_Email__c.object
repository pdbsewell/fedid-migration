    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>AO_Business_Unit__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Indicates the business unit derived from the program</description>
        <externalId>false</externalId>
        <formula>AO_Program_Applicant__r.AO_Program__r.Business_Unit__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Business Unit</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AO_Contact__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Applicant Emails</relationshipLabel>
        <relationshipName>Applicant_Emails</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_Email_Body__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Contains the Rendered Email content that will be sent to the applicant.

Used by SFMC to send automated comms</description>
        <inlineHelpText>Contains the Rendered Email content that will be sent to the applicant.</inlineHelpText>
        <label>Email Body</label>
        <length>4000</length>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Html</type>
        <visibleLines>25</visibleLines>
    </fields>
    <fields>
        <fullName>AO_Email_Sent__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Indicates whether the email was sent to the applicant</description>
        <label>Email Sent</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>AO_Email_Subject__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Contains the Subject line of the email to be sent to the applicant</description>
        <label>Email Subject</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>AO_Program_Applicant__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>Restrict</deleteConstraint>
        <label>Program Applicant</label>
        <referenceTo>AO_Program_Applicant__c</referenceTo>
        <relationshipLabel>Applicant Emails</relationshipLabel>
        <relationshipName>Applicant_Emails</relationshipName>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_Recipient_Email_Address_Type__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Indicates the email address type that this email will be sent to</description>
        <externalId>false</externalId>
        <label>Recipient&apos;s Email Address Type</label>
        <length>80</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AO_Recipient_Email_Address__c</fullName>
        <externalId>false</externalId>
        <label>Recipient Email Address</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Recipient_Email_Address__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>PII</complianceGroup>
        <description>Indicates the email address of the recipient</description>
        <externalId>false</externalId>
        <formula>CASE( AO_Recipient_Email_Address_Type__c ,&quot;Students&quot;,  IF( AO_Contact__r.Monash_Email_Address__c != null, AO_Contact__r.Monash_Email_Address__c, AO_Contact__r.Email)  ,&quot;Finance&quot;,$Setup.AO_Abroad_Settings__c.Finance_Team_Email__c ,&quot;&quot;)</formula>
        <label>Recipient Email Address</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Applicant Email</label>
    <nameField>
        <displayFormat>ApplicantEmail-{000000000}</displayFormat>
        <label>Applicant Emails Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Applicant Emails</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
