<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Created for: PD | Holds: Faculty specific contact details to use in email templates | Match &apos;Faculty Name&apos; to Course object&apos;s picklist &apos;Managing Faculty&apos;</description>
    <fields>
        <fullName>Faculty_Email__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Email</label>
        <required>false</required>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Faculty_Phone_Label__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Phone Label</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Faculty_Phone__c</fullName>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Phone</label>
        <required>false</required>
        <type>Phone</type>
    </fields>
    <fields>
        <fullName>Faculty_Student_Email_CC__c</fullName>
        <description>All emails going to the student via Salesforce will be copied to this email address.</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Student Email CC</label>
        <required>false</required>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Faculty_Website_Label__c</fullName>
        <description>Display URL</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Website Label</label>
        <required>false</required>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Faculty_Website_URL__c</fullName>
        <description>Actual URL</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Website URL</label>
        <required>false</required>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Faculty_Website__c</fullName>
        <description>Display URL</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Faculty Website</label>
        <required>false</required>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Managing_Faculty__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Managing Faculty</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Terms_and_Conditions_URL__c</fullName>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Terms and Conditions URL</label>
        <required>false</required>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Vendor_ID__c</fullName>
        <description>Use in PD, for Magento API [Enabling multi faculty facility on Magento]</description>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Vendor ID</label>
        <precision>10</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Faculty Custom Data</label>
    <pluralLabel>Faculty Custom Data</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
