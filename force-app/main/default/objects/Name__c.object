        <label>All records</label>
    </listViews>
    <listViews>
        <fullName>Names_with_brackets</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>Full_Name_Link__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>First_Name__c</field>
            <operation>contains</operation>
            <value>(</value>
        </filters>
        <filters>
            <field>Is_Active__c</field>
            <operation>equals</operation>
            <value>1</value>
        </filters>
        <filters>
            <field>Is_Primary__c</field>
            <operation>equals</operation>
            <value>1</value>
        </filters>
        <label>Names with brackets</label>
    </listViews>
