    <deploymentStatus>Deployed</deploymentStatus>
    <description>Name of a person (Contact)</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Relationship to Contact.</description>
        <inlineHelpText>Please provide the contact record this name is linked to.</inlineHelpText>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Names</relationshipLabel>
        <relationshipName>Names</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>End_Date__c</fullName>
        <description>This defines the date until the name is valid for.</description>
        <inlineHelpText>Please provide the date the name is valid through, or leave it empty if it is not known or not end dated.</inlineHelpText>
        <label>End Date</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>External_System_ID__c</fullName>
        <caseSensitive>true</caseSensitive>
        <description>Unique ID used to identify records in an external system.</description>
        <externalId>true</externalId>
        <inlineHelpText>Unique ID used to identify records in an external system.</inlineHelpText>
        <label>External System ID</label>
        <length>100</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>First_Name__c</fullName>
        <description>First (given) name.</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the first (given) name.</inlineHelpText>
        <label>First name</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Full_Name_Link__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Hyper-linked full name field for listview and related lists</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&apos;/lightning/r/&apos;+ Id + &apos;/view&apos;,
Full_Name__c
, &apos;_self&apos;)</formula>
        <inlineHelpText>Hyper-linked full name field</inlineHelpText>
        <label>Full name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Full_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Fullname built from:
Salutation__c/Prefix__c
First_Name__c/Preferred_First_Name
Middle_Name__c
Last_Name__c
Suffix__c</description>
        <externalId>false</externalId>
        <formula>TRIM(
BLANKVALUE(TEXT(Salutation__c),Prefix__c) + &apos; &apos;
+ BLANKVALUE(Preferred_First_Name__c,First_Name__c + &apos; &apos; + Middle_Name__c ) + &apos; &apos;
+ Last_Name__c + &apos; &apos;
+ TEXT(Suffix__c)
)</formula>
        <inlineHelpText>Fullname built from the populated fields</inlineHelpText>
        <label>Full name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Is_Active__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Indicates whether a name is active, usually when end date is in the past or the start date is in the future. This value Is automatically (by a scheduled process) set to &quot;false&quot; if End_Date__c is populated and in the past or the Start_Date__c is in the future.
If manually set/changed to &quot;True&quot; (&quot;False&quot;), then the End_Date__c is automatically removed (added with the current date).</description>
        <inlineHelpText>Please indicate whether the name is active or not (inactive).</inlineHelpText>
        <label>Active</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Mononymous_Name__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Indicates that there is no first name specified</description>
        <label>Mononymous Name</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Primary__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Global primary (by Contact), as such only a single Name__c record can be flagged as primary per Contact Lookup.
If selected manually, all other records (for the Contact) will be marked as non-primary (false)
If none are selected, the entry with the latest Start_Date__c will be automatically marked as primary.</description>
        <inlineHelpText>Please indicate whether the name is the primary for this Contact.</inlineHelpText>
        <label>Primary</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Key_UID__c</fullName>
        <businessStatus>Active</businessStatus>
        <caseSensitive>false</caseSensitive>
        <description>System Field - Unique Key Combination field</description>
        <externalId>true</externalId>
        <inlineHelpText>System Field - Unique Key Combination field</inlineHelpText>
        <label>Key UID</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Last_Name__c</fullName>
        <description>Last name.</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the last (family) name.</inlineHelpText>
        <label>Last name</label>
        <length>255</length>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Middle_Name__c</fullName>
        <description>Middle name(s).</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the middle name(s).</inlineHelpText>
        <label>Middle name</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Preferred_First_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>PII</complianceGroup>
        <description>The preferred first name. This will be rolled up to the contact as the first name if primary.</description>
        <externalId>false</externalId>
        <inlineHelpText>The preferred first name</inlineHelpText>
        <label>Preferred First Name</label>
        <length>80</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Prefix__c</fullName>
        <description>Name prefix e.g. Prof, Dr, Honourable, Judge etc.</description>
        <externalId>false</externalId>
        <inlineHelpText>Please provide the (formal) name prefix(es).</inlineHelpText>
        <label>Name Prefix</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Primary_set_by__c</fullName>
        <description>Use as indicator if the record (only if Is_Primary__c changed) has been modified by user or system.</description>
        <externalId>false</externalId>
        <label>Primary set by</label>
        <length>80</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Rollup_Rank__c</fullName>
        <description>System Field - a simple way to prioritise Student Names for Student Contacts. This is used as an additional sort in the name roll-up SOQL.</description>
        <externalId>false</externalId>
        <formula>IF(AND(Contact__r.Is_Student__c,  ISPICKVAL(Type__c, &apos;Student Name&apos;)),&apos;10&apos;,&apos;100&apos;)</formula>
        <label>Rollup Rank</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
