        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Enquiry non-closed status fields that should be included in firing the logic.</inlineHelpText>
        <label>Included Non-Closed Status</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Match_on_Non_Closed_Status__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Rule will only match Enquiries that have one of the listed Non-Closed statuses</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Rule will only match Enquiries that have one of the listed Non-Closed statuses</inlineHelpText>
        <label>Match on Non-Closed Status</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>New_Enquiry_Priority__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>New Enquiry Priority</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>-- Do not change --</fullName>
                    <default>true</default>
                    <label>-- Do not change --</label>
                </value>
                <value>
                    <fullName>High</fullName>
                    <default>false</default>
                    <label>High</label>
                </value>
                <value>
                    <fullName>Medium</fullName>
                    <default>false</default>
                    <label>Medium</label>
                </value>
                <value>
                    <fullName>Low</fullName>
                    <default>false</default>
                    <label>Low</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>New_Enquiry_Status__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>New Enquiry Status</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
