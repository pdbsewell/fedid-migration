        <filterScope>Everything</filterScope>
        <label>All</label>
        <language>en_US</language>
    </listViews>
    <listViews>
        <fullName>Faculty_Graduate_Research</fullName>
        <columns>MasterLabel</columns>
        <columns>Active__c</columns>
        <columns>Applied_Origin__c</columns>
        <columns>Applied_to_Origin__c</columns>
