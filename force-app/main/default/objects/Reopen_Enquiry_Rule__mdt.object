        </valueSet>
    </fields>
    <fields>
        <fullName>Re_Opened_Retain_Owner__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Controls whether the reopened enquiry (less than within days) ratains its owner</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Re-Opened Retain Owner</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Reopen_Enquiry__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Checkbox to control when an incoming email reopens an enquiry or create a seperate enquiry</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Checkbox to control when an incoming email reopens an enquiry or create a seperate enquiry</inlineHelpText>
        <label>Reopen Enquiry</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Use_Assignment_Rules__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Flag to control the auto assignment of the enquiries.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Flag to control the auto assignment of the enquiries.</inlineHelpText>
        <label>Use Assignment Rules</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Use_EmailToCase_Mapping__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Flag that controls whether the email to case mapping is going to be used for reopened enquiries</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Flag that controls whether the email to case mapping is going to be used for reopened enquiries</inlineHelpText>
        <label>Use EmailToCase Mapping</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Within_Calendar_Days__c</fullName>
        <description>Enquiries will not be reopened when the number of days lapse</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Enquiries will not be reopened when the number of days lapse</inlineHelpText>
        <label>Within Calendar Days</label>
        <precision>18</precision>
        <required>true</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Reopen Enquiry Rule</label>
