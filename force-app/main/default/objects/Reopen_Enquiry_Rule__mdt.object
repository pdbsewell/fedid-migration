    <fields>
        <fullName>Assign_Original_as_Parent_Enquiry__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Field to control whether the created enquiry is related to the original enquiry as parent</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
