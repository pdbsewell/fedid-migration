                </value>
                <value>
                    <fullName>New</fullName>
                    <default>false</default>
                    <label>New</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Original_Enquiry_Priority__c</fullName>
        <description>Priority value to be included on the reopened enquiries.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Priority value to be included on the reopened enquiries.</inlineHelpText>
