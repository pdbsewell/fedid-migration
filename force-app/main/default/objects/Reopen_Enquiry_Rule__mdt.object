                    <label>Low</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Original_Enquiry_Status__c</fullName>
        <description>Controls the status field value to update</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Controls the status field value to update</inlineHelpText>
        <label>Original Enquiry Status</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Open</fullName>
                    <default>true</default>
                    <label>Open</label>
                </value>
                <value>
                    <fullName>Reopened</fullName>
                    <default>false</default>
                    <label>Reopened</label>
                </value>
