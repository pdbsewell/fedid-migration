<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Custom metadata to manage the enquiry behavior when an incoming emailmessage comes in from a closed enquiry</description>
    <fields>
