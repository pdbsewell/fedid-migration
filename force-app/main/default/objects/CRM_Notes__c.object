    <fields>
        <fullName>Text__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Text body of the Note</description>
        <label>Text</label>
        <length>5000</length>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>10</visibleLines>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Type of Note

- a subset of note types from Callista relevant to assessments</description>
        <label>Type</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>CENTRAL</fullName>
                    <default>false</default>
                    <label>CENTRAL ADMINISTRATION SERVICE NOTES</label>
                </value>
                <value>
                    <fullName>CREDIT</fullName>
                    <default>false</default>
                    <label>FROM ONLINE CREDIT APP</label>
                </value>
                <value>
                    <fullName>ESOS</fullName>
                    <default>false</default>
                    <label>ESOS INFORMATION</label>
                </value>
                <value>
                    <fullName>FACULTY</fullName>
                    <default>false</default>
                    <label>FACULTY NOTES</label>
                </value>
                <value>
                    <fullName>FEE-REFUND</fullName>
                    <default>false</default>
                    <label>FEE REFUND DETAILS</label>
                </value>
                <value>
                    <fullName>FEES UNIT</fullName>
                    <default>false</default>
                    <label>FEES UNIT, STUDENT NOTES</label>
                </value>
                <value>
                    <fullName>INTPAYMENT</fullName>
                    <default>false</default>
                    <label>INTERNATIONAL STUDENT OFFER ACCETANCES PAYMENT</label>
                </value>
                <value>
                    <fullName>QL-SUMMARY</fullName>
                    <default>false</default>
                    <label>SUMMARY OF ACADEMIC &amp; ENGLISH QUALIFICATION &amp; CREDIT GRANTED</label>
                </value>
                <value>
                    <fullName>SCHOLARSHP</fullName>
                    <default>false</default>
                    <label>SCHOLARSHIP</label>
                </value>
                <value>
                    <fullName>STDY-GRNT</fullName>
                    <default>false</default>
                    <label>STUDY GRANT</label>
                </value>
                <value>
                    <fullName>VTAC-IN-CR</fullName>
                    <default>false</default>
                    <label>VTAC-IN-CR</label>
                </value>
                <value>
                    <fullName>VTAC-RMRKS</fullName>
                    <default>false</default>
                    <label>VTAC-RMRKS</label>
                </value>
                <value>
                    <fullName>VTAC-IN-RM</fullName>
                    <default>false</default>
                    <label>VTAC-IN-RM</label>
                </value>
                <value>
                    <fullName>GTE</fullName>
                    <default>false</default>
                    <label>GENUINE TEMPORARY ENTRANCE ADMISSION DETAILS</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <label>CRM Notes</label>
    <nameField>
        <label>CRM Notes Name</label>
        <trackHistory>false</trackHistory>
        <type>Text</type>
    </nameField>
    <pluralLabel>CRM Notes</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Validate_INTPAYMENT_text_format</fullName>
        <active>true</active>
        <description>INTPAYMENT text format should always be - 

Package Deposit: $1000
OSHC: $500
OSHC Sponsored: Y/N
Tuition Sponsored: Y/N</description>
        <errorConditionFormula>AND(
  TEXT( Type__c ) = &apos;INTPAYMENT&apos;,
  NOT(
    REGEX(
      Text__c,
      &quot;^Package Deposit: \\$\\d+\\r?\\nOSHC: \\$\\d+\\r?\\nOSHC Sponsored: [YN]\\r?\\nTuition Sponsored: [YN]$&quot;
    )
  )
)
&amp;&amp; 
NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c)</errorConditionFormula>
        <errorDisplayField>Text__c</errorDisplayField>
        <errorMessage>Please check the format of the text.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validate_STDYGRNT_text_format</fullName>
        <active>true</active>
        <description>ONLY record Alumni Discount or TNE discounts codes here, format as follows YYYY/1-10%AlumniDiscount or YYYY-TNE-5000X1</description>
        <errorConditionFormula>AND(
TEXT( Type__c ) = &apos;STDY-GRNT&apos;,
NOT(
REGEX(Text__c, &quot;^[0-9]{4}.*$&quot;)
)
)
&amp;&amp;
NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c)</errorConditionFormula>
        <errorDisplayField>Text__c</errorDisplayField>
        <errorMessage>ONLY record Alumni Discount or TNE discounts codes here, format as follows YYYY/1-10%AlumniDiscount or YYYY-TNE-5000X1</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
