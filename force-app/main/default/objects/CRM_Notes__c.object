    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Application_Course_Preference__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to ACP</description>
        <label>Application Course Preference</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>$Source.Contact__c</field>
                <operation>equals</operation>
                <valueField>Application_Course_Preference__c.Applicant__c</valueField>
            </filterItems>
            <filterItems>
                <field>$Source.Application__c</field>
                <operation>equals</operation>
                <valueField>Application_Course_Preference__c.Application__c</valueField>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Application_Course_Preference__c</referenceTo>
        <relationshipLabel>CRM Notes</relationshipLabel>
        <relationshipName>CRM_Notes</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
