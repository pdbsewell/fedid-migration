    <fields>
        <fullName>Type__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Type of Channel (which maps to Callista Address Type)
it supports Callista types + the &quot;MAILING&quot; type (which is used by the Lead Management).</description>
        <inlineHelpText>Type of Channel - CRM Users are not expected to select Callista values</inlineHelpText>
        <label>Type</label>
        <required>true</required>
        <securityClassification>Public</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>HOME</fullName>
                    <default>false</default>
                    <label>Home</label>
                </value>
                <value>
                    <fullName>MAILING</fullName>
                    <default>false</default>
                    <label>Mailing</label>
                </value>
                <value>
                    <fullName>POSTAL</fullName>
                    <default>false</default>
                    <label>Postal</label>
                </value>
                <value>
                    <fullName>POSTAL-EXT</fullName>
                    <default>false</default>
                    <label>Postal Extended</label>
                </value>
                <value>
                    <fullName>OS-POSTAL</fullName>
                    <default>false</default>
                    <label>Overseas Postal</label>
                </value>
                <value>
                    <fullName>OS-HOME</fullName>
                    <default>false</default>
                    <label>Overseas Home</label>
                </value>
                <value>
                    <fullName>AP-EMAIL</fullName>
                    <default>false</default>
                    <label>Application Email</label>
                </value>
                <value>
                    <fullName>GRADUATION-APPL</fullName>
                    <default>false</default>
                    <label>Graduation Email</label>
                </value>
                <value>
                    <fullName>EMERCONT</fullName>
                    <default>false</default>
                    <label>Emergency Contact</label>
                </value>
                <value>
                    <fullName>BILLING</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Billing</label>
                </value>
                <value>
                    <fullName>BUSINESS</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Business</label>
                </value>
                <value>
                    <fullName>DEFAULT</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Default</label>
                </value>
                <value>
                    <fullName>LEGAL</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Legal</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Unique_Id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>Use in the event handler trigger for mapping</description>
        <externalId>true</externalId>
        <label>Unique Id</label>
        <length>100</length>
