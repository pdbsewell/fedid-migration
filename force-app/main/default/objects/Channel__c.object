    <fields>
        <fullName>AU_Post_Code__c</fullName>
        <description>AU Post Code for Source System</description>
        <externalId>false</externalId>
        <label>AU Post Code</label>
        <length>20</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Address_Key__c</fullName>
        <description>Used for contact point creation</description>
        <externalId>false</externalId>
        <formula>Street__c +  City__c + State__c +  TEXT(Country__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Address Key</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Channel_Link__c</fullName>
        <description>Alternative to the auto number field for listviews</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&quot;/lightning/r/&quot; &amp; Id + &quot;/view&quot;, Name &amp; CHR(160) &amp; IF( Deleted_In_Source__c,&quot;[Pending Delete]&quot;+CHR(160),&quot;&quot;) &amp; IF(ISBLANK(Person_ID__c),IF(ISBLANK(Contact__r.Person_ID__c),&quot;&quot;,Contact__r.Person_ID__c &amp; &quot;/&quot;), Person_ID__c &amp; &quot;/&quot;) &amp; TEXT(Type__c) &amp; CASE(TEXT(Type__c), &quot;EMERCONT&quot;, &quot;/&quot; &amp; UPPER(Relationship__c),&quot;&quot;),&quot;_self&quot;)</formula>
        <label>Channel</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>City__c</fullName>
        <externalId>false</externalId>
        <label>City</label>
        <length>40</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
