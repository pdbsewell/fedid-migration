        <unique>true</unique>
    </fields>
    <fields>
        <fullName>is_Active__c</fullName>
        <description>Defines whether this Channel is considered as active based on defined attributes</description>
        <formula>IF(
	AND(
		NOT(Deleted_In_Source__c),
		Start_Date__c &lt;= TODAY(), 
		OR(
			End_Date__c &gt; TODAY(),
			ISNULL(End_Date__c)
		)
	),
TRUE,
FALSE)</formula>
        <label>Active</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
