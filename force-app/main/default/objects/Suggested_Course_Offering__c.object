    <validationRules>
        <fullName>Check_Open_Opportunity</fullName>
        <active>true</active>
        <description>can&apos;t update record if open opportunity</description>
        <errorConditionFormula>AND(
   ISCHANGED ( Primary__c ),
   OR(
     ISPICKVAL(Bulk_Data_Processing__r.Status__c, &quot;Processing Offer&quot;),
     ISPICKVAL(Bulk_Data_Processing__r.Status__c, &quot;Offer Created&quot;),
     ISPICKVAL(Bulk_Data_Processing__r.Status__c, &quot;Offer Error&quot;),
     ISPICKVAL(Bulk_Data_Processing__r.Status__c, &quot;Completed&quot;)
   )
)</errorConditionFormula>
        <errorMessage>Active offer has been detected for the BDP record. Please close the active offer in Opportunity or Quote.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Existing_Primary</fullName>
        <active>true</active>
        <description>One one primary suggested course offering is allow at a time</description>
        <errorConditionFormula>AND( 
Primary__c,
ISCHANGED(Primary__c),
Bulk_Data_Processing__r.Primary_Course_Offering__c &gt;= 1
)</errorConditionFormula>
        <errorMessage>Please ensure that the existing Transfer To ACP is updated accordingly before setting a new primary Suggested Course Offering record.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
