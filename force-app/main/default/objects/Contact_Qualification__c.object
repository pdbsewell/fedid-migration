    <validationRules>
        <fullName>Name_and_Title_char_limit_on_Publication</fullName>
        <active>true</active>
        <description>Name and Title char limit on Publications</description>
        <errorConditionFormula>IF(
    AND(RecordType.Name == &apos;Publications&apos;, AND(LEN(Name_of_Publisher_Journal_Org__c) &lt;= 500, LEN(Title_of_Publication_Work_Chapter_Paper__c) &lt;= 500)), 
    false,
	(IF
		(
			AND(RecordType.Name != &apos;Publications&apos;, AND(LEN(Name_of_Publisher_Journal_Org__c) &lt;= 200, LEN(Title_of_Publication_Work_Chapter_Paper__c) &lt;= 200)),
			false,
			IF(NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c), true, false)
		)
	)
)</errorConditionFormula>
        <errorMessage>characters limit for Name of Publisher/Journal/Org and Title of Publication/Work/Chapter/Paper is 500 for Publications and 200 for other types</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
