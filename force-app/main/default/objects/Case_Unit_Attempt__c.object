    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>AP_Must_Enrolled_CP_Limit</fullName>
        <active>true</active>
        <errorConditionFormula>AND(RecordType.DeveloperName = &apos;Academic_Progress_Assessment&apos;, OR(TEXT(Type__c) = &apos;Limit on enrolled credit points&apos;, TEXT(Type__c) = &apos;Must pass a specific number of credit points&apos;), ISBLANK(Enrolled_Credit_Points_Limit__c))</errorConditionFormula>
        <errorDisplayField>Enrolled_Credit_Points_Limit__c</errorDisplayField>
        <errorMessage>Please provide Enrolled Credit Points Limit.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>AP_Must_Staff_Comment</fullName>
        <active>true</active>
        <errorConditionFormula>AND(RecordType.DeveloperName = &apos;Academic_Progress_Assessment&apos;, OR(TEXT(Type__c) = &apos;Other&apos;, TEXT(Type__c) = &apos;Unit type restriction&apos;), ISBLANK(Comment__c))</errorConditionFormula>
        <errorDisplayField>Comment__c</errorDisplayField>
        <errorMessage>Please provide Staff Comment.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>AP_Must_Unit_Code</fullName>
        <active>true</active>
        <errorConditionFormula>AND(RecordType.DeveloperName = &apos;Academic_Progress_Assessment&apos;, OR(TEXT(Type__c) = &apos;Must be enrolled in specific unit(s)&apos;, TEXT(Type__c) = &apos;Must pass specific unit(s)&apos;), ISBLANK(Unit_Code__c))</errorConditionFormula>
        <errorDisplayField>Unit_Code__c</errorDisplayField>
        <errorMessage>Please provide Unit Code.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Unit_Type_Restriction</fullName>
        <active>true</active>
        <errorConditionFormula>IF(Trigger_Validation_Rule__c = &apos;Must be enrolled in specific unit(s)&apos;, true, false)</errorConditionFormula>
        <errorMessage>Only one enrolment condition with type as &quot;Must be enrolled in specific unit(s)&quot; can exist for an &quot;Academic Progress Assessment&quot; case.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
