    <fields>
        <fullName>Unit_Title__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Reflects either Unit Attempt Title or Unit Offering Title (needed for email merge field)</description>
        <externalId>false</externalId>
        <formula>IF(!ISBLANK(Unit_Attempt__c),
    Unit_Attempt__r.Title__c,
    IF(!ISBLANK(Unit_Offering__c),
        Unit_Offering__r.Title__c,
        &apos;&apos;
    )
)</formula>
        <label>Unit Title</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Unit__c</fullName>
        <description>Displays the Title of the unit</description>
        <externalId>false</externalId>
        <formula>IF( NOT(ISBLANK( Unit_Attempt__c )) 
            , HYPERLINK(&apos;/&apos;+Id,Unit_Attempt__r.Unit_Code__c + &apos; - &apos; + Unit_Attempt__r.Title__c,&apos;_self&apos; )
            , IF( NOT(ISBLANK( Unit_Offering__c )) 
            , HYPERLINK(&apos;/&apos;+Id,Unit_Offering__r.Unit_Code__c + &apos; - &apos; + Unit_Offering__r.Title__c,&apos;_self&apos; )
            , HYPERLINK(&apos;/&apos;+Id,Unit_Code__c,&apos;_self&apos; )))</formula>
        <label>Unit</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
