    <fields>
        <fullName>Handbook__c</fullName>
        <externalId>false</externalId>
        <formula>IF(NOT(ISBLANK(Unit_Attempt__r.Unit_Code__c)), HYPERLINK($Label.Handbook_URL + Unit_Attempt__r.Unit_Code__c, &apos;View Handbook&apos;, &apos;_blank&apos;), 
IF(NOT(ISBLANK(Unit_Offering__r.Unit_Code__c)), HYPERLINK($Label.Handbook_URL + Unit_Offering__r.Unit_Code__c, &apos;View Handbook&apos;, &apos;_blank&apos;), 
HYPERLINK($Label.Handbook_URL + Unit_Code__c, &apos;View Handbook&apos;, &apos;_blank&apos;)))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Handbook</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Is_Closed_On_Create__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>This field will be marked as true if the record is created with an approved status. This is used to report how many records were auto-approved.</description>
        <label>Is Closed On Create</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Moodle_Assessment_ID__c</fullName>
        <description>&apos;Moodle Assessment ID&apos; will now capture the Assignment ID of the specific assessment task we will attempt to update from a students live Moodle activities.</description>
        <externalId>false</externalId>
        <label>Moodle Assessment ID</label>
        <length>25</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Moodle_Integration_Status__c</fullName>
        <description>&apos;Moodle Integration Status&apos; will convey a message to confirm whether the integration update attempt to update Moodle was successful or unsuccessful.</description>
        <externalId>false</externalId>
        <label>Moodle Integration Status</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Origin__c</fullName>
        <description>This field is used to capture whether this record was filled in from Moodle or user-provided.
- If the data was received from and filled in from Moodle - it will be &quot;Moodle eLMS&quot;.
- If the data was received from and filled in by the student - it will be &quot;User Input&quot;.</description>
        <label>Origin</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Callista</fullName>
                    <default>false</default>
                    <label>Callista</label>
                </value>
                <value>
                    <fullName>Moodle eLMS</fullName>
                    <default>false</default>
                    <label>Moodle eLMS</label>
                </value>
                <value>
                    <fullName>User Input</fullName>
                    <default>false</default>
                    <label>User Input</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
