            <field>Status__c</field>
            <operation>equals</operation>
            <value>Approved,Approved Alternative Assessment,Approved Extension,Approved Exemption,Declined,Withdrawn</value>
        </filters>
        <filters>
            <field>CREATED_DATE</field>
            <operation>greaterOrEqual</operation>
