        <fullName>Contact__c</fullName>
        <description>Links to the contact from Enquiry</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&apos;/&apos;+ Enquiry__r.ContactId, Enquiry__r.Contact.Full_Name__c ,&apos;_self&apos; )</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
