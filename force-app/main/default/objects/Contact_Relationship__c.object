    <validationRules>
        <fullName>End_Date_Greater_Than_Start_Date</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	End_Date__c  &lt;  Start_Date__c,
    NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c)
	)</errorConditionFormula>
        <errorMessage>End Date cannot be smaller than Start Date</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
