<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>Represents the mapping of which Queue or User own DoI subject matters</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Queue_Name__c</fullName>
        <description>Queue Name (Developer Name) for Subject Matter</description>
        <externalId>false</externalId>
        <label>Queue Name</label>
        <length>64</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Staff_Authcate__c</fullName>
        <description>Staff Authcate (User.FederationIdentifier) for Subject Matter</description>
        <externalId>false</externalId>
        <label>Staff Authcate</label>
        <length>16</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Subject_Matter__c</fullName>
        <caseSensitive>false</caseSensitive>
        <externalId>false</externalId>
        <label>Subject Matter</label>
        <length>64</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <label>DoI Subject Owner Mapping</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Subject_Matter__c</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
        <language>en_US</language>
    </listViews>
    <visibility>Public</visibility>
</CustomObject>
