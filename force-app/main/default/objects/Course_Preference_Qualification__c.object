    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Used to track the pre requisite information relating to an individual Application Course Preference. For example, where English is a requirement for course entry, this junction object serves as the fulfilment of that requirement by assigning a Qualification record to the ACP.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Application_Course_Preference_Parent__c</fullName>
        <deleteConstraint>Cascade</deleteConstraint>
        <description>Used as the &quot;parent&quot; record when linking them together. Always populated on create</description>
        <inlineHelpText>Used as the &quot;parent&quot; record when linking them together. Always populated on create</inlineHelpText>
        <label>Application Course Preference Parent</label>
        <referenceTo>Application_Course_Preference__c</referenceTo>
        <relationshipLabel>Course Preference Qualifications (Application Course Preference Parent)</relationshipLabel>
        <relationshipName>Assessed_Qualifications</relationshipName>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Application_Course_Preference__c</fullName>
        <deleteConstraint>Cascade</deleteConstraint>
        <description>Lookup to the Application Course Preference object which should be associated with a Qualification for the purposes of pre requisite fulfilment</description>
        <inlineHelpText>Lookup to the Application Course Preference object which should be associated with a Qualification for the purposes of pre requisite fulfilment</inlineHelpText>
        <label>Application Course Preference</label>
        <referenceTo>Application_Course_Preference__c</referenceTo>
        <relationshipLabel>Course Preference Qualifications</relationshipLabel>
        <relationshipName>Course_Preference_Qualifications</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Contact_Qualification__c</fullName>
        <deleteConstraint>Cascade</deleteConstraint>
        <description>The Contact Qualification which is reflective of a record which meets the eligibility criteria of the Application Course Preference.</description>
        <inlineHelpText>The Contact Qualification which is reflective of a record which meets the eligibility criteria of the Application Course Preference.</inlineHelpText>
        <label>Contact Qualification</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>$Source.Contact__c</field>
                <operation>equals</operation>
                <valueField>Contact_Qualification__c.Contact__c</valueField>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Contact_Qualification__c</referenceTo>
        <relationshipLabel>Course Preference Qualifications</relationshipLabel>
        <relationshipName>Course_Preference_Qualifications</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Contact__c</fullName>
        <deleteConstraint>Cascade</deleteConstraint>
        <description>A link to the applicant record</description>
        <inlineHelpText>A link to the applicant record</inlineHelpText>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Course Preference Qualifications</relationshipLabel>
        <relationshipName>Course_Preference_Qualifications</relationshipName>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
