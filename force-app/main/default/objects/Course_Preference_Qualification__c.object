            </valueSetDefinition>
            <valueSettings>
                <controllingFieldValue>VCE English Equivalent</controllingFieldValue>
                <controllingFieldValue>Monash English Pathway</controllingFieldValue>
                <controllingFieldValue>Language of Instruction</controllingFieldValue>
                <controllingFieldValue>English Test Results</controllingFieldValue>
                <controllingFieldValue>Education</controllingFieldValue>
                <controllingFieldValue>Valid and Verified Professional Registration</controllingFieldValue>
