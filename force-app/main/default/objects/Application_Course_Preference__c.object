    <fields>
        <fullName>Age_as_at_course_start_date_del__c</fullName>
        <externalId>false</externalId>
        <formula>IF(Course_Offering__r.Start_Date__c&lt;Applicant__r.Birthdate, &quot;&quot;,

TEXT(IF(YEAR(Course_Offering__r.Start_Date__c)=YEAR(Applicant__r.Birthdate),0,IF(YEAR(Course_Offering__r.Start_Date__c)-YEAR(Applicant__r.Birthdate)=1,IF(MONTH(Course_Offering__r.Start_Date__c)=MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),0,1),IF(MONTH(Course_Offering__r.Start_Date__c)&lt;MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),1,0),1)),IF(MONTH(Course_Offering__r.Start_Date__c)-MONTH(Applicant__r.Birthdate)&lt;0,YEAR(Course_Offering__r.Start_Date__c)-YEAR(Applicant__r.Birthdate)-1,IF(MONTH(Course_Offering__r.Start_Date__c)=MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),YEAR(Course_Offering__r.Start_Date__c)-YEAR(Applicant__r.Birthdate)-1,YEAR(Course_Offering__r.Start_Date__c)-YEAR(Applicant__r.Birthdate)),YEAR(Course_Offering__r.Start_Date__c)-YEAR(Applicant__r.Birthdate)))))) &amp; &quot; years, &quot; &amp;

TEXT(IF(YEAR(Course_Offering__r.Start_Date__c)=YEAR(Applicant__r.Birthdate),IF(MONTH(Course_Offering__r.Start_Date__c)=MONTH(Applicant__r.Birthdate),0,IF(MONTH(Course_Offering__r.Start_Date__c)&gt;MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),MONTH(Course_Offering__r.Start_Date__c)-MONTH(Applicant__r.Birthdate)-1,MONTH(Course_Offering__r.Start_Date__c)-MONTH(Applicant__r.Birthdate)),0)),IF(MONTH(Course_Offering__r.Start_Date__c)=MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),11,0),IF(MONTH(Course_Offering__r.Start_Date__c)&gt;MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),MONTH(Course_Offering__r.Start_Date__c)-MONTH(Applicant__r.Birthdate)-1,MONTH(Course_Offering__r.Start_Date__c)-MONTH(Applicant__r.Birthdate)),IF(MONTH(Course_Offering__r.Start_Date__c)&lt;MONTH(Applicant__r.Birthdate),IF(DAY(Course_Offering__r.Start_Date__c)&lt;DAY(Applicant__r.Birthdate),11-(MONTH(Applicant__r.Birthdate)-MONTH(Course_Offering__r.Start_Date__c)),12-(MONTH(Applicant__r.Birthdate)-MONTH(Course_Offering__r.Start_Date__c))),12-(MONTH(Applicant__r.Birthdate)-MONTH(Course_Offering__r.Start_Date__c))))))) &amp; &quot; months, &quot; &amp;

TEXT(IF(DAY(Course_Offering__r.Start_Date__c)&gt;=DAY(Applicant__r.Birthdate),DAY(Course_Offering__r.Start_Date__c)-DAY(Applicant__r.Birthdate),31-(DAY(Applicant__r.Birthdate)-DAY(Course_Offering__r.Start_Date__c)))) &amp; &quot; days&quot;

)</formula>
        <label>Applicant Age as at course start date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
