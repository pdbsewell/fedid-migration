    <fields>
        <fullName>Course__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to course code, filtering out Unit Set courses</description>
        <label>Course</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>Course__c.Type__c</field>
                <operation>notEqual</operation>
                <value>Unit Set</value>
            </filterItems>
            <isOptional>true</isOptional>
        </lookupFilter>
        <referenceTo>Course__c</referenceTo>
        <relationshipLabel>ACP Courses</relationshipLabel>
        <relationshipName>Application_Course_Preferences</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Credit_Adjusted_Course_Duration_Type__c</fullName>
        <externalId>false</externalId>
        <formula>IF (NOT(ISBLANK(TEXT(Course_Offering__r.Override_Duration_Unit__c ) ) ), 
        TEXT(Course_Offering__r.Override_Duration_Unit__c),
        &apos;Year&apos;
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Used to capture the outcome of Credit/RPL Assessment</inlineHelpText>
        <label>Credit: Adjusted Course Duration Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Credit_Adjusted_Course_Duration__c</fullName>
        <description>This field is used to record the course duration after taking into account the approved credit points. This field needs to be displayed/consumed along with the Adjusted_Course_Duration_Type__c picklist.</description>
        <externalId>false</externalId>
        <inlineHelpText>What is the new course duration after the Credit/RPL assessment?</inlineHelpText>
        <label>Credit: Adjusted Course Duration</label>
        <precision>5</precision>
        <required>false</required>
        <scale>2</scale>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Credit_Assessment_Decision__c</fullName>
        <description>This field is used by assessors in faculty departments to record their decision against the assessment of an applicant&apos;s request for credit (Recognition of Prior Learning) during the Additional Requirements Assessment stage of the admissions process.</description>
        <inlineHelpText>Used to capture the outcome of Credit/RPL Assessment</inlineHelpText>
        <label>Credit: Credit Assessment Decision</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Approved</fullName>
                    <default>false</default>
                    <label>Approved</label>
                </value>
                <value>
                    <fullName>Not Approved</fullName>
                    <default>false</default>
                    <label>Not Approved</label>
                </value>
                <value>
                    <fullName>Applicant Input Required</fullName>
                    <default>false</default>
                    <label>Applicant Input Required</label>
                </value>
                <value>
                    <fullName>Internal Input Required</fullName>
                    <default>false</default>
                    <label>Internal Input Required</label>
                </value>
                <value>
                    <fullName>Cancelled</fullName>
                    <default>false</default>
                    <label>Cancelled</label>
                </value>
                <value>
                    <fullName>Granted</fullName>
                    <default>false</default>
                    <label>Granted</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Credit_Assessment_Flag__c</fullName>
        <description>Boolean flag to determine if ACP has RPL Points</description>
        <formula>AND(
OR( ISPICKVAL(Credit_Assessment_Decision__c, &quot;Approved&quot;), ISPICKVAL(Credit_Assessment_Decision__c, &quot;Granted&quot;) ),
 NOT( ISBLANK(Approved_Credit_Points__c)) ,
 NOT( ISBLANK(Credit_Adjusted_Course_Duration_Type__c)),
 NOT( ISBLANK(Credit_Adjusted_Course_Duration__c))
)</formula>
        <label>Credit Assessment Flag</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>DSS_Decision__c</fullName>
        <label>DSS Decision</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Approved</fullName>
                    <default>false</default>
                    <label>Approved</label>
                </value>
                <value>
                    <fullName>Rejected</fullName>
                    <default>false</default>
                    <label>Rejected</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>DSS_Outcome__c</fullName>
        <description>Translation of the Task: DSS Check to a display version to be used by the front end. Only if the Task: DSS Check field has a value of &apos;Complete&apos; or &apos;Failed&apos; will any information be displayed in this field.</description>
        <externalId>false</externalId>
        <formula>IF(ISPICKVAL(Task_DSS_Check__c, &apos;Completed&apos;), &apos;Approved&apos;,
IF(ISPICKVAL(Task_DSS_Check__c, &apos;Failed&apos;), &apos;Rejected&apos;,
&apos; &apos;))</formula>
        <label>DSS Outcome</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
