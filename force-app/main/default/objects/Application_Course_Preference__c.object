    <fields>
        <fullName>Embargoed_Reason__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Formula that determines some kind of embargoed status</description>
        <externalId>false</externalId>
        <formula>If (CONTAINS(Admission_Category__c, &apos;VTAC&apos;),
CASE (Admission_Category__c,&apos;VTAC-IS&apos;,&apos;VTAC INT&apos;,&apos;VTAC-MC-IS&apos;,&apos;VTAC INT&apos;,&apos;VTAC&apos;),If(CONTAINS(Admission_Category__c, &apos;HDR&apos;), &apos;GradResearch&apos;, &apos;&apos;))</formula>
        <inlineHelpText>ACP matches an embargoed rule</inlineHelpText>
        <label>Embargoed Reason</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
