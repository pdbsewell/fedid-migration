    <fields>
        <fullName>Adjusted_Course_Duration_Type__c</fullName>
        <description>This field is used to record the course duration type after taking into account the approved credit points. This field needs to be displayed/consumed along with the Credit_Adjusted_Course_Duration__c field.</description>
