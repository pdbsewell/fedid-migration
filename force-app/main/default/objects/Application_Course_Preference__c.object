    <fields>
        <fullName>Faculty_Queue_API_Name__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Used to determine which Queue (public group) based on Managing Faculty for assigning ACP Tasks. This field is used in ACP work relay process</description>
        <externalId>false</externalId>
        <formula>CASE( Managing_Faculty__c ,
    &quot;Faculty of Art, Design and Architecture&quot;,&quot;WR_Fac_Art_Design_Architecture&quot;,
    &quot;Faculty of Arts&quot;,&quot;WR_Fac_Arts&quot;,
    &quot;Faculty of Business and Economics&quot;, &quot;WR_Fac_BusEco&quot;,
    &quot;Faculty of Education&quot;, &quot;WR_Fac_Education&quot;,
    &quot;Faculty of Engineering&quot;, &quot;WR_Fac_Engineering&quot;,
    &quot;Faculty of Information Technology&quot;, &quot;WR_Fac_IT&quot;,
    &quot;Faculty of Law&quot;, &quot;WR_Fac_Law&quot;,
    &quot;Faculty of Medicine, Nursing and Health Sciences&quot;, &quot;WR_Fac_MNHS&quot;,
    &quot;Faculty of Pharmacy and Pharmaceutical Sciences&quot;, &quot;WR_Fac_Pharmacy&quot;,
    &quot;Faculty of Science&quot;, &quot;WR_Fac_Science&quot;,
