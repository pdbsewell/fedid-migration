            </valueSettings>
            <valueSettings>
                <controllingFieldValue>WITHDRAWN</controllingFieldValue>
                <controllingFieldValue>WTHDRN-R</controllingFieldValue>
                <controllingFieldValue>WTHDRN-C-R</controllingFieldValue>
                <controllingFieldValue>WITHDRAWC</controllingFieldValue>
                <controllingFieldValue>OFFER-PROV</controllingFieldValue>
