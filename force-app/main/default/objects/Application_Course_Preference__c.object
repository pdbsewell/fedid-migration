    <fields>
        <fullName>Course_Term__c</fullName>
        <description>Course Term calculated from the Commencement Period, for use in Indo Offer Conga Template (BAHASA version).</description>
        <externalId>false</externalId>
        <formula>TRIM(MID(Course_Offering__r.Admission_Calendar_Description__c, 5,(FIND(&quot;intake&quot;, LOWER(Course_Offering__r.Admission_Calendar_Description__c),7)-5)))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Term</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
