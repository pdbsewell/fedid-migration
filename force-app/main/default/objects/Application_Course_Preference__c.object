    <fields>
        <fullName>Is_Deferred__c</fullName>
        <description>Is the ACP deferred?</description>
        <formula>IF(
      AND(
        NOT(ISBLANK(Deferred_Commencement_Period__c)),
        OR(
          Deferment_Status_LOV__r.Value__c = &apos;APPROVED&apos;,
          Deferment_Status_LOV__r.Value__c = &apos;COND-PAID&apos;,
          Deferment_Status_LOV__r.Value__c = &apos;WITHDRN-CA&apos;,
          Deferment_Status_LOV__r.Value__c = &apos;APPROVED-R&apos;
        )
      ), 
      TRUE,
      FALSE
    )</formula>
        <label>Deferred?</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
