    <fields>
        <fullName>Course_Points__c</fullName>
        <description>Used in PD for Conga certificate printing</description>
        <externalId>false</externalId>
        <formula>IF(
    ISPICKVAL(Certificate_to_be_printed__c,&quot;&quot;),
    &quot;&quot;,
    IF(
        Course_Offering__r.Course__r.Points__c = 0,
        &quot;0&quot;,
        IF(
            ISPICKVAL(Certificate_to_be_printed__c,&quot;Completion without credit points&quot;),
            &quot;0&quot;,
            IF(
                ISPICKVAL(Certificate_to_be_printed__c,&quot;Attendance&quot;),
                &quot;0&quot;,
                TEXT(Course_Offering__r.Course__r.Points__c)
            )        
        )
    )    
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Points</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Points_for_Independent_Study__c</fullName>
        <description>Used in PD for Conga certificate printing</description>
        <externalId>false</externalId>
        <formula>IF(
ISPICKVAL(Certificate_to_be_printed__c,&quot;Attendance&quot;),
&quot;0&quot;,
TEXT(Course_Offering__r.Course__r.Points__c)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Points for Independent Study</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
