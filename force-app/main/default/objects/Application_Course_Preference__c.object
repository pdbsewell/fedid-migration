TEXT(Application__r.GTE_Decision__c) &amp; &quot; on &quot; &amp; 
TEXT(DAY(DATEVALUE(Application__r.GTE_Last_Completed_On__c))) &amp; &quot;/&quot; &amp; 
TEXT(MONTH(DATEVALUE(Application__r.GTE_Last_Completed_On__c))) &amp; &quot;/&quot; &amp;
