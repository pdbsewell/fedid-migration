    <sharingModel>Private</sharingModel>
    <startsWith>Vowel</startsWith>
    <validationRules>
        <fullName>OnHoldReasonIsRequired</fullName>
        <active>true</active>
        <description>On Hold reason is required when Status = On Hold</description>
        <errorConditionFormula>AND($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c = false, ISPICKVAL(Workflow_Status__c,&apos;On Hold&apos;),
ISBLANK(TEXT(On_Hold_Reason__c)))</errorConditionFormula>
        <errorDisplayField>On_Hold_Reason__c</errorDisplayField>
        <errorMessage>On Hold Reason field is required for the On Hold Assessments</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Precedent_Info</fullName>
        <active>true</active>
        <errorConditionFormula>OR(
      AND(ISBLANK(Precedent_ID__c), NOT(ISBLANK(TEXT(Requirement_Satisfied_Code__c)))),
      AND(NOT(ISBLANK(Precedent_ID__c)), ISBLANK(TEXT(Requirement_Satisfied_Code__c)))
      )</errorConditionFormula>
        <errorMessage>Precedent Id and Requirement Satisfied Code must be entered</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Restrict_GCO_Auto_On_Invalid_Intake</fullName>
        <active>true</active>
        <description>Message to indicate a wrong intake period for GCO</description>
        <errorConditionFormula>AND($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c = false,  
ISPICKVAL(Conditional_Automation__c,&apos;Generic&apos;),
NOT($User.Full_Name__c== &apos;Automated Process&apos;),
RIGHT( Intake_Period__c, LEN(Intake_Period__c)-FIND(&quot;/&quot;,  Intake_Period__c))&lt;&gt;&apos;1&apos;,
RIGHT( Intake_Period__c, LEN(Intake_Period__c)-FIND(&quot;/&quot;,  Intake_Period__c))&lt;&gt;&apos;2&apos;,
RIGHT( Intake_Period__c, LEN(Intake_Period__c)-FIND(&quot;/&quot;,  Intake_Period__c))&lt;&gt;&apos;SUM&apos;,
RIGHT( Intake_Period__c, LEN(Intake_Period__c)-FIND(&quot;/&quot;,  Intake_Period__c))&lt;&gt;&apos;SPR&apos;,
RIGHT( Intake_Period__c, LEN(Intake_Period__c)-FIND(&quot;/&quot;,  Intake_Period__c))&lt;&gt;&apos;W&apos;
)</errorConditionFormula>
        <errorDisplayField>Conditional_Automation__c</errorDisplayField>
        <errorMessage>Generic conditional offer does not apply to the intake period for this application</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Restrict_GCO_When_No_PersonID</fullName>
        <active>true</active>
        <description>Person Id on the contact must not be empty before proceeding with a Generic Conditional Offer for the related ACP.</description>
        <errorConditionFormula>AND($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c = false,NOT($User.Full_Name__c== &apos;Automated Process&apos;),
ISPICKVAL(Conditional_Automation__c,&apos;Generic&apos;), ISBLANK( Callista_Student_Id__c))</errorConditionFormula>
        <errorDisplayField>Conditional_Automation__c</errorDisplayField>
        <errorMessage>Person ID is blank.  Please resolve the contact issue before proceeding with a Generic Conditional Offer for this ACP</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Restrict_GCO_when_CO_Not_Approved</fullName>
        <active>true</active>
        <errorConditionFormula>AND($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c = false,NOT($User.Full_Name__c== &apos;Automated Process&apos;),
ISPICKVAL(PRIORVALUE(Conditional_Automation__c),&apos;&apos;),
ISPICKVAL(Conditional_Automation__c,&apos;Generic&apos;),Course_Offering__r.Override_Reviewed__c == false)</errorConditionFormula>
        <errorDisplayField>Conditional_Automation__c</errorDisplayField>
        <errorMessage>The Course Offering Override information must be reviewed before proceeding with a Generic Conditional Offer for this ACP</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validate_Credit_Adjusted_Duration</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
 NOT(ISBLANK(Credit_Adjusted_Course_Duration__c)),
 NOT(Credit_Adjusted_Course_Duration_Type__c == &apos;Year&apos;),
 FLOOR(Credit_Adjusted_Course_Duration__c) != Credit_Adjusted_Course_Duration__c
)</errorConditionFormula>
        <errorMessage>Adjusted Course Duration must be a whole number AND only one decimal point is allowed for Credit: Adjusted Course Duration if Credit: Adjusted Course Duration Type is Year(s).</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>Add_Payment</fullName>
        <availability>online</availability>
        <displayType>button</displayType>
        <encodingKey>UTF-8</encodingKey>
