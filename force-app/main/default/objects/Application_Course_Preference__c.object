    <fields>
        <fullName>Additional_Reqs_Assessment_Decision__c</fullName>
        <description>This field is used by assessors in faculty departments to record their outcome against the assessment of students (mainly international) during the Additional Requirements Assessment stage of the admissions process where the faculty may assess the applicant&apos;s eligibility for a course through interviews, statement of purposes, auditions etc.</description>
        <label>Specialist Selection Decision</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Met</fullName>
                    <default>false</default>
                    <label>Met</label>
                </value>
                <value>
                    <fullName>Not Met</fullName>
                    <default>false</default>
                    <label>Not Met</label>
                </value>
                <value>
                    <fullName>Agree</fullName>
                    <default>false</default>
                    <label>Agree</label>
                </value>
                <value>
                    <fullName>Disagree</fullName>
                    <default>false</default>
                    <label>Disagree</label>
                </value>
                <value>
                    <fullName>Applicant Input Required</fullName>
                    <default>false</default>
                    <label>Applicant Input Required</label>
                </value>
                <value>
                    <fullName>Internal Input Required</fullName>
                    <default>false</default>
                    <label>Internal Input Required</label>
                </value>
                <value>
                    <fullName>Eligible for Conditional Offer</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Eligible for Conditional Offer</label>
                </value>
                <value>
                    <fullName>Eligible for Full Offer</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Eligible for Full Offer</label>
                </value>
                <value>
                    <fullName>No Decision: Return to Central Admissions</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>No Decision: Return to Central Admissions</label>
                </value>
                <value>
                    <fullName>Not Eligible</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Not Eligible</label>
                </value>
            </valueSetDefinition>
        </valueSet>
