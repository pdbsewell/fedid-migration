        <fullName>Entry_Qualification_Status_LOV__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>LOV lookup to the qualification status values</description>
        <inlineHelpText>Indicates if the applicant is eligible for consideration.</inlineHelpText>
        <label>Entry Qualification Status</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>List_of_Values__c.Type__c</field>
                <operation>equals</operation>
                <value>Entry Qualification</value>
            </filterItems>
            <filterItems>
                <field>List_of_Values__c.Is_Active__c</field>
                <operation>equals</operation>
                <value>True</value>
            </filterItems>
            <isOptional>true</isOptional>
        </lookupFilter>
        <referenceTo>List_of_Values__c</referenceTo>
