    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Exploding_Leads_V2__c</columns>
        <columns>Acquisition_Source_Campaign__c</columns>
        <columns>Email__c</columns>
        <columns>Exploded_Target__c</columns>
        <columns>Status__c</columns>
        <columns>LAST_UPDATE</columns>
        <columns>CREATED_DATE</columns>
        <columns>CREATEDBY_USER</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>Pending_Records</fullName>
        <columns>NAME</columns>
        <columns>First_Name__c</columns>
        <columns>Last_Name__c</columns>
        <columns>Email__c</columns>
        <columns>Acquisition_Source_Campaign__c</columns>
        <columns>Event_Campaigns__c</columns>
        <columns>Broad_Area_of_Interest_Update_Mode__c</columns>
        <columns>Exploded_Target__c</columns>
        <columns>Status__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Status__c</field>
            <operation>notEqual</operation>
            <value>Success</value>
        </filters>
        <label>Pending Records</label>
    </listViews>
    <nameField>
        <displayFormat>SPS-{0}</displayFormat>
        <label>Staged Prospective Student Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Staged Prospective Students</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Matching_keys_required</fullName>
        <active>true</active>
        <description>if Exploded Target (Contact ID) is empty, First Name, Last Name, and Email is required. Matching Keys (FN,LN,Email) will be used to determine the matching Contact</description>
        <errorConditionFormula>IF( 
 	ISBLANK( Exploded_Target__c ),
 	OR(
 		ISBLANK( First_Name__c ),
 		ISBLANK( Last_Name__c ),
 		ISBLANK( Email__c )
 	), 
 	false
)</errorConditionFormula>
        <errorMessage>First Name, Last Name, and Email is required if Exploded Target is blank</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
