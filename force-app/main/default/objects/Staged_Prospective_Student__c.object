    <fields>
        <fullName>Contact_Qualification_JSON__c</fullName>
        <description>Sets of Qualification &amp; Institution submitted the prospective student in JSON format.

Expected JSON format : [  
   {  
      &quot;attributes&quot;:{  
         &quot;type&quot;:&quot;Contact_Qualification__c&quot;
      },
      &quot;Other_Qualification__c&quot;:&quot;XXXXX&quot;,
      &quot;Institution_Name__c&quot;:&quot;YYYYY&quot;
   },
   {  
      &quot;attributes&quot;:{  
         &quot;type&quot;:&quot;Contact_Qualification__c&quot;
      },
      &quot;Other_Qualification__c&quot;:&quot;XXXXX&quot;,
      &quot;Institution_Name__c&quot;:&quot;YYYYY&quot;
   }
]
XXXXX for Qualification would the name of the Qualification.
YYYYY for Institution would be the name of the institution.</description>
        <inlineHelpText>Sets of Qualification &amp; Institution submitted the prospective student in JSON format.</inlineHelpText>
        <label>Contact Qualification JSON</label>
        <length>5000</length>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
