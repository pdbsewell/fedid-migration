    <fields>
        <fullName>FoR_Code__c</fullName>
        <businessStatus>Active</businessStatus>
        <caseSensitive>false</caseSensitive>
        <description>FoR Code stating the code/number linked to the Field of Research</description>
        <externalId>true</externalId>
        <inlineHelpText>FoR Code - https://www.arc.gov.au/sites/default/files/minisite/static/10419/ERA2015/app-3_appendix-2.html</inlineHelpText>
        <label>FoR Code</label>
        <length>6</length>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>FoR_Name__c</fullName>
        <description>FoR Name</description>
        <externalId>false</externalId>
        <inlineHelpText>FoR Name</inlineHelpText>
        <label>FoR Name</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Hierarchical_level__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Describes the Hierarchy Level for the division, group and field</description>
        <externalId>false</externalId>
        <formula>CASE(LEN(FoR_Code__c), 
	2,&quot;Division&quot;, 
	4,&quot;Group&quot;,
	6,&quot;Field&quot;,
	&quot;N/A&quot;)</formula>
        <inlineHelpText>Describes the Hierarchy Level for the division, group and field</inlineHelpText>
        <label>Hierarchical level</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Inactive__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Set this to TRUE if this FoR is inactive and not to be used</description>
        <inlineHelpText>Set this to TRUE if this FoR is inactive and not to be used</inlineHelpText>
        <label>Inactive</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Parent_FoR__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Parent FoR Code for FoR Type Group or Field</description>
        <inlineHelpText>Parent FoR Code for FoR Type Group or Field</inlineHelpText>
        <label>Parent FoR</label>
        <referenceTo>Fields_of_Research__c</referenceTo>
        <relationshipLabel>Child Fields of Research</relationshipLabel>
        <relationshipName>Child_Fields_of_Research</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
