    <fields>
        <fullName>Calendar_Code__c</fullName>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(TEXT( Sequence_Number_Year__c )), TEXT( Sequence_Number__c ),  TEXT(Sequence_Number_Year__c) + &apos;_&apos; + TEXT( Sequence_Number__c ) )</formula>
        <label>Calendar Code</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Calendar_Name_Alternate__c</fullName>
        <externalId>false</externalId>
        <formula>Year__c + &apos;/&apos; + Type_Alt__c</formula>
        <label>Calendar Name Alternate</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Category__c</fullName>
        <label>Calendar Category</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>ADMISSION</fullName>
                    <default>false</default>
                    <label>ADMISSION</label>
                </value>
                <value>
                    <fullName>TEACHING</fullName>
                    <default>false</default>
                    <label>TEACHING</label>
                </value>
                <value>
                    <fullName>ASSESSMENT</fullName>
                    <default>false</default>
                    <label>ASSESSMENT</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
