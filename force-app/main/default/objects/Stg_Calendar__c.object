        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Description_Transformation__c</fullName>
        <externalId>false</externalId>
        <formula>IF(  ISBLANK( Description__c )  ,  Year__c + &apos; &apos; +  Type_Description__c , Description__c )</formula>
        <label>Calendar Description Transformation</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
