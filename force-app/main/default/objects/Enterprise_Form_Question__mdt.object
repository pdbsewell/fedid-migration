<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Form Question meta data to organise Questions being used on Monash forms</description>
    <fields>
        <fullName>Group__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Group</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>GE</fullName>
                    <default>true</default>
                    <label>GE</label>
                </value>
                <value>
                    <fullName>IP</fullName>
                    <default>false</default>
                    <label>IP</label>
                </value>
                <value>
                    <fullName>IC</fullName>
                    <default>false</default>
                    <label>IC</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Question__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Question</label>
        <required>false</required>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Type</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Text</fullName>
                    <default>true</default>
                    <label>Text</label>
                </value>
                <value>
                    <fullName>Picklist</fullName>
                    <default>false</default>
                    <label>Picklist</label>
                </value>
                <value>
                    <fullName>MultiPicklist</fullName>
                    <default>false</default>
                    <label>MultiPicklist</label>
                </value>
                <value>
                    <fullName>RadioGroup</fullName>
                    <default>false</default>
                    <label>RadioGroup</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Value__c</fullName>
        <description>Please ensure to separate values using semicolon symbol</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Please ensure to separate values using semicolon symbol</inlineHelpText>
        <label>Value</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Enterprise Form Question</label>
    <listViews>
        <fullName>IC_Questions</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>Group__c</columns>
        <columns>Question__c</columns>
        <columns>Type__c</columns>
        <columns>Value__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Group__c</field>
            <operation>equals</operation>
            <value>IC</value>
        </filters>
        <label>IC Questions</label>
    </listViews>
    <listViews>
        <fullName>IP_Questions</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>Group__c</columns>
        <columns>Question__c</columns>
        <columns>Type__c</columns>
        <columns>Value__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Group__c</field>
            <operation>equals</operation>
            <value>IP</value>
        </filters>
        <label>IP Questions</label>
    </listViews>
    <pluralLabel>Enterprise Form Questions</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
