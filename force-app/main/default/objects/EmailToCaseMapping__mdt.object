                </value>
                <value>
                    <fullName>SR_Enquiry</fullName>
                    <default>false</default>
                    <label>SR Enquiry</label>
                </value>
                <value>
                    <fullName>School Enquiry</fullName>
                    <default>false</default>
                    <label>School Enquiry</label>
                </value>
