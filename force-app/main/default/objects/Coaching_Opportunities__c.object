    <validationRules>
        <fullName>Error_Reason_Check</fullName>
        <active>true</active>
        <description>If a user is a selected in &quot;Officer TC Faculty Other Sources&quot;, then a value must be supplied in &quot;Error Reason&quot;</description>
        <errorConditionFormula>NOT(ISBLANK(Officer_TC_Faculty_Other_Sources__c)) &amp;&amp; ISPICKVAL(Error_Reason__c, &quot;&quot;)</errorConditionFormula>
        <errorMessage>Please select &apos;Error reason&apos; before proceeding.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Error_Type_Check</fullName>
        <active>true</active>
        <description>If a user is a selected in &quot;Officer TC Faculty Other Sources&quot;, then a value must be supplied in &quot;Error Type&quot;</description>
        <errorConditionFormula>NOT(ISBLANK(Officer_TC_Faculty_Other_Sources__c)) &amp;&amp; ISPICKVAL(Error_type__c, &quot;&quot;)</errorConditionFormula>
        <errorMessage>Please select &apos;Error type&apos; before proceeding</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Process_Owner_Check</fullName>
        <active>true</active>
        <description>If the Responsible User is empty &amp; Team Coordinator is empty then process Owner should have a value</description>
        <errorConditionFormula>ISBLANK(Officer_TC_Faculty_Other_Sources__c) &amp;&amp; ISBLANK(Process_Owner__c)</errorConditionFormula>
        <errorMessage>Process Owner OR Officer not selected. Please check if correct.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Team_Coord_Check</fullName>
        <active>true</active>
        <description>If a user is a selected in &quot;Officer TC Faculty Other Sources&quot;, then a value must be supplied in &quot;Team Coordinator&quot;</description>
        <errorConditionFormula>NOT(ISBLANK(Officer_TC_Faculty_Other_Sources__c)) &amp;&amp; ISBLANK(Team_Coordinator__c)</errorConditionFormula>
        <errorMessage>Team Coordinator not selected. Please check if correct.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
