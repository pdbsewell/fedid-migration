        <columns>Team_Coordinator__c</columns>
        <columns>TC_TL_actions_to_be_taken__c</columns>
        <columns>Error_Reason__c</columns>
        <columns>Error_type__c</columns>
        <columns>TC_TL_feedback_assigned_to__c</columns>
        <columns>TC_TL_final_response__c</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>TC_TL_final_response__c</field>
            <operation>notContain</operation>
