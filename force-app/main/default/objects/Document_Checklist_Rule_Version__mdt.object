<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Metadata used to group up document checklist rules</description>
    <fields>
        <fullName>Category__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Category</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Application Assessment</fullName>
                    <default>true</default>
                    <label>Application Assessment</label>
                </value>
                <value>
                    <fullName>Offer Acceptance</fullName>
                    <default>false</default>
                    <label>Offer Acceptance</label>
                </value>
                <value>
                    <fullName>Offer</fullName>
                    <default>false</default>
                    <isActive>false</isActive>
                    <label>Offer</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Default__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Only one version of the category should be a default</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Only one version of the category should be a default</inlineHelpText>
        <label>Default</label>
        <type>Checkbox</type>
    </fields>
    <label>Document Checklist Rule Version</label>
    <listViews>
        <fullName>All</fullName>
        <columns>Default__c</columns>
        <columns>MasterLabel</columns>
        <columns>Category__c</columns>
        <columns>DeveloperName</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <pluralLabel>Document Checklist Rule Versions</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
