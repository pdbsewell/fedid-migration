    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>true</defaultValue>
        <label>Active</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Course_Code__c</fullName>
        <externalId>false</externalId>
        <formula>Course_Offering__r.Course__r.Name</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Code</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Offering__c</fullName>
        <label>Course Offering</label>
        <referenceTo>Course_Offering__c</referenceTo>
        <relationshipLabel>Course Offering Pricings</relationshipLabel>
        <relationshipName>Course_Offering_Pricings</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>DiscountEvidenceType__c</fullName>
        <label>Discount Evidence Type</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>NotRequired</fullName>
                    <default>true</default>
                    <label>Not Required</label>
                </value>
                <value>
                    <fullName>Text</fullName>
                    <default>false</default>
                    <label>Text</label>
                </value>
                <value>
                    <fullName>Attachment</fullName>
                    <default>false</default>
                    <label>Attachment</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>EndDate__c</fullName>
        <label>Pricing End Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Fee__c</fullName>
        <label>Fee</label>
        <precision>8</precision>
        <required>true</required>
        <scale>2</scale>
        <trackTrending>false</trackTrending>
        <type>Currency</type>
    </fields>
    <fields>
        <fullName>Pricing_Name__c</fullName>
        <description>Pricing Name for COP</description>
        <externalId>false</externalId>
        <label>Pricing Name</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Pricing_Type__c</fullName>
        <label>Pricing Type</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Normal Rate</fullName>
                    <default>true</default>
                    <label>Normal Rate</label>
                </value>
                <value>
                    <fullName>Early Bird</fullName>
                    <default>false</default>
                    <label>Early Bird</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>StartDate__c</fullName>
        <label>Pricing Start Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <label>Course Offering Pricing</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Course_Offering__c</columns>
        <columns>Course_Code__c</columns>
        <columns>Pricing_Name__c</columns>
        <columns>Pricing_Type__c</columns>
        <columns>StartDate__c</columns>
        <columns>EndDate__c</columns>
        <columns>Fee__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>COP-{000}</displayFormat>
        <label>COPID</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Course Offering Pricings</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>EarlyBirdDatesValidation</fullName>
        <active>true</active>
        <description>To check that the Pricing Start Date &amp; Pricing End Date are defined.</description>
        <errorConditionFormula>AND(ISPICKVAL(Pricing_Type__c , &apos;Early Bird&apos;), OR(ISBLANK( StartDate__c ),ISBLANK(  EndDate__c ) ) )</errorConditionFormula>
        <errorMessage>Please define Pricing Start and Pricing End dates for Early Bird pricing.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>NormalRatesDatesValidation</fullName>
        <active>true</active>
        <description>To check that the Pricing Start Date &amp; Pricing End Date are blank.</description>
        <errorConditionFormula>AND(NOT(ISPICKVAL(Pricing_Type__c , &quot;Early Bird&quot;)), 
  OR(NOT(ISBLANK(StartDate__c)),NOT(ISBLANK(EndDate__c)) )
   )</errorConditionFormula>
        <errorMessage>Please leave Pricing Start and Pricing End dates blank for Normal pricing.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>StartDtEarlierthanEndDT</fullName>
        <active>true</active>
        <errorConditionFormula>StartDate__c&gt;EndDate__c</errorConditionFormula>
        <errorMessage>Pricing Start Date must be earlier than the Pricing End Date.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
