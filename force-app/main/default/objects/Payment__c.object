    <label>Payment</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>UPDATEDBY_USER</columns>
        <columns>LAST_UPDATE</columns>
        <columns>CREATEDBY_USER</columns>
        <filterScope>Everything</filterScope>
        <label>All Payments</label>
    </listViews>
    <listViews>
        <fullName>All_Payments_Not_Processed</fullName>
        <columns>NAME</columns>
        <columns>Application__c</columns>
        <columns>Contact__c</columns>
        <columns>Course_Code__c</columns>
        <columns>Course_Offering__c</columns>
        <columns>Course_Title__c</columns>
        <columns>Payment_Amount__c</columns>
        <columns>Payment_Date__c</columns>
        <columns>Payment_Status__c</columns>
        <columns>Send_Receipt__c</columns>
        <columns>UPDATEDBY_USER</columns>
        <columns>LAST_UPDATE</columns>
        <columns>Payment_Type__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Payment_Status__c</field>
            <operation>equals</operation>
            <value>Not Processed,Refund Not Processed</value>
        </filters>
        <label>All Payments - Not Processed</label>
    </listViews>
    <listViews>
        <fullName>Todays_Payments</fullName>
        <columns>NAME</columns>
        <columns>Contact__c</columns>
        <columns>Course_Code__c</columns>
        <columns>Course_Title__c</columns>
        <columns>Payment_Amount__c</columns>
        <columns>Payment_Type__c</columns>
        <columns>Payment_Date__c</columns>
        <columns>Payment_Status__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>CREATEDBY_USER</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>CREATED_DATE</field>
            <operation>equals</operation>
            <value>TODAY</value>
        </filters>
        <label>Todays Payments</label>
    </listViews>
    <nameField>
        <displayFormat>PY-{000000}</displayFormat>
        <label>Payment ID</label>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Payments</pluralLabel>
    <searchLayouts>
        <excludedStandardButtons>New</excludedStandardButtons>
    </searchLayouts>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Refund_must_be_a_negative_number</fullName>
        <active>true</active>
        <description>To enforce negative values when the Payment Status is Refund Processed</description>
        <errorConditionFormula>OR(AND(ISPICKVAL(Payment_Status__c,&apos;Refund Processed&apos;), Payment_Amount__c &gt;0),
AND(ISPICKVAL(Payment_Status__c,&apos;Refund Not Processed&apos;),Payment_Amount__c &gt;0))</errorConditionFormula>
        <errorDisplayField>Payment_Amount__c</errorDisplayField>
        <errorMessage>Refund amount must be negative value</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validate_Receipt_Fields</fullName>
        <active>true</active>
        <description>Validate receipt fields</description>
        <errorConditionFormula>AND(
Send_Receipt__c ,
OR(
ISBLANK(Quantity__c),
ISBLANK(Payment_Amount__c),
ISPICKVAL(Payment_Type__c,&apos;&apos;)
)
)</errorConditionFormula>
        <errorMessage>The following fields are mandatory when trying to send a receipt : Quantity, Payment Type, Payment Amount</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
