                </value>
                <value>
                    <fullName>Science</fullName>
                    <default>false</default>
                    <label>Science</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>From_Address__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>From Address available for the enquiry record type</inlineHelpText>
        <label>From Address</label>
        <required>false</required>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Order__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Order of how addresses are shown</inlineHelpText>
        <label>Order</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Record_Type_DeveloperName__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Enquiry Type API Name</inlineHelpText>
        <label>Record Type DeveloperName</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Send_Email_Quick_Action_API_Name__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>API Name for the quick action relevant for the enquiry record type</inlineHelpText>
        <label>Send Email Quick Action API Name</label>
        <length>255</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Enquiry Email From Address Mapping</label>
    <listViews>
        <fullName>Faculty_Graduate_Research</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>Record_Type_DeveloperName__c</columns>
        <columns>Applied_to_Faculty__c</columns>
        <columns>From_Address__c</columns>
        <columns>Active__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>MasterLabel</field>
            <operation>contains</operation>
            <value>Graduate Research</value>
        </filters>
        <filters>
            <field>MasterLabel</field>
            <operation>notContain</operation>
            <value>MGE</value>
        </filters>
        <label>Faculty Graduate Research</label>
        <language>en_US</language>
    </listViews>
    <listViews>
        <fullName>MGE_Email_From_Mappings</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>Order__c</columns>
        <columns>Record_Type_DeveloperName__c</columns>
        <columns>From_Address__c</columns>
        <columns>Active__c</columns>
        <columns>Send_Email_Quick_Action_API_Name__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Record_Type_DeveloperName__c</field>
            <operation>equals</operation>
            <value>MGE_Enquiry</value>
        </filters>
        <label>MGE Email From Mappings</label>
        <language>en_US</language>
    </listViews>
    <pluralLabel>Enquiry Email From Address Mappings</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
