        <label>Applied to School</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>true</sorted>
                <value>
                    <fullName>Australian Regenerative Medicine Institute</fullName>
                    <default>true</default>
                    <label>Australian Regenerative Medicine Institute</label>
                </value>
                <value>
                    <fullName>Biological Sciences</fullName>
                    <default>false</default>
                    <label>Biological Sciences</label>
                </value>
                <value>
                    <fullName>Biomedicine Discovery Institute Graduate School &amp; School of Biomedical Sciences</fullName>
                    <default>false</default>
                    <label>Biomedicine Discovery Institute Graduate School &amp; School of Biomedical Sciences</label>
                </value>
                <value>
                    <fullName>Chemistry</fullName>
                    <default>false</default>
                    <label>Chemistry</label>
                </value>
                <value>
                    <fullName>Clinical Sciences</fullName>
                    <default>false</default>
