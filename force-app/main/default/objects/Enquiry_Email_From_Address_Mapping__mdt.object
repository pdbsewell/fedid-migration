<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Custom Metadata to setup available email from per Enquiry Record Types</description>
    <fields>
        <fullName>Active__c</fullName>
        <defaultValue>false</defaultValue>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Controls if the setting is enabled or disabled</inlineHelpText>
        <label>Active</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Applied_to_Faculty__c</fullName>
        <description>used to filter Email From Addresses based on Faculty</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Applied to Faculty</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Business and Economics</fullName>
                    <default>true</default>
                    <label>Business and Economics</label>
                </value>
                <value>
                    <fullName>Engineering</fullName>
                    <default>false</default>
                    <label>Engineering</label>
                </value>
                <value>
                    <fullName>MADA</fullName>
                    <default>false</default>
                    <label>MADA</label>
                </value>
                <value>
                    <fullName>Arts</fullName>
                    <default>false</default>
                    <label>Arts</label>
                </value>
                <value>
                    <fullName>Education</fullName>
                    <default>false</default>
                    <label>Education</label>
                </value>
                <value>
                    <fullName>Information Technology</fullName>
                    <default>false</default>
                    <label>Information Technology</label>
                </value>
                <value>
                    <fullName>Law</fullName>
                    <default>false</default>
                    <label>Law</label>
                </value>
                <value>
                    <fullName>MNHS</fullName>
                    <default>false</default>
                    <label>MNHS</label>
                </value>
                <value>
                    <fullName>MSI</fullName>
                    <default>false</default>
                    <label>MSI</label>
                </value>
                <value>
                    <fullName>MUARC</fullName>
                    <default>false</default>
                    <label>MUARC</label>
                </value>
                <value>
                    <fullName>Pharmacy and Pharmaceutical Sciences</fullName>
                    <default>false</default>
                    <label>Pharmacy and Pharmaceutical Sciences</label>
                </value>
                <value>
                    <fullName>Science</fullName>
                    <default>false</default>
                    <label>Science</label>
                </value>
                <value>
                    <fullName>MSDI</fullName>
                    <default>false</default>
                    <label>MSDI</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
