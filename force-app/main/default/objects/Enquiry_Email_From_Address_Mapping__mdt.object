                    <default>false</default>
                    <label>Mathematics</label>
                </value>
                <value>
                    <fullName>Medicine, Nursing &amp; Health Sciences</fullName>
                    <default>false</default>
                    <label>Medicine, Nursing &amp; Health Sciences</label>
                </value>
                <value>
                    <fullName>Nursing &amp; Midwifery</fullName>
                    <default>false</default>
                    <label>Nursing &amp; Midwifery</label>
