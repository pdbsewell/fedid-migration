    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Competitor_Name_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	OR(
		ISPICKVAL( Reason_for_Decision__c , &apos;Applying/applied at Competitor&apos;), 
		ISPICKVAL( Reason_for_Decision__c , &apos;Accepted offer at another Institution&apos;)
	),

	ISPICKVAL(  Competitor_Name__c  , &apos;&apos;) 
)</errorConditionFormula>
        <errorDisplayField>Competitor_Name__c</errorDisplayField>
        <errorMessage>Please provide Competitor Name</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Competitor_Reason_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	OR(
		ISPICKVAL( Reason_for_Decision__c , &apos;Applying/applied at Competitor&apos;), 
		ISPICKVAL( Reason_for_Decision__c , &apos;Accepted offer at another Institution&apos;)
	),

	ISPICKVAL( Competitor_Reason__c , &apos;&apos;) 
)</errorConditionFormula>
        <errorDisplayField>Competitor_Reason__c</errorDisplayField>
        <errorMessage>Please provide Competitor Reason</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Decision_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	ISPICKVAL(Call_Result__c, &apos;Yes&apos;), 
	ISBLANK( TEXT( Decision__c ))
)</errorConditionFormula>
        <errorDisplayField>Decision__c</errorDisplayField>
        <errorMessage>Please provide Decision</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Provide_Competitor_Name</fullName>
        <active>true</active>
        <description>IF the agent logging the call selects competitor name as overseas university or other, the system will prompt them to provide the name</description>
        <errorConditionFormula>AND(
	OR(
   		ISPICKVAL( Competitor_Name__c, &apos;Overseas University&apos; ),
   		ISPICKVAL( Competitor_Name__c, &apos;Other&apos; )
	),

	ISBLANK( Competitor_Name_Other__c )
)</errorConditionFormula>
        <errorDisplayField>Competitor_Name_Other__c</errorDisplayField>
        <errorMessage>Please provide the competitor name</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Reason_for_Decision_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	ISPICKVAL( Call_Result__c, &apos;Yes&apos; ), 
	NOT( ISPICKVAL (Decision__c, &apos;Still Deciding&apos; )), 
	ISBLANK( TEXT( Reason_for_Decision__c )) 
)</errorConditionFormula>
        <errorDisplayField>Reason_for_Decision__c</errorDisplayField>
        <errorMessage>Please provide Reason for Decision</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
