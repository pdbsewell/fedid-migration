    <fields>
        <fullName>Person_ID__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Contact__c )),

	IF( Contact__r.RecordType.DeveloperName = &apos;Student&apos;, 

		Contact__r.Person_ID_unique__c, 
		NULL 
	),

	IF( NOT( ISBLANK( Lead__c )),  
		
		IF( LEN( Lead__r.Person_ID__c ) &lt;= 10, 

			Lead__r.Person_ID__c, 
			NULL
		), 
		NULL
	)
)</formula>
        <label>Person ID</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Phone__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Lead__c )),
	Lead__r.Phone,

	IF( NOT( ISBLANK( Contact__c )),
		Contact__r.Phone,
		NULL
	)
)</formula>
        <label>Phone</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Preferred_Contact_Time__c</fullName>
        <label>Preferred Contact Time</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
