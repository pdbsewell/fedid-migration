    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>This object is used to capture call information by Student Recruitment during their outbound call campaign</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>true</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>Call_Name__c</fullName>
        <description>Link to Lead or Contact</description>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Lead__c )),
	HYPERLINK(&quot;/&quot; + Lead__c,  Lead__r.FirstName&amp;&quot; &quot;&amp;  Lead__r.LastName, &quot;_blank&quot;),

	IF( NOT( ISBLANK( Contact__c )),
		HYPERLINK(&quot;/&quot; + Contact__c,  Contact__r.FirstName&amp;&quot; &quot;&amp;  Contact__r.LastName, &quot;_blank&quot;),
		&quot;No Lead/Contact&quot;
	)
)</formula>
        <label>Call Name</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Call_Result__c</fullName>
        <label>Call Result</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Yes</fullName>
                    <color>#78C953</color>
                    <default>false</default>
                    <label>Yes</label>
                </value>
                <value>
                    <fullName>No-No Answer</fullName>
                    <color>#AFCADF</color>
                    <default>false</default>
                    <label>No-No Answer</label>
                </value>
                <value>
                    <fullName>No-Not Available</fullName>
                    <color>#2F5D85</color>
                    <default>false</default>
                    <label>No-Not Available</label>
                </value>
                <value>
                    <fullName>No-Wrong Number</fullName>
                    <color>#0B24BE</color>
                    <default>false</default>
                    <label>No-Wrong Number</label>
                </value>
                <value>
                    <fullName>No-Not Applicable</fullName>
                    <color>#0B6FCE</color>
                    <default>false</default>
                    <label>No-Not Applicable</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Call_Status__c</fullName>
        <label>Call Status</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Open</fullName>
                    <color>#A53711</color>
                    <default>true</default>
                    <label>Open</label>
                </value>
                <value>
                    <fullName>Closed</fullName>
                    <color>#419249</color>
                    <default>false</default>
                    <label>Closed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Campaign_Type__c</fullName>
        <externalId>false</externalId>
        <formula>TEXT( Campaign__r.Type )</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Campaign Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Campaign__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Campaign</label>
        <referenceTo>Campaign</referenceTo>
        <relationshipLabel>SR Lead Calls</relationshipLabel>
        <relationshipName>SR_Call_Leads</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Campus__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Contact__c )),  TEXT( Contact__r.Campus__c )  ,
IF( NOT( ISBLANK( Lead__c )),    Lead__r.Campus__c,
NULL))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Campus</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Check_Time_For__c</fullName>
        <description>IF(
	NOT( ISBLANK( Lead__r.City )),
	HYPERLINK(&quot;https://www.timeanddate.com/worldclock/?query=&quot; &amp; Lead__r.City, Lead__r.City),

IF(
	AND(
		ISBLANK( Lead__r.City ),
		NOT( ISBLANK( Lead__r.Country ))
	),
	HYPERLINK(&quot;https://www.timeanddate.com/worldclock/?query=&quot; &amp; Lead__r.Country, Lead__r.Country),
	NULL
))</description>
        <externalId>false</externalId>
        <formula>IF(
	NOT( ISBLANK( Country__c )),

	HYPERLINK(&quot;https://www.google.com.au/search?q=time+&quot; &amp; Country__c, Country__c),
	HYPERLINK(&quot;https://www.google.com.au/search?q=time+Australia&quot;, &apos;Australia&apos;)
)</formula>
        <label>Check Time For</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Competitor_Course_Name__c</fullName>
        <externalId>false</externalId>
        <label>Competitor Course Name</label>
        <length>200</length>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
