    <fields>
        <fullName>Contact__c</fullName>
        <deleteConstraint>Restrict</deleteConstraint>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>SR Lead Calls</relationshipLabel>
        <relationshipName>SR_Lead_Calls</relationshipName>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Country__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Lead__c )),
	Lead__r.Country,

	IF( NOT( ISBLANK( Contact__c )),
		TEXT( Contact__r.Country_of_Residence__c ),
		NULL
	)
)</formula>
        <label>Country</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Study_Area__c</fullName>
        <externalId>false</externalId>
        <formula>Lead__r.Course_Study_Area__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course/Study Area</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Date_of_Birth__c</fullName>
        <formula>IF( NOT( ISBLANK( Contact__c )), NULL,
IF( NOT( ISBLANK( Lead__c )),    Lead__r.Date_of_Birth__c  ,
NULL))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Date of Birth</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Decision__c</fullName>
        <label>Decision</label>
        <required>false</required>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <controllingField>Call_Result__c</controllingField>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Will Apply</fullName>
                    <color>#419249</color>
                    <default>false</default>
                    <label>Will Apply</label>
                </value>
                <value>
                    <fullName>Will Not Apply</fullName>
                    <color>#A53711</color>
                    <default>false</default>
                    <label>Will Not Apply</label>
                </value>
                <value>
                    <fullName>Accept Offer</fullName>
                    <color>#419249</color>
                    <default>false</default>
                    <label>Accept Offer</label>
                </value>
                <value>
                    <fullName>Defer Offer</fullName>
                    <color>#F96FB7</color>
                    <default>false</default>
                    <label>Defer Offer</label>
                </value>
                <value>
                    <fullName>Decline Offer</fullName>
                    <color>#A53711</color>
                    <default>false</default>
                    <label>Decline Offer</label>
                </value>
                <value>
                    <fullName>Still Deciding</fullName>
                    <color>#0B24BE</color>
                    <default>false</default>
                    <label>Still Deciding</label>
                </value>
            </valueSetDefinition>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Will Apply</valueName>
            </valueSettings>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Will Not Apply</valueName>
            </valueSettings>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Accept Offer</valueName>
            </valueSettings>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Defer Offer</valueName>
            </valueSettings>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Decline Offer</valueName>
            </valueSettings>
            <valueSettings>
                <controllingFieldValue>Yes</controllingFieldValue>
                <valueName>Still Deciding</valueName>
            </valueSettings>
        </valueSet>
    </fields>
    <fields>
        <fullName>Email__c</fullName>
        <externalId>false</externalId>
        <formula>IF( NOT( ISBLANK( Contact__c )),  Contact__r.Email  ,
IF( NOT( ISBLANK( Lead__c )),    Lead__r.Email ,
NULL))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Email</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
