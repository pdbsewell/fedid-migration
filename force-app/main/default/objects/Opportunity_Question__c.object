    <fields>
        <fullName>Opportunity__c</fullName>
        <description>Linked Opportunity</description>
        <inlineHelpText>Opportunity the question links to</inlineHelpText>
        <label>Opportunity</label>
        <referenceTo>Opportunity</referenceTo>
        <relationshipLabel>Opportunity Questions</relationshipLabel>
        <relationshipName>Opportunity_Questions</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Outcome_Flag__c</fullName>
        <description>Display a flag colour based on Outcome</description>
        <externalId>false</externalId>
        <formula>IMAGE( 
CASE(Outcome__c, 
&quot;GREEN&quot;, &quot;/img/samples/flag_green.gif&quot;,
&quot;AMBER&quot;, &quot;/img/samples/flag_yellow.gif&quot;,
&quot;RED&quot;, &quot;/img/samples/flag_red.gif&quot;, 
&quot;/s.gif&quot;), 
&quot;Outcome&quot;)</formula>
        <inlineHelpText>Display a flag colour based on Outcome</inlineHelpText>
        <label>Outcome Flag</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
