    <fields>
        <fullName>Chat_Link__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>GDPR</complianceGroup>
        <description>Used by Monash Connect Console for Live Person Chat Case Feed</description>
        <externalId>false</externalId>
        <formula>IF(CONTAINS(LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)), &quot;staging&quot;), &quot;https://unicrm--staging.sandbox.lightning.force.com/&quot;,
IF(CONTAINS(LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)), &quot;sit&quot;), &quot;https://unicrm--sit.sandbox.lightning.force.com/&quot;,
IF(CONTAINS(LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)), &quot;qa&quot;), &quot;https://unicrm--mcqa.sandbox.lightning.force.com/&quot;, &quot;https://unicrm.lightning.force.com/&quot;) ))
+ Id</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Chat Link</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
