    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>Default</compactLayoutAssignment>
    <compactLayouts>
        <fullName>Default</fullName>
        <fields>Name</fields>
        <fields>AO_Application_Status__c</fields>
        <fields>AO_Faculty_Status__c</fields>
        <fields>AO_Program__c</fields>
        <fields>AO_Contact__c</fields>
        <label>Default</label>
    </compactLayouts>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Applicants relating to a particular programs</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>AO_Account_Host_Institution__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Host Institution</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>Account.RecordType.Name</field>
                <operation>equals</operation>
                <value>Partner</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Program Applicants</relationshipLabel>
        <relationshipName>Program_Applicants</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_Application_Status__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Select appropriate Status of Student Program&apos;s Application</description>
        <label>Application Status</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>AO_Application_Status</valueSetName>
        </valueSet>
    </fields>
    <fields>
        <fullName>AO_Contact__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>Restrict</deleteConstraint>
        <description>Indicates the applicant of a particular program</description>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Program Applicants</relationshipLabel>
        <relationshipName>Program_Applicants</relationshipName>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_Country__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Mention the country of Institution</description>
        <label>Country</label>
        <referenceTo>Country_Attribute__c</referenceTo>
        <relationshipLabel>Program Applicants</relationshipLabel>
        <relationshipName>Program_Applicants</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_End_Date__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Contains Program Applicant&apos;s End date in current academic year</description>
        <inlineHelpText>Program Applicant&apos;s End date in current academic year</inlineHelpText>
        <label>End Date</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>AO_Faculty_Status__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Select appropriate Status for Faculty</description>
        <label>Faculty/School status</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Approved</fullName>
                    <default>false</default>
                    <label>Approved</label>
                </value>
                <value>
                    <fullName>Eligible</fullName>
                    <default>false</default>
                    <label>Eligible</label>
                </value>
                <value>
                    <fullName>Enrolled by Faculty(ies)/School(s)</fullName>
                    <default>false</default>
                    <label>Enrolled by Faculty(ies)/School(s)</label>
                </value>
                <value>
                    <fullName>Not Approved</fullName>
                    <default>false</default>
                    <label>Not Approved</label>
                </value>
                <value>
                    <fullName>One Faculty/School Approved, Pending Other</fullName>
                    <default>false</default>
                    <label>One Faculty/School Approved, Pending Other</label>
                </value>
                <value>
                    <fullName>One Faculty/School Not Approved, Pending Other</fullName>
                    <default>false</default>
                    <label>One Faculty/School Not Approved, Pending Other</label>
                </value>
                <value>
                    <fullName>Shortlisted</fullName>
                    <default>false</default>
                    <label>Shortlisted</label>
                </value>
                <value>
                    <fullName>Study Plan Approved but Needs More Units</fullName>
                    <default>false</default>
                    <label>Study Plan Approved but Needs More Units</label>
                </value>
                <value>
                    <fullName>Study Plan Approved by Faculty(ies)/School(s)</fullName>
                    <default>false</default>
                    <label>Study Plan Approved by Faculty(ies)/School(s)</label>
                </value>
                <value>
                    <fullName>Study Plan Not Approved by Faculty(ies)/School(s)</fullName>
                    <default>false</default>
                    <label>Study Plan Not Approved by Faculty(ies)/School(s)</label>
                </value>
                <value>
                    <fullName>Study Plan Under Assessment</fullName>
                    <default>false</default>
                    <label>Study Plan Under Assessment</label>
                </value>
                <value>
                    <fullName>Submitted</fullName>
                    <default>false</default>
                    <label>Submitted</label>
                </value>
                <value>
                    <fullName>Successful</fullName>
                    <default>false</default>
                    <label>Successful</label>
                </value>
                <value>
                    <fullName>Unsuccessful</fullName>
                    <default>false</default>
                    <label>Unsuccessful</label>
                </value>
                <value>
                    <fullName>Withdrawn</fullName>
                    <default>false</default>
                    <label>Withdrawn</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>AO_Program_Location__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Update Program Location here</description>
        <externalId>false</externalId>
        <label>Program Location</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>AO_Program__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>Restrict</deleteConstraint>
        <description>Indicates the program to which the applicant is related to</description>
        <label>Program</label>
        <referenceTo>AO_Program__c</referenceTo>
        <relationshipLabel>Program Applicants</relationshipLabel>
        <relationshipName>Program_Applicants</relationshipName>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>AO_Start_Date__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Contains Program Applicant&apos;s Start date in current academic year</description>
        <inlineHelpText>Program Applicant&apos;s Start date in current academic year</inlineHelpText>
        <label>Start Date</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Contact_Hyperlink__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Hyperlink of the contact record for use in flow</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&apos;/&apos; &amp; AO_Contact__c , AO_Contact__r.Full_Name__c, &apos;_blank&apos;)</formula>
        <inlineHelpText>Hyperlink of the contact record for use in flow</inlineHelpText>
        <label>Contact Hyperlink</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Program Applicant</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>AO_Contact__c</columns>
        <columns>AO_Program__c</columns>
        <columns>AO_Program_Location__c</columns>
        <columns>AO_Application_Status__c</columns>
        <columns>AO_Faculty_Status__c</columns>
        <columns>AO_Start_Date__c</columns>
        <columns>AO_End_Date__c</columns>
        <columns>AO_Account_Host_Institution__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>PA-{000000}</displayFormat>
        <label>Program Applicant Name</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Program Applicants</pluralLabel>
    <searchLayouts>
        <excludedStandardButtons>OpenListInQuip</excludedStandardButtons>
        <excludedStandardButtons>NewFromDocument</excludedStandardButtons>
        <excludedStandardButtons>Accept</excludedStandardButtons>
        <excludedStandardButtons>ChangeOwner</excludedStandardButtons>
        <excludedStandardButtons>Import</excludedStandardButtons>
        <excludedStandardButtons>MassAssignRecordLabel</excludedStandardButtons>
        <listViewButtons>Bulk_Update</listViewButtons>
    </searchLayouts>
    <sharingModel>ReadWrite</sharingModel>
    <validationRules>
        <fullName>AO_PA_VALIDATE_END_BEFORE_START_DATE</fullName>
        <active>true</active>
        <description>End date can&apos;t be before Start Date</description>
        <errorConditionFormula>AO_End_Date__c &lt;= AO_Start_Date__c</errorConditionFormula>
        <errorMessage>End date can&apos;t be before or on the same day as the Start Date</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>Assign_Form_prog_Applicant</fullName>
        <availability>online</availability>
        <displayType>massActionButton</displayType>
        <encodingKey>UTF-8</encodingKey>
        <height>600</height>
        <linkType>url</linkType>
        <masterLabel>Assign Form</masterLabel>
        <openType>sidebar</openType>
        <protected>false</protected>
        <requireRowSelection>true</requireRowSelection>
        <url>/flow/SCR_Program_Applicant_Form_Assignment?retURL={! AO_Program__c.Id }</url>
    </webLinks>
    <webLinks>
        <fullName>Bulk_Update</fullName>
        <availability>online</availability>
        <displayType>massActionButton</displayType>
        <encodingKey>UTF-8</encodingKey>
        <height>600</height>
        <linkType>url</linkType>
        <masterLabel>Bulk Update</masterLabel>
        <openType>sidebar</openType>
        <protected>false</protected>
        <requireRowSelection>true</requireRowSelection>
        <url>/flow/SCR_AO_Bulk_Update?retURL=lightning/o/AO_Program_Applicant__c/list?filterName=All</url>
    </webLinks>
</CustomObject>
