        <columns>Is_Active__c</columns>
        <columns>Classification__c</columns>
        <filterScope>Everything</filterScope>
        <label>All records</label>
    </listViews>
    <nameField>
        <label>Social Handle</label>
        <trackHistory>false</trackHistory>
        <type>Text</type>
    </nameField>
    <pluralLabel>Social Handles</pluralLabel>
