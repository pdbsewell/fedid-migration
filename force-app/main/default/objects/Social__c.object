    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>Standard</compactLayoutAssignment>
    <compactLayouts>
        <fullName>Standard</fullName>
        <fields>Name</fields>
        <fields>Type__c</fields>
