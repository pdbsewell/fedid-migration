    <fields>
        <fullName>GPA__c</fullName>
        <description>A grade point average is a number representing the average value of the accumulated final grades earned in courses over time. More commonly called a GPA, a student&apos;s grade point average is calculated by adding up all accumulated final grades and dividing that figure by the number of grades awarded.
Ranges usually from 1.0 to 5.0</description>
        <externalId>false</externalId>
        <isFilteringDisabled>false</isFilteringDisabled>
        <isNameField>false</isNameField>
