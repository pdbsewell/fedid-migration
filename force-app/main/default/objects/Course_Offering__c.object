    <fields>
        <fullName>Commencement_Period__c</fullName>
        <externalId>false</externalId>
        <formula>Course__r.ACAD_Year__c
&amp; &quot; &quot; &amp;
CASE( Admission_Calendar_Type__c ,
&apos;ADM-1&apos;, &apos;Semester 1 (February start)&apos;,
&apos;ADM-2&apos;, &apos;Semester 2 (July start)&apos;,
&apos;ADM-SPRING&apos;, &apos;Spring Semester (July-Nov start, varies by course)&apos;,
&apos;ADM-SUMMR&apos;, &apos;Summer Semester&apos;,
&apos;ADM-WNTR&apos;, &apos;Winter Semester (April-June start, varies by course)&apos;,
NULL)</formula>
        <label>Commencement Period</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
