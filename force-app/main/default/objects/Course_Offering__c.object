    </fields>
    <fields>
        <fullName>Registration_Close_Date__c</fullName>
        <description>The last day on which participants can register for the Course Offering. A default value is set under the Process Builder, PD Update CO [Partitioning for Short Courses]</description>
        <inlineHelpText>Defaults to the day before the Start Date unless a different date is entered</inlineHelpText>
        <label>Registration Close Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Registration_Count__c</fullName>
