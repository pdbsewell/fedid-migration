        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Unit_Set_Key__c</fullName>
        <externalId>false</externalId>
        <formula>IF(AND(!ISBLANK( Unit_Set_Code__c ),!ISBLANK( Unit_Set_Version__c )),Unit_Set_Code__c + &apos;_&apos; + TEXT(Unit_Set_Version__c ) ,null)</formula>
        <label>Unit Set Key</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
