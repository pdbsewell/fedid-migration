    <fields>
        <fullName>Unit_Set_Code__c</fullName>
        <externalId>true</externalId>
        <label>Unit Set Code</label>
        <length>10</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Unit_Set_Description__c</fullName>
        <externalId>false</externalId>
        <label>Unit Set Description</label>
        <length>200</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
