    <validationRules>
        <fullName>Cancelled_reason_is_mandatory</fullName>
        <active>true</active>
        <description>PD-If the status is cancelled, then the Cancelled reason field is mandatory.</description>
        <errorConditionFormula>AND(ISPICKVAL( Status__c , &apos;Cancelled&apos;), ISBLANK( Reason_for_Cancellation__c ),ISPICKVAL( Course__r.Type__c,&apos;Short_Course&apos;))</errorConditionFormula>
        <errorDisplayField>Reason_for_Cancellation__c</errorDisplayField>
        <errorMessage>Reason for cancellation is required</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Course_Is_inactive</fullName>
        <active>true</active>
        <description>PD-Check course is active when creating new course offering</description>
        <errorConditionFormula>AND( Course__r.Inactive__c = true, ISPICKVAL( Course__r.Type__c, &apos;Short_Course&apos;),  ISNEW())</errorConditionFormula>
        <errorMessage>The course is not active. You can only create a new course offering for active courses.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validate_Override_Duration</fullName>
        <active>true</active>
        <errorConditionFormula>OR(
AND(NOT(ISNULL(Override_Duration__c)),ISBLANK(TEXT(Override_Duration_Unit__c))),
AND(NOT(ISBLANK(TEXT(Override_Duration_Unit__c))),ISNULL(Override_Duration__c))
)</errorConditionFormula>
        <errorMessage>In order to override course duration, you must set Override Duration and Override Duration Unit at the same time.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validate_Override_Duration_Decimal</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
NOT(ISBLANK(Override_Duration__c)),
NOT(ISPICKVAL(Override_Duration_Unit__c, &apos;Year&apos;)),
FLOOR(Override_Duration__c) != Override_Duration__c
)</errorConditionFormula>
        <errorMessage>Override Duration must be a whole number AND only one decimal point is allowed for Override Duration if Override Duration Unit is Year(s).</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Venue_required_when_course_is_confirmed</fullName>
        <active>true</active>
        <description>PD-Venue is mandatory when course is confirmed (Confirmed__c = true)</description>
        <errorConditionFormula>AND(Confirmed__c = true , ISBLANK( Venue__c ),  ISPICKVAL(Course__r.Type__c ,&apos;Short_Course&apos;))</errorConditionFormula>
        <errorDisplayField>Venue__c</errorDisplayField>
        <errorMessage>Venue is mandatory when course is confirmed</errorMessage>
    </validationRules>
