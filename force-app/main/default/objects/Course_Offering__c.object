    <fields>
        <fullName>Course_Duration__c</fullName>
        <externalId>false</externalId>
        <formula>Course__r.Duration_FT__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Duration</label>
        <precision>18</precision>
        <required>false</required>
        <scale>1</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Key__c</fullName>
        <externalId>false</externalId>
        <formula>IF(AND(!ISBLANK(Course_Code__c),!ISBLANK(Course_Version_Number__c)),Course_Code__c + &apos;_&apos; +  TEXT(Course_Version_Number__c) ,null)</formula>
        <label>Course_Key</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Offering_Detail__c</fullName>
        <externalId>false</externalId>
        <formula>IF(ISPICKVAL(Status__c,&apos;Available&apos;),
&apos;At [&apos; &amp; Venue__r.Name &amp; &apos;] Starting on [&apos; &amp; TEXT(Start_Date__c) &amp; &apos;]&apos; &amp; &apos; [ Full: $&apos; &amp;  TEXT(Fee__c)  &amp; &apos; Con: $&apos; &amp;  TEXT(Concession_Fee__c)  &amp; &apos; ] &apos; &amp; IMAGE(&quot;/servlet/servlet.FileDownload?file=01528000004SDIR&quot;,&quot;AVAILABLE&quot;,19,80) &amp; &quot; [ &quot; &amp; TEXT(Number_of_Remaining_Places__c) &amp; &apos; Places ]&apos;, 
IF(ISPICKVAL(Status__c,&apos;Full&apos;),
&apos;At [&apos; &amp; Venue__r.Name &amp; &apos;] Starting on [&apos; &amp; TEXT(Start_Date__c) &amp; &apos;]&apos; &amp; &apos; [ Full: $&apos; &amp; TEXT(Fee__c) &amp; &apos; Con: $&apos; &amp; TEXT(Concession_Fee__c) &amp; &apos; ] &apos; &amp; IMAGE(&quot;/servlet/servlet.FileDownload?file=01528000004SDIT&quot;,&quot;WAITLIST&quot;,20,76) &amp; &quot; [ &quot; &amp; TEXT(Number_of_Remaining_Places__c) &amp; &apos; Places ]&apos;,
IF(ISPICKVAL(Status__c,&apos;Cancelled&apos;),
&apos;At [&apos; &amp; Venue__r.Name &amp; &apos;] Starting on [&apos; &amp; TEXT(Start_Date__c) &amp; &apos;]&apos; &amp; &apos; [ Full: $&apos; &amp; TEXT(Fee__c) &amp; &apos; Con: $&apos; &amp; TEXT(Concession_Fee__c) &amp; &apos; ] &apos; &amp; IMAGE(&quot;/servlet/servlet.FileDownload?file=01528000004SDIS&quot;,&quot;CANCELLED&quot;,21,74) &amp; &quot; [ &quot; &amp; TEXT(Number_of_Remaining_Places__c) &amp; &apos; Places ]&apos;,&apos;&apos;
)))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Offering Detail</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
