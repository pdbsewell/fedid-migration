<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>REST callout integration details</description>
    <fields>
        <fullName>API_Version__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>API Version</label>
        <length>20</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Debug_Log__c</fullName>
        <defaultValue>false</defaultValue>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Debug Log</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Enable_Send__c</fullName>
        <defaultValue>false</defaultValue>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Enable Send?</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Endpoint_Relative_URL__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Endpoint Relative URL</label>
        <length>200</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>HTTP_Method__c</fullName>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>HTTP Method</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>HEAD</fullName>
                    <default>false</default>
                    <label>HEAD</label>
                </value>
                <value>
                    <fullName>GET</fullName>
                    <default>true</default>
                    <label>GET</label>
                </value>
                <value>
                    <fullName>POST</fullName>
                    <default>false</default>
                    <label>POST</label>
                </value>
                <value>
                    <fullName>PATCH</fullName>
                    <default>false</default>
                    <label>PATCH</label>
                </value>
                <value>
                    <fullName>DELETE</fullName>
                    <default>false</default>
                    <label>DELETE</label>
                </value>
                <value>
                    <fullName>PUT</fullName>
                    <default>false</default>
                    <label>PUT</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Integration_Log__c</fullName>
        <defaultValue>false</defaultValue>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Integration Log</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Interface_Id__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Interface Id</label>
        <length>20</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Named_Credential__c</fullName>
        <externalId>false</externalId>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Named Credential</label>
        <length>100</length>
        <required>false</required>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Request_Time_out__c</fullName>
        <defaultValue>0</defaultValue>
        <description>Configurable time out on HTTP Request object</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Request Time out</label>
        <precision>10</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Integration Point</label>
    <pluralLabel>Integration Points</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
