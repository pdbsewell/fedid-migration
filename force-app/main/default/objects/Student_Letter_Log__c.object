    <label>Student Letter Log</label>
    <listViews>
        <fullName>All</fullName>
        <booleanFilter>1 OR 2</booleanFilter>
        <columns>NAME</columns>
        <columns>Student_Id__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>Letter_Price__c</columns>
        <columns>Payment_Method__c</columns>
        <columns>Payment_Status__c</columns>
        <columns>Receipt_Id__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Payment_Status__c</field>
            <operation>equals</operation>
            <value>SUCCESSFUL</value>
        </filters>
        <filters>
            <field>Payment_Status__c</field>
            <operation>equals</operation>
            <value>UNSUCCESSFUL</value>
        </filters>
        <label>All Digital Letters</label>
    </listViews>
    <listViews>
        <fullName>All_Digital_Letters_Last_7_Days</fullName>
        <booleanFilter>1 AND 2 AND (3 OR 4)</booleanFilter>
        <columns>NAME</columns>
