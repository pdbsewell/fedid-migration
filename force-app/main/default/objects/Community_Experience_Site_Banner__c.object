<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Site banner used for announcements in My Application</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Active__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Feature switch</description>
        <label>Active</label>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Additional_Message__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>This is an additional message if announcement takes more than 255 characters</description>
        <label>Additional Message</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>End_Date__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>End date of the announcement</description>
        <label>End Date</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>Message__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Message shown in the banner</description>
        <label>Message</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>Start_Date__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Start Date of the announcement</description>
        <label>Start Date</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>URL_Link__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>HDR Url Link</description>
        <label>URL Link</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>URL_Text__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>HDR Url Text</description>
        <externalId>false</externalId>
        <label>URL Text</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Community Experience Site Banner</label>
    <visibility>Public</visibility>
</CustomObject>
