    </compactLayouts>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>This allows the definition of various country attributes (e.g. mapping to ISO codes, ABS codes, Australian border, department of education codes, restricted countries, flags for different user groups which can be used to drive sharing of records etc.)</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Read</externalSharingModel>
    <fields>
        <fullName>Active_Ind__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>true</defaultValue>
        <description>An indicator for record status. Allows country records to be disabled from selection but retain historical data relationships.</description>
        <label>Active Ind</label>
        <securityClassification>Public</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Active_f__c</fullName>
        <description>On/Off light bulb indicator</description>
        <externalId>false</externalId>
        <formula>IF (Active_Ind__c
, IMAGE(&quot;/resource/1500335404000/GraphicsPackNew/fatcow/farmfresh/16/lightbulb.png&quot;, &quot;Active&quot;, 16, 16)
, IMAGE(&quot;/resource/1500335404000/GraphicsPackNew/fatcow/farmfresh/16/lightbulb_off.png&quot;, &quot;Not Active&quot;, 16, 16)
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Active if yellow!</inlineHelpText>
        <label>Active</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Alt_Code__c</fullName>
