        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Has Responded</label>
        <securityClassification>Internal</securityClassification>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Default__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Helps set Campaign member status as default</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Please set at least one status per RecordType/Type as default.</inlineHelpText>
        <label>Is Default</label>
        <securityClassification>Internal</securityClassification>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Sequence__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Order in which the status has to be applied</description>
        <externalId>false</externalId>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Enter a sequence number in which the order of the status&apos;s will be applied.</inlineHelpText>
        <label>Sequence</label>
        <precision>3</precision>
        <required>false</required>
        <scale>0</scale>
        <securityClassification>Internal</securityClassification>
        <type>Number</type>
        <unique>false</unique>
    </fields>
