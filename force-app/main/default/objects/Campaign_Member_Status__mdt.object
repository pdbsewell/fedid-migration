                    <label>MonTrack</label>
                </value>
                <value>
                    <fullName>Non Montrack</fullName>
                    <default>false</default>
                    <label>Non Montrack</label>
                </value>
                <value>
                    <fullName>SR Campaign</fullName>
                    <default>false</default>
                    <label>SR Campaign</label>
                </value>
                <value>
                    <fullName>Subscription List</fullName>
                    <default>false</default>
                    <label>Subscription List</label>
                </value>
                <value>
                    <fullName>Event</fullName>
                    <default>false</default>
                    <label>Event</label>
                </value>
                <value>
                    <fullName>ERDA_Guest_List</fullName>
                    <default>false</default>
                    <label>ERDA_Guest_List</label>
                </value>
                <value>
                    <fullName>Volunteers_Campaign</fullName>
                    <default>false</default>
                    <label>Volunteers_Campaign</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Campaign_Type__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Campaign Type for which statuses have to be defined.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <inlineHelpText>Leave blank if statuses have to be generated by Campaign Record Type.
NOTE: If a campaign has both Type and Record Type records here, a combination of all the statuses will be generated.</inlineHelpText>
        <label>Campaign Type</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>MonTrack</fullName>
                    <default>true</default>
                    <label>MonTrack</label>
                </value>
                <value>
                    <fullName>Student Recruitment Event</fullName>
                    <default>false</default>
                    <label>Student Recruitment Event</label>
                </value>
                <value>
                    <fullName>Domestic Pre App</fullName>
                    <default>false</default>
                    <label>Domestic Pre App</label>
                </value>
                <value>
                    <fullName>Domestic Post App</fullName>
                    <default>false</default>
                    <label>Domestic Post App</label>
                </value>
                <value>
                    <fullName>International Pre App</fullName>
                    <default>false</default>
                    <label>International Pre App</label>
                </value>
                <value>
                    <fullName>International Post App</fullName>
                    <default>false</default>
                    <label>International Post App</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Has_Responded__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
