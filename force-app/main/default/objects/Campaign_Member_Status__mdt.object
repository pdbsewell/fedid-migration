<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This contains all possible status for campaign member</description>
    <fields>
        <fullName>Campaign_Record_Type__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Campaign Record types for which Campaign member statuses have to be generated.</description>
