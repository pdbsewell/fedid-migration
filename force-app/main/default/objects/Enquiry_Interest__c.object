    <fields>
        <fullName>Course_Managing_Faculty__c</fullName>
        <description>pulls managing faculty through to enquiry interest, or , if no course linked then presents the text field equivalent if keyed in at Enquiry Interest level</description>
        <externalId>false</externalId>
        <formula>IF(NOT(ISBLANK( Course__c )),
 TEXT(Course__r.Managing_Faculty__c) ,  Managing_Faculty__c )</formula>
        <label>Course Managing Faculty</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Title_Text__c</fullName>
        <description>placeholder for legacy data, and surfaced via formula field</description>
        <externalId>false</externalId>
        <label>Course Title Text</label>
        <length>250</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Title__c</fullName>
        <description>for use in the console sidebar view</description>
        <externalId>false</externalId>
        <formula>IF(
NOT(ISBLANK(Course__r.Course_Description__c )),
Course__r.Course_Description__c,
   IF(NOT(ISBLANK(Course_Title_Text__c)), Course_Title_Text__c,
&quot;&quot;))</formula>
        <label>Course Title</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>if person is interested in a specific course, this field links to that course record.</description>
        <label>Course</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>Course__c.Depreciated__c</field>
                <operation>equals</operation>
                <value>False</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Course__c</referenceTo>
        <relationshipLabel>Enquiry Interests</relationshipLabel>
        <relationshipName>Enquiry_Interests</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
