    </fields>
    <fields>
        <fullName>Article_Link__c</fullName>
        <externalId>false</externalId>
        <formula>IF(TEXT($UserRole.PortalType)==&apos;CustomerPortal&apos;,HYPERLINK(  LEFT($Api.Partner_Server_URL_390, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_390))+&apos;s/article/&apos;+ ArticleType__c, Name ,&quot;_self&quot;),HYPERLINK(LEFT($Api.Partner_Server_URL_390, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_390))+ArticleType__c, Name ,&quot;&quot;))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Article Link</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
