        <fullName>eff_course_code_lookup__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Indicates the encumbrance is related to a specific course attempt</description>
        <label>Course Attempt</label>
        <lookupFilter>
            <active>true</active>
            <errorMessage>The course attempt must be for the encumbered student</errorMessage>
            <filterItems>
                <field>$Source.Contact__c</field>
                <operation>equals</operation>
                <valueField>Course_Attempt__c.Contact__c</valueField>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Course_Attempt__c</referenceTo>
