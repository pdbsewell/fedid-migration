        <fullName>Version_Formula_Field__c</fullName>
        <description>Field created to get the value whenever the version field is not null and use in course code with version field</description>
        <externalId>false</externalId>
        <formula>IF((Version__c) != null, &apos;_&apos; + (Version__c), (Version__c) )</formula>
        <label>Version Formula Field</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
