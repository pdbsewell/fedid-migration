<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Words used by Parser settings to identify which words should always be on all caps or small caps</description>
    <fields>
        <fullName>Case__c</fullName>
        <description>Defines how the keyword should be presented.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Case</label>
        <required>false</required>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Lower</fullName>
                    <default>true</default>
                    <label>Lower</label>
                </value>
                <value>
                    <fullName>Upper</fullName>
                    <default>false</default>
                    <label>Upper</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <label>Document Checklist Parser Keyword</label>
    <listViews>
        <fullName>All</fullName>
        <columns>MasterLabel</columns>
        <columns>DeveloperName</columns>
        <columns>Case__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <pluralLabel>Document Checklist Parser Keywords</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
