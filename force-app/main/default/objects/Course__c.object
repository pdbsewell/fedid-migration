    <fields>
        <fullName>Course_Full_Description__c</fullName>
        <description>This field created to enhance course search in offline registration. With this field, user can search either course code or course name</description>
        <externalId>false</externalId>
        <formula>Name &amp; &quot; &quot; &amp;  Course_Description__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Course Full Description</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Level__c</fullName>
        <externalId>false</externalId>
        <formula>if ( CONTAINS (Course_Description__c, &quot;Bachelor&quot;) , &quot;UG&quot; , 
if ( CONTAINS (Course_Description__c, &quot;Master&quot;), &quot;PG&quot;, 
if ( TEXT(Managing_Faculty__c) = &quot;PPA&quot;, &quot;Monash College - Non Award&quot;,&quot;Unknown&quot; 
) 
) 
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Check &quot;Course Description&quot; and select UG, PG or Unknown AND if Course Description is empty and Managing Faculty is PPA, then select Monash Collage - Non Award</inlineHelpText>
        <label>Course Level</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Course_Master__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to the parent course master to group all courses with the same Course Code</description>
        <label>Course Master</label>
        <referenceTo>Course_Master__c</referenceTo>
        <relationshipLabel>Courses</relationshipLabel>
        <relationshipName>Courses</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
