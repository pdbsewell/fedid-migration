    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Managing_Faculty</fullName>
        <active>true</active>
        <description>Used in PD</description>
        <errorConditionFormula>OR (
      AND ($UserRole.Name = &apos;Education Short Courses Team&apos;, NOT(ISPICKVAL(Managing_Faculty__c,&apos;Faculty of Education&apos;))),
      AND ($UserRole.Name = &apos;BusEco Short Courses Team&apos;, NOT(ISPICKVAL(Managing_Faculty__c,&apos;Faculty of Business &amp; Economics&apos;))),
      AND ($UserRole.Name = &apos;Medicine Short Courses Team&apos;,
      AND( NOT(ISPICKVAL(Managing_Faculty__c,&apos;Faculty of Medicine, Nursing &amp; Health Sciences&apos;)), 
       NOT(ISPICKVAL(Managing_Faculty__c,&apos;School of Clinical Sciences (SCS)&apos;)),
       NOT(ISPICKVAL(Managing_Faculty__c,&apos;Monash Centre for Health Research and Implementation (MCHRI)&apos;)), 
       NOT(ISPICKVAL(Managing_Faculty__c,&apos;MNHS Student Academic Support Unit (SASU)&apos;)), 
       NOT(ISPICKVAL(Managing_Faculty__c,&apos;The School of Public Health and Preventive Medicine (SPHPM)&apos;)))), 
      AND ($UserRole.Name = &apos;Arts Short Courses Team&apos;, NOT(ISPICKVAL(Managing_Faculty__c,&apos;Faculty of Arts&apos;))),
      AND ($UserRole.Name = &apos;MSDI Short Courses Team&apos;, NOT(ISPICKVAL(Managing_Faculty__c,&apos;Monash Sustainable Development Institute&apos;)))
)</errorConditionFormula>
        <errorDisplayField>Managing_Faculty__c</errorDisplayField>
        <errorMessage>Please make sure you create and edit records belong to your faculty</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Short_Course_picklist_value</fullName>
        <active>true</active>
        <description>Short Course</description>
        <errorConditionFormula>AND(
ISPICKVAL(Type__c,&apos;Academic_Course&apos;),$Profile.Id   =  &apos;00e0l000000DfOg&apos;)</errorConditionFormula>
        <errorDisplayField>Type__c</errorDisplayField>
        <errorMessage>You cannot select type of Academic Course</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>New_Course_Offering</fullName>
        <availability>online</availability>
        <displayType>button</displayType>
        <encodingKey>UTF-8</encodingKey>
        <linkType>url</linkType>
        <masterLabel>New Course Offering</masterLabel>
        <openType>replace</openType>
        <protected>false</protected>
        <url>/lightning/o/Course_Offering__c/new?defaultFieldValues=
Course__c={!Course__c.Id},
Fee__c={!TEXT(Course__c.Fee__c)},
Concession_Fee__c= {!TEXT(Course__c.Concession_Fee__c)},
Faculty__c={!URLENCODE(TEXT(Course__c.Managing_Faculty__c))},
Course_Type__c=Short Course,
retURL={!Course__c.Id}</url>
    </webLinks>
</CustomObject>
