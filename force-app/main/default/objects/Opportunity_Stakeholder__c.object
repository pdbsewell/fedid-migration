    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Relates Contact records as stakeholders to an opportunity. This duplicates the Opportunity Contact Role, but benefits from being a custom object (record types, tabs etc)</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Contact_Formula__c</fullName>
        <description>Formula field with hyperlink to parent contact record.</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(Contact__c, Contact__r.Full_Name__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Contact</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Reference to a Contact record as stakeholder</description>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Opportunity Stakeholders</relationshipLabel>
        <relationshipName>OpportunityStakeholders</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>true</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Opportunity__c</fullName>
        <description>Reference to the opportunity the contact is a stakeholder for.</description>
        <inlineHelpText>Please provide the Opportunity reference the Contact is a stakeholder for.</inlineHelpText>
        <label>Opportunity</label>
        <referenceTo>Opportunity</referenceTo>
        <relationshipLabel>Stakeholders</relationshipLabel>
        <relationshipName>Stakeholders</relationshipName>
        <relationshipOrder>1</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Role__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The role the stakeholder holds in the opportunity</description>
        <inlineHelpText>Please provide the role of the Contact assumes in the opportunity.</inlineHelpText>
        <label>Role</label>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>BDM</fullName>
                    <default>false</default>
                    <label>BDM</label>
                </value>
                <value>
                    <fullName>Monash Innovation representative</fullName>
                    <default>false</default>
                    <label>Monash Innovation representative</label>
                </value>
                <value>
                    <fullName>Primary Chief Investigator</fullName>
                    <default>false</default>
                    <label>Primary Chief Investigator</label>
                </value>
                <value>
                    <fullName>Associate Investigator</fullName>
                    <default>false</default>
                    <label>Associate Investigator</label>
                </value>
                <value>
                    <fullName>Partner Investigator</fullName>
                    <default>false</default>
                    <label>Partner Investigator</label>
                </value>
                <value>
                    <fullName>Sponsor</fullName>
                    <default>false</default>
                    <label>Sponsor</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <label>Stakeholder</label>
    <nameField>
        <displayFormat>OSN-{000000}</displayFormat>
        <label>Opportunity Stakeholder Name</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Stakeholders</pluralLabel>
    <recordTypeTrackHistory>false</recordTypeTrackHistory>
    <recordTypes>
        <fullName>Enterprise</fullName>
        <active>true</active>
        <description>Stakehoder roles for Enterprise opportunities</description>
        <label>Enterprise</label>
        <picklistValues>
            <picklist>Role__c</picklist>
            <values>
                <fullName>Associate Investigator</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>BDM</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Monash Innovation representative</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Partner Investigator</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Primary Chief Investigator</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Sponsor</fullName>
                <default>false</default>
            </values>
        </picklistValues>
    </recordTypes>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
