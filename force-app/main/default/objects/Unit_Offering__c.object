    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Unit_Code__c</columns>
        <columns>Unit_Version__c</columns>
        <columns>Academic_Year__c</columns>
        <columns>Location__c</columns>
        <columns>Offered_Ind__c</columns>
        <columns>Calendar_Type__c</columns>
        <columns>Teaching_Period__c</columns>
        <columns>Title__c</columns>
        <columns>Active_Ind__c</columns>
        <columns>Managing_Faculty__c</columns>
        <columns>Managing_Department__c</columns>
        <columns>Teaching_Responsibility__c</columns>
        <columns>CREATED_DATE</columns>
        <columns>LAST_UPDATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Academic_Year__c</field>
            <operation>greaterOrEqual</operation>
            <value>2023</value>
        </filters>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>Monash_Forms_Overload_able_UOs</fullName>
        <columns>NAME</columns>
        <columns>Unit_Code__c</columns>
        <columns>Title__c</columns>
        <columns>Offered_Ind__c</columns>
        <columns>Academic_Year__c</columns>
        <columns>Calendar__c</columns>
        <columns>Location__c</columns>
        <columns>Unit_Mode__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Offered_Ind__c</field>
            <operation>equals</operation>
            <value>1</value>
        </filters>
        <filters>
            <field>Academic_Year__c</field>
            <operation>equals</operation>
            <value>2024,2025</value>
        </filters>
        <filters>
            <field>Calendar__c</field>
            <operation>notEqual</operation>
        </filters>
        <filters>
            <field>Location__c</field>
            <operation>notEqual</operation>
        </filters>
        <filters>
            <field>Unit_Code__c</field>
            <operation>notEqual</operation>
        </filters>
        <filters>
            <field>Unit_Mode__c</field>
            <operation>notEqual</operation>
        </filters>
        <label>Monash Forms - Overload(able) UOs</label>
    </listViews>
