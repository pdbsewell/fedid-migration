    <fields>
        <fullName>Writeback_Apex_Job_Id__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Id of Async context that is currently processing this Award for writeback</description>
        <externalId>false</externalId>
        <label>Writeback Apex Job Id</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Writeback_Requested_Age_Minutes__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Minutes since the last writeback was requested. Blank if no writeback is pending</description>
        <externalId>false</externalId>
        <formula>IF(
  ISBLANK(Last_Callista_Writeback_Success_Time__c) || Callista_Writeback_Requested_Time__c &gt; Last_Callista_Writeback_Success_Time__c,
  (NOW() - Callista_Writeback_Requested_Time__c) * 1440,
  NULL
)</formula>
        <label>Writeback Requested Age (Minutes)</label>
        <precision>18</precision>
        <required>false</required>
        <scale>2</scale>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Writeback_Retry_Attempt__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Number of writeback attempts made by GradsCallistaSyncBatch (set to 0 on success)</description>
        <externalId>false</externalId>
        <label>Writeback Retry Attempt</label>
        <precision>8</precision>
        <required>false</required>
        <scale>0</scale>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Graduation Award</label>
    <listViews>
        <fullName>All1</fullName>
        <columns>NAME</columns>
        <columns>Integration_Id__c</columns>
        <columns>Graduation_Application__c</columns>
        <columns>Graduation_Payment__c</columns>
        <columns>Is_Attending_Ceremony__c</columns>
        <columns>Has_Attendance_Fee_Waiver__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <listViews>
        <fullName>Non_Attending_Externally_Paid</fullName>
        <booleanFilter>(1 OR 3) AND 2</booleanFilter>
        <columns>NAME</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Is_Attending_Ceremony__c</field>
            <operation>equals</operation>
            <value>0</value>
        </filters>
        <filters>
            <field>Receipt_Number_External_System__c</field>
            <operation>notEqual</operation>
        </filters>
        <filters>
            <field>Cancellation_Date__c</field>
            <operation>notEqual</operation>
        </filters>
        <label>Non-Attending Externally Paid</label>
    </listViews>
    <nameField>
        <displayFormat>GAWARD-{0000000}</displayFormat>
        <label>Graduation Award Number</label>
        <trackHistory>true</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Graduation Awards</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>Student_Person_Id__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Course_Code__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Award_Code_1__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Award_Code_2__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Is_Attending_Ceremony__c</searchResultsAdditionalFields>
    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Cant_Remove_Applied_Waiver</fullName>
        <active>true</active>
        <description>Can&apos;t remove an Applied Application&apos;s Waiver or External Receipt Number</description>
        <errorConditionFormula>ISPICKVAL(Graduation_Application__r.Status__c, &quot;Applied&quot;)
&amp;&amp;
(
  (!Has_Attendance_Fee_Waiver__c &amp;&amp; PRIORVALUE(Has_Attendance_Fee_Waiver__c)) 
  ||
  (ISBLANK(Receipt_Number_External_System__c) &amp;&amp; NOT(ISBLANK(PRIORVALUE(Receipt_Number_External_System__c))))
)</errorConditionFormula>
        <errorMessage>Can&apos;t remove Waiver or External Receipt Number from Applied Application</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
