        <businessStatus>Active</businessStatus>
        <description>Person Id from the student&apos;s contact record</description>
        <externalId>false</externalId>
        <formula>Graduation_Application__r.Student__r.Person_ID_unique__c</formula>
        <label>Student Person Id</label>
