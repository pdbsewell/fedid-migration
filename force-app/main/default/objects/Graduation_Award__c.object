    <fields>
        <fullName>Has_Pending_Callista_Writeback__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>This Award has been queued for a writeback</description>
        <formula>Callista_Writeback_Requested_Time__c &lt; Last_Callista_Writeback_Success_Time__c
||
ISBLANK(Last_Callista_Writeback_Success_Time__c) &amp;&amp; NOT(ISBLANK(Callista_Writeback_Requested_Time__c))</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Has Pending Callista Writeback</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
