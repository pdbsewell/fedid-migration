    <enableHistory>true</enableHistory>
    <fields>
        <fullName>Access_HR__c</fullName>
        <defaultValue>false</defaultValue>
        <label>Access HR</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Answer_Link__c</fullName>
        <description>Used by Monash Connect, as a work around in missing lightning functionality of attaching article link in email.</description>
        <externalId>false</externalId>
        <formula>IF( RecordType.Name == &apos;FAQ&apos;, HYPERLINK(&quot;https://www.monash.edu/students/support/connect/contact-us?_hs-q=&quot;+UrlName, Title),
            HYPERLINK(IF(CONTAINS(LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)), &quot;unicrm&quot;), &quot;https://connect.monash.edu/&quot;,
            IF(CONTAINS(LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)), &quot;staging&quot;), &quot;https://staging-monashpartner.cs58.force.com/askmonash&quot;,
            &quot;https://sit-monashpartner.cs74.force.com/askmonash/&quot;))+&quot;s/article/&quot;+UrlName, Title)

            )</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Answer Link</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Answer__c</fullName>
        <label>Public facing only</label>
        <length>32768</length>
