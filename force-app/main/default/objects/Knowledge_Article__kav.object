    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <compactLayouts>
        <fullName>HR_FAQ_Compact_Layout</fullName>
        <fields>Title</fields>
        <fields>ArticleNumber</fields>
        <fields>PublishStatus</fields>
        <fields>ValidationStatus</fields>
