    <searchLayouts>
        <customTabListAdditionalFields>TITLE</customTabListAdditionalFields>
        <customTabListAdditionalFields>ARTICLE_NUMBER</customTabListAdditionalFields>
        <customTabListAdditionalFields>ABSTRACT</customTabListAdditionalFields>
        <customTabListAdditionalFields>URL_NAME</customTabListAdditionalFields>
        <customTabListAdditionalFields>LAST_PUBLISHED_DATE</customTabListAdditionalFields>
        <customTabListAdditionalFields>Record_Type__c</customTabListAdditionalFields>
        <searchResultsAdditionalFields>TITLE</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>ARTICLE_NUMBER</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>ABSTRACT</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>URL_NAME</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>LAST_PUBLISHED_DATE</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Record_Type__c</searchResultsAdditionalFields>
    </searchLayouts>
    <validationRules>
        <fullName>Cannot_change_URL</fullName>
        <active>true</active>
        <errorConditionFormula>AND( 
NOT(RecordType.DeveloperName = &apos;FAQ&apos;), 
NOT(RecordType.DeveloperName = &apos;HR_FAQ&apos;), 
NOT(RecordType.DeveloperName = &apos;HR_Standard_Text&apos;), 
NOT(RecordType.DeveloperName = &apos;Knowledge&apos;), 
NOT(RecordType.DeveloperName = &apos;Standard_Text&apos;), 

NOT( ISNEW() ), 
ISCHANGED(UrlName), 
Confirm_URL_Change__c = FALSE 

)</errorConditionFormula>
        <errorMessage>You have attempted to change the article URL, please tick Confirm URL 
Change checkbox to proceed with this change.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Planned_Publication_Date</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	Automatically_Publish_On_Approval__c == false, 
	ISBLANK(Planned_Publication_Date__c),
	NOT($Permission.Allow_Validation_Status_Publish),
	NOT(RecordType.DeveloperName = &apos;Monash_Adviser&apos;),
	NOT(RecordType.DeveloperName = &apos;Course Information&apos;),
        NOT(RecordType.DeveloperName = &apos;Monash_Connect&apos;),
	NOT((RecordType.DeveloperName = &apos;SR_FAQ&apos;)),
	NOT(RecordType.DeveloperName = &apos;Knowledge&apos;),
    NOT(RecordType.DeveloperName = &apos;Alumni_Engagement&apos;),
	NOT(ISPICKVAL(Faculty_Business_Unit__c, &apos;Monash College&apos;))
)</errorConditionFormula>
        <errorMessage>Please select either &quot;Automatically Publish On Approval&quot; or specify a &quot;Planned publication date&quot;</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Publication_Date_not_set</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	NOT(RecordType.DeveloperName = &apos;Monash_Adviser&apos;),
	NOT(RecordType.DeveloperName = &apos;Course Information&apos;),
	NOT(RecordType.DeveloperName = &apos;SR_FAQ&apos;),
	NOT(RecordType.DeveloperName = &apos;Knowledge&apos;),
    NOT(RecordType.DeveloperName = &apos;Alumni_Engagement&apos;),
        NOT(RecordType.DeveloperName = &apos;Monash_Connect&apos;),
	NOT($Permission.Allow_Validation_Status_Publish),
	OR(
		AND(
			ISBLANK(Planned_Publication_Date__c), 
			Automatically_Publish_On_Approval__c = false, 
			ISPICKVAL( ValidationStatus , &quot;Draft&quot;)
		),
		AND(
			!ISBLANK(Planned_Publication_Date__c), 
			Automatically_Publish_On_Approval__c = True, 
			ISPICKVAL( ValidationStatus , &quot;Draft&quot;)
		)
	),
	NOT(ISPICKVAL(Faculty_Business_Unit__c, &apos;Monash College&apos;))
)</errorConditionFormula>
        <errorMessage>Please set a &apos;Publication Date&apos; or select &apos;Automatically Publish on Approval&apos;</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Removal_Date_required</fullName>
        <active>true</active>
        <errorConditionFormula>AND(NOT($Permission.Allow_Validation_Status_Publish),(IsBlank(Proposed_Removal_Date__c) &amp;&amp; (IsPickval( Proposed_Removal_Status__c,&quot;Archive&quot;) || IsPickval( Proposed_Removal_Status__c,&quot;Draft&quot;))))</errorConditionFormula>
        <errorMessage>Please select Proposed Removal Date</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Removal_Status_required</fullName>
        <active>true</active>
        <errorConditionFormula>AND(NOT($Permission.Allow_Validation_Status_Publish),(!IsBlank(Proposed_Removal_Date__c) &amp;&amp; (!IsPickval( Proposed_Removal_Status__c,&quot;Archive&quot;) &amp;&amp; !IsPickval( Proposed_Removal_Status__c,&quot;Draft&quot;))))</errorConditionFormula>
        <errorMessage>Please select Proposed Removal Status</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Review_Date_cant_be_less_than_today</fullName>
        <active>true</active>
        <errorConditionFormula>AND(NOT($Permission.Allow_Validation_Status_Publish),(Review_Date__c &lt;TODAY()))</errorConditionFormula>
        <errorMessage>Review date cannot be less than today.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Validation_Status_Draft</fullName>
        <active>true</active>
        <errorConditionFormula>AND(NOT($Permission.Allow_Validation_Status_Publish),IsChanged(ValidationStatus) &amp;&amp; !IsPickVal(ValidationStatus,&quot;Draft&quot;)|| 
(!IsChanged(ValidationStatus) &amp;&amp; !IsPickVal(ValidationStatus,&quot;Draft&quot;)))</errorConditionFormula>
        <errorMessage>Please change the Validation Status to &apos;Draft&apos; before submitting FAQ for approval</errorMessage>
    </validationRules>
</CustomObject>
