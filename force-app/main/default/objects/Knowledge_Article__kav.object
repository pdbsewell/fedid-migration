    <fields>
        <fullName>PendingApprovalFormula__c</fullName>
        <externalId>false</externalId>
        <formula>&quot;CommunicationCoordinator&quot;+&quot;,&quot; +
If(Superannuation__c= true, &quot;Super&quot;,&apos;&apos;)+&quot;,&quot; +  
If(Payroll_Services__c= true, &quot;Payroll&quot;,&apos;&apos;) +&quot;,&quot; + 
If( Recruitment__c =true, &quot;Recruitment&quot;,&apos;&apos;)+&quot;,&quot; + 
If( Access_HR__c =true, &quot;Access&quot;, &apos;&apos;)+&quot;,&quot; + 
If( Employee_Assistance__c  = true, &quot;Employee&quot;,&apos;&apos;) +&quot;,&quot; + 
If( Ethical_conduct__c =true, &quot;Ethical&quot;,&apos;&apos;) +&quot;,&quot; +  
If( Gender_Equity__c =true, &quot;Gender&quot;,&apos;&apos;) +&quot;,&quot; +   
If( Leadership_Organisational_Development__c =true, &quot;Leadership&quot;,&apos;&apos;) +&quot;,&quot; +   
If( Remuneration_Global_Mobility__c =true, &quot;Remuneration&quot;,&apos;&apos;) +&quot;,&quot; +   
If( Staff_Development__c = true,&quot;Staff&quot;, &apos;&apos;) +&quot;,&quot; +
If( Workforce_Policy_Procedure__c =true, &quot;Policy&quot;, &apos;&apos;) +&quot;,&quot; + 
If( Workplace_Relations__c =true, &quot;Relations&quot;,&apos;&apos;) +&quot;,&quot; +  
If( WorkforceAnalytics__c =True, &quot;Analytics&quot;, &apos;&apos;) +&quot;,&quot; +  
&quot;Knowledge&quot;</formula>
        <label>PendingApprovalFormula</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
