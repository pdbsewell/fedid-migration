    <label>Knowledge/Article</label>
    <listViews>
        <fullName>Academic_Progress_AP_MC_Knowledge</fullName>
        <columns>ARTICLE_NUMBER</columns>
        <columns>TITLE</columns>
        <columns>PUBLISH_STATUS</columns>
        <columns>LAST_PUBLISHED_DATE</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>RECORDTYPE</field>
            <operation>equals</operation>
            <value>Knowledge_Article__kav.Monash_Connect</value>
        </filters>
        <filters>
            <field>PUBLISH_STATUS</field>
            <operation>equals</operation>
            <value>2</value>
        </filters>
        <filters>
            <field>Topics</field>
            <operation>includes</operation>
            <value>AP</value>
        </filters>
