    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Defines a team of users that hold a relationship with a contact. This is for visibility purposes only and does not imply any record access.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>false</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Relationship with the Contact Object</description>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipName>ContactTeams</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Role__c</fullName>
        <label>Role</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>MSDI Lead</fullName>
                    <default>false</default>
                    <label>MSDI Lead</label>
                </value>
                <value>
                    <fullName>PRM (Philanthropy)</fullName>
                    <default>false</default>
                    <label>PRM (Philanthropy)</label>
                </value>
                <value>
                    <fullName>Lead</fullName>
                    <default>false</default>
                    <label>Lead</label>
                </value>
                <value>
                    <fullName>Member</fullName>
                    <default>false</default>
                    <label>Member</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Team_Member__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Team Member</label>
        <referenceTo>User</referenceTo>
        <relationshipName>ContactTeams</relationshipName>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>UniqueID__c</fullName>
        <caseSensitive>false</caseSensitive>
        <externalId>false</externalId>
        <label>UniqueID</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <label>Contact Team</label>
    <nameField>
        <displayFormat>CT-{00000}</displayFormat>
        <label>Contact Team Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Contact Teams</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Validate_Unique_PRM</fullName>
        <active>true</active>
        <description>A PRM record already exists</description>
        <errorConditionFormula>ISPICKVAL(Role__c, &quot;PRM (Philanthropy)&quot;) &amp;&amp; Contact__r.ucinn_ascendv2__PRM__c &lt;&gt; Team_Member__c</errorConditionFormula>
        <errorMessage>There should only be one PRM per Contact</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
