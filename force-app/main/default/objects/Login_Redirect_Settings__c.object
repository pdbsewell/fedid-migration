<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>Settings controlling behaviour of LoginRedirectController.cls</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Network_Name__c</fullName>
        <description>Experience site network name used to find network id. Corresponds to the Name field on the Network object.
e.g. my.application or Ask.Monash</description>
        <externalId>false</externalId>
        <inlineHelpText>Experience site network name used to find network id. Corresponds to the Name field on the Network object.
e.g. my.application or Ask.Monash</inlineHelpText>
        <label>Network Name</label>
        <length>255</length>
        <required>true</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Permission_Sets__c</fullName>
        <description>Comma separated list of permission set API names to assign (or ensure are already assigned) the to user prior to redirection. e.g. &apos;Customer_Community_My_Application&apos;</description>
        <externalId>false</externalId>
        <inlineHelpText>Comma separated list of permission set API names to assign (or ensure are already assigned) the to user prior to redirection. e.g. &apos;Customer_Community_My_Application&apos;</inlineHelpText>
        <label>Permission Sets</label>
        <length>255</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Login Redirect Settings</label>
    <visibility>Public</visibility>
</CustomObject>
