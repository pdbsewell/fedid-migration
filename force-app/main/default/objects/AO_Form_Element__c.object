    <fields>
        <fullName>Visibility_Rule_Operator__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Operator for comparison of condition in element</description>
        <label>Visibility Rule Operator</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>==</fullName>
                    <default>false</default>
                    <label>== (Equal)</label>
                </value>
                <value>
                    <fullName>!=</fullName>
                    <default>false</default>
                    <label>!= (Not Equal)</label>
                </value>
                <value>
                    <fullName>&lt;</fullName>
                    <default>false</default>
                    <label>&lt; (Less Than)</label>
                </value>
                <value>
                    <fullName>&gt;</fullName>
                    <default>false</default>
                    <label>&gt; (Greater Than)</label>
                </value>
                <value>
                    <fullName>&lt;=</fullName>
                    <default>false</default>
                    <label>&lt;= (Less Than or Equal)</label>
                </value>
                <value>
                    <fullName>&gt;=</fullName>
                    <default>false</default>
                    <label>&gt;= (Greater Than or Equal)</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Visibility_Rule_Value__c</fullName>
