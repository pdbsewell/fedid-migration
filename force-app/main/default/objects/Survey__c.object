    <fields>
        <fullName>Article_Detail_Link__c</fullName>
        <externalId>false</externalId>
        <formula>IF( 
CONTAINS($Api.Partner_Server_URL_390, &apos;visual&apos;), 
&apos;https://&apos;+ 
MID($Api.Partner_Server_URL_390, FIND( &apos;visual&apos;, $Api.Partner_Server_URL_390)-4,4) 
+&apos;salesforce.com/&apos;, 
LEFT($Api.Partner_Server_URL_390, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_390)) 
) + Article_Id__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Article Detail Link</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Article_Id__c</fullName>
        <externalId>false</externalId>
        <label>Article Id</label>
        <length>18</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Article_Link__c</fullName>
        <externalId>false</externalId>
        <formula>HYPERLINK( 
IF( 
CONTAINS($Api.Partner_Server_URL_260, &apos;visual&apos;), 
&apos;https://&apos;+ 
MID($Api.Partner_Server_URL_260, FIND( &apos;visual&apos;, $Api.Partner_Server_URL_260)-4,4) 
+&apos;salesforce.com/&apos;, 
LEFT($Api.Partner_Server_URL_260, FIND( &apos;/services&apos;, $Api.Partner_Server_URL_260)) 
) + Article_Id__c, &apos;Open Article&apos; 
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Article Link</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
