<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <eventType>HighVolume</eventType>
    <fields>
        <fullName>BulkProcessed__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Flag to indicate whether the record has been bulk processed in the post-merge calculations</description>
        <isFilteringDisabled>false</isFilteringDisabled>
        <isNameField>false</isNameField>
        <isSortingDisabled>false</isSortingDisabled>
        <label>BulkProcessed</label>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Counter__c</fullName>
        <description>Counter value to store the current record count which is to be bulk processed in the post-merge logic.</description>
        <externalId>false</externalId>
        <isFilteringDisabled>false</isFilteringDisabled>
        <isNameField>false</isNameField>
        <isSortingDisabled>false</isSortingDisabled>
        <label>Counter</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>MergeAccount__c</fullName>
