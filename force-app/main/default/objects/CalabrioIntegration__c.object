<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>contains settings for Calabrio Integration</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>AllowCallout__c</fullName>
        <defaultValue>false</defaultValue>
        <label>AllowCallout</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>AllowedStaff__c</fullName>
        <description>Selected monash staff callout will be allowed in the first run.</description>
        <label>AllowedStaff</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>TextArea</type>
    </fields>
    <fields>
        <fullName>CalabrioURL__c</fullName>
        <label>CalabrioURL</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>Client_ID__c</fullName>
        <externalId>false</externalId>
        <label>Client ID</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Client_Secret__c</fullName>
        <externalId>false</externalId>
        <label>Client Secret</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>CalabrioIntegration</label>
    <visibility>Public</visibility>
</CustomObject>
