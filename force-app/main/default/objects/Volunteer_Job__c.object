        <fullName>of_Volunteers_Needed__c</fullName>
        <externalId>false</externalId>
        <label># of Volunteers Needed</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>of_Volunteers_Still_Needed__c</fullName>
        <externalId>false</externalId>
        <formula>of_Volunteers_Needed__c -  Number_of_Volunteers__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label># of Volunteers Still Needed</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Volunteer Job</label>
    <listViews>
        <fullName>All_Jobs</fullName>
        <columns>NAME</columns>
        <columns>Campaign__c</columns>
        <columns>Volunteer_Type__c</columns>
        <columns>Number_of_Volunteers__c</columns>
        <columns>Number_of_Volunteers_Still_Needed__c</columns>
        <columns>Number_of_Completed_Hours__c</columns>
        <columns>Ongoing__c</columns>
        <columns>Display_on_Website__c</columns>
        <columns>Inactive__c</columns>
        <filterScope>Everything</filterScope>
        <label>All Jobs</label>
    </listViews>
    <listViews>
        <fullName>Available_Jobs</fullName>
        <columns>NAME</columns>
        <columns>Campaign__c</columns>
        <columns>Externally_Visible__c</columns>
        <columns>Number_of_Volunteers_Still_Needed__c</columns>
        <columns>Number_of_Completed_Hours__c</columns>
        <columns>Ongoing__c</columns>
        <columns>Inactive__c</columns>
        <filterScope>Everything</filterScope>
        <filters>
            <field>Inactive__c</field>
            <operation>notEqual</operation>
            <value>1</value>
        </filters>
        <label>Available Jobs</label>
    </listViews>
    <listViews>
        <fullName>Jobs_Feedback_to_Monash</fullName>
        <columns>NAME</columns>
        <columns>Campaign__c</columns>
        <columns>Number_of_Volunteers__c</columns>
