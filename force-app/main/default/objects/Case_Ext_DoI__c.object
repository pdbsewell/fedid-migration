    </fields>
    <fields>
        <fullName>CE_Name__c</fullName>
        <description>Alternative field to the auto number</description>
        <externalId>false</externalId>
        <formula>HYPERLINK(&apos;/&apos;+Id, CE_Enquiry__r.CaseNumber + &apos;/&apos; + text(CE_Enquiry__r.Category_Level_1__c) , &apos;_self&apos; )</formula>
