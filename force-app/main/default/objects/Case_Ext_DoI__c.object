                    <default>false</default>
                    <label>Foreign affiliations &amp; associations</label>
                </value>
                <value>
                    <fullName>Gifts, Benefits, &amp; Hospitality</fullName>
                    <default>false</default>
                    <label>Gifts, Benefits, &amp; Hospitality</label>
                </value>
                <value>
                    <fullName>Other Interests</fullName>
                    <default>false</default>
                    <label>Other Interests</label>
                </value>
                <value>
                    <fullName>Procurement</fullName>
                    <default>false</default>
                    <label>Procurement</label>
                </value>
