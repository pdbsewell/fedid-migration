    <fields>
        <fullName>CE_Enquiry__c</fullName>
        <description>Parent Enquiry for the declaration of interest record</description>
        <label>Enquiry</label>
        <lookupFilter>
            <active>true</active>
            <filterItems>
                <field>Case.RecordType.Name</field>
                <operation>equals</operation>
                <value>Declaration of Interest</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Case</referenceTo>
        <relationshipLabel>Case Extensions - DoI</relationshipLabel>
        <relationshipName>Declaration_of_Interest</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
