<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>A case status in which the &quot;clock should stop,&quot; i.e. time calculated in business hours should not be added to the &quot;Time With Support&quot; field. - moved from custom object (Stop Status)</description>
    <label>Case Stop Status</label>
    <pluralLabel>Case Stop Statuses</pluralLabel>
    <visibility>Public</visibility>
</CustomObject>
