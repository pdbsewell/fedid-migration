    </searchLayouts>
    <sharingModel>ControlledByParent</sharingModel>
    <validationRules>
        <fullName>Awarded_Amount_Validation</fullName>
        <active>true</active>
        <description>Awarded amount can only be populated during negotiation and close stage.</description>
        <errorConditionFormula>AND(
    NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c), 
    Awarded_Amount__c &gt; 0,
 
        NOT(ISPICKVAL(Opportunity__r.StageName, &apos;Negotiation/Review&apos;)),
        NOT(ISPICKVAL(Opportunity__r.StageName, &apos;Closed Won&apos;)),
        NOT(ISPICKVAL(Opportunity__r.StageName, &apos;Closed Lost&apos;))
   
)</errorConditionFormula>
        <errorDisplayField>Awarded_Amount__c</errorDisplayField>
        <errorMessage>Awarded Amount can only be populated when Opportunity stage is ‘Negotiation/Review’ or ‘Closed&apos;</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Primary_Funder_Validation</fullName>
        <active>true</active>
        <description>Only one primary funder allowed per opportunity</description>
        <errorConditionFormula>AND(NOT($Setup.Bypass_Mute_Request__c.Bypass_All_Validation_Rules__c), Opportunity__r.Primary_Funder_Count__c &gt; 0, OR(AND(ISCHANGED(Primary_Funder__c), Primary_Funder__c), AND(ISNEW(), Primary_Funder__c)))</errorConditionFormula>
        <errorMessage>A funding record already exists as a primary funder, uncheck the primary funder field to proceed</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
