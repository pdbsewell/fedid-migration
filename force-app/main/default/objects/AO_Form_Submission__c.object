    <recordTypes>
        <fullName>Monash_Abroad</fullName>
        <active>true</active>
        <label>Monash Abroad</label>
        <picklistValues>
            <picklist>AO_Status__c</picklist>
            <values>
                <fullName>Assigned</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Draft</fullName>
                <default>false</default>
            </values>
