    <validationRules>
        <fullName>AO_VALIDATE_Deadline_Date</fullName>
        <active>true</active>
        <description>Deadline Date on Form Submission should only be populated for Adhoc Forms</description>
        <errorConditionFormula>AND(OR(ISPICKVAL(AO_Program_Form_Map__r.AO_Sequence__c ,&apos;Primary&apos;), 
 ISPICKVAL(AO_Program_Form_Map__r.AO_Sequence__c ,&apos;Subsequent&apos;)), NOT(ISBLANK(AO_Deadline_Date__c ) ))</errorConditionFormula>
        <errorDisplayField>AO_Deadline_Date__c</errorDisplayField>
        <errorMessage>Deadline date should not be updated for Primary or Subsequent Form Submissions</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
