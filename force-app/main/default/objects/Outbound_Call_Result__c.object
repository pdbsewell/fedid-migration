        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Lead_Broad_area_s_of_interest__c</fullName>
        <businessStatus>Active</businessStatus>
        <complianceGroup>GDPR</complianceGroup>
        <description>Used bY SR Outbound Call Team.</description>
        <externalId>false</externalId>
        <formula>IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c, &quot;Art, Design and Architecture&quot; ), &quot;Art, Design and Architecture;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Arts, Humanities and Social Sciences&quot; ), &quot;Arts, Humanities and Social Sciences;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Business&quot; ), &quot;Business;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Education&quot; ), &quot;Education;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Engineering&quot; ), &quot;Engineering;&quot;,null )&amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Information Technology&quot; ), &quot;Information Technology;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Law&quot; ), &quot;Law;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Medicine, Nursing and Health Sciences&quot; ), &quot;Medicine, Nursing and Health Sciences;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;None&quot; ), &quot;None;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Pharmacy and Pharmaceutical Sciences&quot; ), &quot;Pharmacy and Pharmaceutical Sciences;&quot;,null ) &amp;
IF ( INCLUDES ( Case__r.Lead__r.Broad_area_s_of_interest__c , &quot;Science&quot; ), &quot;Science;&quot;,null )</formula>
        <label>Lead - Broad area(s) of interest</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
