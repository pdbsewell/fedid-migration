    <searchLayouts/>
    <sharingModel>Private</sharingModel>
    <validationRules>
        <fullName>Call_Result_Required_Call_Status_Closed</fullName>
        <active>true</active>
        <errorConditionFormula>IF(TEXT(Call_Status__c) = &apos;Closed&apos; &amp;&amp; ISBLANK(TEXT(Call_Result__c)), true, false)</errorConditionFormula>
        <errorDisplayField>Call_Result__c</errorDisplayField>
        <errorMessage>&quot;Call Result&quot; is required to mark &quot;Call Status&quot; as &quot;Closed&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Callback_On_Only_When_Callback_Requested</fullName>
        <active>true</active>
        <errorConditionFormula>IF(RecordType.DeveloperName == &apos;MonCon_Support&apos;, IF(TEXT(Call_Result__c) &lt;&gt; &apos;Callback Requested&apos; &amp;&amp; NOT(ISNULL(Callback_On__c)), TRUE, FALSE), FALSE)</errorConditionFormula>
        <errorMessage>&quot;Callback On&quot; can only be provided if &quot;Call Result&quot; is &quot;Callback Requested&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Callback_On_Rqd_On_Callback_Requested</fullName>
        <active>true</active>
        <errorConditionFormula>IF(RecordType.DeveloperName == &apos;MonCon_Support&apos;, IF(TEXT(Call_Result__c) = &apos;Callback Requested&apos; &amp;&amp; ISNULL(Callback_On__c), TRUE, FALSE), FALSE)</errorConditionFormula>
        <errorDisplayField>Callback_On__c</errorDisplayField>
        <errorMessage>&quot;Callback On&quot; must be provided if &quot;Call Result&quot; is &quot;Callback Requested&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Comments_Required_For_Follow_Up_Required</fullName>
        <active>true</active>
        <errorConditionFormula>IF(TEXT(Call_Result__c) = &apos;Follow-up Required&apos; &amp;&amp; ISBLANK(Comments__c), TRUE, FALSE)</errorConditionFormula>
        <errorMessage>&quot;Comments&quot; must be specified if &quot;Call Result&quot; is &quot;Follow-up Required&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Competitor_Name_Australia_Validation</fullName>
        <active>true</active>
        <description>for Campaign type= Domestic Post App 
Decision = Decline Offer
Reason For Decision = Plan to study at another institution
Preferred Study Destination = Other international destination

Competitor Name Australia should be blank</description>
        <errorConditionFormula>AND(
$Profile.Name = &quot;SR Base Profile&quot;,
$RecordType.Name = &quot;Domestic Post App&quot;,
ISPICKVAL(Decision__c, &quot;Decline Offer&quot;),
ISPICKVAL(Reason_For_Decision__c, &quot;Plan to study at another institution&quot;),
ISPICKVAL(Preferred_Study_Destination__c, &quot;Other international destination&quot;),
NOT(ISBLANK(TEXT(Competitor_Name__c)))
)</errorConditionFormula>
        <errorDisplayField>Competitor_Name__c</errorDisplayField>
        <errorMessage>Competitor Name Australia should be blank when Decision = Decline Offer, Reason For Decision = Plan to study at another institution and Preferred Study Destination = Other international destination</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Competitor_Name_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	OR(
		ISPICKVAL(Reason_For_Decision__c, &apos;Applying At Another Institution&apos;),
		ISPICKVAL(Reason_For_Decision__c, &apos;Accepted Offer At Another Institution&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;VIC&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;SA&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;NSW&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;TAS&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;QLD&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;WA&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;ACT&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;NT&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;Australia&apos;),
                ISPICKVAL(Preferred_Study_Destination__c, &apos;Undisclosed&apos;)
	),
	ISPICKVAL(Competitor_Name__c , &apos;&apos;)
)</errorConditionFormula>
        <errorDisplayField>Competitor_Name__c</errorDisplayField>
        <errorMessage>Please provide Competitor Name</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Competitor_Reason_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
    OR(
        ISPICKVAL(Reason_For_Decision__c, &apos;Applying At Another Institution&apos;),        
        ISPICKVAL(Reason_For_Decision__c, &apos;Accepted Offer At Another Institution&apos;)
        
    ),
    NOT(ISPICKVAL(Competitor_Reason__c, &apos;Study in Home Country&apos;)),
    ISPICKVAL(Competitor_Name__c , &apos;&apos;)
)</errorConditionFormula>
        <errorDisplayField>Competitor_Reason__c</errorDisplayField>
        <errorMessage>Please provide Competitor Reason</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Decision_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	RecordType.DeveloperName  &lt;&gt; &apos;MonCon_Support&apos;,
	ISPICKVAL(Call_Result__c, &apos;Yes&apos;),
	ISBLANK(TEXT(Decision__c))
)</errorConditionFormula>
        <errorDisplayField>Decision__c</errorDisplayField>
        <errorMessage>Please provide Decision</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Domestic_PlanToStudyAtAnotherInstitution</fullName>
        <active>true</active>
        <errorConditionFormula>IF(
	AND(
		RecordType.DeveloperName = &apos;Domestic_Post_App&apos;,
		TEXT(Reason_For_Decision__c) = &apos;Plan to study at another institution&apos;,
		OR(
			ISBLANK(TEXT(Competitor_Reason__c)),
			ISBLANK(TEXT(Preferred_Study_Destination__c))
		)
	),
	true,
	false
)</errorConditionFormula>
        <errorMessage>Competitor Reason and Preferred Study Destination are required if Reason For Decision is &quot;Plan to study at another institution&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Is_Archival_Allowed</fullName>
        <active>true</active>
        <errorConditionFormula>PRIORVALUE(Call_Status__c) != &apos;Open&apos; &amp;&amp; TEXT(Call_Status__c) = &apos;Archived&apos; &amp;&amp; $Permission.Archive_Record = false</errorConditionFormula>
        <errorMessage>You do not have permission to archive this record.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>MonCon_Risk_Category_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
            RecordType.DeveloperName = &apos;MonCon_Support&apos;,
            ISPICKVAL(Retention_Status__c, &apos;CoP&apos;) ||
            ISPICKVAL(Retention_Status__c, &apos;Declined Offer&apos;) ||
            ISPICKVAL(Retention_Status__c, &apos;Deferred Offer&apos;) ||
            ISPICKVAL(Retention_Status__c, &apos;Firm Discontinue&apos;) ||
            ISPICKVAL(Retention_Status__c, &apos;Firm Intermission&apos;) ||
            ISPICKVAL(Retention_Status__c, &apos;Still Deciding&apos;),
            ISBLANK(Risk_Category__c)
        )</errorConditionFormula>
        <errorDisplayField>Risk_Category__c</errorDisplayField>
        <errorMessage>Please provide &quot;Risk Category&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>MonCon_Support_Decision_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
                RecordType.DeveloperName = &apos;MonCon_Support&apos;,
                OR(
                    ISPICKVAL(Call_Result__c, &apos;Enquiry Created&apos;),
                    ISPICKVAL(Call_Result__c, &apos;No Follow-up Required&apos;)
                ),
                OR(ISBLANK(TEXT(Engagement_Type__c)), ISBLANK(TEXT(Retention_Status__c)))
            )</errorConditionFormula>
        <errorMessage>&quot;Engagement Type&quot; and &quot;Decision&quot; are required for Call Result &quot;Enquiry Created&quot; and &quot;No Follow-up Required&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Plan_To_Study_At_Another_Institution</fullName>
        <active>true</active>
        <errorConditionFormula>IF(
	AND(
		RecordType.DeveloperName = &apos;International_Post_App&apos;,
		TEXT(Reason_For_Decision__c) = &apos;Plan to study at another institution&apos;,
		OR(
			ISBLANK(TEXT(Competitor_Reason__c)),
			ISBLANK(TEXT(Preferred_Study_Destination__c)),
			AND(ISBLANK(TEXT(Competitor_Name__c)), ISBLANK(Competitor_Name_Other__c)),
			ISBLANK(TEXT(Preferred_Country_Of_Study__c))
		)
	),
	true,
	false
)</errorConditionFormula>
        <errorMessage>Competitor Reason, Preferred Study Destination, Preferred Country Of Study, and one of Competitor Name or Competitor Name Other are required if Reason For Decision is &quot;Plan to study at another institution&quot;.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Preferred_Country_of_Study</fullName>
        <active>true</active>
        <description>Preferred Country of Study for SR Business unit</description>
        <errorConditionFormula>AND(
RecordType.DeveloperName &lt;&gt; &apos;MonCon_Support&apos;,
ISPICKVAL(Competitor_Name__c, &apos;Overseas University&apos;),
ISBLANK(TEXT(Preferred_Country_Of_Study__c))
)</errorConditionFormula>
        <errorDisplayField>Preferred_Country_Of_Study__c</errorDisplayField>
        <errorMessage>Please provide Preferred Country of Study.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Provide_Competitor_Name</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
	OR(
		ISPICKVAL(Competitor_Name__c, &apos;Overseas University&apos;),
		ISPICKVAL(Competitor_Name__c, &apos;Other&apos;)
	),
	ISBLANK(Competitor_Name_Other__c)
)</errorConditionFormula>
        <errorDisplayField>Competitor_Name_Other__c</errorDisplayField>
        <errorMessage>Please provide Competitor Name</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Queue_Cannot_Edit_Call_Result</fullName>
        <active>true</active>
        <errorConditionFormula>IF
        (
        RecordType.DeveloperName = &apos;MonCon_Support&apos; &amp;&amp; Owner_Name__c = &apos;Outbound Call: Unassigned&apos; &amp;&amp; ISCHANGED(Call_Result__c),
        TRUE,
        FALSE
        )</errorConditionFormula>
        <errorMessage>Call Result cannot be changed for outbound calls assigned to &quot;Outbound Call: Unassigned&quot; queue.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Reason_For_Decision_Cannot_Be_Blank</fullName>
        <active>true</active>
        <errorConditionFormula>AND(
RecordType.DeveloperName &lt;&gt; &apos;MonCon_Support&apos;,
ISPICKVAL(Call_Result__c, &apos;Yes&apos;),
NOT(ISPICKVAL(Decision__c, &apos;Application Already Submitted&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;CoP&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;Decline Study Grant Offer&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;Educ Agent Will Follow-Up&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;Extension Request of Study Grant&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;November intake- will study online (from onshore)&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;November intake- will study online (from offshore)&apos;)) &amp;&amp;
NOT(ISPICKVAL(Decision__c, &apos;Other&apos;)),
ISBLANK(TEXT(Reason_For_Decision__c))
)</errorConditionFormula>
        <errorDisplayField>Reason_For_Decision__c</errorDisplayField>
        <errorMessage>Please provide Reason For Decision</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Reasons_Not_To_Study_Validation</fullName>
        <active>true</active>
        <description>Reasons Not To Study is compulsory when Campaign type= Domestic Post App, Decision = Decline Offer and Reason For Decision = Decided not to study at this time</description>
        <errorConditionFormula>AND(
$Profile.Name = &quot;SR Base Profile&quot;,
$RecordType.Name = &quot;Domestic Post App&quot;,
ISPICKVAL(Decision__c, &quot;Decline Offer&quot;),
ISPICKVAL(Reason_For_Decision__c, &quot;Decided not to study at this time&quot;),
(ISBLANK(TEXT(Reasons_Not_To_Study__c)))
)</errorConditionFormula>
        <errorDisplayField>Reasons_Not_To_Study__c</errorDisplayField>
        <errorMessage>Reasons Not To Study is compulsory when Decision = Decline Offer and Reason For Decision = Decided not to study at this time</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>Record_Type_Campaign_Type</fullName>
        <active>true</active>
        <errorConditionFormula>IF(
	OR(
		AND(
			RecordType.DeveloperName = &apos;Domestic_Post_App&apos;,
			Campaign__c != null,
			TEXT(Campaign__r.Type) != &apos;Domestic Post App&apos;
		),
		AND(
			RecordType.DeveloperName = &apos;Domestic_Pre_App&apos;,
			Campaign__c != null,
			TEXT(Campaign__r.Type) != &apos;Domestic Pre App&apos;
		),
		AND(
			RecordType.DeveloperName = &apos;International_Post_App&apos;,
			Campaign__c != null,
			TEXT(Campaign__r.Type) != &apos;International Post App&apos;
		),
		AND(
			RecordType.DeveloperName = &apos;International_Pre_App&apos;,
			Campaign__c != null,
			TEXT(Campaign__r.Type) != &apos;International Pre App&apos;
		)
	),
	true,
	false
)</errorConditionFormula>
        <errorMessage>Record type must align with campaign type for SRA outbound calls.</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
</CustomObject>
