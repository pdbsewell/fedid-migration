    <fields>
        <fullName>Mentor_Location__c</fullName>
        <description>The location of the job shadow host</description>
        <externalId>false</externalId>
        <formula>CreatedBy.City + &quot;,&quot;  + CreatedBy.State</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>The location of the job shadow host</inlineHelpText>
        <label>Mentor Location</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Mentor_Name__c</fullName>
        <description>The Job Shadow Host&apos;s name</description>
        <externalId>false</externalId>
