    <fields>
        <fullName>Total_Openings__c</fullName>
        <defaultValue>3</defaultValue>
        <description>The amount of available mentee slots the mentor has available.</description>
        <externalId>false</externalId>
        <inlineHelpText>The amount of available mentee slots the mentor has available.</inlineHelpText>
        <label>Total Openings</label>
        <precision>2</precision>
        <required>true</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Mentor</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>CREATEDBY_USER</columns>
        <columns>Mentor_Name__c</columns>
        <columns>Application_Status__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <label>Mentor Role</label>
        <trackHistory>false</trackHistory>
        <type>Text</type>
    </nameField>
    <pluralLabel>Mentors</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
