        <fullName>Number_of_Mentees_Accepted__c</fullName>
        <label>Number of Mentees_Accepted</label>
        <summaryFilterItems>
            <field>Mentee__c.Application_Status__c</field>
            <operation>equals</operation>
            <value>Approved</value>
        </summaryFilterItems>
        <summaryForeignKey>Mentee__c.Mentor__c</summaryForeignKey>
        <summaryOperation>count</summaryOperation>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
