    <validationRules>
        <fullName>Record_Type_is_Requested</fullName>
        <active>true</active>
        <errorConditionFormula>AND(ISNEW(), RecordType.Name = &apos;Requested&apos;)</errorConditionFormula>
        <errorMessage>To create a new document request you must start in &apos;Draft&apos; status on the previous page</errorMessage>
    </validationRules>
    <visibility>Public</visibility>
    <webLinks>
        <fullName>Send_Email</fullName>
        <availability>online</availability>
        <displayType>button</displayType>
        <linkType>javascript</linkType>
        <masterLabel>Send Email</masterLabel>
        <openType>onClickJavaScript</openType>
        <protected>false</protected>
        <url>{!REQUIRESCRIPT(&quot;/soap/ajax/64.0/connection.js&quot;)} 

var p = new sforce.SObject(&apos;Document_Requested__c&apos;); 
p.id = &quot;{!Document_Requested__c.Id}&quot;; 
p.Document_Request_Status__c = &quot;Requested&quot;; 
result = sforce.connection.update([p]); 
location.reload(true);</url>
    </webLinks>
</CustomObject>
