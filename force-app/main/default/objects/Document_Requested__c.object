        <fullName>Comments__c</fullName>
        <label>Comments</label>
        <length>10000</length>
        <trackFeedHistory>false</trackFeedHistory>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>DR__c</fullName>
        <externalId>false</externalId>
        <formula>IF(INCLUDES( Documents_Requested__c, &quot;ACCEPT-ADM&quot;), &quot;Course offer acceptance document&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;APTTESTRES&quot;), &quot;Results of aptitude test&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;CREDITAPPL&quot;), &quot;Credit application&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;CV_SUPPDOC&quot;), &quot;Resume/Curriculum vitae&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;DIPDEGCERT&quot;), &quot;Diploma or degree certificate&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;EMPREFRNCE&quot;), &quot;Employment reference&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;ENGMEDINST&quot;), &quot;Proof of English language medium of instruction&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;FOLIO_ITEM&quot;), &quot;Image of artwork for art and design folio&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;GRD_DEG&quot;), &quot;Previous degrees - graduation&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;GRD_NAME&quot;), &quot;Official name change - graduation&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;HDR-APPL&quot;), &quot;HDR application summary&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;HDR-OFFER&quot;), &quot;HDR offer letter&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;IELTSTOEFL&quot;), &quot;Results of English language test&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;OTHERDCTYP&quot;), &quot;Other document type not listed&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PARENT_GUARDIAN&quot;), &quot;Parental Consent&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PORTFOLIO&quot;), &quot;Learning portfolio&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PRFEMPLMNT&quot;), &quot;Proof of employment&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PRFPROFREG&quot;), &quot;Proof of Professional Registration&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PRF_ID&quot;), &quot;Proof of citizenship/residency or identity&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;PRF_NAME&quot;), &quot;Proof of change of name&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;SCHPREDRES&quot;), &quot;Results forecast from secondary school&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;SECSCH_RES&quot;), &quot;Results from secondary school&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;STMTOFPRPS&quot;), &quot;Statement of purpose&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;TERTED_TRA&quot;), &quot;Results from tertiary studies&quot; + BR() , NULL) +
IF(INCLUDES( Documents_Requested__c, &quot;UNITOUTLNE&quot;), &quot;Unit outline from tertiary studies&quot; + BR() , NULL)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Document Requested</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
