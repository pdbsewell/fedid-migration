<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>List</customSettingsType>
    <description>CaseTrigger and EmailMessageTrigger will only fire on these list of Case Record Types</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>API_Name__c</fullName>
        <description>Case Record Type Label (NOT the Name)</description>
        <externalId>false</externalId>
        <inlineHelpText>Case Record Type Label</inlineHelpText>
        <label>API Name</label>
        <length>100</length>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>RecordTypes Allowed on CaseTrigger</label>
    <visibility>Public</visibility>
</CustomObject>
