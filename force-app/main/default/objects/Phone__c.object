    <fields>
        <fullName>Aligned__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>System indicator - Are the Phone contact and the Channel contact the same record?

Introduced to assist in finding issues created by contact merge.

Will show true for Phone records not linked to Channels.</description>
        <formula>BLANKVALUE(Channel__r.Contact__c, Contact__c) == Contact__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <inlineHelpText>Channel and Phone Contact records align</inlineHelpText>
        <label>Aligned</label>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Callista_address_type__c</fullName>
        <description>The address type as defined in Callista</description>
        <externalId>false</externalId>
        <formula>TEXT(Channel__r.Type__c)</formula>
        <label>Callista Address Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Callista_rollup_rank__c</fullName>
        <description>The ranking of Callista address types used to prioritise which types should take priority for a rollup of Callista addresses. A lower value indicates a higher priority than a higher value</description>
        <externalId>false</externalId>
        <formula>CASE(Callista_address_type__c,
&quot;GRADUATION-APPL&quot;, &quot;00&quot;,
&quot;POSTAL&quot;, &quot;10&quot;,
&quot;POSTAL-EXT&quot;, &quot;20&quot;,
&quot;OS-POSTAL&quot;, &quot;30&quot;,
&quot;HOME&quot;, &quot;40&quot;,
&quot;OS-HOME&quot;, &quot;50&quot;,
&quot;MAILING&quot;, &quot;60&quot;,
&quot;AP-EMAIL&quot;, &quot;70&quot;,
&quot;&quot;)</formula>
        <label>Callista Rollup Rank</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Channel_Link__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>A link to the descriptive channel name field rather than the auto-number</description>
        <externalId>false</externalId>
        <formula>Channel__r.Channel_Link__c</formula>
        <label>Channel</label>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Channel__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Channel lookup field for the Contact Point object record</description>
        <label>Channel</label>
        <lookupFilter>
            <active>true</active>
            <errorMessage>Phone channels must be for the same Contact record</errorMessage>
            <filterItems>
                <field>Channel__c.Contact__c</field>
                <operation>equals</operation>
                <valueField>$Source.Contact__c</valueField>
            </filterItems>
            <filterItems>
                <field>Channel__c.Type__c</field>
                <operation>notEqual</operation>
                <value>EMERCONT</value>
            </filterItems>
            <isOptional>false</isOptional>
        </lookupFilter>
        <referenceTo>Channel__c</referenceTo>
        <relationshipLabel>Phones</relationshipLabel>
        <relationshipName>Phones</relationshipName>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Classification__c</fullName>
        <description>Defines how the phone number is classified, i.e. in which context it is used.
 Classification of the phone which is used to roll-up the phone number to the Contact, if certain conditions are met.</description>
        <inlineHelpText>Please provide a classification of the phone number</inlineHelpText>
        <label>Classification</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Contact_Point_Classification</valueSetName>
        </valueSet>
    </fields>
    <fields>
        <fullName>Contact__c</fullName>
        <description>Relationship to Contact.</description>
        <inlineHelpText>Please provide the contact record this phone number is linked to.</inlineHelpText>
        <label>Contact</label>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>Phone Numbers</relationshipLabel>
        <relationshipName>Phones</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>true</reparentableMasterDetail>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Country_Code__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The country code stored separately from the phone number, which will also include this value.

Populated as a result of formatting, it will not affect the building of the phone number itself.</description>
        <externalId>false</externalId>
        <inlineHelpText>International country code that was identified when phone formatting was applied</inlineHelpText>
        <label>Country Code</label>
        <length>6</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Country__c</fullName>
        <businessStatus>Active</businessStatus>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Populated as a result of successfully being matched against a PHONE_NUMBER_FORMAT system setting regular expression.</description>
        <inlineHelpText>The country regex the phone number was successfully formatted against.</inlineHelpText>
        <label>Country</label>
        <referenceTo>Country_Attribute__c</referenceTo>
        <relationshipLabel>Phones</relationshipLabel>
        <relationshipName>Phones</relationshipName>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>End_Date__c</fullName>
        <description>This defines the date until the phone number is valid for.</description>
        <inlineHelpText>Please provide the date the phone number is valid through, or leave it empty if it is not known or not end dated.</inlineHelpText>
        <label>End Date</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>External_System_ID__c</fullName>
        <caseSensitive>true</caseSensitive>
        <description>Unique ID used to identify records in an external system.</description>
        <externalId>true</externalId>
        <inlineHelpText>Unique ID used to identify records in an external system.</inlineHelpText>
        <label>External System ID</label>
        <length>100</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>ISO_Country__c</fullName>
        <description>The ISO name of the linked Country</description>
        <externalId>false</externalId>
        <formula>TEXT(Country__r.Country__c)</formula>
        <inlineHelpText>The ISO name of the linked Country</inlineHelpText>
        <label>ISO Country</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Is_Active__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Indicates whether a phone number is active, usually when end date is in the past or the start date is in the future. This value Is automatically (by a scheduled process) set to &quot;false&quot; if End_Date__c is populated and in the past or the Start_Date__c is in the future.
If manually set/changed to &quot;True&quot; (&quot;False&quot;), then the End_Date__c is automatically removed (added with the current date).</description>
        <inlineHelpText>Please indicate whether the phone number is active or not (inactive).</inlineHelpText>
        <label>Active</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Deleted__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>A soft delete flag on the record. 

An overnight purge process removes the record.</description>
        <inlineHelpText>Soft deleted, queued for purging</inlineHelpText>
        <label>Deleted</label>
        <securityClassification>Public</securityClassification>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Is_Primary__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Global primary (by Contact), as such only a single Phone__c record can be flagged as primary per Contact Lookup.
If selected manually, all other records (for the Contact) will be marked as non-primary (false)
If none are selected, the entry with the latest Start_Date__c will be automatically marked as primary.</description>
        <inlineHelpText>Please indicate whether the phone number is primary for this Contact.</inlineHelpText>
        <label>Primary</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Key_UID__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>System Field - Unique Key Combination field</description>
        <externalId>true</externalId>
        <inlineHelpText>System Field - Unique Key Combination field</inlineHelpText>
        <label>Key UID</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>Primary_set_by__c</fullName>
        <description>Use as indicator if the record (only if Is_Primary__c changed) has been modified by user or system.</description>
        <externalId>false</externalId>
        <label>Primary set by</label>
        <length>80</length>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Source__c</fullName>
        <description>Source of the phone number.</description>
        <inlineHelpText>Please enter source of the phone number, i.e. how were the details obtained.</inlineHelpText>
        <label>Source</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Contact_Point_Source</valueSetName>
        </valueSet>
    </fields>
    <fields>
        <fullName>Start_Date__c</fullName>
        <description>The date the phone number is valid from.</description>
        <inlineHelpText>Please provide a date indicating the valid from for the phone number</inlineHelpText>
        <label>Start Date</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>TimeZone__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Time zone of the linked Country</description>
        <externalId>false</externalId>
        <formula>IF(ISBLANK(TEXT(Country__r.Time_Zone__c)), &apos;Australia/Sydney&apos;, TEXT(Country__r.Time_Zone__c))</formula>
        <label>TimeZone</label>
        <required>false</required>
        <securityClassification>Public</securityClassification>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Type__c</fullName>
        <description>Type of the phone number.

The order of the values is important as it drives some of the primary record selection behaviour.</description>
        <inlineHelpText>Please enter the phone number type</inlineHelpText>
        <label>Type</label>
        <required>true</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Mobile</fullName>
                    <default>false</default>
                    <label>Mobile</label>
                </value>
                <value>
                    <fullName>Landline</fullName>
                    <default>false</default>
                    <label>Landline</label>
                </value>
                <value>
                    <fullName>Assistant</fullName>
                    <default>false</default>
                    <label>Assistant</label>
                </value>
                <value>
                    <fullName>Fax</fullName>
                    <default>false</default>
                    <label>Fax</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
                <value>
                    <fullName>Undefined</fullName>
                    <default>true</default>
                    <label>Undefined</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Verification_Status__c</fullName>
        <description>Verification status of the record based from its source.</description>
        <label>Verification Status</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetName>Phone_Verification_Status</valueSetName>
        </valueSet>
    </fields>
    <label>Phone</label>
    <listViews>
        <fullName>All_Mobiles</fullName>
        <columns>Contact__c</columns>
        <columns>NAME</columns>
        <columns>Type__c</columns>
        <columns>Is_Primary__c</columns>
        <columns>Is_Active__c</columns>
        <columns>Start_Date__c</columns>
