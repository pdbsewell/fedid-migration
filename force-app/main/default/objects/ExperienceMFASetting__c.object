<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <customSettingsType>Hierarchy</customSettingsType>
    <description>Custom setting that controls Experience MFA configurations.</description>
    <enableFeeds>false</enableFeeds>
    <fields>
        <fullName>Autotest_Bypass_Key__c</fullName>
        <description>Field that holds the keyword that is used by autotest users to bypass MFA challenge screen</description>
        <externalId>false</externalId>
        <label>Autotest Bypass Key</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>Experience MFA Setting</label>
    <visibility>Public</visibility>
</CustomObject>
