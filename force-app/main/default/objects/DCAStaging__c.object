    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Staging object to track the records for post merge bulk async processing</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>BulkProcessed__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Flag to indicate whether the record has been bulk processed in the post-merge calculations.</description>
        <label>BulkProcessed</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>Counter__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Counter value to store the current record count which is to be bulk processed in the post-merge logic.</description>
        <externalId>false</externalId>
        <label>Counter</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>MergeAccount__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Flag to identify if account is merged</description>
        <label>MergeAccount</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>MergeContact__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Flag to identify if contact is merged</description>
        <label>MergeContact</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>MergeUser__c</fullName>
        <businessStatus>Active</businessStatus>
        <defaultValue>false</defaultValue>
        <description>Flag to identify if user is merged</description>
        <label>MergeUser</label>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>TotalContactsToBeBulkProcessed__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>The count of contact records to be bulk processed in the post-merge logic</description>
        <externalId>false</externalId>
        <label>TotalContactsToBeBulkProcessed</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>primaryContactId__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Primary Contact id</description>
        <externalId>true</externalId>
        <label>primaryContactId</label>
        <length>20</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>uniqueId__c</fullName>
        <businessStatus>Active</businessStatus>
        <description>Unique Identifier for a batch of contacts included in the DCA run</description>
        <externalId>true</externalId>
        <label>uniqueId</label>
        <length>50</length>
        <required>false</required>
        <securityClassification>Internal</securityClassification>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <label>DCAStaging</label>
    <listViews>
