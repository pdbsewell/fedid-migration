<!-- https://developer.salesforce.com/forums#!/feedtype=SINGLE_QUESTION_DETAIL&dc=Lightning&criteria=OPENQUESTIONS&id=9060G000000XieaQAC -->
<aura:component implements="forceCommunity:availableForAllPageTypes" access="global">
    <c:PORTAL_LightningMessageModals />
    <c:PORTAL_MessageHandlingService aura:id="MessageHandlingService" />
    
    <aura:attribute name="daysOfWeek" type="String[]"/>
    <aura:attribute name="week1" type="String"/>
    <aura:attribute name="month" type="String"/>
    <aura:attribute name="currentMonth" type="Date"/>
    <aura:attribute name="pickList" type="String[]"/>
    <aura:attribute name="selectedDept" type="String" default="Any"/>
    <aura:attribute name="selectedUser" type="String" default="Any"/>
    <aura:attribute name="listingList" type="Object[]"/>
    
    <aura:attribute name="inputEventName" type="String" default="GoogleMapEvent" access="global"/>    
    <aura:handler event="c:PORTAL_EVT_Calendar" action="{!c.listingListChanged}"/>      
    
    <aura:attribute name="options" type="List"/>
    <aura:attribute name="selectedOption" type="String"/>
    <aura:attribute name="beginningYear" type="String"/>
    <aura:attribute name="endingYear" type="String"/>
    <aura:attribute name="disableLastMonthButton" type="Boolean" default="false" />
    <aura:attribute name="disableNextMonthButton" type="Boolean" default="false" />
 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <div class="slds-box slds-datepicker">
 
    <div class="slds-grid slds-page-header" role="banner">
        <div class=" slds-size--1-of-12 slds-align--absolute-center"> <lightning:buttonIcon name="lastMonth" alternativeText="Back" iconName="utility:chevronleft" disabled="{!v.disableLastMonthButton}" onclick="{!c.lastMonth}"/> </div>
   	    <div class=" slds-size--4-of-12 slds-align--absolute-center"> <b>{!v.month} </b></div>
        <div class=" slds-size--1-of-12 slds-align--absolute-center">  <lightning:buttonIcon name="nextMonth" alternativeText="Back" iconName="utility:chevronright" disabled="{!v.disableNextMonthButton}" onclick="{!c.nextMonth}"/> </div>
        <div class=" slds-size--7-of-12 slds-align--absolute-center"> 
            <lightning:combobox name="year" value="{!v.selectedOption}" options="{!v.options}" variant="label-hidden" onchange="{! c.handleYearChange }"/>
    	</div>
        
    </div>
    
    <table aria-labelledby="month" aria-multiselectable="true" class="slds-datepicker__month" role="grid">
        <thead>
            <tr class="slds-text-title--caps">
                <aura:iteration items="{!v.daysOfWeek}" var="day">
                    <th class="slds-cell-shrink" scope="col" style="text-align: center;"><b>{!day}</b> </th>
                </aura:iteration>
            </tr>
        </thead>
        <tbody>
            {!v.body}
            
        </tbody>
    </table>
    <div class="slds-p-top_medium">
            <div class=" slds-size--1-of-12 slds-align--absolute-center"> </div>
            <div class=" slds-size--9-of-12 slds-align--absolute-center"> <b><a href="" onclick="{!c.todayClicked}" >Today</a></b></div>
            <div class=" slds-size--1-of-12 slds-align--absolute-center"> </div>
            <div class=" slds-size--1-of-12 slds-align--absolute-center">   </div>      
        </div>
    </div>
</aura:component>