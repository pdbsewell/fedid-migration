<aura:component implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" 
                controller="asmAlertsApplicationCC"
                access="global" >

    <aura:attribute name="applicationId" type="Id" default=""/>

    <aura:attribute name="anyAlerts" type="Boolean" default="false"/>
    <aura:attribute name="isUnder18AtApplication" type="Boolean" default=""/>
    <aura:attribute name="hasEncumbrances" type="Boolean" default=""/>
    <aura:attribute name="applicationFeePaid" type="Boolean" default="true"/>    
    <aura:attribute name="gteAlertSubmissionLocation" type="Boolean" default=""/>
    <aura:attribute name="gteAlertQualification" type="Boolean" default=""/>
    <aura:attribute name="creditIntention" type="Boolean" default=""/>
    <aura:attribute name="taskQualification" type="Boolean" default=""/>
    <aura:attribute name="taskVisa" type="Boolean" default=""/>    
    <aura:attribute name="hasAccessEquity" type="Boolean" default=""/>
    <aura:attribute name="admkey" type="Boolean" default=""/>

    <!-- loading variable -->
    <aura:attribute name="showComponentLoader" type="Boolean" default="true"/>

    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <lightning:card footer="" title="Alerts" iconName="action:priority">
        <!-- card body -->
        <p class="slds-border_top">
            <!-- show spinner -->
            <aura:if isTrue="{!v.showComponentLoader}">
                <div class="slds-is-relative" style="min-height: 75px;">
                    <lightning:spinner alternativeText="Loading" size="medium" variant="brand" />
                </div>
            </aura:if>        
            <!-- show content / hide spinner -->
            <aura:if isTrue="{!!v.showComponentLoader}">
                <aura:if isTrue="{!v.anyAlerts}">
                    <!-- alerts -->
                    <lightning:layout multipleRows="true" class="slds-p-horizontal_small slds-p-top_medium">                        
                        <aura:if isTrue="{!v.hasEncumbrances}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="Active Encumbrances"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>

                        <aura:if isTrue="{!v.applicationFeePaid != true}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="Application Fee Not Reconciled"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>

                        <aura:if isTrue="{!v.taskVisa}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="Visa Check Task Pending/Failed"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>

                        <aura:if isTrue="{!v.taskQualification}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="Qualification Task(s) not completed"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>  
                        <aura:if isTrue="{!v.gteAlertSubmissionLocation}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="GTE (Submission Location)"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>
                        <aura:if isTrue="{!v.gteAlertQualification}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="GTE (Qualification)"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>
                        <aura:if isTrue="{!v.creditIntention}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="Credit (Advanced Standing) Application"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>
                        <aura:if isTrue="{!v.admkey}">
                            <lightning:layoutItem>
                                <div class="slds-m-bottom_small slds-m-horizontal_xx-small">
                                    <lightning:badge class="badge_red_notification" label="An ACP here has not been created in Callista"/>
                                </div>
                            </lightning:layoutItem>
                        </aura:if>
                    </lightning:layout>

                    <aura:set attribute="else">
                        <p class="slds-p-horizontal_small slds-p-top_x-small slds-text-color_success">
                            No Alerts for this Application.
                        </p>
                    </aura:set>
                </aura:if>
            </aura:if>
        </p>
    </lightning:card>

    <div></div>

</aura:component>