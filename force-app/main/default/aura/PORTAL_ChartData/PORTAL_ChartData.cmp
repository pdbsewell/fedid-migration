<!-- This component is used to start the query to get data to initialize PORTAL_Chart.cmp -->

<aura:component implements="forceCommunity:availableForAllPageTypes" controller="PORTAL_ChartDataController" access="global">
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <aura:registerEvent name="PORTAL_EVT_Chart" type="c:PORTAL_EVT_Chart"/>

</aura:component>