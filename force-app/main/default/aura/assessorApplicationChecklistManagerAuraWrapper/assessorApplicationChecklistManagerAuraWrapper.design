<design:component >
    <design:attribute name="fileColumnCount" label="File Column Count" default="1" datasource="1,2" description='Columns count for the files shown by the checklist' />
    <design:attribute name="viewType" label="View Type" datasource="Application,Application Course Preference" description="Object page where the component is shown" />
    <design:attribute name="prioritizeOther" label="Prioritize Other?" default="false" description="Other section should be shown at the top" />
    <design:attribute name="showHeader" default="true" label="Show Header" description="Header section is shown" />
    <design:attribute name="showNew" default="true" label="Show New" description="New Checklist button is shown" />      
    <design:attribute name="showDocumentReminder" default="true" label="Show Document Reminder" description="Document Reminder button is shown" />  
</design:component>