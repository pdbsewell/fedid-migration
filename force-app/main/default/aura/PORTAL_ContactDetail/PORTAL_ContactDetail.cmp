<aura:component implements="forceCommunity:availableForAllPageTypes,force:hasRecordId" controller="PORTAL_DirectoryController" access="global">
    
    <aura:attribute name="department" type="String" access="public"/>
    <aura:attribute name="major" type="String" access="public"/>
    
    <aura:attribute name="contact" type="Contact" 
                    default="{ 'sobjectType': 'Contact' }" access="public"/>
    
    <aura:attribute name="myContact" type="Contact" 
                    default="{ 'sobjectType': 'Contact' }" access="public"/>    
    
    <lightning:overlayLibrary aura:id="overlaySendDirectMessage"/>
    
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>   
    <lightning:card title="Alumni Information">
        <div class="slds-grid slds-wrap">
            <div class="slds-col slds-size_6-of-12">
                <div class="slds-form-element slds-p-left_medium slds-p-bottom_x-small">
                    <label class="slds-form-element__label">Name</label>
                    <div class="slds-form-element__control">
                        <ui:outputText value="{!v.contact.Name}"/>
                    </div>
                </div>
            </div>
            <div class="slds-col slds-size_6-of-12">
                <div class="slds-form-element slds-p-left_medium slds-p-bottom_x-small">
                    <label class="slds-form-element__label">Class Year</label>
                    <div class="slds-form-element__control">
                        <ui:outputText value="{!v.contact.ucinn_ascendv2__Preferred_Class_Year__c}"/>
                    </div>
                </div>
            </div>
            <div class="slds-col slds-size_6-of-12">
                <div class="slds-form-element slds-p-left_medium slds-p-bottom_x-large">
                    <label class="slds-form-element__label">Department</label>
                    <div class="slds-form-element__control">
                        <ui:outputText value="{!v.department}"/>
                    </div>
                </div>
            </div>
            <div class="slds-col slds-size_6-of-12">
                <div class="slds-form-element slds-p-left_medium slds-p-bottom_x-large">
                    <label class="slds-form-element__label">Major</label>
                    <div class="slds-form-element__control">
                        <ui:outputText value="{!v.major}"/>
                    </div>
                </div>
            </div>
            
            <div class="slds-col slds-size_12-of-12">
                <div class="slds-form-element slds-p-left_medium slds-p-bottom_x-small">
                    <aura:if isTrue="{!v.contact.unknown_custom_field != null}">
                        <a href="{!v.contact.unknown_custom_field}">
                            <img style="width:40px;height:40px;" src="https://test.salesforce.com/icons/linkedin-black.png" class="social-media-image"/>
                        </a>
                    </aura:if>
                    <aura:if isTrue="{!v.contact.unknown_custom_field != null}">
                        <a href="{!v.contact.unknown_custom_field}">
                            <img style="width:40px;height:40px;" src="https://test.salesforce.com/icons/facebook-black.png" class="social-media-image"/>
                        </a>
                    </aura:if>
                    <aura:if isTrue="{!v.contact.unknown_custom_field != null}">
                        <a href="{!v.contact.unknown_custom_field}">
                            <img style="width:40px;height:40px;" src="https://test.salesforce.com/icons/twitter-black.png" class="social-media-image"/>
                        </a>
                    </aura:if>
                    <aura:if isTrue="{!v.contact.unknown_custom_field != null}">
                        <a href="{!v.contact.unknown_custom_field}">
                            <img style="width:40px;height:40px;" src="https://test.salesforce.com/icons/google-black.png" class="social-media-image"/>
                        </a>
                    </aura:if>
                    <aura:if isTrue="{!v.contact.unknown_custom_field != null}">
                        <a href="{!v.contact.unknown_custom_field}">
                            <img style="width:35px;height:35px;" src="{!$Resource.Instagram_Icon}" class="social-media-image"/>
                        </a>
                    </aura:if>
                </div>
            </div>
            
        </div>
    </lightning:card>
    
    <aura:if isTrue="{!v.contact.Id != v.myContact.Id}">
        <br></br>
        <lightning:layout>
            <lightning:layoutItem flexibility="auto">
                <lightning:button variant="brand" type="button" name="send-message" label="Send Message" onclick="{!c.sendMessage}"/>   
            </lightning:layoutItem>        
        </lightning:layout>
        <br></br>

    </aura:if>
    
</aura:component>