<aura:component controller="PORTAL_MentorListController" access="global">
    
    <c:PORTAL_LightningMessageModals />
    <c:PORTAL_MessageHandlingService aura:id="MessageHandlingService" />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />    
    
    <aura:attribute name="contact" type="Contact" 
                    default="{ 'sobjectType': 'Contact' }"/>
    
    <aura:attribute name="myStatus" type="String" default="" access="public"/>
    
    <aura:attribute name="item" type="Mentor__c" access="public"/>
    <aura:attribute name="menteeRecordId" type="String" access="public"/>
    <aura:attribute name="isInitDone" type="Boolean" default="false" access="public"/>
    
    <aura:attribute name="sharing" type="String" default="All" access="public"/>
    <aura:attribute name="relevance" type="String" default="All" access="public"/>
    
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    
    <aura:attribute name="sortedBy" type="String"/>
    <aura:attribute name="sortedDirection" type="String"/>
    <aura:attribute name="defaultSortDirection" type="String"/>
    
    <lightning:overlayLibrary aura:id="overlaySendDirectMessage"/>
    <lightning:overlayLibrary aura:id="overlayLibEditMentor"/>
    <lightning:overlayLibrary aura:id="overlayLibEditMentee"/>
    
    <aura:attribute name="recordError" type="String" access="private"/>
    <aura:attribute name="recordErrorMentee" type="String" access="private"/>
    
    <force:recordData aura:id="recordHandler"
                      recordId="{!v.item.Id}"
                      fields="Id"
                      targetError="{!v.recordError}" />
    
    <!-- Need isInitDone to make sure we get menteeRecordId first before creating component.  Otherwise, delete doesn't work. -->
    <aura:if isTrue="{!v.isInitDone}"> 
        <force:recordData aura:id="recordHandlerMentee"
                          recordId="{!v.menteeRecordId}"
                          fields="Id"
                          targetError="{!v.recordErrorMentee}" /> 
    </aura:if>
    
    <lightning:card>
        
        <aura:set attribute="title">
            <aura:if isTrue="{!v.sharing == 'My Request' }"> 
                <aura:if isTrue="{!v.myStatus == 'Approved' }"> 
                    <lightning:icon iconName="action:approval" alternativeText="Approved" title="Your request has been approved." size="x-small"/>
                </aura:if>
                <aura:if isTrue="{!v.myStatus == 'Declined' }"> 
                    <lightning:icon iconName="action:reject" alternativeText="Approved" title="Your request has been declined." size="x-small"/>
                </aura:if>
                <aura:if isTrue="{!v.myStatus == 'Submitted' }"> 
                    <lightning:progressIndicator currentStep="1" type="path" variant="base">
                        <lightning:progressStep label="Submitted" value="1"/>
                        <lightning:progressStep label="Approved/Declined" value="2"/>
                    </lightning:progressIndicator>
                </aura:if>
            </aura:if>
            <aura:if isTrue="{!v.sharing == 'Me' }"> 
                <aura:if isTrue="{!v.item.Application_Status__c == 'Approved' }"> 
                    <lightning:icon iconName="action:approval" alternativeText="Approved" title="Your request has been approved." size="x-small"/>
                </aura:if>
                <aura:if isTrue="{!v.item.Application_Status__c == 'Declined' }"> 
                    <lightning:icon iconName="action:reject" alternativeText="Approved" title="Your request has been declined." size="x-small"/>
                </aura:if>
                <aura:if isTrue="{!v.item.Application_Status__c == 'Submitted' }"> 
                    <lightning:progressIndicator currentStep="1" type="path" variant="base">
                        <lightning:progressStep label="Submitted" value="1"/>
                        <lightning:progressStep label="Approved/Declined" value="2"/>
                    </lightning:progressIndicator>
                </aura:if>

            </aura:if>            
        </aura:set>
        
        <aura:set attribute="actions">
            <aura:if isTrue="{!v.sharing == 'Me' }">
                <div class="slds-p-top_small">    
                    <lightning:button label="Edit" onclick="{!c.editMentorApplication}"/>
                    <lightning:button label="Delete" variant="destructive" onclick="{!c.handleDeleteMentorRecord}"/>
                </div>
            </aura:if>
            <aura:if isTrue="{!v.sharing == 'All' }"> 
                <lightning:button label="Apply" onclick="{!c.submitMenteeApplication}"/>
            </aura:if>
            <aura:if isTrue="{!v.sharing == 'My Request' }"> 
                <aura:if isTrue="{!v.myStatus == 'Approved' }"> 
                    <lightning:button label="Send Message" onclick="{!c.sendMessage}"/>
                    <aura:set attribute="else">
                        <div class="slds-p-top_small">                        
                            <lightning:button label="Edit" onclick="{!c.editMenteeApplication}"/>
                            <lightning:button label="Delete" variant="destructive" onclick="{!c.handleDeleteMenteeRecord}"/>
                        </div>
                    </aura:set>
                </aura:if>
            </aura:if>             
        </aura:set>   
        <lightning:recordViewForm recordId="{!v.item.Id}" objectApiName="Mentor__c">
            <lightning:layout horizontalAlign="center">
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Mentor_Name__c"/>
                </lightning:layoutItem>
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Is_Available__c"/>
                </lightning:layoutItem>
            </lightning:layout>
            
            <lightning:layout horizontalAlign="center">
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Name"/>
                </lightning:layoutItem>
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Job_Responsibilities__c"/>
                </lightning:layoutItem>
            </lightning:layout>
            
            <lightning:layout horizontalAlign="center">
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Mentoring_Category__c"/>
                </lightning:layoutItem>
                <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="6">
                    <lightning:outputField fieldName="Additional_Role_Details_and_Notes__c"/>
                </lightning:layoutItem>
            </lightning:layout>
            
        </lightning:recordViewForm>
        
        <aura:set attribute="footer">
            <aura:if isTrue="{!v.sharing == 'Me' }"> 
                <lightning:layout multipleRows="true" horizontalAlign="center">
                    <lightning:layoutItem padding="around-small" size="12">
                        
                        <lightning:datatable aura:id="menteeList"
                                             columns="{! v.columns }"
                                             data="{! v.data }"
                                             keyField="Id"
                                             hideCheckboxColumn="true"
                                             onsort="{! c.updateColumnSorting }"
                                             sortedBy="{!v.sortedBy}"  
                                             sortedDirection="{!v.sortedDirection}"
                                             defaultSortDirection="{!v.defaultSortDirection }"
                                             onrowaction="{!c.handleRowAction}" />
                        
                    </lightning:layoutItem>
                    
                    
                </lightning:layout>
            </aura:if>
        </aura:set>
        
    </lightning:card>
    <br></br>
    
    
    
    
</aura:component>