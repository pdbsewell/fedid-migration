<design:component label="PORTAL UCIN Listing Career">
    <design:attribute name="title" label="Title"/>
    <design:attribute name="recordTypeDeveloperName" label="Record Type" datasource="apex://PORTAL_UCIN_ListingRecordTypePickList"/>
    <design:attribute name="category" label="Category" datasource="apex://PORTAL_UCIN_ListingCategoryPickList"/>
    <design:attribute name="maxNumberOfRecords" label="Max. Number of Records" min="1" max="1000"/>
</design:component>