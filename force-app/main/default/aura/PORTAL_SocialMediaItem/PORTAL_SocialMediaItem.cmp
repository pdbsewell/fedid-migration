<aura:component implements="forceCommunity:availableForAllPageTypes" controller="PORTAL_MyProfileController">
	<aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="socialMedia" type="ucinn_ascendv2__Social_Media__c"/>

    <lightning:card title="{!v.socialMedia.ucinn_ascendv2__Platform__c}" iconName="standard:scan_card">
        <p class="slds-text-heading--medium slds-p-horizontal--small">
           Name: {!v.socialMedia.Name}
        </p>
        <p class="slds-p-horizontal--small">
           URL: {!v.socialMedia.ucinn_ascendv2__URL__c}
        </p>
    </lightning:card>
</aura:component>