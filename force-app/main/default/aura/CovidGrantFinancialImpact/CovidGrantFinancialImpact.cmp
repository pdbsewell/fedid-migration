<!--
* @author
* @date 08/04/2020
* @group Monash Connect
* @description Covid Grant Form - Financial Impacts
* @revision  - 08/04/2020 - Initial Create 
 -->
<aura:component>
    <aura:attribute name="covidGrantAmount" type="String" default=""/>
    <aura:attribute name="newCase" type="case" />

    <div>
        <!-- covid grant 5000 -->
        <aura:if isTrue="{!v.covidGrantAmount == '5000'}">
            <!-- Section Heading -->
            <h2><lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpacts}" /></h2>
            <!-- Description -->
            <p><lightning:formattedRichText value="{!$Label.c.CovidGrant5000FinancialImpactsBodyLine1}" /></p>
            <p><lightning:formattedRichText value="{!$Label.c.CovidGrant5000FinancialImpactsBodyLine2}" /></p>
        </aura:if>
        <!-- covid grant 7000 -->
        <aura:if isTrue="{!v.covidGrantAmount == '7000'}">
            <!-- Section Heading -->
            <h2><lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpacts}" /></h2>
            <!-- Description -->
            <p><lightning:formattedRichText value="{!$Label.c.CovidGrant7000FinancialImpactsBodyLine1}" /></p>
            <p><lightning:formattedRichText value="{!$Label.c.CovidGrant7000FinancialImpactsBodyLine2}" /></p>
        </aura:if>

        <!-- Description - Input Field -->
        <div class="sq-form-question">
            <table border="1">
                <tr style="font-size: 20px;">
                    <th class="slds-p-around_xx-small" style="width: 6%">
                    </th>
                    <th style="width: 47%">                        
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableHeaderType}" />
                    </th>
                    <th style="width: 47%">
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableHeaderExample}" />                        
                    </th>
                </tr>
                <!-- covid grant 7000 -->
                <aura:if isTrue="{!v.covidGrantAmount == '7000'}">
                    <tr>
                        <td style="vertical-align: top;">
                            <center style="margin-left: 5px;">
                                <lightning:input type="checkbox"
                                    value="{!v.newCase.TemporaryImpactLossOfIncome}"
                                    class="sq-form-field"
                                    checked="false"
                                    variant="label-hidden"
                                    onchange="{!c.handleImpactLossOfIncomeChange}"/>
                            </center>
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableLossOfIncome}" />
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableLossOfIncomeExample}" />                            
                        </td>
                    </tr>
                </aura:if>
                <tr>
                    <td style="vertical-align: top;">
                        <center style="margin-left: 5px;">
                            <lightning:input type="checkbox"
                                value="{!v.newCase.TemporaryImpactTechnology}"
                                class="sq-form-field"
                                checked="false"
                                variant="label-hidden"
                                onchange="{!c.handleImpactTechnologyChange}"/>
                        </center>
                    </td>
                    <td style="vertical-align: top;">
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTechnology}" />                        
                    </td>
                    <td style="vertical-align: top;">
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTechnologyExample}" />
                    </td>
                </tr>
                <tr>
                    <td style="vertical-align: top;">
                        <center style="margin-left: 5px;">
                            <lightning:input type="checkbox"
                                value="{!v.newCase.TemporaryImpactAccomodation}"
                                class="sq-form-field"
                                checked="false"
                                variant="label-hidden"
                                onchange="{!c.handleImpactAccomodationChange}"/>
                        </center>
                    </td>
                    <td style="vertical-align: top;">
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableAccommodation}" />                         
                    </td>
                    <td style="vertical-align: top;">
                        <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableAccommodationExample}" />                        
                    </td>
                </tr>

                <!-- covid grant 5000 -->
                <aura:if isTrue="{!v.covidGrantAmount == '5000'}">
                    <tr>
                        <td style="vertical-align: top;">
                            <center style="margin-left: 5px;">
                                <lightning:input type="checkbox"
                                    value="{!v.newCase.TemporaryImpactTravel}"
                                    class="sq-form-field"
                                    checked="false"
                                    variant="label-hidden"
                                    onchange="{!c.handleImpactTravelChange}"/>
                            </center>
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTravel}" />                   
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTravelExample}" />                        
                        </td>
                    </tr>
                </aura:if>
                <!-- covid grant 7000 -->
                <aura:if isTrue="{!v.covidGrantAmount == '7000'}">
                    <tr>
                        <td style="vertical-align: top;">
                            <center style="margin-left: 5px;">
                                <lightning:input type="checkbox"
                                    value="{!v.newCase.TemporaryImpactTravel}"
                                    class="sq-form-field"
                                    checked="false"
                                    variant="label-hidden"
                                    onchange="{!c.handleImpactTravelChange}"/>
                            </center>
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTravel7000}" />                        
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableTravelExample}" />                        
                        </td>
                    </tr>
                </aura:if>
                <!-- covid grant 5000 -->
                <aura:if isTrue="{!v.covidGrantAmount == '5000'}">
                    <tr>
                        <td style="vertical-align: top;">
                            <center style="margin-left: 5px;">
                                <lightning:input type="checkbox"
                                    value="{!v.newCase.TemporaryImpactFoodIncidentals}"
                                    class="sq-form-field"
                                    checked="false"
                                    variant="label-hidden"
                                    onchange="{!c.handleImpactFoodIncidentalsChange}"/>
                            </center>
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableFoodIncidentals}" />                            
                        </td>
                        <td style="vertical-align: top;">
                            <lightning:formattedRichText value="{!$Label.c.CovidGrantFinancialImpactsTableIncidentalsExample}" />                            
                        </td>
                    </tr>
                </aura:if>
            </table>
        </div>
    </div>
</aura:component>