<aura:component implements="forceCommunity:availableForAllPageTypes" access="global">

    <aura:attribute name="subject" type="String" default="" access="public"/>   
    <aura:attribute name="body" type="String" default="" access="public"/>   

    <aura:attribute name="contact" type="Contact" 
    				default="{ 'sobjectType': 'Contact' }" access="global"/>
        
	<lightning:overlayLibrary aura:id="overlaySendDirectMessage"/>      

    <aura:attribute name="showSpinner" type="Boolean" default="false" />

    <aura:if isTrue="{!v.showSpinner}">
        <lightning:spinner />
    </aura:if>


    <lightning:layout>
        <lightning:layoutItem flexibility="auto" padding="horizontal-small">
            <div class="slds-form-element">

                <div class="slds-form-element__control">
                    
                     <lightning:input name="input1" value="{! v.subject }" label="Subject" />
                </div>
            </div>
        </lightning:layoutItem>
    </lightning:layout>
    <lightning:layout>
        <lightning:layoutItem flexibility="auto" padding="horizontal-small">
            <div class="slds-form-element">
                <label class="slds-form-element__label">Body</label>
                <div class="slds-form-element__control">
                    <ui:inputTextArea aura:id="body" value="{!v.body}" rows="5"/>
                </div>
            </div>
        </lightning:layoutItem>           
    </lightning:layout>
    
    <lightning:layout>
        <lightning:layoutItem flexibility="auto" padding="around-small">
            <lightning:button variant="neutral" type="button" name="cancel" label="Cancel" onclick="{!c.cancel}"/>            
            <lightning:button variant="brand" type="button" name="send" label="Send" onclick="{!c.send}"/>
        </lightning:layoutItem>           
    </lightning:layout>
  
</aura:component>