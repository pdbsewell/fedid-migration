<aura:component >
    <!-- To identify if user is logged in or not -->
    <aura:attribute name="isAnonymousUser" type="Boolean" access="public" default="true"/>
    <aura:attribute name="giftTypeSelected" type="String" access="public" required="true"/>
    <aura:attribute name="designationRec" type="Object" access="public"/>
    <aura:attribute name="selectedDesignations" type="Object[]" access="public" required="true"/>
    <aura:attribute name="availableDesignations" type="Object[]" access="public" required="true"/>
    <aura:attribute name="tableIndexVar" type="Integer" access="public" default="-1" required="true"/>

    <aura:attribute name="designationOptions" type="Object[]" access="public" />

    <aura:registerEvent name="designationListItemEvent" type="c:PORTAL_EVT_ListItem"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="change" value="{!v.selectedDesignations}" action="{!c.selectedDesignationsChanged}"/>

    <tr>
        <td scope="row" data-label="Designation">
            <!-- Designation Picklist -->
            <ui:inputSelect multiple="false" aura:id="designationOptions" label="" change="{!c.designationChange}">
                <aura:iteration items="{!v.designationOptions}" var="designation">
                    <ui:inputSelectOption text="{!designation.Id}" label="{!designation.Name}"/>
                </aura:iteration>
            </ui:inputSelect>
        </td>

        <td scope="row" data-label="Description" class="ascend-data-label-padding-right">
            <div class="slds-truncate ascend-long-output-float-right-mobile" title="{!v.designationRec.ucinn_ascendv2__Designation_Name__c}">
                <ui:outputText value="{!v.designationRec.ucinn_ascendv2__Designation_Name__c}" class="slds-output" />
            </div>
        </td>

<!--        <aura:if isTrue="{!equals(v.isAnonymousUser, false)}"> -->
            <td scope="row">
                <lightning:buttonIcon title="Delete" iconName="utility:delete" onclick="{!c.deleteDesignation}" alternativeText="Delete" />
            </td>
<!--        </aura:if> -->
    </tr>
</aura:component>