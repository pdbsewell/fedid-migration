<!-- 
 @name MonashHeadLineComponent
 -->
<aura:component implements="forceCommunity:availableForAllPageTypes" controller="LightningMonashHeadLineController" access="global" >
    <aura:attribute name="firstName" type="string" required="false"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <div> 
    <section  class="Headline">
        <h1 class="headlineTitle">
            <span class="hline">
                <span class="uiOutputText" >Hello</span>{!v.firstName}, <span class="uiOutputText">{!$Label.c.Community_Hello_Message}</span>
            </span></h1>
    </section>
    </div>
</aura:component>