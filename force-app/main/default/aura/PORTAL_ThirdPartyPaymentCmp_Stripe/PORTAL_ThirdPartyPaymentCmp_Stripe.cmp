<aura:component >
    <aura:attribute name="thirdPartyPaymentData" type="Object" access="public"/>
    <aura:attribute name="amountToPayToday" type="Decimal" access="public"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <aura:method name="validateCreditCardInfomationSync" action="{!c.validateCreditCardInfomationSync}"/>
    <div class="slds-size_1-of-1">
        <fieldset class="slds-box slds-theme_default slds-container">
            <legend class="slds-text-heading_medium slds-p-vertical_x-small">
                <h1 class="slds-text-heading_medium">Credit Card Payment</h1>
            </legend>
            <div class="slds-align_absolute-center">
                <div class="slds-size_1-of-1 slds-medium-size_1-of-3 slds-large-size_1-of-4">
                    <div class="">
                        <ui:inputCurrency label="Amount Due Today: " labelClass="slds-text-title_caps slds-text-heading_small" class="" value="{!v.amountToPayToday}"  disabled="true"/>
                    </div>
                    <div class="slds-m-top_small">
                        <ui:inputText aura:id="stripeCreditCardFieldId" label="Credit Card Number: " labelClass="slds-text-title_caps slds-text-heading_small" class="" placeholder="#### #### #### ####" required="true" value="{!v.thirdPartyPaymentData.creditCardNumberStr}" blur="{!c.creditCardNumberChanged}"/>
                    </div>
                    <div class="slds-m-top_small">
                        <ui:inputText aura:id="stripeExpirationDateFieldId" label="Expiration Date: " labelClass="slds-text-title_caps slds-text-heading_small" class="" placeholder="MM/YY" required="true" value="{!v.thirdPartyPaymentData.exprDateStr}" blur="{!c.expirationDateChanged}"/>
                    </div>
                    <div class="slds-m-top_small">
                        <ui:inputText aura:id="stripeCcvFieldId" label="CVV: " labelClass="slds-text-title_caps slds-text-heading_small" class="" placeholder="" required="true" value="{!v.thirdPartyPaymentData.cvvStr}" blur="{!c.cvvChanged}"/>
                    </div>
                </div>
            </div>
        </fieldset>
    </div>
</aura:component>