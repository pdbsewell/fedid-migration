<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId" access="global">

    <aura:attribute name="recordId" type="String"/>
    <aura:attribute name="relatedListSettingName" type="String" default="RelatedList_UniCrmRelationship"/>

    <ucinn_ascendv2:RelatedList recordId="{!v.recordId}"
    							outsideAscendPackage = "true"
                    			relatedListSettingName="{!v.relatedListSettingName}"
                    />
</aura:component>