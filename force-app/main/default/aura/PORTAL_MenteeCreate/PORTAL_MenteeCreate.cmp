<aura:component implements="forceCommunity:availableForAllPageTypes" controller="PORTAL_MentorListController" access="global">
    
    <aura:attribute name="recordId" type="String" default="" access="public"/> 
    <aura:attribute name="mentorRecId" type="String" default="" access="public"/> 
    <aura:attribute name="contactId" type="String" default="" access="public"/> 
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
	<lightning:overlayLibrary aura:id="overlayLibMenteeCreate"/>

<!--
    <lightning:recordForm aura:id="myform"
                          recordId="{!v.recordId}"
                          objectApiName="Mentee__c"
                          layoutType="Full"
                          columns="2"
                          mode="edit"
                          onload="{!c.handleLoad}"
                          onsubmit="{!c.handleSubmit}"
                          onsuccess="{!c.handleSuccess}"
                          oncancel="{!c.handleCancel}" />
-->
    
     <lightning:recordEditForm aura:id="myform"
         recordId="{!v.recordId}"
         objectApiName="Mentee__c"
         onload="{!c.handleLoad}"
         onsubmit="{!c.handleSubmit}"
         onsuccess="{!c.handleSuccess}">

        <lightning:inputField fieldName="Topics_of_Interest__c" />
         
            <div class="slds-m-top_medium">
                <lightning:button type="button" name="cancel" label="Cancel" onclick="{!c.handleCancel}"/>
                <lightning:button variant="brand" type="submit" name="save" label="Save" />
            </div>         
         

    </lightning:recordEditForm>    
    
</aura:component>