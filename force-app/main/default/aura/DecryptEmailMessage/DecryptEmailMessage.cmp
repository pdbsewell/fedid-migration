<aura:component implements="force:lightningQuickActionWithoutHeader,force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,forceCommunity:availableForAllPageTypes,force:hasRecordId"
                access="global" controller="MCSensitiveEnquiryServices">
    
    <lightning:workspaceAPI aura:id="workspace" />
    <lightning:navigation aura:id="navigation"/>
    
    <aura:attribute name="showSpinner" type="Boolean" default="true" />
    <aura:attribute name="hasAccess" type="Boolean" default="false" />
    <aura:attribute name="noAccess" type="Boolean" default="false" />
    <aura:attribute name="decryptedData" type="String" />
	<aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <!-- spinner -->
    <aura:if isTrue="{!v.showSpinner}">
        <span>Decrypting...</span>
        <div class="backgroundInverse">
            <lightning:spinner alternativeText="Loading" variant="inverse">Decrypting...</lightning:spinner>
        </div>
    </aura:if>
    
    <!-- Has Access Content -->
    <aura:if isTrue="{!v.hasAccess}">
        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Decrypted Sensitive Information</h2>
        <div class="slds-border_top slds-m-top_x-small">
            <div class="row slds-m-top_x-small">
                <ui:outputTextArea aura:id="oTextarea" value="{!v.decryptedData}"/>
            </div>
            <div class="row slds-border_top slds-m-top_x-small"/>
        </div>
    </aura:if>
    
    <!-- No Access Content -->
    <aura:if isTrue="{!v.noAccess}">
        <h2 class="slds-text-heading_medium slds-hyphenate slds-m-top_x-small slds-align_absolute-center" style="height:5rem">Insufficient Access.</h2>
    </aura:if>
</aura:component>