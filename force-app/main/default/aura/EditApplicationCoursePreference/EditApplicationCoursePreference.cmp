<aura:component implements="force:lightningQuickAction,lightning:actionOverride,force:hasRecordId,lightning:isUrlAddressable" access="global">
    <!-- open subtab-->
    <lightning:workspaceAPI aura:id="workspace" />
    
    <!-- component variables -->
    <aura:attribute access="global" name="acpid" type="String" default="" />
    <aura:attribute access="global" name="intializetype" type="String" default="" />

    <!-- constructor -->
    <aura:handler name="init" value="{!this}" action="{!c.init}"/>

    <!-- add application course acpId wizard -->
    <aura:renderIf isTrue="{!v.acpid}">
        <c:editApplicationCoursePreferenceWizard acpId="{!v.acpid}" onrequestclose="{!c.closeFocusedTab}"/>
    </aura:renderIf>
</aura:component>