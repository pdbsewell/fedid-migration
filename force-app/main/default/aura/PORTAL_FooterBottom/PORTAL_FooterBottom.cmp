<aura:component description="footer" implements="forceCommunity:availableForAllPageTypes" access="global">
    <aura:attribute name="footer" type="String"	default="UC Innovation, Inc." access="global"/>
    <aura:attribute name="footerYear" type="String"	default="2019" access="global"/>
    
    <div class="slds-text-align_center"> 
        <lightning:layout>
            <lightning:layoutItem flexibility="auto" padding="around-large" size="12">
                <big>{!v.footerYear} {!v.footer}</big>
            </lightning:layoutItem>
        </lightning:layout>
        <br></br>
    </div>
</aura:component>