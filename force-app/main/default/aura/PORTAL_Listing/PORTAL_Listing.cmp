<aura:component implements="forceCommunity:availableForAllPageTypes" access="global">
    <aura:attribute name="baseUrl" type="String" default=""/>
    <aura:attribute name="listingList" type="Listing__c[]" />
    <aura:attribute name="listingListToDisplay" type="Listing__c[]" />    
    
    <aura:attribute name="displayMode" type="String" default="List" access="public"/>
    <aura:attribute name="recordType" type="String" default="Event" access="public"/>
    <aura:attribute name="scope" type="String" default="All" access="public"/>
    <aura:attribute name="sharing" type="String" default="All" access="public"/>
    <aura:attribute name="relevance" type="String" default="All" access="public"/>
    <aura:attribute name="showAttending" type="String" default="Yes" access="public"/>
    <aura:attribute name="enableSearch" type="String" default="Yes" access="public"/>
    
    <aura:attribute name="showAddress" type="String" default="Yes" access="public"/>
    <aura:attribute name="showCategory" type="String" default="Yes" access="public"/>
    
    <aura:attribute name="itemSize" type="String" default="ascend-portal-listing-item-large" access="public"/>
    <aura:attribute name="gridSize" type="String" default="slds-size_1-of-1" access="public"/>    
    
    <aura:attribute name="showStartDate" type="String" default="Yes" access="public"/>
    <aura:attribute name="showStartTime" type="String" default="Yes" access="public"/>
    <aura:attribute name="showEndDate" type="String" default="Yes" access="public"/>
    <aura:attribute name="showEndTime" type="String" default="Yes" access="public"/>
    
    <aura:attribute name="maxItems" type="String" default="10" access="public"/>
    <aura:attribute name="showMap" type="String" default="No" access="public"/>
    <aura:attribute name="headerImagePosition" type="String" default="Left" access="public"/>
    <aura:attribute name="portalZone" type="String" default="All" access="public"/>
    
    <aura:attribute name="itemsPerPage" type="Integer" default="2" />
    <aura:attribute name="previousButtonDisabled" type="Boolean" default="true" />
    <aura:attribute name="nextButtonDisabled" type="Boolean" default="false" />
    <aura:attribute name="totalNumberOfPages" type="Integer" />
    <aura:attribute name="currentPage" type="Integer" default="1" />   
    
    <aura:attribute name="outputEventName" type="String" default="GoogleMapEvent" access="global"/>
    
    <aura:attribute name="currentDate" type="String" default="" access="public"/>
    <aura:attribute name="searchText" type="String" default=""/>    
    
</aura:component>