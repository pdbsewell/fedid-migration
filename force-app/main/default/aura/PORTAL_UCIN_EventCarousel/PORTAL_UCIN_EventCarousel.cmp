<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" >
	
    <aura:attribute name="eventList" type="List"/>
    
    <div class="flex sm:hidden pb-2 flex-row shadow">
            	<div class="self-center py-2">
                    <div class="slds-carousel">
                        <div class="slds-carousel__stage">
                            
                            <!--To navigate through the carousel items decrement/increment the translate percentage by 100% per item  -->
                            
                            <div class="slds-carousel__panels" style="transform:translateX(-0%)">
                                
                                <!-- iterate through and replace eventList[0] with iteration variable -->
                                
                                <div id="content-id-01" class="w-full sm:w-full md:w-1/2 lg:w-1/3 bg-white pb-4 slds-carousel__panel" role="tabpanel" aria-hidden="true" aria-labelledby="indicator-id-01">
                                    <div class="w-full relative">
                                        <img src="{!$ContentAsset.03S4a00000000Gi}" class="w-full" />
                                        <h4 class="absolute text-xl bottom-0 max-w-3/4 px-4 py-2 text-white mb-4 bg-blue">{!v.eventList[0].Name}</h4>
                                    </div>
                                    <div class="p-4 relative">
                                        <div class="">
                                            <span class="font-bold uppercase pb-4">Date: </span><span> 
                                            <aura:if isTrue="{!not(empty(v.eventList[0].Start_Date_Time__c))}">
                                                <aura:if isTrue="{!not(empty(v.eventList[0].End_Date_Time__c))}">
                                                    <lightning:formattedDateTime value="{!v.eventList[0].Start_Date_Time__c}" day="numeric" month="short" weekday="short" hour="numeric" minute="2-digit" timeZone="Australia/Melbourne"/>
                                                    - 
                                                    <lightning:formattedDateTime value="{!v.eventList[0].End_Date_Time__c}" day="numeric" month="short" weekday="short" hour="numeric" minute="2-digit" timeZone="Australia/Melbourne"/>
                                                    <aura:set attribute="else">
                                                        <lightning:formattedDateTime value="{!v.eventList[0].Start_Date_Time__c}" day="numeric" month="short" weekday="short" hour="numeric" minute="2-digit" timeZone="Australia/Melbourne"/>
                                                    </aura:set>
                                                </aura:if>
                                            </aura:if>
                                            </span>
                                        </div>
                                        <div class="">
                                            <span class="w-full font-bold uppercase pb-4">Location: </span>
                                            <span>
                                                <aura:if isTrue="{!v.eventList[0].Online_Event__c}">
                                                    Online
                                                    <aura:set attribute="else">
                                                        <aura:if isTrue="{!v.eventList[0].Country__c == 'Australia'}">
                                                            <aura:if isTrue="{!not(empty(v.eventList[0].Street__c))}">
                                                                {!v.eventList[0].Street__c}
                                                            </aura:if>
                                                            <aura:if isTrue="{!not(empty(v.eventList[0].City__c))}">
                                                                <aura:if isTrue="{!not(empty(v.eventList[0].Street__c))}">
                                                                    , 
                                                                </aura:if>
                                                                {!v.eventList[0].City__c}
                                                            </aura:if>
                                                            <aura:set attribute="else">
                                                                <aura:if isTrue="{!not(empty(v.eventList[0].Street__c))}">
                                                                    {!v.eventList[0].Street__c}
                                                                </aura:if>
                                                                <aura:if isTrue="{!not(empty(v.eventList[0].Country__c))}">
                                                                    <aura:if isTrue="{!not(empty(v.eventList[0].Street__c))}">
                                                                        , 
                                                                    </aura:if>
                                                                    {!v.eventList[0].Country__c}
                                                                </aura:if>
                                                            </aura:set>
                                                        </aura:if>
                                                    </aura:set>
                                                </aura:if>
                                            </span>
                                        </div>
                                        <aura:unescapedHtml value="{!v.eventList[0].Body_Content__c}"/>
                                        
                                        <div style="padding-top:30px;">
                                            <a class="font-semibold border border-blue px-4 py-2 absolute right-0 bottom-0 mr-4 bg-white text-blue hover:text-blue ucin-button" href="{!v.eventList[0].Event_URL__c}" target="_blank">View more</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <ul class="slds-carousel__indicators" role="tablist">
                                <li class="slds-carousel__indicator" role="presentation">
                                    <a id="indicator-id-01" class="slds-carousel__indicator-action" href="javascript:void(0);" role="tab" tabindex="-1" aria-selected="false" aria-controls="content-id-01" title="Event 1">
                                    <span class="slds-assistive-text">Event  1</span>
                                    </a>
                                </li>
                                <li class="slds-carousel__indicator" role="presentation">
                                    <a id="indicator-id-02" class="slds-carousel__indicator-action slds-is-active" href="javascript:void(0);" role="tab" tabindex="0" aria-selected="true" aria-controls="content-id-02" title="Event 2">
                                    <span class="slds-assistive-text">Event 2</span>
                                    </a>
                                </li>
                                <li class="slds-carousel__indicator" role="presentation">
                                    <a id="indicator-id-03" class="slds-carousel__indicator-action" href="javascript:void(0);" role="tab" tabindex="-1" aria-selected="false" aria-controls="content-id-03" title="Event 3">
                                    <span class="slds-assistive-text">Event 3</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div> 
                </div>
            </div>
    
</aura:component>