<aura:component >
    <aura:attribute name="giftTypeSelected" type="String" access="public"/>
    <aura:attribute name="installmentRec" type="Object" access="public"/>
    <aura:attribute name="tableIndexVar" type="Integer" access="public" default="-1"/>

    <tr>
        <aura:if isTrue="{!v.giftTypeSelected == 'Pledge'}">
            <td scope="row" data-label="Designation" class="data-label-padding-right">
                <div class="slds-truncate long-output-float-right-mobile" title="{!v.installmentRec.ucinn_ascendv2__Designation__r.Name}">
                    <ui:outputText value="{!v.installmentRec.ucinn_ascendv2__Designation__r.Name}"/>
                </div>
            </td>
            <td scope="row" data-label="Amount">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Amount__c}">
                    <ui:outputCurrency value="{!v.installmentRec.ucinn_ascendv2__Amount__c}" />
                </div>
            </td> 
            <td scope="row" data-label="Expected Date">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Expected_Date__c}">
                    <ui:outputDate value="{!v.installmentRec.ucinn_ascendv2__Expected_Date__c}" />
                </div>
            </td>
        </aura:if>
        <aura:if isTrue="{!v.giftTypeSelected == 'PledgePayment'}">
            <td scope="row" data-label="Designation" class="data-label-padding-right">
                <div class="slds-truncate long-output-float-right-mobile" title="{!v.installmentRec.ucinn_ascendv2__Designation__r.Name}">
                    <ui:outputText value="{!v.installmentRec.ucinn_ascendv2__Designation__r.Name}"/>
                </div>
            </td>
            <td scope="row" data-label="Amount">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Amount__c}">
                    <ui:outputCurrency value="{!v.installmentRec.ucinn_ascendv2__Amount__c}" />
                </div>
            </td>
            <td scope="row" data-label="Remaining Amount">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Expected_Less_Payment_Amount_Formula__c}">
                    <ui:outputCurrency value="{!v.installmentRec.ucinn_ascendv2__Expected_Less_Payment_Amount_Formula__c}" />
                </div>
            </td>
            <td scope="row" data-label="Expected Date">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Expected_Date__c}">
                    <ui:outputDate value="{!v.installmentRec.ucinn_ascendv2__Expected_Date__c}" />
                </div>
            </td>
            <td scope="row" data-label="Gift Date">
                <div class="slds-truncate" title="{!v.installmentRec.ucinn_ascendv2__Gift_Date__c}">
                    <ui:outputDate value="{!v.installmentRecucinn_ascendv2__.Gift_Date__c}" />
                </div>
            </td>
        </aura:if>
    </tr>
</aura:component>