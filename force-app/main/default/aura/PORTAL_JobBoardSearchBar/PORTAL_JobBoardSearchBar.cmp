<aura:component >

    <aura:attribute name="searchType" type="String" default="anything" />
    <aura:attribute name="data" type="String" default="" />
    <aura:attribute name="enterKeyNotification" type="Boolean" default="true" />

    <div>
        <div class="slds-grid">
            <div class="slds-col slds-size_1-of-1 slds-large-size_10-of-12" style="margin-right: -33px;">
                <ui:inputText value="{!v.data}" keyup="{!c.inputKeyUp}" />
            </div>
            <div class="slds-col slds-size_1-of-1 slds-large-size_1-of-12" style="height: 25px; width: 25px; position: relative; top: 5px;">
                <aura:if isTrue="{!v.searchType == 'anything'}">
                    <lightning:icon iconName="utility:search" size="small" />
                </aura:if>
                <aura:if isTrue="{!v.searchType == 'location'}">
                    <lightning:icon iconName="utility:checkin" size="small" />
                </aura:if>
            </div>
        </div>
    </div>
 
</aura:component>