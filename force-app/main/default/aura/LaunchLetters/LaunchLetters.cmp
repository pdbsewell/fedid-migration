<!--
Author: Cartick Sub
Date: 11 August 2020, modified 1 October 2020
Description: URL addressable Aura component used to launch Lighting web component from detail page button
-->

<aura:component implements="lightning:isUrlAddressable">
    <aura:handler name="init" value="{!this}" action="{!c.initialize}"/>
    <aura:handler name="change" value="{!v.pageReference}" action="{!c.onPageReferenceChange}"/>
    <lightning:workspaceAPI aura:id="workspace" />
    
    <aura:attribute name="studentId" type="String"/>
    <aura:attribute name="contactId" type="String"/>       
    <c:studentLetterHub studentId="{!v.studentId}" contactId="{!v.contactId}"/>
</aura:component>