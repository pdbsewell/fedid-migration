<aura:component >
    <aura:attribute name="tributeRecList" type="Object[]" access="public"/>
    <aura:handler name="tributeListItemEvent" event="c:PORTAL_EVT_ListItem" action="{!c.tributeListItemEventHandler}" />

    <div class="slds-size_1-of-1">
        <fieldset class="slds-box slds-theme_default slds-container">
            <legend class="slds-text-heading_medium slds-p-vertical_x-small">
                <h1 class="slds-text-heading_medium">Tributes Information</h1>
            </legend>

            <table class="slds-table slds-table_bordered slds-table_striped slds-table_cell-buffer slds-table_fixed-layout slds-no-row-hover slds-max-medium-table_stacked-horizontal">
                <thead class="slds-text-heading_label">
                    <tr>
                        <th scope="col"><div class="slds-truncate" title="Tribute Type">Tribute Type</div></th>
                        <th scope="col"><div class="slds-truncate" title="Constituent">Constituent</div></th>
                        <th scope="col"><div class="slds-truncate" title="Tributee">Tributee</div></th>
                        <th scope="col"><div class="slds-truncate" title="Notify">Notify</div></th>
                        <th scope="col"><div class="slds-truncate" title="Address">Address</div></th>
                        <th scope="col"><div class="slds-truncate" title="Occasion">Occasion</div></th>
                        <th scope="col"><div class="slds-truncate" title="Action">Action</div></th>
                    </tr>
                </thead>
                <tbody>
                    <aura:iteration items="{!v.tributeRecList}" var="tributeRec" indexVar="i">
                        <c:PORTAL_TributeListItem tributeRec="{!tributeRec}"
                                                  tableIndexVar="{#i}" />
                    </aura:iteration>
                </tbody>
            </table>
            <ui:button class="slds-button slds-m-top_medium" buttonTitle="Add" label="Add" press="{!c.addTribute}"/>
        </fieldset>
    </div>
</aura:component>