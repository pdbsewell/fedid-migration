<design:component >
    <design:attribute name="allowDelete" label="Allow Delete" description="Setting this to true will allow the users to delete work experience records. You can enter either true or false. If you entered an invalid value, it will default to false." />
    <design:attribute name="isAppComponent" label="Is component under the parent application?" description="If this is set to true, the users will see the Application Work Experience Provided record list. Otherwise, you will see the list of Work Experience. You can enter either true or false. If you entered an invalid value, it will default to false." />
</design:component>