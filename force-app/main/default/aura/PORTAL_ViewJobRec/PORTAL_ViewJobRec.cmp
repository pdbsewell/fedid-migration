<aura:component access="global" controller="PORTAL_JobBoardController">

    <!-- <aura:handler name="init" value="{!this}" action="{!c.doInit}" /> -->
    
    <aura:attribute name="jobRecId" type="String" required="true" />

    <lightning:recordViewForm recordId="{!v.jobRecId}" objectApiName="Job__c">
        <div class="slds-box">
            
            <lightning:outputField fieldName="Description__c" />
            <br />

            <lightning:outputField fieldName="Qualification__c" />
            <br />

            <lightning:outputField fieldName="Desired_Skills__c" />
            <br />

            <lightning:outputField fieldName="Desired_Majors__c" />
            <br />

            <lightning:outputField fieldName="Position_Type__c" />
            <br />

            <lightning:outputField fieldName="Work_Hours_Per_Week__c" />
            <br />

            <lightning:outputField fieldName="Require_Work_Authorization__c" />
            <br />
        </div>
    </lightning:recordViewForm>


</aura:component>