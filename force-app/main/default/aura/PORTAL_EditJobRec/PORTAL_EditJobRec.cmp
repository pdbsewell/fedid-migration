<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" controller="PORTAL_JobBoardController">

    <!-- <aura:handler name="init" value="{!this}" action="{!c.doInit}" /> -->

    <aura:attribute name="jobRecId" type="String" required="true" />

    <aura:attribute name="disabled" type="Boolean" default="false" />
    <aura:attribute name="saved" type="Boolean" default="false" />
    <aura:attribute name="showSpinner" type="Boolean" default="true" />

    <aura:if isTrue="{!v.showSpinner}">
        <lightning:spinner />
    </aura:if>

    <aura:if isTrue="{!!v.saved}">
        <lightning:recordEditForm

            onload="{!c.handleLoad}"
            onsubmit="{!c.handleSubmit}"
            onsuccess="{!c.handleSuccess}"

            recordId="{!v.jobRecId}"
            objectApiName="Job__c">

            <!-- the messages component is for error messages -->
            <lightning:messages />
            <lightning:inputField fieldName="Description__c" />
            <lightning:inputField fieldName="Qualification__c" />
            <lightning:inputField fieldName="Desired_Skills__c" />
            <lightning:inputField fieldName="Desired_Majors__c" />
            <lightning:inputField fieldName="Position_Type__c" />
            <lightning:inputField fieldName="Work_Hours_Per_Week__c" />
            <lightning:inputField fieldName="Require_Work_Authorization__c" />

            <div class="slds-m-top_medium">
                <lightning:button disabled="{!v.disabled}" variant="brand" type="submit" name="save" label="Save" />
            </div>
        </lightning:recordEditForm>

        <aura:set attribute="else">
            <p>Saved!</p>
        </aura:set>
    </aura:if>

</aura:component>