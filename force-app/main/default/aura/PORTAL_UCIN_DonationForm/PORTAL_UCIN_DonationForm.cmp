<!--
  @description       : 
  @author            : Pramod V
  @group             : 
  @last modified on  : 06-21-2021
  @last modified by  : Pramod V
  Modifications Log 
  Ver   Date         Author     Modification
  1.0   06-21-2021   Pramod V   Initial Version
-->
<aura:component controller="PORTAL_UCIN_DonationController" implements="forceCommunity:availableForAllPageTypes" access="global" >
	<!--Input from Portal-->
	<aura:attribute name="showAmountChoice" type="Boolean" default="true"/>
    <aura:attribute name="selectedDonateFrequency" type="String" default="once"/>
    <aura:attribute name="selectedDonateAmount" type="Decimal" default="100"/>
    <aura:attribute name="selectedDesignation" type="String"/>
    <aura:attribute name="selectedDesignationId" type="String"/>
    <aura:attribute name="selectedDesignationLabel" type="String"/>
    <aura:attribute name="selectableDonateOnceAmounts" type="String" default="50|100|200"/>
    <aura:attribute name="selectableDonateMonthlyAmounts" type="String" default="50|100|200"/>
    <aura:attribute name="selectableDesignationIds" type="String"/>
    <aura:attribute name="defaultDesignationSFId" type="String"/>
    <aura:attribute name="defaultDesignationId" type="String"/>
    <aura:attribute name="defaultAppealCode" type="String"/>
    <aura:attribute name="giftTypeSelected" type="String" access="public"/> 
	<aura:attribute name="captchaResponseKey" type="String" access="public"/>
	<aura:attribute name="captchaBypassToken" type="String" access="public"/>
    <aura:attribute name="isOtherDesignationSelected" type="Boolean" default="false"/>
	<aura:attribute name="isAnonymousUser" type="Boolean" default="true"/>
    <aura:attribute name="donationFrequencyList" type="String[]"/>
    <aura:attribute name="donationFrequencies" type="String"/>
	<aura:attribute name="donationAmountList" type="Decimal[]"/>
    <aura:attribute name="countryOptionList" type="PORTAL_UCIN_DonationController.SelectOptionDetail[]"/>
    <aura:attribute name="salutationList" type="PORTAL_UCIN_DonationController.SelectOptionDetail[]"/>
    <aura:attribute name="errorMessageMap" type="Map"/>
	<aura:attribute name="designationList" type="Object[]"/>
	<aura:attribute name="showCaptcha" type="Boolean" default="true"/>
	<aura:attribute name="rateLimitKey" type="String"/>


	<aura:attribute name="isEditing" type="Boolean" default="true"/>
	
	<!--Backend objects-->
    <aura:attribute name="paymentChargeId" type="String" access="public"/>
    <aura:attribute name="constituentRec" type="Contact" access="public"/>
    <aura:attribute name="organizationRec" type="Account" access="public"/>
	
	<!--Button labels-->
    <aura:attribute name="submitButtonLabel" type="String" default="Donate"/>
    <aura:attribute name="btnSubmitLabel" type="String"/>
    <aura:attribute name="btnSubmitDisabled" type="Boolean" default="false"/>
	
	<!--Calculated values-->
    <aura:attribute name="isContactInfoLoaded" type="Boolean" default="false"/>
    <aura:attribute name="isGtmViewInvoked" type="Boolean" default="false"/>
	<aura:attribute name="isSecurityChallengePassed" type="Boolean" default="false"/>
	<aura:attribute name="loaded" type="Boolean" default="true" />

	<!-- Experian Attributes -->
	<aura:attribute name="readyForLoading" type="Boolean" default="false"/>
	<aura:attribute name="addressLine" type="String"/>
	<aura:attribute name="contactEmail" type="String"/>
	<aura:attribute name="contactPhone" type="String"/>
	<aura:attribute name="phoneVerification" type="String"/>
	<aura:attribute name="emailVerification" type="String"/>
	<aura:attribute name="phoneSavedCountry" type="String"/>

	<aura:attribute name="emailAddress" type="String"/>
	<aura:attribute name="emailVerificationStatus" type="String"/>
	<aura:attribute name="phoneNumber" type="String"/>
	<aura:attribute name="phoneVerificationStatus" type="String"/>
	<aura:attribute name="address1" type="String"/>
	<aura:attribute name="city" type="String"/>
	<aura:attribute name="state" type="String"/>
	<aura:attribute name="country" type="String"/>
	<aura:attribute name="postalcode" type="String"/>
	<aura:attribute name="dpid" type="String"/>
	<aura:attribute name="addressverification" type="String"/>
	<aura:attribute name="manualAddressValidity" type="String"/>


    <!--Handlers-->    
    <aura:handler name="init" value="{!this}" action="{!c.onInit}"/>
	<aura:handler name="render" value="{!this}" action="{!c.onRender}"/>
	
	<ltng:require styles="{!$Resource.Monash_Portal_CSS_Minified}"/>
	<lightning:notificationsLibrary aura:id="notifLib"/>
	
	<div class="bg-gray-mon max-w-1300 m-auto slds-is-relative">
		<!-- Spinner -->
		<div>
			<aura:if isTrue="{!!v.loaded }">
				<lightning:spinner alternativeText="Loading" />
			</aura:if>
		</div>
		
		<!--Banner-->
		<!--
		<div class="mt-4">
			<div class="container-xl relative w-full">
				<img src="{!$ContentAsset.footerBannerDesktop}" alt="" />
				<span class="absolute bottom-3.5rem md:bottom-5rem left-2rem text-4xl md:text-6xl font-extrabold uppercase text-white">Change It.</span>
				<span class="absolute bottom-1.5rem left-2rem text-4xl md:text-6xl font-extrabold uppercase text-green">For Good<span class="text-white">.</span></span>
			</div>
		</div>
		-->

		<!--Main Form html-->
		<div class="bg-white w-full h-full flex flex-wrap justify-between sm:p-6">
			<div class="bg-gray-mon w-full h-full mb-6 border-solid border-gray-mon">
				<div class="relative sm:border-gray sm:border-solid sm:border">
					<span class="absolute w-1/3 border-solid border-t-4 border-blue"></span>
					<div class="flex flex-col sm:flex-row md:flex-col flex-wrap justify-between bg-white px-4 sm:px-6 py-6">
						<h4 class="w-full pb-6 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">
							How would you like to donate?
						</h4>
						<div class='flex w-full flex-wrap justify-around'>
                            <aura:iteration items="{!v.donationFrequencyList}" var="df">
                                <label class="{!df == v.selectedDonateFrequency ? 'w-full sm:w-1/2 bg-blue py-2 px-4 mr-0 border-solid border border-blue text-white text-center text-3xl lg:text-2xl font-bold text-white cursor-pointer' : 'w-full sm:w-1/2 bg-white py-2 px-4 ml-0 border-solid border border-blue text-center text-3xl lg:text-2xl font-bold text-blue cursor-pointer'}">
                                    <input class="absolute invisible" type="radio" name="donate-frequency" value="{!df}" onchange="{!c.onSelectDonationFrequency}"/>Donate {!df}
                                </label>
                            </aura:iteration>
                        </div>
					</div>
					<div class="flex flex-col sm:flex-row flex-wrap bg-white px-4 sm:px-6 py-6">
						<h4 class="w-full pb-6 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">
							My donation amount
						</h4>
						<div class="flex-1 flex flex-row flex-wrap">
							<aura:iteration items="{!v.donationAmountList}" var="da">
                                <label class="{!da == v.selectedDonateAmount ? 'flex-1 bg-blue py-2 px-4 mx-2 md:mx-0 border-solid border border-blue text-center text-3xl lg:text-2xl font-bold text-white cursor-pointer' : 'flex-1 bg-white py-2 px-4 border-solid border border-blue text-white text-center text-3xl lg:text-2xl font-bold text-blue cursor-pointer'}">
                                    <input class="absolute invisible" type="radio" name="donate-amount" value="{!da}" onchange="{!c.onSelectDonationAmount}"/>${!da}
                                </label>
                            </aura:iteration>
						</div>
						<aura:if isTrue="{!v.showAmountChoice}">
							<span class="w-1/12 self-center text-dark-grey text-3xl lg:text-2xl font-bold text-center ">or</span>
							<div class="flex-1 flex flex-row">
								<input id="tbxOtherDonationAmount" type="text" class="w-full px-6 py-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" placeholder="My choice" value="" onblur="{!c.onEnterDonationAmount}"/>
							</div>
							<aura:set attribute="else">
								<span class="w-1/12 self-center text-dark-grey text-3xl lg:text-2xl font-bold text-center "/>
								<div class="flex-1 flex flex-row"></div>
							</aura:set>
						</aura:if>												
					</div>
				</div>
			</div>
			<div class="bg-gray-mon w-full h-full mb-6 border-solid border-gray-mon">
				<div class="relative bg-white sm:border-gray sm:border-solid sm:border">
					<span class="absolute w-1/3 border-solid border-t-4 border-blue"></span>
					<div class="flex flex-col px-4 sm:px-6 py-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">Area of giving</h4>
						<div class="flex flex-row flex-wrap items-baseline">
							<aura:iteration items="{!v.designationList}" var="di">
                                <div class="w-full sm:w-1/2 md:w-1/3 my-3 flex flex-row items-center">
                                    <input class="w-4 h-4 mr-4 border-solid border-dark-grey border bg-white ucin-light-grey-font" type="radio" id="{!di.Id}" name="area-of-giving" value="{!di.ucinn_ascendv2__External_System_ID__c}" onchange="{!c.onSelectDesignation}" />
                                    <label class="flex-1 text-xl lg:text-lg ucin-light-grey-font" for="{!di.ucinn_ascendv2__External_System_ID__c}">{!di.ucinn_ascendv2__Designation_Name__c}</label>
                                </div>
                            </aura:iteration>
							<div class="w-full sm:w-1/2 md:w-1/3 my-3 flex flex-row items-center">
								<input class="w-4 h-4 mr-4 border-solid border-dark-grey border bg-white ucin-light-grey-font" type="radio" id="rbAogOther" name="area-of-giving" />
								<label class="w-3/4" for="">
                                    <input id="tbxOtherDesignation" class="w-full border-solid border-grey border px-2 py-1 text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="My choice" onblur="{!c.onEnterDesignation}"/>
                                </label>
							</div>
						</div>
					</div>
					<div class="flex flex-col px-4 sm:px-6 py-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">
							<label for="gift-pref">What inspired you to give today?</label>
						</h4>
						<textarea id="tbxDonationComments" class="w-full border-solid border-grey border px-4 py-2 text-xl lg:text-lg ucin-light-grey-font" rows="2" placeholder="Comments"></textarea>
					</div>
				</div>
			</div>

			<!--Bio info input-->
			<div class="bg-gray-mon w-full h-full mb-6 border-solid border-gray-mon">
				<div class="relative bg-white sm:border-gray sm:border-solid sm:border">
					<span class="absolute w-1/3 border-solid border-t-4 border-blue"></span>
					<div class="flex flex-col px-4 sm:px-6 py-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">My contact details</h4>

						<div class="flex flex-row flex-wrap justify-between ">
							<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font">Name<span class="slds-text-color_destructive">*</span></label>
						</div>
						<div class="flex flex-row flex-wrap justify-between">
							<select id="ddlSalutation" class="w-1/3 sm:w-1/4 md:w-1/12 mb-2 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" data-componentName="cmpSalutation" onchange="{!c.onCompleteField}">
                                <option value="" text=""></option>
								<aura:iteration items="{!v.salutationList}" var="salut">
                                    <option value="{!salut.value}" text="{!salut.name}"></option>    
                                </aura:iteration>                               
                            </select>
							<input id="tbxFirstname" class="w-full sm:w-auto sm:flex-1 mb-2 sm:mx-2 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="First name" data-componentName="cmpFirstname" onblur="{!c.onCompleteField}" />
							<input id="tbxLastname" class="w-full sm:w-auto sm:flex-1 mb-2 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="Last name" data-componentName="cmpLastname" onblur="{!c.onCompleteField}" />
						</div>

						<aura:if isTrue="{!v.readyForLoading}">
							<div class="flex flex-row flex-wrap justify-between ">
								<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font">Phone number<span class="slds-text-color_destructive">*</span></label>
							</div>
							<div class="flex flex-row flex-wrap justify-between">
								<!-- Experian phone number validation -->
								<div id="phoneComp" class="w-full sm:w-auto sm:flex-1 mb-2 p-2 text-xl lg:text-lg ucin-light-grey-font addressBorder">
									<c:phoneNumberValidationEDQ aura:id="mobileNumberSearch"
																phoneNumberlabel="Phone Number"
																phoneNumberRegEx="[\+]?[\d\s]{5,25}"
																defaultCountry="Australia"
																componentName="mobilePhone"
																savedPhoneNumber="{!v.contactPhone}"
																savedCountry="{!v.phoneSavedCountry}"
																verificationStatus="{!v.phoneVerification}">
									</c:phoneNumberValidationEDQ>
								</div>
							</div>
							<div class="flex flex-row flex-wrap justify-between paddingLabel">
								<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font">Email<span class="slds-text-color_destructive">*</span></label>
							</div>
							<div class="flex flex-row flex-wrap justify-between ">
								<div class="w-full sm:w-auto sm:flex-1 mb-2 p-2 text-xl lg:text-lg ucin-light-grey-font emailBorder">
									<!-- Experian email validation -->
									<c:emailValidationEDQ aura:id="personalEmailValidate"
														  componentName="personalEmail"
														  savedEmail="{!v.contactEmail}"
														  verificationStatus="{!v.emailVerification}"/>
								</div>
							</div>

							<div class="flex flex-row flex-wrap justify-between">
								<div class="w-full sm:w-auto sm:flex-1 mb-2 p-2 text-xl lg:text-lg ucin-light-grey-font addressBorder">
									<!-- Experian Address component -->
									<c:addressSearchEDQ aura:id="addressSearchComp"
														isAddressDisabled="{!!v.isEditing}"
														streetMandatory = "true"
														cityMandatory="true"
														defaultCountry="Australia"
														stateMandatory="true"
														postCodeMandatory="true">
									</c:addressSearchEDQ>
								</div>
							</div>

							<aura:if isTrue="{!v.addressLine.length > 0}">
								<div class="flex flex-row flex-wrap justify-between">
									<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font">Current Address: {!v.addressLine}</label>
								</div>
							</aura:if>
						</aura:if>
						<div class="w-full flex flex-row items-baseline">
							<input id="cbAnonymousDonation" class="w-4 h-4 mr-4 appearance-none border-solid border-dark-grey border bg-white ucin-light-grey-font" type="checkbox" />
							<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font" for="gift-pref-anon">Please do not recognise my gift publicly</label>
						</div>
					</div>

					<!-- Payment Info Input-->
					<div class="flex flex-col px-4 sm:px-6 py-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">My payment information</h4>
						<div>
							<div class="flex flex-row flex-wrap justify-between">
								<input id="tbxCardholderName" class="w-full sm:w-auto sm:flex-1 mb-2 sm:mr-1 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="Cardholder's name" data-componentName="cmpCardHolderName" onblur="{!c.onCompleteField}" />
								<input id="tbxCardNumber" class="w-full sm:w-auto sm:flex-1 mb-2 sm:ml-1 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="Credit card number" data-componentName="cmpCardNumber" onblur="{!c.onCompleteField}" />
							</div>
							<div class="flex flex-row flex-wrap justify-between my-2">
								<select id="ddlCardType" class="w-full sm:w-auto sm:flex-1 sm:mr-1 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" data-componentName="cmpCardType" onchange="{!c.onCompleteField}">
                                    <option value="">Card type</option>
                                    <option value="Mastercard">Mastercard</option>
									<option value="VISA">VISA</option>
									<option value="American Express">American Express</option>
                                </select>
                                <input id="tbxCardExpireDate" class="w-full sm:w-auto sm:flex-1 sm:ml-1 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="Card expiry (MM/YY)" data-componentName="cmpCardExpiry" onblur="{!c.onCompleteField}" />
								<input id="tbxCardSecurityCode" class="w-full sm:w-auto sm:flex-1 sm:ml-1 p-2 border-solid border-grey border text-xl lg:text-lg ucin-light-grey-font" type="text" placeholder="Card security code" data-componentName="cmpCardSecurityCode" onblur="{!c.onCompleteField}" />
							</div>
						</div>
					</div>

					<!--Preferences input-->
					<div class="flex flex-col px-4 sm:px-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold">Have you made a gift in your Will to Monash?</h4>
						<div class="flex flex-row flex-wrap justify-between">
							<div class="w-full my-3 flex flex-row items-center">
								<input class="w-4 h-4 mr-4 appearance-none border-solid border-dark-grey border bg-white" type="checkbox" id="cbLearnMoreWill" name="learn-more-will" />
								<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font" for="learn-more-will">I’ve already included a gift in my Will to Monash</label>
							</div>
							<div class="w-full my-3 flex flex-row items-center">
								<input class="w-4 h-4 mr-4 appearance-none border-solid border-dark-grey border bg-white" type="checkbox" id="cbWillReady" name="will-ready" />
								<label class="flex-1 text-xl lg:text-lg ucin-light-grey-font" for="will-ready">I would like some more information about leaving a gift in my Will to Monash</label>
							</div>
						</div>
					</div>

					<!--Capcha-->
					<div class="flex flex-col px-4 sm:px-6 py-6">
						<h4 class="pb-4 text-dark-grey text-2xl sm:text-3xl lg:text-2xl leading-lesstight font-bold"><label for="gift-pref">Additional security</label></h4>
						<p class="text-xl lg:text-lg ucin-light-grey-font">This is a security measure to help prevent fraud.</p>

						<aura:if isTrue="{!v.showCaptcha}">
							<c:reCaptcha aura:id="captchaComp" oncaptchachange="{!c.handleDispatchCaptchaEvent}"></c:reCaptcha>
					   </aura:if>

						<button aura:id="btnSubmit" class="self-start bg-blue border-blue border-solid my-6 py-4 px-16 font-semibold" disabled="{!v.btnSubmitDisabled}" onclick="{!c.onSubmitDonation}">
                            <span class="text-white text-2xl lg:text-xl">{!v.btnSubmitLabel}</span>
                        </button>
						<div style="padding-top:20px;">
							<p class="text-xl lg:text-lg ucin-light-grey-font">To donate by phone or Electronic Funds Transfer (EFT), please contact the Donor Relations team between 9.00am and 5.00pm Monday to Friday on (03) 9903 1608 or via email at <a href='mailto:donor.relations@monash.edu'>donor.relations@monash.edu</a></p>
							<p class="text-xl lg:text-lg ucin-light-grey-font my-2">Donations of $2 or more are tax-deductible for Australian tax purposes. Your email confirmation will include a copy of your receipt.</p>
						</div>
					</div>
				</div>
			</div>
            
			<div class="bg-gray-mon w-full h-full my-4">
				<div class="relative bg-white">
					<div class="flex flex-col px-4 sm:px-6">
						<div>
							<p class="text-xl lg:text-lg font-bold ucin-light-grey-font">Privacy statement</p>
                            <p class="text-xl lg:text-lg ucin-light-grey-font">Monash University is committed to protecting your privacy. Your personal details are held and used in accordance with the Information Privacy Principles of the Privacy and Data Protection Act 2014 (Vic). To read more, please review our <a href="https://www.monash.edu/privacy-monash" target="_blank">privacy statement.</a></p>
                            <p class="text-xl lg:text-lg ucin-light-grey-font">To update your details, <a href="https://www.monash.edu/alumni/connect/update-your-details">click here</a>.</p>
						</div>
					</div>
				</div>
			</div>
            
		</div>
	</div>
</aura:component>