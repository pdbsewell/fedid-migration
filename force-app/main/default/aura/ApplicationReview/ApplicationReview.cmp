                                            <div class="slds-truncate">{!work.Position__c}</div>
                                        </td>
                                        <td data-label="Start Date">
                                            <div class="slds-truncate">{!work.Start_Date__c}</div>
                                        </td>
                                        <td data-label="End Date">
                                            <aura:if isTrue="{!work.End_Date__c != null}" >
                                                <div class="slds-truncate">{!work.End_Date__c}</div>
                                                <aura:set attribute="else">
                                                    <div class="slds-truncate">Ongoing</div>
                                                </aura:set>
                                            </aura:if>

                                        </td>
                                    </tr>
                                    </tbody>
                                </aura:iteration>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </aura:if>

    <aura:if isTrue="{!and(v.fullApplication.Application.Guardian_Full_Name__c != '', v.fullApplication.Application.Guardian_Full_Name__c != null)}" >
        <!--<c:ApplicationLightHeader title="Parent Guardian Details" />-->
        <div class="slds-grid slds-gutters slds-wrap" style="width: 100%;">
            <div class="slds-col" style="width: 100%;">
                <!-- Parent Guardian Details -->
                <div class="sectionContainer slds-wrap" style="padding: 0 15px 0 0;">
                    <div class="slds-size_3-of-6 sectionContainerTopBorder"></div>
                    <div class="sectionContainerBody slds-size_5-of-5">
                        <div class="slds-size_5-of-5">
                            <h2>Parent Guardian Details</h2>
                        </div>

                        <div class="slds-size_5-of-5">
                            <div class="slds-section section-float">
                                <div class="slds-col--padded">
                                    <form class="slds-form--stacked">
                                        <div class="slds-grid slds-wrap slds-grid--pull-padded slds-p-vertical--medium iteration-block">
                                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                                <div class="slds-text-title">Guardian Full Name</div>
                                                <div class="slds-text-body--regular">{!v.fullApplication.Application.Guardian_Full_Name__c}</div>
                                            </div>
                                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                                <div class="slds-text-title">Guardian Phone Number</div>
                                                <div class="slds-text-body--regular">{!v.fullApplication.Application.Guardian_Phone_Number__c}</div>
                                            </div>
                                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                                <div class="slds-text-title">Guardian Email Address</div>
                                                <div class="slds-text-body--regular">{!v.fullApplication.Application.Guardian_Email_Address__c}</div>
                                            </div>
                                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                                <div class="slds-text-title">Guardian Relationship</div>
                                                <div class="slds-text-body--regular">{!v.fullApplication.Application.Guardian_Relationship__c}</div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </aura:if>
</aura:component>