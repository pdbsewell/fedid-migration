                                        </td>
                                        <td data-label="Date Achieved">
                                            <div class="slds-truncate">{!other.Date_Achieved__c}</div>
                                        </td>
                                    </tr>
                                    </tbody>
                                </aura:iteration>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </aura:if>

    <aura:if isTrue="{!v.englishQualifications.length > 0}" >
        <!--<c:ApplicationLightHeader title="English Tests" />-->
        <div class="slds-grid slds-gutters slds-wrap" style="width: 100%;">
            <div class="slds-col" style="width: 100%;">
                <!-- English Tests -->
                <div class="sectionContainer slds-wrap" style="padding: 0 15px 0 0;">
                    <div class="slds-size_3-of-6 sectionContainerTopBorder"></div>
                    <div class="sectionContainerBody slds-size_5-of-5">
                        <div class="slds-size_5-of-5">
                            <h2>English Tests</h2>
                        </div>

                        <div class="slds-size_5-of-5">
                            <!--QUALIFICATIONS TABLE -->
                            <table class="slds-table slds-table--bordered slds-table--cell-buffer slds-table--fixed-layout ">
                                <thead>
                                <tr class="slds-text-title_caps">
                                    <th scope="col">
                                        <div class="slds-truncate" title="Assessment Type/Qualification">Assessment Type/Qualification</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-cell-wrap" title="Date of Completion">Date of Completion</div>
                                    </th>
                                    <th scope="col">
                                        <div class="slds-cell-wrap" title="Score">Score</div>
                                    </th>
                                </tr>
                                </thead>
                                <aura:iteration items="{!v.englishQualifications}" var="eng" >
                                    <tbody>
                                    <tr>
                                        <td data-label="Course Title">
                                            <div class="slds-cell-wrap slds-truncate" style="float: left; width: 300px; word-wrap: break-word;">{!eng.Qualification__r.Qualification_Name__c}</div>
                                        </td>
                                        <aura:if isTrue="{!eng.isCompleted__c}">
                                            <td data-label="Expected Date of Completion">
                                                <div class="slds-truncate">{!eng.Expected_date_of_completion__c}</div>
                                            </td>
                                            <aura:set attribute="else">
                                                <td data-label="Date of Completion">
                                                    <div class="slds-truncate">{!eng.Date_Achieved__c}</div>
                                                </td>
                                            </aura:set>
                                        </aura:if>
                                        <td data-label="Overall Score">
                                            <div class="slds-truncate">{!eng.Score__c}</div>
                                        </td>
                                    </tr>
                                    </tbody>
                                </aura:iteration>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </aura:if>

    <!--Heading for next section-->

    <aura:if isTrue="{!v.fullApplication.Experience.length > 0}" >
        <!--<c:ApplicationLightHeader title="Work Experience" />-->
        <div class="slds-grid slds-gutters slds-wrap" style="width: 100%;">
            <div class="slds-col" style="width: 100%;">
                <!-- Work Experience -->
                <div class="sectionContainer slds-wrap" style="padding: 0 15px 0 0;">
                    <div class="slds-size_3-of-6 sectionContainerTopBorder"></div>
