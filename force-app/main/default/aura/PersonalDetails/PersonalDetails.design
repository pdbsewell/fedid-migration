<design:component>
    <design:attribute name="isRedirect" label="Is Redirect?" description="Defines if the component is a Redirect Component or if it saves in place" />
    <design:attribute name="redirectURL" label="Redirect URL" description="Defines the URL to redirect to in the event the Redirect function is filled. Page URL online not the fully qualified one" />
    <design:attribute name="redirectLabel" label="Redirect Label" description="Shows on the button if IsRedirect = True" />
    <design:attribute name="saveOnlyLabel" label="Save Only Label" description="Shows on the button if IsRedirect = False" />
</design:component>