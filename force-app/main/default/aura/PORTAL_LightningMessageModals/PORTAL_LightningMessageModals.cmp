<aura:component implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute name="messageExists" type="Boolean" default="false"/>
    <aura:attribute name="message" type="String" default="" />
    <aura:attribute name="messageType" type="String" default="" />
    <!-- <aura:handler name="lightningMessageEvent" event="c:PORTAL_EVT_LightningMessage" action="{!c.handleComponentMessageEvent}" /> -->
    <aura:handler event="c:PORTAL_EVT_LightningMessage" action="{!c.handleApplicationMessageEvent}" />

    <!-- For System Error Handling -->
    <div class="slds-hide" aura:id="sysErrorMessage" style="position: relative; z-index: 9999">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_large">
            <div class="slds-modal__container">
                <header class="slds-modal__header sys-error-header-coler">
                    <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">System Error</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                    <p>{!v.message}</p>
                </div>
                <footer class="slds-modal__footer">
                    <ui:button class="slds-button slds-button--brand" buttonTitle="OK" label="OK" press="{!c.okButtonClickedForSysError}"/>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>
    
    <!-- For Validation Error Handling -->
    <div class="slds-hide" aura:id="validationErrorMessage" style="position: relative; z-index: 9999">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-02" aria-modal="true" aria-describedby="modal-content-id-2" class="slds-modal slds-fade-in-open slds-modal_large">
            <div class="slds-modal__container">
                <header class="slds-modal__header validation-error-header-coler">
                    <h2 id="modal-heading-02" class="slds-text-heading_medium slds-hyphenate">Validation Error</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-2">
                    <p>{!v.message}</p>
                </div>
                <footer class="slds-modal__footer">
                    <ui:button class="slds-button slds-button--brand" buttonTitle="OK" label="OK" press="{!c.okButtonClickedForValidationError}"/>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>

    <!-- For Warning Error Handling -->
    <div class="slds-hide" aura:id="warningErrorMessage" style="position: relative; z-index: 9999">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-03" aria-modal="true" aria-describedby="modal-content-id-3" class="slds-modal slds-fade-in-open slds-modal_large">
            <div class="slds-modal__container">
                <header class="slds-modal__header warning-error-header-coler">
                    <h2 id="modal-heading-03" class="slds-text-heading_medium slds-hyphenate">Warning</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-3">
                    <p>{!v.message}</p>
                </div>
                <footer class="slds-modal__footer">
                    <ui:button class="slds-button slds-button--brand" buttonTitle="OK" label="OK" press="{!c.okButtonClickedForWarningError}"/>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>

    <!-- For Confirmation Handling -->
    <div class="slds-hide" aura:id="confirmationMessage" style="position: relative; z-index: 9999">
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-04" aria-modal="true" aria-describedby="modal-content-id-4" class="slds-modal slds-fade-in-open slds-modal_large">
            <div class="slds-modal__container">
                <header class="slds-modal__header not-error-header-coler">
                    <h2 id="modal-heading-04" class="slds-text-heading_medium slds-hyphenate">Confirmation</h2>
                </header>
                <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-4">
                    <p>{!v.message}</p>
                </div>
                <footer class="slds-modal__footer">
                    <ui:button class="slds-button slds-button--brand" buttonTitle="OK" label="OK" press="{!c.okButtonClickedForConfirmation}"/>
                </footer>
            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
    </div>
</aura:component>