<aura:component>
    <aura:attribute name="day" type="String" access="public"/>
    <aura:attribute name="date" type="Object" access="public"/>
    <aura:attribute name="visible" type="Boolean" default="true" access="public"/>
    <aura:attribute name="hasListing" type="Boolean" default="false" access="public"/>
    <aura:attribute name="toDoItems" type="String[]" access="public"/>
    
    <aura:registerEvent name="PORTAL_EVT_CalendarDayClicked" type="c:PORTAL_EVT_CalendarDayClicked"/>
    
    <aura:if isTrue="{!v.visible}">
        <aura:if isTrue="{!v.hasListing}"> 
            <td class="slds-is-selected slds-p-top_medium">
                <span class="slds-day slds-align_absolute-center" onclick="{!c.dayClicked}">{!v.day}</span>
            </td>
            <aura:set attribute="else">
                <td class="slds-p-top_medium">
                    <span class="slds-day slds-align_absolute-center" onclick="{!c.dayClicked}">{!v.day}</span>
                </td>
            </aura:set>
        </aura:if>
        <aura:set attribute="else">
            <td class="slds-p-top_medium">
                <span class="slds-align_absolute-center"></span>
            </td>
        </aura:set>
    </aura:if>
    
</aura:component>