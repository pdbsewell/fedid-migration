<aura:component implements="forceCommunity:availableForAllPageTypes" controller="LightningMonashHeadLineController" access="global" >
 <aura:attribute name="firstName" type="string" required="false"/>
 <aura:attribute name="homePageUrl" type="string" required="false"/>
 <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <div class="slds-grid slds-wrap">
        
        <div class="slds-size--12-of-12 slds-medium-size--12-of-12 slds-p-top--large ques-text slds-align_absolute-center">
            Thanks for getting in touch.
        </div>
        
         <div class="slds-size--12-of-12 slds-medium-size--12-of-12 slds-p-top--large ques-desc slds-align_absolute-center">
            {!$Label.c.AskMonashSLA}
        </div>
        
        <div class="slds-size--12-of-12 slds-medium-size--12-of-12 slds-p-top--large slds-align_absolute-center slds-p-bottom_xx-large">
            <div class="slds-align_absolute-center">
                <button class="btn-custom" onclick="{!c.redirectHomepage}">Back to Home</button>
            </div>
        </div>
    </div>
    
</aura:component>