<aura:component implements="force:lightningQuickActionWithoutHeader,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes,force:hasRecordId"
                access="global" controller="EmailToPdfController" description="EmailToPdfAction">
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="loading" type="Boolean" default="true" />
    <aura:attribute name="message" type="String" default="Generating PDF..." />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>

    <div class="container slds-is-relative">

        <h1 class="{!v.loading? '': 'result'}">{!v.message}</h1>

        <!-- placeholder tag for link to PDF -->
        <a target="_blank" href="" aura:id="link"></a>

        <aura:if isTrue="{!v.loading}">
            <div class="loading slds-is-relative">
                <lightning:spinner alternativeText="Loading" />
            </div>
        </aura:if>
    </div>

</aura:component>