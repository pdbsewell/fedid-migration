<!--
* @author unknown
* @date unknown
* @group Admissions
* @description Work Experience Form of My.App Community Experience
* @revision
*           12.04.2024 - Arnie Ug - Adding Validation Rules/RegEx to a Position, Employer, Given and Family Names fields
 -->
<aura:component
                implements="flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" 
                controller="appAddWorkExperienceCC"
                access="global" >
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />

    <aura:attribute name="applicationId" type="String" access="global" />
    <aura:attribute name="appId" type="Id" description="the current application Id parsed from URL arguments"/>
    <aura:attribute name="user" type="User" description="the current community user"/>
    <aura:attribute name="contactId" type="Id" description="the current Contact Id based on logged in userapp"/>

    <aura:attribute name="state" type="String" default="START" description="the state of the component"/>
    <aura:attribute name="workExperiences" type="Work_Experience__c[]" description="the list of Work Experiences added to this Application"/>
    <aura:attribute name="historicalWorkExperiences" type="Work_Experience__c[]" description="the list of uneditable Work Experiences added to this Application"/>

    <aura:attribute name="workExp" type="Work_Experience__c" default=""
                    description="the current Work Experience record for edit or create"/>

    <aura:attribute name="addRef" type="Boolean" default="false" description="whether or not to add referee"/>
    <aura:attribute name="countryOptions" type="List" description="options for selecting the referee country"/>

    <aura:attribute name="idToDelete" type="Id" default="" description="the Id of the record to delete"/>
    <aura:attribute name="showConfirmDelete" type="Boolean" default="false"/>

    <aura:attribute name="showSpinner" type="Boolean" default="false"/>
    <aura:attribute name="showErrors" type="Boolean" default="false" description="if there are any errors on save, to show/hide the alert box"/>
    <aura:attribute name="saveErrors" type="List" description="any errors preventing save"/>
    
    <aura:attribute name="employmentRegExp" type="String" default="false"/>
    <aura:attribute name="employmentPatterMsg" type="String" default="false"/>
    <aura:attribute name="refereeRegExp" type="String" default="false"/>
    <aura:attribute name="refereePatterMsg" type="String" default="false"/>

    <div class="slds">
        <!-- LOADING SPINNER -->
        <div class="{!if(v.showSpinner == true, '', 'slds-hide')}">
            <lightning:spinner aura:id="spinner" alternativeText="Saving"/>
        </div>
        <!-- END LOADING SPINNER -->

        <!-- DELETE CONFIRMATION POPUP -->
        <div class="{!if(v.showConfirmDelete==true, '', 'slds-hide')}">

            <div role="alertdialog" tabindex="-1" aria-labelledby="prompt-heading-id" aria-describedby="prompt-message-wrapper" class="slds-modal slds-fade-in-open slds-modal--prompt">
                <div class="slds-modal__container">
                    <div class="slds-modal__header slds-theme--error slds-theme--alert-texture">
                        <h2 class="slds-text-heading--small" id="prompt-heading-id" style="color: #ffffff;">{!$Label.c.App_DeleteConfirmation}</h2>
                    </div>
                    <div class="slds-modal__content slds-p-around--medium">
                        <p>Are you sure you want to delete this work experience?</p>
                    </div>
                    <div class="slds-modal__footer slds-theme--default">
                        <lightning:button label="Yes"
                                          iconPosition="left"
                                          variant="brand"
                                          onclick="{!c.onClickConfirmDelete}">
                        </lightning:button>
                        <lightning:button label="No"
                                          iconPosition="left"
                                          class="slds-button slds-button--neutral"
                                          onclick="{!c.onClickCancelDelete}">
                        </lightning:button>
                    </div>
                </div>
            </div>
            <div class="slds-backdrop slds-backdrop--open"></div>
        </div>
        <!-- DELETE CONFIRMATION POPUP -->

        <!-- ALERT: ANY Errors on save-->
        <div class="{!if(v.showErrors == true, '', 'slds-hide')}" style="">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <h3 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">Please complete the following:</h3>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <ul class="slds-list_dotted slds-text-align--left">
                            <aura:iteration items="{!v.saveErrors}" var="error">
                                <li>{!error}</li>
                            </aura:iteration>
                        </ul>
                    </div>
                    <footer class="slds-modal__footer">
                        <button class="slds-button slds-button_neutral" onclick="{!c.onClickCloseErrors}">Close</button>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
        <!-- END SAVE ERRORS -->

        <div class="{!if(v.state == 'START','','slds-hide')}">

            <div class="slds-p-vertical--large">
                <table class="slds-table slds-table--bordered slds-table--cell-buffer slds-table--fixed-layout ">
                    <thead>
                    <tr class="slds-text-title--caps">
                        <th scope="col">
                            <div title="posTH">Position</div>
                        </th>
                        <th scope="col" class="hideOnMobile">
                            <div title="empTH">Employer</div>
                        </th>
                        <th scope="col" class="hideOnMobile">
                            <div title="empTH">Date</div>
                        </th>
                        <th scope="col">
                            <div class="slds-truncate slds-align_absolute-center" title="Action" >Action</div>
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    <!-- ITERATION FOR WORK EXPERIENCE -->
                        <aura:iteration items="{!v.workExperiences}" var="workExp">
                            <tr>
                                <td>
                                    <div class="slds-truncate" >
                                        {!workExp.Position__c}
                                    </div>
                                </td>
                                <td>
                                    <div class="slds-truncate" >
                                        {!workExp.Employer_Name__c}
                                    </div>
                                </td>
                                <td data-label="Start Date">
                                    <div class="slds-float_left">
                                        <aura:If isTrue="{!workExp.End_Date__c == null}">
                                            <div class="slds-truncate" >
                                                <ui:outputDate value="{!workExp.Start_Date__c}" format="dd/MMM/yyyy"/>&nbsp;-&nbsp;Present
                                            </div>
                                            <aura:set attribute="else">
                                                <ui:outputDate value="{!workExp.Start_Date__c}" format="dd/MMM/yyyy"/>&nbsp;-&nbsp;<ui:outputDate value="{!workExp.End_Date__c}" format="dd/MMM/yyyy"/>
                                            </aura:set>
                                        </aura:If>
                                    </div>
                                </td>
                                <td data-label="Action">
                                    <div class="slds-truncate slds-align--absolute-center">
                                        <lightning:button label=""
                                                          iconPosition="left"
                                                          name="{!workExp.Id}"
                                                          onclick="{!c.onClickEdit}"
                                                          variant="base">
                                            <lightning:icon iconName="utility:edit" size="small" alternativeText="edit"/>
                                        </lightning:button>
                                        <lightning:button label=""
                                                          iconPosition="left"
                                                          name="{!workExp.Id}"
                                                          onclick="{!c.showConfirmDeletePopup}"
                                                          variant="base">
                                            <lightning:icon iconName="utility:close" size="small" alternativeText="Remove Item" />
                                        </lightning:button>
                                    </div>
                                </td>
                            </tr>
                        </aura:iteration>
                    <!-- END - ITERATION FOR APPLICATION WORK EXPERIENCE PROVIDED -->

                    <!-- ITERATION FOR PREVIOUS Application Work Experiences -->
                    <aura:iteration items="{!v.historicalWorkExperiences}" var="workExp">
                        <tr>
                            <td>
                                <div class="slds-truncate" >
                                    {!workExp.Position__c}
                                </div>
                            </td>
                            <td>
                                <div class="slds-truncate" >
                                    {!workExp.Employer_Name__c}
                                </div>
                            </td>
                            <td data-label="Start Date">
                                <div class="slds-float_left">
                                    <aura:If isTrue="{!workExp.End_Date__c == null}">
                                        <div class="slds-truncate" >
                                            <ui:outputDate value="{!workExp.Start_Date__c}" format="dd/MMM/yyyy"/>&nbsp;-&nbsp;Present
                                        </div>
                                        <aura:set attribute="else">
                                            <ui:outputDate value="{!workExp.Start_Date__c}" format="dd/MMM/yyyy"/>&nbsp;-&nbsp;<ui:outputDate value="{!workExp.End_Date__c}" format="dd/MMM/yyyy"/>
                                        </aura:set>
                                    </aura:If>
                                </div>
                            </td>
                            <td data-label="Action">
                                <div class="slds-truncate slds-align--absolute-center">
                                    <lightning:helptext
                                            content="This work experience cannot be edited or deleted"
                                            iconName="utility:preview"
                                    />
                                </div>
                            </td>
                        </tr>
                    </aura:iteration>
                    <!-- END ITERATION FOR PREVIOUS Application Work Experiences -->

                    </tbody>
                </table>
            </div>

            <!-- ADD NEW BUTTON -->
            <div class="slds-button-group" role="group">
                <button class="secondaryButton" onclick="{!c.onClickAddNew}">
                    <lightning:icon class="secondaryIcon" iconName="utility:add" size="small" />&nbsp;&nbsp;Work Experience
                </button>
            </div>
        </div>


        <div class="{!if(v.state == 'EDIT', '', 'slds-hide')}">
            <h3 class="slds-section__title">New Work Experience</h3>
            <lightning:input aura:id="position"
                             label="Position"
                             required="true"
                             pattern="{!v.employmentRegExp}"
                             messageWhenPatternMismatch="{!v.employmentPatterMsg}"
                             value="{!v.workExp.Position__c}"/>
            <lightning:input aura:id="employer"
                             label="Employer"
                             required="true"
                             pattern="{!v.employmentRegExp}"
                             messageWhenPatternMismatch="{!v.employmentPatterMsg}"
                             value="{!v.workExp.Employer_Name__c}"/>
            <lightning:input aura:id="startDate"
                             label="Start Date"
                             required="true"
                             type="date"
                             value="{!v.workExp.Start_Date__c}"/>
            <lightning:input aura:id="endDate"
                             label="End Date (leave blank if continuing)"
                             required="false"
                             type="date"
                             value="{!v.workExp.End_Date__c}"/>
            <lightning:select aura:id="selectCountry"
                              label="Country"
                              value="{!v.workExp.Country__c}"
                              required="true"
                              onchange="{!c.onSelectRefCountry}"
            >
                <aura:iteration var="option" items="{! v.countryOptions}">
                    <option value="{! option.value }"
                            selected="{!if(v.workExp.Country__c==option.value)}">{! option.label }</option>
                </aura:iteration>
            </lightning:select>

            <div class="{!if(v.addRef==false, '', 'slds-hide')}">
                <div class="slds-p-vertical--x-large">
                    <button class="secondaryButton" onclick="{!c.onClickAddReferee}">
                        <lightning:icon class="secondaryIcon" iconName="utility:add" size="small" />&nbsp;&nbsp;Add Referee
                    </button>
                </div>
            </div>
            <div class="{!if(v.addRef == true, '', 'slds-hide')}">
                <div class="slds-p-vertical--x-large">
                    <h3 class="slds-section__title">Referee</h3>
                    <div class="slds-text-body--regular">{!$Label.c.App_ContactPersonDetailsLabel}</div>
                </div>

                <lightning:input aura:id="givenName"
                                 label="Given Name"
                                 required=""
                                 pattern="{!v.refereeRegExp}"
                                 messageWhenPatternMismatch="{!v.refereePatterMsg}"
                                 value="{!v.workExp.Contact_Person_First_Name__c}"/>
                <lightning:input aura:id="familyName"
                                 label="Family Name"
                                 required=""
                                 pattern="{!v.refereeRegExp}"
                                 messageWhenPatternMismatch="{!v.refereePatterMsg}"
                                 value="{!v.workExp.Contact_Person_Last_Name__c}"/>

                <lightning:input label="Email"
                                 required=""
                                 type="email"
                                 value="{!v.workExp.Contact_Person_Email__c}"/>

                <lightning:input label="Contact Number"
                                 required=""
                                 type="tel"
                                 value="{!v.workExp.Contact_Person_Phone__c}"/>
            </div>

            <div class="slds-form-element slds-p-vertical--large">
                <div class="slds-m-top_medium">                    
                    <button class="primaryButton" onclick="{!c.onClickSave}" style="margin-right: 15px;">
                        Save
                    </button>
                    <button class="secondaryButton" onclick="{!c.onClickCancel}">
                        Cancel
                    </button>
                </div>
            </div>
        </div>

    </div>
</aura:component>