<design:component>
	<design:attribute name="objectBinding" label="Object Binding" description="Used to define which object this component relates to" />
	<design:attribute name="helperText" label="Helper Text" description="Defines the text at the top of the component to prompt the user" />
	<design:attribute name="modalHelperText" label="Modal Helper Text" description="Defines the text within the Create Document Modal" />
	<design:attribute name="saveSubmitted" label="Save Submitted Contact Documents" description="Defines if the Contact Document saves with a True status to send to Callista" />
</design:component>