<aura:component description="footer top" implements="forceCommunity:availableForAllPageTypes" controller="PORTAL_FooterTopController" access="global">
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>    
    <aura:attribute name="baseUrl" type="String" default=""/>
    <aura:attribute name="linkedInIconUrl" type="String" default=""/>
    <aura:attribute name="facebookIconUrl" type="String" default=""/>
    <aura:attribute name="twitterIconUrl" type="String" default=""/>
    <aura:attribute name="googlePlusIconUrl" type="String" default=""/>
    
    <div class="slds-text-align_center">    
        <lightning:layout>   
            <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="12">
                <br></br>
                <big>STAY CONNECTED</big>
                <br></br>
            </lightning:layoutItem>
        </lightning:layout>     
        <lightning:layout>   
            <lightning:layoutItem flexibility="auto" padding="horizontal-small" size="12">
                <br></br>
                <a href="https://www.linkedin.com/"><img src="{!v.linkedInIconUrl}" class="social-media-image"/></a>
                <a href="https://www.facebook.com/"><img src="{!v.facebookIconUrl}" class="social-media-image"/></a>
                <a href="https://twitter.com/"><img src="{!v.twitterIconUrl}" class="social-media-image"/></a>
                <a href="https://plus.google.com/"><img src="{!v.googlePlusIconUrl}" class="social-media-image"/></a>
                <br></br>
                <br></br>
            </lightning:layoutItem>
        </lightning:layout>    
    </div>
    
</aura:component>