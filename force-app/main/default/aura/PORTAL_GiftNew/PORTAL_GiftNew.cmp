<aura:component >

    <c:PORTAL_MessageHandlingService aura:id="MessageHandlingService" />

    <aura:attribute name="giftTypeSelected" type="String" access="public"/>
    <!-- Top level donation detail container -->
    <!-- <aura:attribute name="portalDonationSetupParams" type="Object" access="public"/> -->
    <aura:attribute name="constituentId" type="String" access="public"/>
    <aura:attribute name="constituentRec" type="Contact" access="public"/>
    <aura:attribute name="organizationId" type="String" access="public"/>
    <aura:attribute name="organizationRec" type="Account" access="public"/>
    <aura:attribute name="giftRec" type="Object" access="public"/>
    <aura:attribute name="selectedDesignations" type="Object[]" access="public"/>
    <aura:attribute name="designationDetailRecList" type="Object[]" access="public"/>
    <aura:attribute name="tributeRecList" type="Object[]" access="public"/>

    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler name="designationDetailListItemEvent" event="c:PORTAL_EVT_ListItem" action="{!c.designationDetailListItemEventHandler}" />
    <aura:method name="validateGiftInfomationSync" action="{!c.validateGiftInfomationSync}"/>

    <div class="slds-size_1-of-1">
        <fieldset class="slds-box slds-theme_default slds-container">
            <legend class="slds-text-heading_medium slds-p-vertical_x-small">
                <h1 class="slds-text-heading_medium">Making a Gift</h1>
            </legend>

            <div class="slds-size_1-of-1" style="position: relative; z-index: 100">
                <c:PORTAL_OpportunitySummary giftTypeSelected="{#v.giftTypeSelected}"
                                             giftRec="{!v.giftRec}"/>
            </div>

            <div class="slds-size_1-of-1 slds-m-top_medium" style="position: relative; z-index: 90">
                <c:PORTAL_DesignationDetailList giftTypeSelected="{#v.giftTypeSelected}" 
                                                designationDetailRecList="{!v.designationDetailRecList}"
                                                selectedDesignations="{!v.selectedDesignations}" />
            </div>

            <div class="slds-size_1-of-1 slds-m-top_medium" style="position: relative; z-index: 80">
                <c:PORTAL_TributeList tributeRecList="{!v.tributeRecList}" />
            </div>
        </fieldset>
    </div>
</aura:component>