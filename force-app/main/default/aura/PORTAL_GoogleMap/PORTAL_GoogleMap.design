<design:component>
	<design:attribute name="markersTitle" label="Markers Title" description="When the map displays multiple markers on the page and shows the list of markers, this property provides the heading title for the markers." />
    <design:attribute name="showFooter" label="Show Footer" description="Shows footer with 'Open in Google Maps' link." />
	<design:attribute name="inputEventName" label="Input Event Name" description="Event name to accept to show locations." />
</design:component>