<aura:component access="public">
    <aura:method name="successServerCall" action="{!c.successServerCall}">
        <aura:attribute name="message" type="String" />
    </aura:method>
    <aura:method name="incompleteServerCall" action="{!c.incompleteServerCall}">
        <aura:attribute name="message" type="String" />
    </aura:method>
    <aura:method name="errorServerCall" action="{!c.errorServerCall}">
        <aura:attribute name="message" type="String" />
    </aura:method>
    <aura:method name="validationError" action="{!c.validationError}">
        <aura:attribute name="message" type="String" />
    </aura:method>
    <aura:method name="warningError" action="{!c.warningError}">
        <aura:attribute name="message" type="String" />
    </aura:method>

    <aura:registerEvent name="lightningMessageEvent" type="c:PORTAL_EVT_LightningMessage"/>
</aura:component>