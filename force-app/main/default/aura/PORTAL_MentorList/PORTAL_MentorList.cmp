<aura:component implements="forceCommunity:availableForAllPageTypes" controller="PORTAL_MentorListController" access="global">
    
    <c:PORTAL_LightningMessageModals />
    <c:PORTAL_MessageHandlingService aura:id="MessageHandlingService" />

    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <aura:attribute name="contact" type="Contact" 
                    default="{ 'sobjectType': 'Contact' }"/>
    
    <aura:attribute name="mentorList" type="Mentor__c[]" />
    <aura:attribute name="mentorListToDisplay" type="Mentor__c[]" />    
    
    <aura:attribute name="sharing" type="String" default="All" access="public"/>
    <aura:attribute name="relevance" type="String" default="All" access="public"/>
    <aura:attribute name="enableSearch" type="String" default="Yes" access="public"/>
    
    <aura:attribute name="maxItems" type="String" default="10" access="public"/>
    
    <aura:attribute name="itemsPerPage" type="Integer" default="2" />
    <aura:attribute name="previousButtonDisabled" type="Boolean" default="true" />
    <aura:attribute name="nextButtonDisabled" type="Boolean" default="false" />
    <aura:attribute name="totalNumberOfPages" type="Integer" />
    <aura:attribute name="currentPage" type="Integer" default="1" />   
    
    
    <aura:handler event="force:showToast" action="{!c.pageRefresh}" />
    
	<lightning:overlayLibrary aura:id="overlayLib"/>      
    
    
    <aura:attribute name="searchText" type="String" default=""/>
    <aura:handler name="change" value="{!v.searchText}" action="{!c.handleSearchTextChange}"/>    

    <aura:if isTrue="{!v.sharing == 'Me' }"> 
        <br></br>
        <lightning:layout horizontalAlign="center">
            <lightning:layoutItem flexibility="auto" size="12">
                <lightning:button label="Submit Mentor Application" onclick="{!c.submitMentorApplication}" />
            </lightning:layoutItem>
        </lightning:layout>
        <br></br>
    </aura:if>
    
    <aura:if isTrue="{!v.enableSearch == 'Yes'}">
        <lightning:input
                         aura:id="enter-search"
                         name="enter-search"
                         label="Search"
                         type="search"
                         value="{!v.searchText}"/>
        <br></br>
    </aura:if>
    
    
    <aura:iteration items="{!v.mentorListToDisplay}" var="item" indexVar="index">
        <aura:if isTrue="{!item.Is_Available__c}">
            <c:PORTAL_MentorListItem item="{!item}"
                                     sharing="{!v.sharing}"
                                     relevance="{!v.relevance}"
                                     contact="{!v.contact}"
                                     />
        </aura:if>
    </aura:iteration>
    
    <aura:if isTrue="{!v.totalNumberOfPages > 1}">
        <br></br>
        <div class="slds-align_absolute-center">
            <lightning:button label="Prev" title="Prev" onclick="{!c.previousPage}" disabled="{!v.previousButtonDisabled}"/>
            
            <div class="slds-p-horizontal_x-small">
                <div class="slds-text-body_regular">{!v.currentPage} of {!v.totalNumberOfPages}</div>
            </div>
            
            <lightning:button label="Next" title="Next" onclick="{!c.nextPage}" disabled="{!v.nextButtonDisabled}"/>
        </div>
    </aura:if>
    
</aura:component>