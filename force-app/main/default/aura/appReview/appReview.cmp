                                    <div class="slds-text-title">Street</div>
                                    <aura:If isTrue="{!and(workExpRec.Work_Experience__r.Contact_Person_Street__c != '', workExpRec.Work_Experience__r.Contact_Person_Street__c != null)}">
                                        <div class="slds-text-body--regular">{!workExpRec.Work_Experience__r.Contact_Person_Street__c}</div>
                                        <aura:set attribute="else">
                                            <div class="slds-text-body--regular opacity-5"><i>Not specified</i></div>
                                        </aura:set>
                                    </aura:If>
                                </div>

                                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                    <div class="slds-text-title">City</div>
                                    <aura:If isTrue="{!and(workExpRec.Work_Experience__r.Contact_Person_City__c != '', workExpRec.Work_Experience__r.Contact_Person_City__c != null)}">
                                        <div class="slds-text-body--regular">{!workExpRec.Work_Experience__r.Contact_Person_City__c}</div>
                                        <aura:set attribute="else">
                                            <div class="slds-text-body--regular opacity-5"><i>Not specified</i></div>
                                        </aura:set>
                                    </aura:If>
                                </div>

                                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                    <div class="slds-text-title">State</div>
                                    <aura:If isTrue="{!and(workExpRec.Work_Experience__r.Contact_Person_State__c != '', workExpRec.Work_Experience__r.Contact_Person_State__c != null)}">
                                        <div class="slds-text-body--regular">{!workExpRec.Work_Experience__r.Contact_Person_State__c}</div>
                                        <aura:set attribute="else">
                                            <div class="slds-text-body--regular opacity-5"><i>Not specified</i></div>
                                        </aura:set>
                                    </aura:If>
                                </div>

                                <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                    <div class="slds-text-title">Postal Code</div>
                                    <aura:If isTrue="{!and(workExpRec.Work_Experience__r.Contact_Person_PostalCode__c != '', workExpRec.Work_Experience__r.Contact_Person_PostalCode__c != null)}">
                                        <div class="slds-text-body--regular">{!workExpRec.Work_Experience__r.Contact_Person_PostalCode__c}</div>
                                        <aura:set attribute="else">
                                            <div class="slds-text-body--regular opacity-5"><i>Not specified</i></div>
                                        </aura:set>
                                    </aura:If>
                                </div>
                            </div>
                            <div class="slds-p-bottom--medium" />
                        </aura:iteration>
                        <aura:set attribute="else">
                            <ui:message severity="info">{!v.noDataText}</ui:message>
                        </aura:set>
                    </aura:If>
        		</form>
            </div>
        </div>
        <!-- END - WORK EXPERIENCE -->
        <!-- START PARENT GUARDIAN INFORMATION-->
        <aura:If isTrue="{!and(v.appRecord.Guardian_Full_Name__c != '', v.appRecord.Guardian_Full_Name__c != null)}">
            <div class="slds-section section-float">
                <div class="slds-col--padded">
                    <form class="slds-form--stacked">
                        <div class="slds-grid slds-wrap slds-grid--pull-padded">
                            <div class="slds-p-vertical--x-large">
                                <h3 class="slds-section__title">Parent Guardian Information</h3>
                            </div>
                        </div>
                        <div class="slds-grid slds-wrap slds-grid--pull-padded slds-p-vertical--medium iteration-block">
                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                <div class="slds-text-title">Guardian Full Name</div>
                                <div class="slds-text-body--regular">{!v.appRecord.Guardian_Full_Name__c}</div>
                            </div>
                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                <div class="slds-text-title">Guardian Phone Number</div>
                                <div class="slds-text-body--regular">{!v.appRecord.Guardian_Phone_Number__c}</div>
                            </div>
                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                <div class="slds-text-title">Guardian Email Address</div>
                                <div class="slds-text-body--regular">{!v.appRecord.Guardian_Email_Address__c}</div>
                            </div>
                            <div class="slds-p-horizontal--small slds-size--1-of-2 slds-medium-size--1-of-2 slds-large-size--1-of-2  slds-has-divider--bottom-space">
                                <div class="slds-text-title">Guardian Full Name</div>
                                <div class="slds-text-body--regular">{!v.appRecord.Guardian_Relationship__c}</div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </aura:If>
        

    </div>
</aura:component>