<design:component >
	<design:attribute name="showContinue" label="Show Continue Button" description="Setting this to true will allow users to see the 'Continue' button." />
    <design:attribute name="showEdit" label="Show Edit Button" description="Setting this to true will allow users to see the 'Edit' button." />
    <design:attribute name="showPrint" label="Show Print Button" description="Setting this to true will allow users to see the 'Print' button." />
</design:component>