<aura:component implements="forceCommunity:availableForAllPageTypes" access="global">
    <c:partnerLogin />

    <!-- hack to hide the chatter file previewer actions - please revisit when salesforce changes their class name for previewer actions -->
    <aura:html tag="style">
        button[title="View File Details"].previewerAction { 
            display: none !important; 
        }

        button[title="Upload New Version"].previewerAction { 
            display: none !important; 
        }

        button[title="Edit File Details"].previewerAction{ 
            display: none !important; 
        }

        button[title="Delete"].previewerAction { 
            display: none !important; 
        }

        a[title="Show More"].menuButton {
            display: none !important; 
        }

        .contentRegion {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .content {
            width: 100% !important;
        }

        .siteforceServiceBody .cCenterPanel {
            max-width: unset !important;
        }
        
        .corneredInput input {
            border: 2px solid #707070 !important;
            border-radius: 0 !important;
        }

        .invalidCorneredInput input {
            border: 2px solid rgb(194, 57, 52) !important;
            border-radius: 0 !important;
        }

        .slds-input-has-icon .slds-input__icon:not(button) {
            pointer-events: visible;
        }
    </aura:html> 
</aura:component>