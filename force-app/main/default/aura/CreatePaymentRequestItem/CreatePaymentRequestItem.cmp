<aura:component implements="force:lightningQuickActionWithoutHeader,force:hasRecordId,lightning:isUrlAddressable" access="global">
    <!-- open subtab-->
    <lightning:workspaceAPI aura:id="workspace" />
    
    <aura:attribute access="global" name="intializetype" type="String" default="" />
    <aura:attribute access="global" name="paymentrequestid" type="String" default="" />

    <!-- constructor -->
    <aura:handler name="init" value="{!this}" action="{!c.init}"/>

    <aura:renderIf isTrue="{!v.paymentrequestid}">
        <c:createPaymentRequestItemWizard paymentrequestid="{!v.paymentrequestid}"
                                          onrequestclose="{!c.closeFocusedTab}"
                                          onopentabs="{!c.openMultipleTabs}">                                  
        </c:createPaymentRequestItemWizard>
    </aura:renderIf>

    <!-- override email template publisher height -->
    <aura:html tag="style">
        .slds-rich-text-area__content {
            max-height: 40vh;
        }
    </aura:html> 
</aura:component>