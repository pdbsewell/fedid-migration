<aura:component implements="forceCommunity:availableForAllPageTypes" access="global" controller="PORTAL_DirectoryController">
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="topCountriesList" type="Object[]"/>
    <aura:attribute name="topIndustriesList" type="Object[]"/>
    <aura:attribute name="totalAlumniCount" type="Integer"/>
    
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>


        <div class="slds-grid slds-wrap">
			<div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
    			<ul class="slds-p-right_small">
                    <li class="slds-welcome-mat__tile">
                        <div class="slds-box slds-box_x-small slds-media summary-box">
                            <div class="slds-media__figure slds-media__figure_fixed-width slds-align_absolute-center slds-m-left_xx-small">
                                <div class="slds-welcome-mat__tile-icon-container">
                                    <span class="slds-icon_container slds-icon-utility-knowledge_base">
    									<lightning:icon iconName="standard:groups" alternativeText="Alumni" />                                
                                    </span>
                                </div>
                            </div>
                            <div class="slds-media__body slds-border_left slds-p-around_small summary-box">
                                <h3 class="slds-welcome-mat__tile-title">Alumni Members</h3>
                                <p class="slds-welcome-mat__tile-description slds-text-heading_large">{!v.totalAlumniCount}</p>
                                <p class="slds-welcome-mat__tile-description slds-text-title_caps slds-p-bottom_x-small">Alumni</p>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
			<div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
    			<ul class="slds-p-right_small slds-p-left_small">
                    <li class="slds-welcome-mat__tile">
                        <div class="slds-box slds-box_x-small slds-media summary-box">
                            <div class="slds-media__figure slds-media__figure_fixed-width slds-align_absolute-center slds-m-left_xx-small">
                                <div class="slds-welcome-mat__tile-icon-container">
                                    <span class="slds-icon_container slds-icon-utility-knowledge_base">
                                        <lightning:icon iconName="standard:account" alternativeText="Industries" />
                                    </span>
                                </div>
                            </div>
                            <div class="slds-media__body slds-border_left slds-p-around_small summary-box">
                                <h3 class="slds-welcome-mat__tile-title">Top Industries</h3>
                                <ul class="slds-list--dotted">
                                    <aura:iteration items="{!v.topIndustriesList}" var="item">
                                        
                                        <li class="slds-item">
                                            <p class="slds-welcome-mat__tile-description">{!item.Name}</p>
                                        </li>
                                        
                                    </aura:iteration>
                                </ul>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>              
            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                <ul class="slds-p-left_small">
                    <li class="slds-welcome-mat__tile">
                        <div class="slds-box slds-box_x-small slds-media summary-box">
                            <div class="slds-media__figure slds-media__figure_fixed-width slds-align_absolute-center slds-m-left_xx-small">
                                <div class="slds-welcome-mat__tile-icon-container">
                                    <span class="slds-icon_container slds-icon-utility-knowledge_base">
                                        <lightning:icon iconName="standard:location" alternativeText="Countries" />
                                    </span>
                                </div>
                            </div>
                            <div class="slds-media__body slds-border_left slds-p-around_small summary-box">
                                <h3 class="slds-welcome-mat__tile-title">Top Countries</h3>
                                <ul class="slds-list--dotted">
                                    <aura:iteration items="{!v.topCountriesList}" var="item">
                                        
                                        <li class="slds-item">
                                            <p class="slds-welcome-mat__tile-description">{!item.MailingCountry}</p>
                                        </li>
                                        
                                    </aura:iteration>
                                </ul>
                            </div>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

    
</aura:component>