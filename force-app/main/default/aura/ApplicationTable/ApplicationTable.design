<design:component>
    <design:attribute name="fieldSet" description="Fields and Labels to show on the table - JSON format" />
    <design:attribute name="targetObject" description="Data to render below the table" />
    <design:attribute name="clause" description="Used to define the filter for the table" />
    <design:attribute name="isEditable" description="Mark as active if the component can be edited, otherwise it is read only" />
</design:component>