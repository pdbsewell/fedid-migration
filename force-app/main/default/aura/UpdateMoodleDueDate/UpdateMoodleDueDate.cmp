<!--
 * @description      : Uses MIX API to initiate an update to the relevant assignments due date in Moodle eLMS
 * @author            : Angelo Rivera
 * @group             : Student Admin
 * @last modified on  : 2021-07-02
 * @last modified by  : Angelo Rivera
 * Modifications Log
 * Ver   Date            Author             Modification
 * 1.0   2021-07-02 - Angelo Rivera - Initial Creation
 -->

<aura:component description="Uses MIX API to initiate an update to the relevant assignments due date in Moodle eLMS."
                implements="force:lightningQuickActionWithoutHeader,force:hasRecordId,force:appHostable,flexipage:availableForAllPageTypes"
                access="global"
                controller="UpdateMoodleCC">

    <!-- attributes -->
    <aura:attribute name="showSpinner" type="Boolean" default="true"/>

    <aura:handler name="init" value="{!this}" action="{!c.init}"/>

    <!-- spinner -->
    <aura:if isTrue="{!v.showSpinner}">
        <div class="backgroundInverse slds-align-middle">
            <lightning:spinner alternativeText="Loading" variant="inverse">Sending Data</lightning:spinner>
        </div>
        <div class="slds-text-align_center slds-text-heading_medium slds-p-top_small">{!$Label.c.Moodle_Integration_Spinner}</div>
    </aura:if>

</aura:component>