<!--Check password this is a view only page, no backend logic here-->
<aura:component implements="forceCommunity:availableForAllPageTypes" access="global">
    <aura:attribute name="goToLoginLabel" type="String" required="false" default="Back to Login"/>
    <aura:attribute name="goToLoginUrl" type="String" required="false" default="./"/>
    <ltng:require styles="{!$Resource.Monash_Portal_CSS_Minified}"/>
    
	<div class="relative">
        <div class="flex justify-center my-4 bg-cover" style="{!'background-image:url('+$ContentAsset.03S4a00000004dP+')'}">
            <div class="max-w-lg flex flex-col justify-center items-center px-6 pt-10 pb-6 overflow-hidden shadow-lg bg-white ucin-whitebox">
                <div class="py-6 self-start">
                    <div class="font-extrabold text-3xl sm:text-5xl mb-2 uppercase leading-none">Alumni Portal</div>
                    <div class="font-medium text-2xl sm:text-3xl mb-2 uppercase leading-none">Check Your Email</div>
                </div>
                <div class="relative w-full flex justify-center items-center">
                    <p class="text-gray text-base">
                        Check the email account associated with your user name for instructions on resetting your password. 
                        Remember to look in your spam folder, where automated messages sometimes filter. 
                        If you still can't log in, contact your administrator.
                    </p>
                </div>
                <div class="self-start w-full sm:w-4/5 max-w-xs pt-2">
                    <p class="text-grey pb-2 text-lg">
                        <a class="underline inline-block align-baseline font-bold text-blue hover:text-blue-800" href="{!v.goToLoginUrl}">
                            {!v.goToLoginLabel}
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</aura:component>