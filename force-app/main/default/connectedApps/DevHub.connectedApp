    <contactEmail>unicrm.coreadmin@monash.edu</contactEmail>
    <description>DevHub Access for Jenkins User</description>
    <label>DevHub</label>
    <oauthConfig>
        <callbackUrl>http://localhost:1717/OauthRedirect</callbackUrl>
