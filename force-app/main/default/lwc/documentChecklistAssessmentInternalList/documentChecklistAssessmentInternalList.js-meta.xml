<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata" fqn="documentChecklistAssessmentInternalList">
    <apiVersion>63.0</apiVersion>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage">
            <property label="Application Id" name="applicationId" type="String" description="Record Id of the parent application of the checklist items that needs to be shown"/>
        </targetConfig>
        <targetConfig targets="lightning__RecordPage">
            <property label="File Column Count" name="fileColumnCount" type="String" default="2" datasource="1,2" description="Columns count for the filesshown by the checklist"/>
            <property label="View Type" name="viewType" type="String" datasource="Application,Application Course Preference,Task" description="Object page where the component is shown"/>
            <property label="Prioritize Other?" name="prioritizeOther" type="Boolean" default="false" description="Other section should be shown at the top"/>
            <property label="Show Header" name="showHeader" type="Boolean" default="true" description="Header section is shown"/>
            <property label="Show Refresh" name="showRefresh" type="Boolean" default="true" description="Refresh button is shown"/>
            <property label="Show New" name="showNew" type="Boolean" default="true" description="New Checklist button is shown"/>
            <property label="Show Document Reminder" name="showDocumentReminder" type="Boolean" default="true" description="Document Reminder button is shown"/>
            <objects>
                <object>Application__c</object>
                <object>Application_Course_Preference__c</object>
                <object>Task</object>
            </objects>
        </targetConfig>
    </targetConfigs>
    <isExposed>true</isExposed>
</LightningComponentBundle>