<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This permission set enables a given user the ability to create and maintain Lightning Email Templates</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>MUM Admissions - Manage Email Template</label>
    <userPermissions>
        <enabled>true</enabled>
        <name>AccessContentBuilder</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>CreateLtngTempFolder</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>CreateLtngTempInPub</name>
    </userPermissions>
</PermissionSet>
