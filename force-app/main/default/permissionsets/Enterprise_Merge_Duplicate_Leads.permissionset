<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>This gives Enterprise users the ability to merge duplicate leads.
Merging duplicate leads requires delete permission to lead records.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Enterprise - Merge Duplicate Leads</label>
    <license>Salesforce</license>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllFields>false</viewAllFields>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <recordTypeVisibilities>
        <recordType>Lead.Enterprise</recordType>
        <visible>true</visible>
    </recordTypeVisibilities>
</PermissionSet>
