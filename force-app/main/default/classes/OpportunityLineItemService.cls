global with sharing class OpportunityLineItemService {

    /**
    * @author Mathew Jose
    * @date 30/10/2019
    * @group SF Offer
    * @description 
    */
    public inherited sharing class OppLineItemCreator{

        @testVisible
        private PriceBookEntriesSelector priceBookEntrySelector;

        /********VARIABLES**********/
        @TestVisible private Opportunity opp;
        @TestVisible private Pricebook2 pricebook;
        @TestVisible private OfferWizardWrapper offerWrapper;
        @TestVisible private List<Application_Course_Preference__c> acpList;
        @TestVisible private Map<ID, Application_Course_Preference__c> updatedACPs;
        @TestVisible private List<PricebookEntry> additionalProductsList;
        @TestVisible private List<OpportunityLineItem>oppLineList;
        @TestVisible private Map<String, String> additionalACPClauses;
        @TestVisible private Map<String, String> additionalBahasaACPClauses;
        @TestVisible private Map<String, Course_Offering__c> courseOfferingByAcpId;
        /********CONSTRUCTORS**********/
        //public OppLineItemCreator(Opportunity opp, List<Application_Course_Preference__c> acpList, List<PricebookEntry> additionalProductsList){
        public OppLineItemCreator(OfferWizardWrapper offerWrapper){
            this.offerWrapper = offerWrapper;
            this.opp = offerWrapper.opptyRecord;
            this.acpList = offerWrapper.selectedACPList;
            this.additionalProductsList = offerWrapper.additionalProducts;
            this.additionalACPClauses = offerWrapper.additionalACPClauses;
            this.additionalBahasaACPClauses = offerWrapper.additionalBahasaACPClauses;
            this.courseOfferingByAcpId = offerWrapper.courseOfferingByAcpId;
            this.oppLineList = new List<OpportunityLineItem>();
            this.priceBookEntrySelector = new PriceBookEntriesSelector();
            this.updatedACPs = offerWrapper.updatedACPs;
        }
        /********PUBLIC**********/

        /**
        * @description set up opportunity line items for creation via the make an offer wizard
        * @author Mathew Jose
        * @return List<OpportunityLineItem> generated by looping through all the acp's and grant/scholarships 
        * @example 
        * List<OpportunityLineItem>oppLinesToInsert = OpportunityLineItemService.OppLineItemCreator(oppRec,selectedACPList,lineItemsList).execute();
        **/        
        public List<OpportunityLineItem> execute(){
            this.pricebook = this.priceBookEntrySelector.selectPricebook2ByExtId(this.opp.Pricebook2.External_ID__c);
            convertAcpsToOppLineItems();
            convertAdditionalProductsToOppLineItems();
            return this.oppLineList;
        }
        /**
        * @description method is used to convert acp's selected in the offer wizard into list of opportunity line items
        * @author Mathew Jose
        * @return Instance of OppLineItemCreator  
        */          
        public OppLineItemCreator convertAcpsToOppLineItems(){
            if (acpList == null || acpList.isEmpty() == true) return this;

			Map<string,PricebookEntry> productIdToPBEntryMap = new Map<string,PricebookEntry>();
            for(Application_Course_Preference__c acp : acpList){
                productIdToPBEntryMap.put(acp.Course_Product_ID__c, null);
                productIdToPBEntryMap.put(acp.Course_Code__c, null);
            } 
            productIdToPBEntryMap = this.priceBookEntrySelector.selectByProduct2ExternalId(this.pricebook.Id,productIdToPBEntryMap.keySet());
            for(Application_Course_Preference__c acp : acpList){
                //fetch using course product id, course code + unit set(if applicable)
                PricebookEntry pbe = productIdToPBEntryMap.get(acp.Course_Product_Id__c);
                //if nothing found try with course code only (this is a rule only for BUNINI courses)
                if (pbe == null) { 
                    pbe = productIdToPBEntryMap.get(acp.Course_Code__c);
                    if (pbe != null && (pbe.Product2.Product_Bundle__c == null || pbe.Product2.Product_Bundle__r.ProductCode != 'BUNUNI')){     
                        pbe = null;
                    }
                }
                if (pbe != null){   //if found a pbe then create oli
                    Course_Offering__c co = courseOfferingByAcpId.get(acp.Id) != null ? courseOfferingByAcpId.get(acp.Id) : acp.Course_Offering__r;
                    oppLineList.add(setOpportunityLineForACP(pbe, acp, co));       
                }else{  //nothing found, this is a problem
                    //throw new LogUtilityException('Product and PricebookEntry not found: '+acp.Course_Product_Id__c);
                    throw new LogUtilityException('Product and/or PricebookEntry not found for '+ acp.Course_Code__c +' - '+ acp.Course_Title__c +' . Please check stg course fee, course fee, product and pricebook entry for the course.'+this.pricebook.Id);
                }
            }
            return this; 
        }
        private OpportunityLineItem setOpportunityLineForACP(PricebookEntry pbe, Application_Course_Preference__c sourceACP, Course_Offering__c co){
            Application_Course_Preference__c acp = updatedACPs != null && updatedACPs.get(sourceACP.Id) != null ? updatedACPs.get(sourceACP.Id) : sourceACP;

            OpportunityLineItem oli = new OpportunityLineItem(
                OpportunityId = opp.Id,
                Quantity = 1,
                UnitPrice = pbe.UnitPrice,
                Product2Id = pbe.Product2Id,
                PricebookEntryId = pbe.Id,
                Application_Course_Preference__c = acp.Id
            );
            //is there any additional clause note ? 
            if (additionalACPClauses != null && additionalACPClauses.get(acp.Id) != null) { 
                oli.Additional_Clause_Notes__c = additionalACPClauses.get(acp.Id);
            }
            //is there any additional Bahasa clause note ? 
            if (additionalBahasaACPClauses != null && additionalBahasaACPClauses.get(acp.Id) != null) { 
                oli.Additional_Bahasa_Clause_Notes__c = additionalBahasaACPClauses.get(acp.Id);
            }
            //stamp dates
            oli.Override_Start_Date__c = acp.Agreed_Start_Date__c;
            oli.Override_End_Date__c = acp.Revised_End_Date__c;
            //parsing duration
            String durationUnit = sourceACP.Credit_Adjusted_Course_Duration_Type__c != null ? sourceACP.Credit_Adjusted_Course_Duration_Type__c : 'Year'; 
            if (co.Override_Duration__c != null){
                oli.Override_Duration__c = durationToString(co.Override_Duration__c, durationUnit);
            }else if (co.Course_Duration__c != null){
                oli.Override_Duration__c = durationToString(co.Course_Duration__c, durationUnit);
            }

            if (acp.Credit_Adjusted_Course_Duration__c > 0){
                oli.Override_Duration_With_RPL__c = durationToString(acp.Credit_Adjusted_Course_Duration__c, durationUnit);
            }else if (co.Override_Duration__c != null){
                oli.Override_Duration_With_RPL__c = durationToString(co.Override_Duration__c, durationUnit);
            }else {
                oli.Override_Duration_With_RPL__c = durationToString(co.Course_Duration__c, durationUnit);
            }
            return oli;
        }
        private String durationToString(Decimal duration, String unit){
            if (duration != null && duration.round() == duration) return duration.intValue() +' '+ unit + '(s)';
            return duration +' '+ unit + '(s)';
        }
        /**
        * @description method is used to convert grants/scholarships selected in the wizard into list of opportunity line items
        * @author Mathew Jose
        * @return Instance of OppLineItemCreator  
        */        
        public OppLineItemCreator convertAdditionalProductsToOppLineItems(){
            if(additionalProductsList != null && !additionalProductsList.IsEmpty()){
                for(PricebookEntry pbe : additionalProductsList){
                    OpportunityLineItem addOli = new OpportunityLineItem();
                    addOli.OpportunityId = opp.Id;
                   
                    addOli.Quantity = 1;
                    addOli.Product2Id = pbe.Product2Id;
                    addOli.PricebookEntryId = pbe.Id;
                    addOli.UnitPrice = pbe.UnitPrice;
                    if(pbe.Product2.Expiry_days__c != null){
                        addOli.Expiry_Date__c = Date.today().addDays(pbe.Product2.Expiry_days__c.intValue());
                    }
                    oppLineList.add(addOli); 
                }
            }
            return this;         
        } 
    }
}