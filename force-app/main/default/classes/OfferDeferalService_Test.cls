@isTest(isParallel=true)
public class OfferDeferalService_Test {
    @isTest
    private static void testgetOffersForDeferral_nooffer(){ 
        Test.startTest();  
        String offers = OfferDeferalService.getOffersForDeferral('00367890');
        Test.stopTest();
        System.assert(offers != null,'Deferral is going ok');
    }

    @isTest
    private static void testOffersForDeferral_success(){
        OfferDeferalService.OfferCourseOfferingMatcher handler = new OfferDeferalService.OfferCourseOfferingMatcher('0034a0000000HnhAAE',new Set<String>{'Signed'});
        handler.opptySelector = (OpportunitiesSelector) Test.createStub(
            OpportunitiesSelector.class, new OpportunitiesSelectorMock()
        );
        handler.coSelector = (CourseOfferingSelector) Test.createStub(
            CourseOfferingSelector.class, new CourseOfferingsSelectorMock()
        );
        String offers = handler.execute();
        System.debug('>> testOffersForDeferral_success : ' + offers);
        System.assert(offers != null,'Deferral is going ok');
        System.assert(offers.countMatches('a205O000001EwkTQAS') == 1,'Administration fees is not excluded');
    }


