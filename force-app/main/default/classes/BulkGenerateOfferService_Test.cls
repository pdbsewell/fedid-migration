    @isTest 
    Static void test_generateQuote(){
        
        // GIVEN : Bulk processing is set for course transfer
        Bulk_Data_Processing__c bdp = new Bulk_Data_Processing__c(Type__c = BDPConstants.COURSE_TRANSFER_TYPE);
        
        Test.startTest();
        
        	// WHEN : Generate quote is invoked
            BulkGenerateOfferService service = new BulkGenerateOfferService();
            Opportunity[] oppties = new Opportunity[]{new Opportunity()};
            service.generateQuote(bdp,oppties);
        Test.stopTest();
        
        // THEN : Opportunities stage name is set to 'Specialist Review'
        Assert.areEqual('Specialist Review', oppties[0].StageName, 'Opportunities stage name should have been set to Specialist Review');
    }

