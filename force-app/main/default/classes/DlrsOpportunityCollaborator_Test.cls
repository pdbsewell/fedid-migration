@isTest(isParallel=false) // Tests on Opportunity leverage Test.getStandardPricebookId() which cannot be called from parallel Apex tests
public class DlrsOpportunityCollaborator_Test {

    /**
     * Test for DLRS logic.
     **/
    @IsTest
    private static void testTrigger() {
        Exception exc = null; // for assert
        try{
            // GIVEN: 3 different account (for external organisations) are in place
            Account acct1 = new Account(Name='Acct1');
            Database.insert(acct1);        
            
            // GIVEN: An open oppties are associated to it
            RecordType recType = [SELECT Id FROM RecordType WHERE SObjectType = 'Opportunity' AND DeveloperName = 'Enterprise' LIMIT 1][0];
            Opportunity oppty1 = new Opportunity();
            oppty1.AccountId = acct1.Id;
            oppty1.RecordTypeId = recType.Id;
            oppty1.Name = 'Oppty1';
            oppty1.Amount = 1.00;
            oppty1.CloseDate = Date.today()+1;
            oppty1.StageName = 'Open';
            Database.insert(oppty1);

            // GIVEN: An open oppties are associated to it
            Opportunity_Collaborator__c collaborator1 = new Opportunity_Collaborator__c();
            collaborator1.Opportunity__c = oppty1.Id;
            Database.insert(collaborator1);

            // WHEN: force the dlrs_Opportunity_CollaboratorTrigger to be invoked, fails the test if org config or other Apex code prevents this.
            Test.startTest();
            // Auto Generated by the Declarative Lookup Rollup Summaries Tool package (dlrs)
            dlrs.RollupService.testHandler(collaborator1);
            Test.stopTest();
        } catch (Exception e) {
            exc = e;
        }
        
        // THEN: no exception occured
        System.assertEquals(null, exc, 'An exception has occured when running the DLRS rollup service on class: '+String.valueOf(Opportunity_Collaborator__c.class));
    }
}