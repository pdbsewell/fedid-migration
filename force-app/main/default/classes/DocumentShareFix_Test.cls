@IsTest
public with sharing class DocumentShareFix_Test {
    public static String CONTACT_NAME = 'DocumentBatchFix';

    @TestSetup
    public static void setup(){
        Contact c = StudFirst_TestHelper.createApplicant();
        c.First_Name__c = CONTACT_NAME;
        insert c;

        Application__c app = StudFirst_TestHelper.createApplication(c);
        app.Source_System__c = 'IDP';
        insert app;

        List<ContentDocumentLink> cDocLinks = new List<ContentDocumentLink>();

        ContentVersion cv = new ContentVersion();
        cv.ContentLocation = 'S';
        cv.VersionData = EncodingUtil.base64Decode('');
        cv.Title = 'TEST';
        cv.PathOnClient = 'test.png';
        insert cv;

        ContentVersion cvRes = [SELECT ContentDocumentId FROM ContentVersion WHERE Id= :cv.Id];

        ContentDocumentLink cdLink = new ContentDocumentLink();
        cdLink.ContentDocumentId = cvRes.ContentDocumentId;
        cdLink.LinkedEntityId = c.Id;
        cdLink.ShareType = 'V';
        cdLink.Visibility = 'AllUsers';
        cDocLinks.add(cdLink);

        ContentDocumentLink cdLink2 = new ContentDocumentLink();
        cdLink2.ContentDocumentId = cvRes.ContentDocumentId;
        cdLink2.LinkedEntityId = app.Id;
        cdLink2.ShareType = 'V';
        cdLink2.Visibility = 'AllUsers';
        cDocLinks.add(cdLink2);

        insert cDocLinks;
    }

    @IsTest
    public static void test_ContentDocumentReassignTest(){
        DocumentShareFix docFix = new DocumentShareFix();

        Test.startTest();
        ID batchprocessid = Database.executeBatch(docFix, 100);
        Test.stopTest();

        List<Contact> contact = [SELECT Id FROM Contact WHERE First_Name__c = :CONTACT_NAME];
        System.assert(contact.size() > 0, 'Unable to get contact');

        List<ContentDocumentLink> links = [SELECT Id, ShareType FROM ContentDocumentLink WHERE LinkedEntityId = :contact[0].Id];
        System.assert(links.size() > 0, 'Unable to get any content document links');

        Boolean updated = true;

        for(ContentDocumentLink link : links){
            if(link.ShareType != 'I'){
                updated = false;
            }
        }
        System.assert(updated == true, 'Unable to update share type');
    }
}