    <description>PD - This process builder updates the certificate to be printed based on the outcome</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
[Application_Course_Preference__c].Course_Type__c = &apos;Short_Course&apos;,
ISPICKVAL( [Application_Course_Preference__c].Course_Result__c ,&quot;&quot;),
NOT(ISPICKVAL(PRIORVALUE([Application_Course_Preference__c].Course_Result__c),&quot;&quot;)))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_11</name>
        <dataType>Boolean</dataType>
        <expression>AND(
{!myVariable_current.Course_Type__c} = &apos;Short_Course&apos;,
ISPICKVAL( {!myVariable_current.Course_Result__c} ,&quot;&quot;),
NOT(ISPICKVAL(PRIORVALUE({!myVariable_current.Course_Result__c}),&quot;&quot;)))</expression>
    </formulas>
