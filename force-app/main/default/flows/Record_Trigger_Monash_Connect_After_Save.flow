<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Reminder For Cases in Awaiting Feedback for 2 days</description>
        <name>Reminder_For_Awaiting_Feedback</name>
        <label>Reminder For Awaiting Feedback</label>
        <locationX>50</locationX>
        <locationY>455</locationY>
        <actionName>Case.Reminder_for_Enquiries_In_Awaiting_Feedback</actionName>
        <actionType>emailAlert</actionType>
        <connector>
            <targetReference>Assign_Case_Comment_Fields</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>SObjectRowId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>Case.Reminder_for_Enquiries_In_Awaiting_Feedback</nameSegment>
    </actionCalls>
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>To assign case comments field for the case comment to be created</description>
        <name>Assign_Case_Comment_Fields</name>
        <label>Assign Case Comment Fields</label>
        <locationX>50</locationX>
        <locationY>575</locationY>
        <assignmentItems>
            <assignToReference>CaseComentRecordVar.ParentId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>CaseComentRecordVar.CommentBody</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>caseCommentTemplate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>createCaseCommentRecord</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_Send_Email_Checkbox</name>
        <label>Check Send Email Checkbox</label>
        <locationX>182</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Send_Email_is_True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.sendReminderEmailForAwaitingFeedback__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Awaiting Customer Feedback</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.sendReminderEmailForAwaitingFeedback__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Reminder_For_Awaiting_Feedback</targetReference>
            </connector>
            <label>Send Email is True</label>
        </rules>
    </decisions>
    <description>To be used to send email alerts or related field updates in after save</description>
    <environments>Default</environments>
    <interviewLabel>Record Trigger: Monash Connect After Save {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record Trigger: Monash Connect After Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>createCaseCommentRecord</name>
        <label>createCaseCommentRecord</label>
        <locationX>50</locationX>
        <locationY>695</locationY>
        <inputReference>CaseComentRecordVar</inputReference>
    </recordCreates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Send_Email_Checkbox</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>RecordType_DeveloperName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Monash_Connect_Enquiry</stringValue>
            </value>
        </filters>
        <filters>
            <field>RecordType_DeveloperName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>MonCon_Support</stringValue>
            </value>
        </filters>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>caseCommentTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Reminder Email has been sent regarding awaiting feedback for more than 2 days.
Case Number: {!$Record.CaseNumber}
Contact Email: {!$Record.ContactEmail}</text>
    </textTemplates>
    <variables>
        <name>CaseComentRecordVar</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>CaseComment</objectType>
    </variables>
</Flow>
