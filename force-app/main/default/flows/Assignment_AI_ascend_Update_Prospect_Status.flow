        <inputParameters>
            <name>message</name>
            <value>
                <stringValue>Error Update Prospect Status</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>recordId</name>
            <value>
                <elementReference>$Record.ucinn_ascendv2__Contact__r.AccountId</elementReference>
            </value>
