    <decisions>
        <description>Does the Course Offering have an attached course?</description>
        <name>Is_Course_attached</name>
        <label>Is Course attached?</label>
        <locationX>1271</locationX>
        <locationY>1403</locationY>
        <defaultConnectorLabel>No attached Course - Do Nothing</defaultConnectorLabel>
        <rules>
            <name>Has_Attached_Course</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Course__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Course_Type_PD</targetReference>
            </connector>
            <label>Has Attached Course</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is the Course Cancelled?</description>
        <name>Is_Course_Cancelled</name>
        <label>Is Course Cancelled?</label>
        <locationX>842</locationX>
        <locationY>2807</locationY>
        <defaultConnectorLabel>Course Is Not Cancelled</defaultConnectorLabel>
        <rules>
            <name>Course_Is_Cancelled</name>
            <conditionLogic>1 AND 2 AND (3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Confirmed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Confirmed__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_ACP_to_Cancelled</targetReference>
            </connector>
            <label>Course Is Cancelled</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is the Course Confirmed?</description>
        <name>Is_Course_Confirmed</name>
        <label>Is Course Confirmed?</label>
        <locationX>446</locationX>
        <locationY>2699</locationY>
        <defaultConnector>
            <targetReference>Is_Course_Cancelled</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Course Not Confirmed</defaultConnectorLabel>
        <rules>
            <name>Course_Is_Confirmed</name>
            <conditionLogic>1 AND (2 OR 3) AND (4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Confirmed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Available</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Full</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Confirmed__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_ACP_to_confirmed</targetReference>
            </connector>
            <label>Course Is Confirmed</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is the associated course type Professional development?</description>
        <name>Is_Course_Type_PD</name>
        <label>Is Course Type PD?</label>
        <locationX>908</locationX>
        <locationY>1511</locationY>
        <defaultConnector>
            <targetReference>Is_Short_Course_Registration_Close_Date_Blank</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Course Type Not PD</defaultConnectorLabel>
        <rules>
            <name>Course_Type_Is_PD</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Course__r.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Short_Course</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Faculty_Course_Type_fields</targetReference>
            </connector>
            <label>Course Type Is PD</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is associated Course Type Professional Development?</description>
        <name>Is_Course_Type_Professional_Development</name>
        <label>Is Course Type Professional Development?</label>
        <locationX>908</locationX>
        <locationY>2591</locationY>
        <defaultConnectorLabel>Course Type Not PD</defaultConnectorLabel>
        <rules>
            <name>Course_Type_PD</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Course__r.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Short_Course</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Course_Confirmed</targetReference>
            </connector>
            <label>Course Type PD</label>
        </rules>
    </decisions>
    <decisions>
        <description>Has the course offering reached the maximum capacity?</description>
        <name>Is_Maximum_Capacity_Zero</name>
        <label>Is Maximum Capacity Zero?</label>
        <locationX>1271</locationX>
        <locationY>863</locationY>
        <defaultConnector>
            <targetReference>Is_Course_attached</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Has_Reached_Max_Capacity</name>
            <conditionLogic>1 AND 2 AND ((3 AND 4) OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Draft</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Remaining_Places</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Registration_Count__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_CO_Status_To_Full</targetReference>
            </connector>
            <label>Has Reached Max Capacity</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is Short Course Registration Close Date Blank?</description>
        <name>Is_Short_Course_Registration_Close_Date_Blank</name>
        <label>Is Short Course Registration Close Date Blank?</label>
        <locationX>908</locationX>
        <locationY>2051</locationY>
        <defaultConnector>
            <targetReference>Is_Course_Type_Professional_Development</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Short_Course_Registration_Close_Date_Is_Blank</name>
            <conditionLogic>1 AND 2 AND (3 OR 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Registration_Close_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Course__r.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Short_Course</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Start_Date__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Registration_Close_Date__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Default_Registration_Close_Date</targetReference>
            </connector>
            <label>Short Course Registration Close Date Is Blank</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if the Course Offering Status is Cancelled</description>
        <name>Is_Status_Cancelled</name>
        <label>Is Status Cancelled?</label>
        <locationX>1271</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Is_Maximum_Capacity_Zero</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Status_Is_Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_CO_Cancelled_Date</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Status Is Cancelled</label>
        </rules>
    </decisions>
    <description>Update fields on Course Offering - Date Cancelled/Postponed, Status, Course Type, Faculty and Registration Close Date. Update ACP fields - Status
Migrated from Course Offering WFs and PBs,
-Update Course Offering Date Cancelled
-Update course offering status to Full
-PD Course Offering Update
-PD Update CO [Partitioning for Short Courses]</description>
    <environments>Default</environments>
    <formulas>
        <name>Faculty</name>
        <dataType>String</dataType>
        <expression>CASE( 
{!$Record.Course__r.Managing_Faculty__c}, &quot;Faculty of Education&quot;,&quot;Faculty of Education&quot;,
&quot;Faculty of Medicine, Nursing &amp;amp; Health Sciences&quot;,&quot;Faculty of Medicine, Nursing &amp;amp; Health Sciences&quot;,
&quot;The School of Public Health and Preventive Medicine (SPHPM)&quot;,&quot;The School of Public Health and Preventive Medicine (SPHPM)&quot;,
&quot;Monash Centre for Health Research and Implementation (MCHRI)&quot;,&quot;Monash Centre for Health Research and Implementation (MCHRI)&quot;,
&quot;MNHS Student Academic Support Unit (SASU)&quot;,&quot;MNHS Student Academic Support Unit (SASU)&quot;,
&quot;School of Clinical Sciences (SCS)&quot;,&quot;School of Clinical Sciences (SCS)&quot;,
&quot;Faculty of Business &amp; Economics&quot;,&quot;Faculty of Business &amp; Economics&quot;,
&quot;Faculty of Arts&quot;,&quot;Faculty of Arts&quot;,
&quot;Monash Sustainable Development Institute&quot;,&quot;Monash Sustainable Development Institute&quot;,
&quot;Monash Centre for Professional Development&quot;,&quot;Monash Centre for Professional Development&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>Is_Record_New</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <description>Set Registration Close Date to Course_Offering__c.Start_Date__c - 1</description>
        <name>Registration_Close_Date</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Start_Date__c} - 1</expression>
    </formulas>
    <formulas>
        <name>Remaining_Places</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Venue__r.Maximum_Capacity__c} - {!$Record.Registration_Count__c}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Today&apos;s Date</description>
        <name>Today_Date</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>Course Offering : AS : Course Offering Field Updates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Course Offering : AS : Course Offering Field Updates</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Set Default Registration Close Date on Course Offering</description>
        <name>Set_Default_Registration_Close_Date</name>
        <label>Set Default Registration Close Date</label>
        <locationX>644</locationX>
        <locationY>2159</locationY>
        <connector>
            <targetReference>Is_Course_Type_Professional_Development</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Error_setting_default_CO_registration_close_date</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Registration_Close_Date__c</field>
            <value>
                <elementReference>Registration_Close_Date</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update ACP Record to Cancelled</description>
        <name>Update_ACP_to_Cancelled</name>
        <label>Update ACP to Cancelled</label>
        <locationX>578</locationX>
        <locationY>2915</locationY>
        <faultConnector>
            <targetReference>Error_updating_ACP_to_Cancelled</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Registered</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Cancelled</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Application_Course_Preferences__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update ACP to confirmed</description>
        <name>Update_ACP_to_confirmed</name>
        <label>Update ACP to confirmed</label>
        <locationX>50</locationX>
        <locationY>2807</locationY>
        <faultConnector>
            <targetReference>Error_updating_ACP_to_confirmed</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Registered</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Course_Confirmed__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Application_Course_Preferences__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update the date on Cancelled/Postponed Date to today&apos;s date</description>
        <name>Update_CO_Cancelled_Date</name>
        <label>Update CO Cancelled Date</label>
        <locationX>1007</locationX>
        <locationY>431</locationY>
        <connector>
            <targetReference>Is_Maximum_Capacity_Zero</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Error_Updating_CO_Cancelled_Date</targetReference>
