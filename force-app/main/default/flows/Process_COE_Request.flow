                <fields>
                    <name>Help_Text</name>
                    <fieldText>&lt;p&gt;&lt;em style=&quot;background-color: rgb(248, 248, 248); font-size: 14px; font-family: Slack-Lato, Slack-Fractions, appleLogo, sans-serif; color: rgb(238, 52, 14);&quot;&gt;For Transfer reason, please choose Discontinued Course Code.&lt;/em&gt;&lt;/p&gt;&lt;p&gt;&lt;em style=&quot;background-color: rgb(248, 248, 248); font-size: 14px; font-family: Slack-Lato, Slack-Fractions, appleLogo, sans-serif; color: rgb(238, 52, 14);&quot;&gt;For Intermit reason, please choose Intermit Course Code.&lt;/em&gt;&lt;/p&gt;</fieldText>
