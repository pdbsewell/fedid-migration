                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                    <visibilityRule>
                        <conditionLogic>or</conditionLogic>
                        <conditions>
                            <leftValueReference>Reason_for_COE</leftValueReference>
                            <operator>EqualTo</operator>
                            <rightValue>
                                <stringValue>TRANSFER</stringValue>
                            </rightValue>
                        </conditions>
                        <conditions>
                            <leftValueReference>Reason_for_COE</leftValueReference>
                            <operator>EqualTo</operator>
                            <rightValue>
                                <stringValue>INTERMIT</stringValue>
                            </rightValue>
