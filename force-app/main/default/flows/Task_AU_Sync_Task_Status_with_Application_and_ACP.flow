    <assignments>
        <name>Release_ACP</name>
        <label>Release ACP</label>
        <locationX>314</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>ACPRecordToUpdate.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_ACP_Record.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>ACPRecordToUpdate.Workflow_Status__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Released</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>ACPRecordToUpdate.Release_Reason__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>completedTaskReleaseReason</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>bUpdateACP</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_Task_Type</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Release_Flag_to_True</name>
        <label>Set Release Flag to True</label>
        <locationX>578</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>ACPRecordToUpdate.Release_Reason__c</assignToReference>
            <operator>Assign</operator>
            <value>
