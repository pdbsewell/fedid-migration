    <description>&quot;After Update&quot; the flow for the MRO Team for setting enquiry defaults &amp; auto responses</description>
    <environments>Default</environments>
    <formulas>
        <name>fEnquiryContactEmail</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Contact.Email}), {!$Record.SuppliedEmail}, {!$Record.Contact.Email})</expression>
    </formulas>
    <formulas>
        <description>To check the new record</description>
        <name>isNew</name>
        <dataType>Boolean</dataType>
        <expression>isNew()</expression>
    </formulas>
    <formulas>
        <name>todayDate</name>
        <dataType>Date</dataType>
        <expression>DATEVALUE(NOW() - (10/24))</expression>
    </formulas>
    <interviewLabel>Case : AU : MRO Enquiry Defaults &amp; Auto Responses {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Case : AU : MRO Auto Response</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Metadata_Record</name>
        <label>Get Metadata Record</label>
        <locationX>2228</locationX>
        <locationY>2039</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Template_Id</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Log_Autoresponse_Fault</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Feature__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>MROAutoEmailNotifications</stringValue>
            </value>
        </filters>
        <filters>
            <field>Is_Active__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>MetadataUniqueName</elementReference>
            </value>
        </filters>
        <object>System_Settings__mdt</object>
        <outputReference>SystemSettingMetadata</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>DeveloperName</queriedFields>
        <queriedFields>Feature__c</queriedFields>
        <queriedFields>Key__c</queriedFields>
        <queriedFields>Value__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Template_Id</name>
        <label>Get Template Id</label>
        <locationX>2228</locationX>
        <locationY>2147</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Send_Email_Notification</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Log_Autoresponse_Fault</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SystemSettingMetadata.Value__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>EmailTemplate</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Enquiry</name>
        <label>Update Enquiry</label>
        <locationX>1040</locationX>
        <locationY>1823</locationY>
        <connector>
            <targetReference>Contact_or_Web_Email</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Enquiry_Update_Fault</targetReference>
        </faultConnector>
        <inputReference>EnquiryRecord</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Enquiry1</name>
        <label>Update Enquiry</label>
        <locationX>1898</locationX>
        <locationY>1439</locationY>
        <inputReference>EnquiryRecord</inputReference>
    </recordUpdates>
    <start>
        <locationX>914</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Opportunity</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;CaseAUMROAutoResponse,&quot;) = false &amp;&amp; {!$Record.RecordType.DeveloperName} = &apos;MRO&apos;</filterFormula>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>FeedItemBody</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Student Type changed to {!$Record.Student_Type__c} by Automated process.</text>
    </textTemplates>
    <variables>
        <name>bUpdateEnquiry</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>EnquiryRecord</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <objectType>Case</objectType>
    </variables>
    <variables>
        <name>MetadataUniqueName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>senderType</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <value>
            <stringValue>OrgWideEmailAddress</stringValue>
        </value>
    </variables>
    <variables>
        <name>SupplietEmailList</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>SystemSettingMetadata</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
