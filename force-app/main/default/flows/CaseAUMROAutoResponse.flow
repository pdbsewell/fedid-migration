    <decisions>
        <name>Check_Incoming_Email_Alert</name>
        <label>Check Incoming Email Alert</label>
        <locationX>1040</locationX>
        <locationY>923</locationY>
        <defaultConnector>
            <targetReference>Decision_Update_Group</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>IncomingEmail_True</name>
            <conditionLogic>1 AND 2 AND (3 OR 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>On Hold</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Awaiting Customer Feedback</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Enquiry_Status_to_Open</targetReference>
            </connector>
            <label>IncomingEmail=True</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Opportunity</name>
        <label>Check Opportunity</label>
        <locationX>1040</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>CheckKeyDate</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OpportunityChanged</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Opportunity__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Opportunity__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Enquiry_Fields</targetReference>
            </connector>
            <label>OpportunityChanged</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Update_Enquiry</name>
        <label>Check Update Enquiry</label>
        <locationX>2030</locationX>
        <locationY>1331</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>IsUpdateRequired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>bUpdateEnquiry</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Enquiry1</targetReference>
            </connector>
            <label>IsUpdateRequired</label>
        </rules>
    </decisions>
    <decisions>
        <name>CheckKeyDate</name>
        <label>Check KeyDate</label>
        <locationX>1040</locationX>
        <locationY>623</locationY>
        <defaultConnector>
            <targetReference>Check_Incoming_Email_Alert</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Key_Date_Not_Null</name>
            <conditionLogic>1 OR (2 AND 3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Key_Date__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Enquiry_Key_Date__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>On Hold</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>On Hold</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Key_Date__r.Due_Date__c</leftValueReference>
