    <decisions>
        <name>checkNationality</name>
        <label>checkNationality</label>
        <locationX>600</locationX>
        <locationY>671</locationY>
        <defaultConnector>
            <targetReference>checkResidencyStatus</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Nationality_AU</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Supplied_Nationality__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>AUSTRALIA</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Supplied_Nationality__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NEW ZEALAND</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateStudentTypeNationality</targetReference>
            </connector>
            <label>Nationality=AU</label>
        </rules>
        <rules>
            <name>Nationality_NOT_AU</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Supplied_Nationality__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Supplied_Nationality__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>AUSTRALIA</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateStudentTypeNationalityInt</targetReference>
            </connector>
            <label>Nationality NOT AU</label>
        </rules>
    </decisions>
    <decisions>
        <name>checkResidencyStatus</name>
