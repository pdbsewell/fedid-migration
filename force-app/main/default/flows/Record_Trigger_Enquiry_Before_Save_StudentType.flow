    <environments>Default</environments>
    <formulas>
        <name>bByPassFlag</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c}</expression>
    </formulas>
    <formulas>
        <name>txtContactProfile</name>
        <dataType>String</dataType>
        <expression>IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;Current Student (Dom) CSD&apos;), &apos;Current Student (Dom) [CSD];&apos;, null) &amp;
IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;Future Student (Dom) FSD&apos;), &apos;Future Student (Dom) [FSD];&apos;, null) &amp;
IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;Future Student (Dom)- Mature FSD&apos;), &apos;Future Student (Dom)- Mature [FSD];&apos;, null) &amp;
IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;Current Student (Int) CSI&apos;), &apos;Current Student (Int) [CSI];&apos;, null) &amp;
IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;Future Student (Int) FSI&apos;), &apos;Future Student (Int) [FSI];&apos;, null) &amp;
IF(INCLUDES({!$Record.Contact.Contact_Profile__c}, &apos;International Applicant IA&apos;), &apos;International Applicant [IA];&apos;, null)</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Enquiry Before Save (StudentType) {!$Flow.CurrentDateTime}</interviewLabel>
