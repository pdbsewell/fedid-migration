    <decisions>
        <name>checkStudentType</name>
        <label>checkStudentType</label>
        <locationX>1425</locationX>
        <locationY>551</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>checkValidRT</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>GetValidRTs.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MonCon_Support</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>GetValidRTs.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash_Connect_Enquiry</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>checkNationality</targetReference>
            </connector>
            <label>checkValidRT</label>
        </rules>
