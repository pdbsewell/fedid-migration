<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Is_Update_Via_API_Integration</name>
        <label>Is Update Via API Integration</label>
        <locationX>182</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.LastModifiedBy.Username</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>integration.monashforms@monash.edu</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Latest_Case_Extension_AP_Record</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <interviewLabel>Sync Academic Progress Details To Case Extension {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Sync Academic Progress Details To Case Extension</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Latest_Case_Extension_AP_Record</name>
        <label>Get Latest Case Extension - AP Record</label>
        <locationX>50</locationX>
        <locationY>455</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Sync_Integration_Fields_From_Case_To_Latest_Case_Extension</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Person_ID__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Contact.Person_ID_unique__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Case_Ext_AP__c</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Sync_Integration_Fields_From_Case_To_Latest_Case_Extension</name>
        <label>Sync Integration Fields From Case To Latest Case Extension</label>
        <locationX>50</locationX>
        <locationY>575</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Latest_Case_Extension_AP_Record.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Description__c</field>
            <value>
                <elementReference>$Record.Description</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>First_Response_Date_Time__c</field>
            <value>
                <elementReference>$Record.First_Response_Date_Time__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>JSON_Payload__c</field>
            <value>
                <elementReference>$Record.JSON_Payload__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Submitted_At__c</field>
            <value>
                <elementReference>$Record.Submitted_At__c</elementReference>
            </value>
        </inputAssignments>
        <object>Case_Ext_AP__c</object>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_Update_Via_API_Integration</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Origin</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>My Engagement and Support</stringValue>
            </value>
        </filters>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
