        <rules>
            <name>dp_Move_to_cluster</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>pl_Move_Collaborators</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>var_CollabFound</leftValueReference>
