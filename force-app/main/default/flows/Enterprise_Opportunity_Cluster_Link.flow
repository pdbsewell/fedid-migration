                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Group_RT_Id</targetReference>
            </connector>
            <label>Move to cluster</label>
        </rules>
        <rules>
            <name>dp_Delete_Collaborators</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>pl_Move_Collaborators</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>var_CollabFound</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Collaborators</targetReference>
            </connector>
            <label>Delete Collaborators</label>
        </rules>
    </decisions>
