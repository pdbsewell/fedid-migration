    <description>Guided student interview for Academic Integrity.
Release 21.5.3.1 (SA-950)</description>
    <environments>Default</environments>
    <interviewLabel>Academic Integrity - Student Interview {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Academic Integrity - Student Interview</label>
