        <inputReference>varTask</inputReference>
    </recordCreates>
    <recordLookups>
        <name>getRT_CaseDefault</name>
        <label>getRT CaseDefault</label>
        <locationX>176</locationX>
        <locationY>782</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>assign_New_Task</targetReference>
        </connector>
        <faultConnector>
            <targetReference>debug_Get_RT_Task</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
