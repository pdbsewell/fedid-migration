    <assignments>
        <name>assign_New_Task</name>
        <label>assign New Task</label>
        <locationX>176</locationX>
        <locationY>890</locationY>
        <assignmentItems>
            <assignToReference>varTask.WhatId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>varEnquiryId</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.OwnerId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.Type</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Meeting</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.Subject</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Academic Integrity - Student Interview</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.Status</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.ActivityDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>dtime_01</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>varTask.RecordTypeId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>getRT_CaseDefault.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>create_New_Task</targetReference>
        </connector>
    </assignments>
    <assignments>
