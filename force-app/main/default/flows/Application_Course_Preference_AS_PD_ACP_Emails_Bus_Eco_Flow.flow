    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Application_Course</name>
        <label>Application Course</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>ApplicationCoursePreference</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>GetApplicationCoursePreference</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Application_Confirmation</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Application_Acceptance</name>
        <label>Application Acceptance</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Cancellation</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Accepted</defaultConnectorLabel>
        <rules>
            <name>Accepted</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Invoice not processed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - CCFund</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Invoiced</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_Acceptance_Email_Action</targetReference>
            </connector>
            <label>Accepted</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Cancellation</name>
        <label>Application Cancellation</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_EOI</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Cancelled</defaultConnectorLabel>
        <rules>
            <name>Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_Cancellation_Email_Action</targetReference>
            </connector>
            <label>Cancelled</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Confirmation</name>
        <label>Application Confirmation</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Acceptance</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Confirmed</defaultConnectorLabel>
        <rules>
            <name>Confirmed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Confirmed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_Confirmation_Email_Action</targetReference>
            </connector>
            <label>Confirmed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_EOI</name>
        <label>Application EOI</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Waitlist</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not EOI</defaultConnectorLabel>
        <rules>
            <name>EOI</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - EOI Only</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_EOI_Thank_You_Email_Action</targetReference>
            </connector>
            <label>EOI</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Selective_Approval_invoice</name>
        <label>Application Selective Approval (invoice)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not Selective Approved (invoice)</defaultConnectorLabel>
        <rules>
            <name>Selective_Approved_invoice</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Offering__r.Pay_by_Invoice__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Invoice_Selective_Approved_Email_Action</targetReference>
            </connector>
            <label>Selective Approved (invoice)</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Selective_Approval_no_invoice</name>
        <label>Application Selective Approval (no invoice)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Selective_Approval_invoice</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Selective Approved</defaultConnectorLabel>
        <rules>
            <name>Selective_Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Offering__r.Pay_by_Invoice__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Selective_Approved_Email_Action</targetReference>
            </connector>
            <label>Selective Approved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Selective_Pending</name>
        <label>Application Selective Pending</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Selective_Approval_no_invoice</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Selective Pending</defaultConnectorLabel>
        <rules>
            <name>Selective_Pending</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Pending Approval</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Selective_Thank_You_Email_Action</targetReference>
            </connector>
            <label>Selective Pending</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Waitlist</name>
        <label>Application Waitlist</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Withdrawal</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Waitlisted</defaultConnectorLabel>
        <rules>
            <name>Waitlisted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Waitlisted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_Waitlisted_Email_Action</targetReference>
            </connector>
            <label>Waitlisted</label>
        </rules>
    </decisions>
    <decisions>
        <name>Application_Withdrawal</name>
        <label>Application Withdrawal</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Application_Selective_Pending</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Withdrawn</defaultConnectorLabel>
        <rules>
            <name>Withdrawn</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Withdrawn</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_BusEco_Withdrawn_Email_Action</targetReference>
            </connector>
            <label>Withdrawn</label>
        </rules>
    </decisions>
    <description>Sends emails for ACP records whose Managing Faculty is Business and Economics</description>
