        </fields>
        <fields>
            <name>Section_Disability_Support_Information</name>
            <fieldText>Disability Support Information</fieldText>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Disability_Support_Information_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_DSSDetails</name>
                    <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;u&gt;Applicant Information:&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Full Name: &lt;/strong&gt;{!GetDSSDetails.Applicant__r.Full_Name__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Age: &lt;/strong&gt;{!GetDSSDetails.Age__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Citizenship Country: &lt;/strong&gt;{!GetDSSDetails.Citizenship_Country__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;Study/Location Details:&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Campus:&lt;/strong&gt; {!GetDSSDetails.Location_Description__c}&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Faculty:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; &lt;/span&gt;{!GetDSSDetails.Managing_Faculty__c}&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Course:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetDSSDetails.Course_Title__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Commencement:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetDSSDetails.Commencement_Period__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Attendance Mode:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetDSSDetails.Attendance_Mode_Description__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Attendance Type:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetDSSDetails.Attendance_Type_Description__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Existing Australian disability support: &lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!GetDSSDetails.Application__r.Existing_Aus_disability_support__c}&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
