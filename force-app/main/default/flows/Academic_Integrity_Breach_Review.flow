    <choices>
        <description>No, a meeting is not required</description>
        <name>c_Noameetingisnotrequired</name>
        <choiceText>No, a meeting is not required</choiceText>
        <dataType>String</dataType>
        <value>
            <elementReference>No</elementReference>
        </value>
    </choices>
    <choices>
        <description>No, this might be a minor breach or needs further investigation</description>
        <name>c_Nothismightbeaminorbreachorneedsfurtherinvestigation</name>
        <choiceText>No, this might be a minor breach or needs further investigation</choiceText>
        <dataType>String</dataType>
        <value>
            <elementReference>No</elementReference>
        </value>
    </choices>
    <choices>
        <description>No, this should be dismissed and the case closed</description>
        <name>c_Nothisshouldbedismissedandthecaseclosed</name>
        <choiceText>No, this should be dismissed and the case closed</choiceText>
        <dataType>String</dataType>
        <value>
            <elementReference>No</elementReference>
        </value>
    </choices>
    <choices>
        <description>Yes, a meeting is required</description>
