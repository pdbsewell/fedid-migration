    <screens>
        <name>screen_Minor_Breach_Parent</name>
        <label>screen Minor Breach (Parent)</label>
        <locationX>1458</locationX>
        <locationY>890</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>dtxt_MinorBreachScreen_parent</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Notify Student / Seek Additional Information&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;The next step is to &lt;/span&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;notify the student &lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;of the suspected breach of academic integrity, by email.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You may also choose to meet with them&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; if you believe it will be useful to do so.&amp;nbsp;Any meeting with the student should occur within 5 days of the notification of the suspected breach.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_parent</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(200, 0, 143); font-size: 16px;&quot;&gt;More than one student is reported to have been involved in this matter.&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;In order to complete the next step, please &lt;/span&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;process each student’s case individually&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;. Individual student cases are listed on the bottom of the left pane.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>screen_Misconduct</name>
        <label>screen Misconduct</label>
        <locationX>402</locationX>
        <locationY>998</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>update_Enquiry_Misconduct</targetReference>
        </connector>
        <fields>
            <name>dtxt_MisconductScreen_0</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Alleged Misconduct&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;This breach will be referred to Student Conduct and Complaints, as an allegation of Academic Misconduct.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p class=&quot;ql-indent-1&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;1. &lt;/span&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-size: 14px;&quot;&gt;Please tell us why you don’t need to investigate this matter further and the case should be immediately escalated to Student Conduct and Complaints.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <fieldType>ObjectProvided</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>false</isRequired>
            <objectFieldReference>getEnquiry.Comments</objectFieldReference>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_MisconductScreen_1</name>
            <fieldText>&lt;p class=&quot;ql-indent-1&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;2. Use the &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Academic Integrity Breach Outcome - Alleged Misconduct&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; email template to inform the student of the outcome.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Click &lt;/span&gt;&lt;strong style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;&lt;em&gt;Next&lt;/em&gt;&lt;/strong&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to finalise your decision and transfer the case to the Student Conduct and Complaints team.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You will not have access to the case once it is transferred. After the investigation is complete and a decision has been made, you will be notified of the final outcome.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <nextOrFinishButtonLabel>Refer to Misconduct</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>screen_Review</name>
        <label>screen Review</label>
        <locationX>1238</locationX>
        <locationY>566</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>decision_Review_Outcome</targetReference>
        </connector>
        <fields>
            <name>dtxt_Review</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 18px; color: rgb(0, 109, 174);&quot;&gt;﻿Case Evidence Review&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;This case has been categorised as &lt;/span&gt;&lt;b style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;{!getEnquiry.Category_Level_2__c}&lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;. Monash&apos;s definition of &lt;/span&gt;&lt;b style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;{!getEnquiry.Category_Level_2__c}&lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt; &lt;/span&gt;&lt;a href=&quot;https://learning-teaching.monash.edu/articulateFiles/academic_integrity/academic-integrity-breach-form-resource/content/index.html#/lessons/AVMkBv9i6X1_gl38hUtmhzxePty7h3Pd&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px; color: rgb(0, 0, 238);&quot;&gt;&lt;u&gt;can be found here&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;, along with examples&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 109, 174); font-size: 14px;&quot;&gt;After reviewing the evidence&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; (on the left ⬅️), please proceed with the following question.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>screen_Review_Section1</name>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>screen_Review_Section1_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_Q1</name>
                    <fieldText>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;Q.&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; After reviewing the initial evidence, do you believe this might be a potential breach of academic integrity?&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>6</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <fields>
                <name>screen_Review_Section1_Column2</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>Q1</name>
                    <choiceReferences>c_Yesthereforethisneedsfurtherinvestigation</choiceReferences>
                    <choiceReferences>c_Nothisshouldbedismissedandthecaseclosed</choiceReferences>
                    <dataType>String</dataType>
                    <fieldText>Your Response</fieldText>
                    <fieldType>DropdownBox</fieldType>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>true</isRequired>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>6</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <isRequired>false</isRequired>
            <regionContainerType>SectionWithoutHeader</regionContainerType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>f_OwnerInitiator</leftValueReference>
                    <operator>NotEqualTo</operator>
                    <rightValue>
                        <elementReference>Yes</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_Q1_Result</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Click &lt;/span&gt;&lt;b style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Next&lt;/b&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to view a confirmation screen before dismissing the case.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Q1</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>No</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_MinorBreachLink</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(0, 0, 0); background-color: transparent;&quot;&gt;Before answering the next question, please review the &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/__data/assets/pdf_file/0005/2641676/Academic-integrity-spectrum.pdf&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px; color: rgb(0, 0, 238); background-color: rgb(255, 255, 255);&quot;&gt;&lt;u&gt;Academic Integrity Breach Seriousness Spectrum&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>(1 OR 2) AND (3 OR 4)</conditionLogic>
                <conditions>
                    <leftValueReference>Q1</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>Yes</elementReference>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>f_OwnerInitiator</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>Yes</elementReference>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Fraud</stringValue>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Contract Cheating</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>screen_Review_Section2</name>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>screen_Review_Section2_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_Q2</name>
                    <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;Q.&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; Is there clear evidence that this is a serious breach of academic integrity that should proceed straight to academic misconduct, &lt;/span&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;without further investigation by you&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;?&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>6</stringValue>
