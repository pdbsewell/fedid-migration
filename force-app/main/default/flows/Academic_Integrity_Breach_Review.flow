                    <name>Q2</name>
                    <choiceReferences>c_Yesreferthistoacademicmisconduct</choiceReferences>
                    <choiceReferences>c_Nothismightbeaminorbreachorneedsfurtherinvestigation</choiceReferences>
                    <dataType>String</dataType>
                    <fieldText>Your Response</fieldText>
                    <fieldType>DropdownBox</fieldType>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>true</isRequired>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
