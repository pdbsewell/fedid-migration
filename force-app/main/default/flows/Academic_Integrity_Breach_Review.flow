        <choiceText>Yes, refer this to academic misconduct</choiceText>
        <dataType>String</dataType>
        <value>
            <elementReference>Yes</elementReference>
        </value>
    </choices>
    <choices>
        <description>Yes, therefore this needs further investigation</description>
        <name>c_Yesthereforethisneedsfurtherinvestigation</name>
        <choiceText>Yes, therefore this needs further investigation</choiceText>
        <dataType>String</dataType>
        <value>
            <elementReference>Yes</elementReference>
        </value>
