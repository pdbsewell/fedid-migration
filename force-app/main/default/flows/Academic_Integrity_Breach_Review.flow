            <name>dtxt_debug_0</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;{!txt_debugDetails}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>screen_Dismiss</name>
        <label>screen Dismiss</label>
        <locationX>2074</locationX>
        <locationY>890</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>update_Enquiry_Dismissed</targetReference>
        </connector>
        <fields>
            <name>dtxt_DismissScreen_0</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Dismiss without investigation / informing student&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;Please let the staff member who reported this case know by emailing them using the &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;Academic Integrity - Allegations Dismissed (to Staff)&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt; email template. You can include the reason for dismissing the case as outlined in the template.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;To learn how to use emails and templates, &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/learning-teaching/TeachHQ/Assessment/academic-integrity/how-to/email-with-service-console-lite&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px; color: rgb(0, 68, 228);&quot;&gt;&lt;b&gt;&lt;u&gt;click here&lt;/u&gt;&lt;/b&gt;&lt;/a&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;Clicking &lt;/span&gt;&lt;b style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;Next&lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt; will mark the case as Dismissed, and close the case.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>screen_Minor_Breach</name>
        <label>screen Minor Breach</label>
        <locationX>50</locationX>
        <locationY>458</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>dtxt_MinorBreachScreen</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 18px; color: rgb(0, 109, 174);&quot;&gt;Notify Student / Seek Additional Information&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;The next step is to &lt;/span&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;notify the student &lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;of the suspected breach of academic integrity, by email.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You may also choose to meet with them&lt;/b&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; if you believe it will be useful to do so.&amp;nbsp;Any meeting with the student should occur within 5 days of the notification of the suspected breach.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_EmailNote</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;Use the &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Academic Integrity - Notice of suspected breach to student (no meeting)&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; or &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Academic Integrity - Notice of suspected breach to student (with meeting) &lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;email template as appropriate, to email the student. &lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;If you want to learn how to send an email, &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/learning-teaching/teachhq/Assessment/academic-integrity/how-to/email-with-service-console-lite&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 0, 238); font-size: 14px;&quot;&gt;&lt;b&gt;&lt;u&gt;click here&lt;/u&gt;&lt;/b&gt;&lt;/a&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You’ll need to provide the student with any evidence you’ll use to make your decision. To do this attach the evidence documents along with the student response form to the email. Be sure to remove or redact any evidence that includes the personal information of other students, such as student numbers, email addresses, IP addresses etc.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You’ll need to allow the student&amp;nbsp;5 working days to reply. If they don’t reply within 3 working days, they will receive an automatic reminder email. If you haven’t received a reply after 5 business days, you can make your decision without waiting for a response.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>screen_Minor_Breach_Section1</name>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>screen_Minor_Breach_Section1_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_Q3</name>
                    <fieldText>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;Q.&lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt; Will you meet with the student?&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>6</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <fields>
                <name>screen_Minor_Breach_Section1_Column2</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>Q3</name>
                    <choiceReferences>c_Yesameetingisrequired</choiceReferences>
                    <choiceReferences>c_Noameetingisnotrequired</choiceReferences>
                    <dataType>String</dataType>
                    <fieldText>Your Response</fieldText>
                    <fieldType>DropdownBox</fieldType>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>true</isRequired>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>6</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <isRequired>false</isRequired>
            <regionContainerType>SectionWithoutHeader</regionContainerType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_MeetingNote</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;color: rgb(0, 109, 174); font-size: 14px;&quot;&gt;﻿Prior to the meeting&lt;/b&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;, you should review the student’s response form and any supporting documents they provided. You can click the “Conduct Interview (Optional)” button on the main flow screen to go through the interview flow to prepare for the interview.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Q3</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>Yes</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
