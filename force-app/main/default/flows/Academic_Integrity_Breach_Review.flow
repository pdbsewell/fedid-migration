                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_Q2_Result</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Click &lt;/span&gt;&lt;b style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Next&lt;/b&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to view a confirmation screen before marking this case as misconduct.&lt;/span&gt;&lt;/p&gt;</fieldText>
