        <name>Yes</name>
        <choiceText>Yes</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>true</stringValue>
        </value>
    </choices>
    <decisions>
        <name>decision_isChild</name>
        <label>decision isChild</label>
        <locationX>644</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>assignChildFalse</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Child</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getEnquiry.ParentId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assignChildTrue</targetReference>
            </connector>
            <label>Is Child</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_Parent</name>
        <label>decision Parent</label>
        <locationX>1590</locationX>
        <locationY>782</locationY>
        <defaultConnector>
            <targetReference>screen_Minor_Breach_0</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>out_Parent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getList_ChildEnquiry</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Minor_Breach_Parent</targetReference>
            </connector>
            <label>out Parent</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_Review_Outcome</name>
        <label>decision Review Outcome</label>
        <locationX>1238</locationX>
        <locationY>674</locationY>
        <defaultConnector>
            <targetReference>assign_Dismissed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>out Dismiss</defaultConnectorLabel>
        <rules>
            <name>out_Misconduct</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Yes</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_SEBS_QueueId</targetReference>
            </connector>
            <label>out Misconduct</label>
        </rules>
        <rules>
            <name>out_Minor_Breach</name>
            <conditionLogic>1 OR 2 OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>No</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q1</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Yes</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q1</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>decision_Parent</targetReference>
            </connector>
            <label>out Minor Breach</label>
        </rules>
    </decisions>
    <description>Flow that helps a user review an AI breach.

2021-11-02 SA-1084 Changed text and on screen:&quot;screen Review&quot;</description>
    <environments>Default</environments>
    <formulas>
        <name>f_OwnerInitiator</name>
        <dataType>String</dataType>
        <expression>IF(
ISBLANK({!getEnquiry.Owner:User.FederationIdentifier})||ISBLANK({!getEnquiry.Initiated_By__r.Authcate__c}),
&quot;false&quot;,
IF(
{!getEnquiry.Owner:User.FederationIdentifier}={!getEnquiry.Initiated_By__r.Authcate__c},
&quot;true&quot;,
&quot;false&quot;
)
)</expression>
    </formulas>
    <interviewLabel>Academic Integrity - {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Academic Integrity - Breach Review</label>
    <loops>
        <name>loop_Child</name>
        <label>loop Child</label>
        <locationX>402</locationX>
        <locationY>1214</locationY>
        <collectionReference>getList_ChildEnquiry</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
