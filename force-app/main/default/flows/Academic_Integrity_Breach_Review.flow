    <recordLookups>
        <name>get_SEBS_QueueId</name>
        <label>get SEBS QueueId</label>
        <locationX>402</locationX>
        <locationY>782</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
