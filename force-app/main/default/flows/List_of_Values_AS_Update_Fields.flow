            </value>
        </inputParameters>
        <nameSegment>Nebula__FlowLogEntry</nameSegment>
        <offset>0</offset>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Check record details before routing to correct action.</description>
        <name>Check_Record</name>
        <label>Check Record</label>
        <locationX>754</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>IsNewEnquiryType</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CaseCategorisation</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateEnquiryType</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>IsNewEnquiryType</label>
        </rules>
        <rules>
            <name>Type_Enquiry</name>
            <conditionLogic>1 AND (2 OR 3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>CaseCategorisation</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Applicant_Value__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Applicant_Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.System_Code_Description__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.System_Code_Description__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Value__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record.Value__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateEnquiryTypeName</targetReference>
            </connector>
            <label>Type=Enquiry</label>
        </rules>
        <rules>
            <name>OtherRecordsModified</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Value__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.System_Code__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.System_Code__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Type__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>$Record__Prior.Type__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Name</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>LOVNameOther</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Unique_Key__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>UniqueNameOther</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateRecordOthers</targetReference>
            </connector>
            <label>OtherRecordsModified</label>
        </rules>
        <rules>
            <name>IsNewAllRecords</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Type__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>EnquiryType</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateRecordOthers</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>IsNewAllRecords</label>
        </rules>
    </decisions>
    <description>Updates and aligns fields</description>
    <environments>Default</environments>
    <formulas>
        <name>byPassFlowFlag</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c}</expression>
    </formulas>
    <formulas>
        <name>isNew</name>
        <dataType>Boolean</dataType>
        <expression>isNew()</expression>
    </formulas>
    <formulas>
        <description>combination of value and system code.</description>
        <name>LOVNameOther</name>
        <dataType>String</dataType>
        <expression>{!$Record.Value__c} &amp; &apos; (&apos; &amp; {!$Record.System_Code__c} &amp;  &apos;)&apos;</expression>
    </formulas>
    <formulas>
        <name>NameEnquiryType</name>
        <dataType>String</dataType>
        <expression>{!$Record.Category_Level_1__c} &amp; &apos;&gt;&apos; &amp; {!$Record.Category_Level_2__c}</expression>
    </formulas>
    <formulas>
        <name>UniqueNameEnquiry</name>
        <dataType>String</dataType>
        <expression>{!$Record.Enquiry_Type__c} &amp; &apos;-&apos; &amp; {!$Record.Category_Level_1__c} &amp; &apos;-&apos; &amp; {!$Record.Category_Level_2__c}</expression>
    </formulas>
    <formulas>
        <name>UniqueNameOther</name>
        <dataType>String</dataType>
        <expression>{!$Record.Value__c} &amp; &apos;-&apos; &amp; TEXT({!$Record.Type__c})</expression>
    </formulas>
    <interviewLabel>List of Value : AS : Update Fields {!$Flow.CurrentDateTime}</interviewLabel>
    <label>List of Values : AS : Update Fields</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
