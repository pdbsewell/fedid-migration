    <recordUpdates>
        <name>UpdateRecordOthers</name>
        <label>UpdateRecordOthers</label>
        <locationX>754</locationX>
        <locationY>863</locationY>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>List_of_Values_Update_Fields</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>LOVNameOther</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Unique_Key__c</field>
            <value>
                <elementReference>UniqueNameOther</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>628</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Record</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false</filterFormula>
        <object>List_of_Values__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
