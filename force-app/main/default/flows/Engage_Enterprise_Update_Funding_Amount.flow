<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Set the primary funder as false for the previous primary funder record</description>
        <name>Copy_1_of_Remove_the_existing_primary_funder</name>
        <label>Copy 1 of Remove the existing primary funder</label>
        <locationX>578</locationX>
        <locationY>863</locationY>
        <assignmentItems>
            <assignToReference>Get_Primary_Funder.Primary_Funder__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Copy_1_of_Update_Previous_Funder_to_False</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Set the primary funder to true for the existing related funder record where opportunity account is equal to the funding funder</description>
        <name>Copy_1_of_Set_Primary_Funder_To_True</name>
        <label>Copy 1 of Set Primary Funder To True</label>
        <locationX>842</locationX>
        <locationY>863</locationY>
        <assignmentItems>
            <assignToReference>Get_Related_Funder_Record.Primary_Funder__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Copy_1_of_Update_Existing_Related_Primary_Funder</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Set the primary funder as false for the previous primary funder record</description>
        <name>Remove_the_existing_primary_funder</name>
        <label>Remove the existing primary funder</label>
        <locationX>1106</locationX>
        <locationY>863</locationY>
        <assignmentItems>
            <assignToReference>Get_Primary_Funder.Primary_Funder__c</assignToReference>
            <operator>Assign</operator>
            <value>
