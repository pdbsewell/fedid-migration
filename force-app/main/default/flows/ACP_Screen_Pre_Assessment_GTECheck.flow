<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Internal_Review</name>
        <label>Assign Internal Review</label>
        <locationX>50</locationX>
        <locationY>998</locationY>
        <assignmentItems>
            <assignToReference>GetGTETaskStatus.Task_GTE__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Internal Input Required</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Update_GTE_Task</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Decision_Navigation</name>
        <label>Decision Navigation</label>
        <locationX>710</locationX>
        <locationY>674</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_GTE_Task</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navGTE.fire2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Queue_GTE_Record</targetReference>
            </connector>
            <label>GTE Task</label>
        </rules>
        <rules>
            <name>Update_Task</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navGTE.fire3</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_GTE_Task</targetReference>
            </connector>
            <label>Update Task</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>frmShowTaskBtn</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISBLANK({!Get_Linked_OPEN_GTE_Task.Id}), False, True)</expression>
    </formulas>
    <formulas>
        <name>frmTaskSubject</name>
        <dataType>String</dataType>
        <expression>&quot;GTE Review: &quot; + &quot; [Applicant: &quot; + {!GetGTEDetails.Applicant__r.Full_Name__c} + &quot;] [Campus: &quot; + {!GetGTEDetails.Location_Description__c}+&quot;]&quot;</expression>
    </formulas>
    <formulas>
        <name>FrmViewDocURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_100}, FIND(&apos;/services&apos;, ({!$Api.Enterprise_Server_URL_100})))&amp;&quot;c/DocumentPreviewer.app?cd=&quot;&amp;{!varContactDocumentId}</expression>
    </formulas>
    <interviewLabel>ACP: Screen: Pre-Assessment: GTECheck {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ACP: Screen: Pre-Assessment: GTECheck</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
