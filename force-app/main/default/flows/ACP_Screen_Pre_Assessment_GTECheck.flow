    <screens>
        <name>Screen_Error</name>
        <label>Screen Error</label>
        <locationX>1106</locationX>
        <locationY>890</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>true</allowPause>
        <fields>
            <name>dtxt_Error</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(225, 25, 50);&quot;&gt;{!$Flow.FaultMessage}&lt;/strong&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>Screen_GTE</name>
        <label>Screen GTE</label>
        <locationX>710</locationX>
        <locationY>566</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Decision_Navigation</targetReference>
        </connector>
        <fields>
            <name>dtxt_GTEScreen</name>
            <fieldText>&lt;p&gt;&lt;strong&gt;Genuine Temporary Entrant:&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;If the applicant are an international student applying for a student visa, in addition to assessing the application against all other&amp;nbsp;&lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/admissions/entry-requirements&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 109, 174);&quot;&gt;entry requirements&lt;/a&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;, Monash is obligated to check that the applicant are genuinely seeking temporary entry into Australia for study purposes.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Section_Entrant_Information</name>
            <fieldText>Entrant Information</fieldText>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Entrant_Information_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_GTEDetails</name>
                    <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;u&gt;Applicant Information:&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Full Name: &lt;/strong&gt;{!GetGTEDetails.Applicant__r.Full_Name__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Age: &lt;/strong&gt;{!GetGTEDetails.Age__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Citizenship Country: &lt;/strong&gt;{!GetGTEDetails.Citizenship_Country__c}&lt;/li&gt;&lt;/ul&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>12</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <isRequired>false</isRequired>
            <regionContainerType>SectionWithHeader</regionContainerType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
