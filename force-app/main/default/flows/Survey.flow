    <decisions>
        <name>article_Type_Check</name>
        <label>article Type Check</label>
        <locationX>1440</locationX>
        <locationY>38</locationY>
        <defaultConnectorLabel>[Default Outcome]</defaultConnectorLabel>
        <rules>
            <name>HRFAQ_article_Type</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>faqArticle.FAQRecordType__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>HR</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>caseRecordTypeLookupHR</targetReference>
            </connector>
            <label>HRFAQ article Type</label>
        </rules>
        <rules>
            <name>FAQ_article_Type</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>faqArticle.FAQRecordType__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>FAQ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>caseRecordTypeLookupMonash_Connect_Enquiry</targetReference>
            </connector>
            <label>FAQ article Type</label>
        </rules>
    </decisions>
    <decisions>
        <name>Bypass_Flow</name>
        <label>Bypass Flow?</label>
        <locationX>168</locationX>
        <locationY>260</locationY>
        <defaultConnectorLabel>Yes</defaultConnectorLabel>
        <rules>
            <name>Bypass_No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>knowledgeArticleLookUp</targetReference>
            </connector>
            <label>No</label>
        </rules>
    </decisions>
    <decisions>
        <name>Case_Needs_to_Be_Created</name>
