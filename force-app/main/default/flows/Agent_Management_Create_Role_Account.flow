<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Call_Integration</name>
        <label>Call Integration</label>
        <locationX>504</locationX>
        <locationY>332</locationY>
        <actionName>InvokeCallistaAgencyInsert</actionName>
        <actionType>apex</actionType>
        <inputParameters>
            <name>createdRoleAccountContactIDs</name>
            <value>
                <elementReference>ResultingContactId</elementReference>
            </value>
        </inputParameters>
        <nameSegment>InvokeCallistaAgencyInsert</nameSegment>
    </actionCalls>
    <actionCalls>
        <name>Format_First_Name_Value</name>
        <label>Format First Name Value</label>
        <locationX>666</locationX>
        <locationY>126</locationY>
        <actionName>AM_Utilities</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Create_Contact_Record_for_Role_Account</targetReference>
        </connector>
        <inputParameters>
            <name>inStrings</name>
            <value>
                <elementReference>TrimmedAccountName</elementReference>
            </value>
        </inputParameters>
        <nameSegment>AM_Utilities</nameSegment>
        <outputParameters>
            <assignToReference>FormattedFirstName</assignToReference>
            <name>output</name>
        </outputParameters>
    </actionCalls>
    <actionCalls>
        <name>Format_Last_Name</name>
        <label>Format Last Name</label>
        <locationX>356</locationX>
        <locationY>131</locationY>
        <actionName>AM_Utilities</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Format_First_Name_Value</targetReference>
        </connector>
        <inputParameters>
            <name>inStrings</name>
            <value>
                <elementReference>TrimmedAccountCity</elementReference>
            </value>
        </inputParameters>
        <nameSegment>AM_Utilities</nameSegment>
        <outputParameters>
            <assignToReference>FormattedLastName</assignToReference>
            <name>output</name>
        </outputParameters>
    </actionCalls>
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <formulas>
        <name>ContactRTDeveloperName</name>
        <dataType>String</dataType>
        <expression>{!$Setup.Agent_Onboarding_Settings__c.Contact_RT_Developer_Name__c}</expression>
    </formulas>
    <formulas>
        <name>TrimmedAccountCity</name>
        <dataType>String</dataType>
        <expression>TRIM({!AccountRecord.City__c})</expression>
    </formulas>
    <formulas>
        <name>TrimmedAccountName</name>
        <dataType>String</dataType>
        <expression>LEFT({!AccountRecord.Name}, 40)</expression>
    </formulas>
    <interviewLabel>Agent Management - Create Role Account {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Agent Management - Create Role Account</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Contact_Record_for_Role_Account</name>
        <label>Create Contact Record for Role Account</label>
        <locationX>504</locationX>
        <locationY>228</locationY>
        <assignRecordIdToReference>ResultingContactId</assignRecordIdToReference>
        <connector>
            <targetReference>Call_Integration</targetReference>
        </connector>
        <inputAssignments>
            <field>AccountId</field>
            <value>
                <elementReference>AccountRecord.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Email</field>
            <value>
                <elementReference>AccountRecord.Email__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>FirstName</field>
            <value>
                <elementReference>FormattedFirstName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>LastName</field>
            <value>
                <elementReference>FormattedLastName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <elementReference>RTRecord.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Role_Account_Flag__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <object>Contact</object>
    </recordCreates>
    <recordLookups>
        <name>Get_Contact_RT_Record</name>
        <label>Get Contact RT Record</label>
        <locationX>180</locationX>
        <locationY>123</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Format_Last_Name</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Agency_Contact</stringValue>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Contact</stringValue>
            </value>
        </filters>
        <object>RecordType</object>
        <outputReference>RTRecord</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <start>
        <locationX>50</locationX>
        <locationY>50</locationY>
        <connector>
            <targetReference>Get_Contact_RT_Record</targetReference>
        </connector>
    </start>
    <status>Active</status>
