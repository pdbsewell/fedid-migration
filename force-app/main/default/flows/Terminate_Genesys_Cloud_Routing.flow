<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Check if the Flow is to be Bypassed</description>
        <name>Check_Flow_Bypassing</name>
        <label>Check Flow Bypassing</label>
        <locationX>380</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Proceed_With_Flow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Prior_Case_Owner_Check</targetReference>
            </connector>
            <label>Proceed With Flow</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if the previous case owner is any one out of seven Monash queues</description>
        <name>Prior_Case_Owner_Check</name>
        <label>Prior Case Owner Check</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Genesys_Cloud_Routing_Queue</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash Connect Future Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash Connect Current Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MPass Card Office</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash Connect - Advisors</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash Connect Course Advice</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>myResearch Support</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retention</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Owner_String__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash Connect Enrolments</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Genesys_Cloud_Routing_Interaction</targetReference>
            </connector>
            <label>Genesys Cloud Routing Queue</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>Trim the comma sign out of MC_Faculty__c</description>
        <name>TrimComma</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!$Record.MC_Faculty__c}, &apos;,&apos;, &apos;&apos;)</expression>
    </formulas>
    <interviewLabel>Terminate Genesys Cloud Routing {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Terminate Genesys Cloud Routing</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Delete Previous Genesys Cloud Routing Interaction</description>
        <name>Delete_Genesys_Cloud_Routing_Interaction</name>
        <label>Delete Genesys Cloud Routing Interaction</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <inputAssignments>
            <field>purecloud__Attributes__c</field>
            <value>
                <stringValue>Enquiry_Number={!$Record.CaseNumber},Enquiry_Type={!$Record.Enquiry_Type__c},Category_Level_1={!$Record.Category_Level_1__c},Category_Level_2={!$Record.Category_Level_2__c},Category_Level_3={!$Record.Category_Level_3__c},Student_Type={!$Record.Student_Type__c},MC_Faculty={!TrimComma},Case_Owner_Name={!$Record.Case_Owner_String__c},Interaction_ID={!$Record.Interaction_ID__c},Owned_By_Queue={!$Record.Owned_By_Queue__c}</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>purecloud__Inbound_Email_Flow__c</field>
            <value>
                <stringValue>Terminate Salesforce Enquiry Routing</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>purecloud__Salesforce_Object_ID__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>purecloud__PureCloud_Routing_Request__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Flow_Bypassing</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>OwnerId</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </filters>
        <filters>
            <field>Owned_By_Queue__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Monash Connect Future Student</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Monash Connect Current Student</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>MPass Card Office</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Monash Connect - Advisors</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Monash Connect Course Advice</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>myResearch Support</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Retention</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Owner_String__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Monash_Connect_Enrolments</stringValue>
            </value>
        </filters>
        <filters>
            <field>Owned_By_Queue__c</field>
            <operator>IsChanged</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
