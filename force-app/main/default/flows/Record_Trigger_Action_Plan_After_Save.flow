            </value>
        </filters>
        <object>Case</object>
        <outputReference>MRO_Enquiry_Record</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>RecordType_DeveloperName__c</queriedFields>
        <queriedFields>Status</queriedFields>
        <queriedFields>Enquiry_Type__c</queriedFields>
        <queriedFields>ContactId</queriedFields>
    </recordLookups>
