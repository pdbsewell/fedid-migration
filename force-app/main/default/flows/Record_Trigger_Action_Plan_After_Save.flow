<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Send Legal In Progress Email.</description>
        <name>Send_Legal_Email_In_Progress</name>
