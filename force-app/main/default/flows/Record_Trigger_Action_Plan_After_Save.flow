    </decisions>
    <decisions>
        <name>Decision_Target_Record</name>
        <label>Decision Target Record</label>
        <locationX>1320</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>outcome_Enquiry_Target_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.TargetId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>500</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Enquiry_Record</targetReference>
            </connector>
            <label>Enquiry Target Record</label>
        </rules>
    </decisions>
    <description>New flow for MRO Action Plan to send an email when the action plan stage changes.</description>
    <environments>Default</environments>
    <formulas>
        <name>bBypassFlowFlag</name>
        <dataType>Boolean</dataType>
        <expression>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c}</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Action Plan {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record-Trigger: Action Plan After Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get Enquiry Record Details</description>
        <name>Get_Enquiry_Record</name>
        <label>Get Enquiry Record</label>
        <locationX>1007</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>checkMRORecord</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
