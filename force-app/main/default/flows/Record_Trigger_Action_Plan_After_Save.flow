            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
    </actionCalls>
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>checkFlowByPassFlag</name>
        <label>checkFlowByPassFlag</label>
        <locationX>553</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>Decision_Target_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>By_Pass_Flow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>bBypassFlowFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>By Pass Flow</label>
        </rules>
    </decisions>
    <decisions>
        <name>checkMRORecord</name>
        <label>checkMRORecord</label>
        <locationX>1007</locationX>
        <locationY>647</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>outcome_MRO_Record_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>MRO_Enquiry_Record</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>MRO_Enquiry_Record.RecordType_DeveloperName__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MRO</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Decision_MRO_Action</targetReference>
            </connector>
            <label>MRO Record Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_MRO_Action</name>
        <label>Decision MRO Action</label>
        <locationX>644</locationX>
        <locationY>755</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>outcome_InProgress</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ActionPlanState</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ActionPlanState</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>MRO_Enquiry_Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Award</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>decision_MRO_Plan_Type</targetReference>
            </connector>
            <label>InProgress</label>
        </rules>
        <rules>
            <name>outcome_Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ActionPlanState</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ActionPlanState</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>MRO_Enquiry_Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Award</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>decision_MRO_Plan_Type1</targetReference>
            </connector>
            <label>Completed</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_MRO_Plan_Type</name>
        <label>decision MRO Plan Type</label>
        <locationX>182</locationX>
        <locationY>863</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>outcome_Legal_Inprogress</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Name</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Legal - </stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Legal_InProgress_Template</targetReference>
            </connector>
            <label>Legal</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_MRO_Plan_Type1</name>
        <label>decision MRO Plan Type</label>
        <locationX>710</locationX>
        <locationY>863</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>outcome_Legal_Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Name</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Legal - </stringValue>
                </rightValue>
            </conditions>
            <connector>
