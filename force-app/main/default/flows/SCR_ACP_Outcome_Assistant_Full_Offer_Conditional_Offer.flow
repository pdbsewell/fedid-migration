            <leftValueReference>currentItem_InternationalACPOfferCondOutcomeStatus.Outcome_Path__c</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>Full Offer / Conditional Offer</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_InternationalACPOfferCondOutcomeStatus.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>OFFER-PROV</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_InternationalACPOfferCondOutcomeStatus.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>OFFER-COND</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>InternationACPOutcomeListOffer</targetReference>
        </connector>
    </collectionProcessors>
