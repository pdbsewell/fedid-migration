    <decisions>
        <name>Assign_LOV_Records_Full_Cond_Offer</name>
        <label>Assign LOV Records Full Cond Offer</label>
        <locationX>1348</locationX>
        <locationY>2846</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Full_Cond_Offer</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OutcomeStatusFullCond</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Status_AssistOfferConditional</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Full_Cond_Offer.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OUTCOME_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatAssignFullCond</targetReference>
            </connector>
            <label>OutcomeStatusFullCond</label>
        </rules>
        <rules>
            <name>DocumentationStatusFullCond</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>DocumentationStatFullCondOffer</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>StatusFormula</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_DOC_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DocumentationStatAssignFullCond</targetReference>
            </connector>
            <label>DocumentationStatusFullCond</label>
        </rules>
        <rules>
            <name>EntryQualificationFullCond</name>
            <conditionLogic>and</conditionLogic>
