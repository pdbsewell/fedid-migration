    <environments>Default</environments>
    <formulas>
        <name>ConditionalOfferStatusValue</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Conditional_Offer_Status_Prov}),IF(ISBLANK({!Conditional_Offer_Status_FullCondOffer}),&apos;&apos;,{!Conditional_Offer_Status_FullCondOffer}),{!Conditional_Offer_Status_Prov})</expression>
    </formulas>
    <formulas>
        <name>ConditionalStatOfferConditional</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!ConditionalOfferStatusValue},&apos;No conditions attached to offer(NOT-APPLIC)&apos;)</expression>
    </formulas>
    <formulas>
        <name>ConditionsMustBeSatisfiedValue</name>
        <dataType>Boolean</dataType>
        <expression>IF({!Outcome_Status_AssistOfferConditional}=&apos;Offer of admission subject to condition(OFFER-COND)&apos;, {!Conditions_must_be_satisfied_FullCondoffer}, IF(AND({!Outcome_Status_AssistOfferConditional}=&apos;Offer of admission provisional(OFFER-PROV)&apos;,ISNULL({!Conditional_Offer_Satisfied_Date})),{!Conditions_must_be_satisfied_FullCondoffer},{!Conditions_must_be_satisfied_readonly}))</expression>
    </formulas>
    <formulas>
        <name>ConditionsSatisfiedOfferCondToProv</name>
        <dataType>Boolean</dataType>
        <expression>IF(AND({!ACPRecord.Outcome_Status_LOV__r.Value__c}=&apos;Offer of admission subject to condition(OFFER-COND)&apos;,{!Outcome_Status_AssistOfferConditional}=&apos;Offer of admission provisional(OFFER-PROV)&apos;),{!ACPRecord.Conditions_Must_Be_Satisfied__c},FALSE)</expression>
    </formulas>
    <formulas>
        <name>DefaultConditionalOfferStatusValue</name>
        <dataType>String</dataType>
        <expression>{!ACPRecord.Conditional_Offer_Status_LOV__r.Description__c}+&apos;(&apos;+{!ACPRecord.Conditional_Offer_Status_LOV__r.Value__c}+&apos;)&apos;</expression>
    </formulas>
    <formulas>
        <name>DocumentationStatFullCondOffer</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Documentation_Status_IntOfferProv}),IF(ISBLANK({!Documentation_Status_IntOfferCond}),IF(ISBLANK({!Documentation_Status_DomOffer}),IF(ISBLANK({!Documentation_Status_DomOfferCond}),&apos;&apos;,{!Documentation_Status_DomOfferCond}),{!Documentation_Status_DomOffer}),{!Documentation_Status_IntOfferCond}),{!Documentation_Status_IntOfferProv})</expression>
    </formulas>
    <formulas>
        <name>getEnglishValidationMessagePROV</name>
        <dataType>String</dataType>
        <expression>IF({!Outcome_Status_AssistOfferConditional}==&apos;Offer of admission provisional(OFFER-PROV)&apos;,IF({!resultEnglishValidationMsg} == &apos;No English&apos;, {!noEnglishQual}, IF({!resultEnglishValidationMsg} == &apos;No Satisfactory English&apos;, {!noEnglishSatQual},{!noEnglishQual})),&apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>getFullOfferValidationMessage</name>
        <dataType>String</dataType>
        <expression>IF({!resultEducationValidationMsg} == &apos;No Education&apos;,{!noEducationQual},IF({!resultEducationValidationMsg} == &apos;No Score Education&apos;,{!noEducationScoreQual},IF({!resultEnglishValidationMsg} == &apos;No English&apos;, {!noEnglishQual}, IF({!resultEnglishValidationMsg} == &apos;No Satisfactory English&apos;, {!noEnglishSatQual},{!allFullOfferValidationFailed}))))</expression>
    </formulas>
    <formulas>
        <name>LongCommentsFullCondOffer</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Long_Comments_FullCondOffer}),{!Long_Comments_FullCondOffer_NR}, {!Long_Comments_FullCondOffer})</expression>
    </formulas>
    <formulas>
        <name>OfferConditionsFullCondOffer</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Offer_Conditions_FullCondOffer}),{!Offer_Conditions_NotRequired}, {!Offer_Conditions_FullCondOffer})</expression>
    </formulas>
    <formulas>
        <name>OfferDate</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!ACPRecord.Offer_Date__c},TODAY())</expression>
    </formulas>
    <formulas>
        <name>OfferLapseDate</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!ACPRecord.Offer_Response_Date__c},TODAY()+42)</expression>
    </formulas>
    <formulas>
        <name>OfferLapseDateValidation</name>
        <dataType>Boolean</dataType>
        <expression>AND({!Offer_Lapse_Date_FullCondOffer} &gt; {!TodaysDate},{!Offer_Lapse_Date_FullCondOffer}&gt;{!Offer_Date_FullCondOffer})</expression>
    </formulas>
    <formulas>
        <name>OfferResponseFullCondOffer</name>
        <dataType>String</dataType>
        <expression>IF({!ACPRecord.Offer_Response_Status_LOV__r.Value__c} == &apos;DEFERRAL&apos;,{!ACPRecord.Offer_Response_Status_LOV__r.Value__c},&apos;PENDING&apos;)</expression>
    </formulas>
    <formulas>
        <name>StatusFormula</name>
        <dataType>String</dataType>
        <expression>{!Loop_LOVs_Full_Cond_Offer.Description__c}+&apos;(&apos;+{!Loop_LOVs_Full_Cond_Offer.Value__c}+&apos;)&apos;</expression>
    </formulas>
    <formulas>
        <name>TodaysDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
