    <decisions>
        <name>Check_Full_Offer_Validation_Results</name>
        <label>Check Full Offer Validation Results</label>
        <locationX>50</locationX>
        <locationY>2246</locationY>
        <defaultConnector>
            <targetReference>No_Further_Screen_Full_Offer_Validation</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Validation Failed</defaultConnectorLabel>
        <rules>
            <name>Validation_Successful</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isValidFullOfferValidation</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_LOVs_Full_Cond_Offer</targetReference>
            </connector>
            <label>Validation Successful</label>
        </rules>
        <rules>
            <name>By_Pass_OFFER_PROV_Education_for_Monash_University_English_Language_Centre</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>isValidFullOfferValidation</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Status_AssistOfferConditional</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Managing_Faculty__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash University English Language Centre</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>No English</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>No Satisfactory English</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Full failed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_LOVs_Full_Cond_Offer</targetReference>
            </connector>
            <label>By Pass OFFER-PROV Education for &apos;Monash University English Language Centre&apos;</label>
        </rules>
        <rules>
            <name>OFFER_PROV_English_Error</name>
            <conditionLogic>1 AND 2 AND 3 AND (4 OR 5 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>isValidFullOfferValidation</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Status_AssistOfferConditional</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Managing_Faculty__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash University English Language Centre</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No English</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No Satisfactory English</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>resultEnglishValidationMsg</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Full failed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>No_Further_Screen_English_Validation</targetReference>
            </connector>
            <label>&apos;OFFER-PROV&apos; English Error</label>
        </rules>
    </decisions>
