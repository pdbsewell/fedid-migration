                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>QUALIFIED</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_ENTRY_QUAL_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EntryQualAssignFullCond</targetReference>
            </connector>
            <label>EntryQualificationFullCond</label>
        </rules>
        <rules>
            <name>OfferResponseFullCond</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>OfferResponseFullCondOffer</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Full_Cond_Offer.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OfferRespAssignFullCond</targetReference>
            </connector>
            <label>OfferResponseFullCond</label>
        </rules>
        <rules>
            <name>ConditionalOfferFullCond</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ConditionalStatOfferConditional</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>StatusFormula</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ConditionalOfferAssignFullCond</targetReference>
            </connector>
            <label>ConditionalOfferFullCond</label>
        </rules>
        <rules>
            <name>ConditionalOfferNotApplicable</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Full_Cond_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
