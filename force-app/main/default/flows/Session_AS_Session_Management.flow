    <actionCalls>
        <name>Send_Session_Email_Alert</name>
        <label>Send Session Email Alert</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>ucinn_ascendv2__Session__c.ucinn_ascendv2__New_Session_Assigned</actionName>
        <actionType>emailAlert</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>SObjectRowId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>ucinn_ascendv2__Session__c.ucinn_ascendv2__New_Session_Assigned</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Validation_Session_Record</name>
        <label>Validation Session Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>New_Session_Assigned</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ucinn_ascendv2__Session_Operator_Assigned__r.UserType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Standard</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.CreatedDate</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <dateTimeValue>1900-01-01T07:00:00.000Z</dateTimeValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Session_Email_Alert</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>New Session Assigned</label>
        </rules>
        <rules>
            <name>Update_Session_Default_Appeal</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Default_Appeal__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Default_Appeal</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Update Session Default Appeal</label>
        </rules>
    </decisions>
    <description>Migrating WF/PBs EPCP-4525.</description>
    <environments>Default</environments>
    <interviewLabel>Session : AS : Session Management {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Session : AS : Session Management</label>
    <processMetadataValues>
