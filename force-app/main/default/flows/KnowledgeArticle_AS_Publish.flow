            </value>
        </inputParameters>
        <nameSegment>publishKnowledgeArticles</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <actionCalls>
        <description>Unlock the article, as it will be locked during the Approval process</description>
        <name>Unlock_Article</name>
        <label>Unlock Article</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>lockRecord</actionName>
        <actionType>lockRecord</actionType>
        <connector>
            <targetReference>Set_Validation_Status_to_Published</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_Error_Unlock_record</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>recordId</name>
            <value>
                <elementReference>inputKnowledgeArticle.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>action</name>
            <value>
                <stringValue>Unlock</stringValue>
            </value>
        </inputParameters>
        <nameSegment>lockRecord</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Adding the Article ID to a list, for use in Knowledge Actions (takes input parameters only as a list of IDs)</description>
        <name>Add_Article_ID_to_list</name>
        <label>Add Article ID to list</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>listArticleIDs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>inputKnowledgeArticle.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Unlock_Article</targetReference>
        </connector>
    </assignments>
    <description>SubFlow which publishes the article, handles Row Lock issues with the Approval process</description>
    <environments>Default</environments>
    <formulas>
        <name>txtLogEntryMessage</name>
        <dataType>String</dataType>
        <expression>&quot;Error during update - &quot; &amp; {!txtScenario}</expression>
    </formulas>
    <interviewLabel>KnowledgeArticle : AS : Publish {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Knowledge/Article : AS : Publish</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Validation_Status_to_Published</name>
        <label>Set Validation Status to Published</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Publish_Article</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_error_update_validation_status</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>inputKnowledgeArticle.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>ValidationStatus</field>
            <value>
                <stringValue>Published</stringValue>
            </value>
        </inputAssignments>
        <object>Knowledge_Article__kav</object>
    </recordUpdates>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Add_Article_ID_to_list</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <variables>
        <description>Knowledge Article record, availabe to set for input</description>
        <name>inputKnowledgeArticle</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>Knowledge_Article__kav</objectType>
    </variables>
    <variables>
        <name>listArticleIDs</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Scenario from which this subflow is invoked</description>
        <name>txtScenario</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
