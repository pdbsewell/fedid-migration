    <decisions>
        <name>IsQueueNull</name>
        <label>IsQueueNull</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>AssignTaskOwner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>QueueAvailable</defaultConnectorLabel>
        <rules>
            <name>NoQueueAvailable</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetQueueName.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CreateTask</targetReference>
            </connector>
            <label>No Queue Available</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>calculatedOwnerName</name>
        <dataType>String</dataType>
        <expression>Case({!Type}, 
&apos;Genuine Student&apos;, &apos;Genuine Student&apos;, 
&apos;Non-guideline assessment&apos;, &apos;Qualification Recognition&apos;,
{!$User.FirstName} + &apos; &apos; + {!$User.LastName})</expression>
    </formulas>
    <formulas>
        <name>CalculatedSubType</name>
        <dataType>String</dataType>
        <expression>{!SubTypeAdditionalAssessment} + {!SubTypeQualificationRecognition} + {!SubTypeWorkExperience}</expression>
    </formulas>
    <formulas>
        <name>FacultyQueueName</name>
        <dataType>String</dataType>
        <expression>CASE( {!GetACPRecord.Managing_Faculty__c},
&quot;Faculty of Art, Design and Architecture&quot;,&quot;Faculty of MADA - Admissions&quot;,
&quot;Faculty of Arts&quot;,&quot;Faculty of Arts - Admissions&quot;,
&quot;Faculty of Business and Economics&quot;, &quot;Faculty of BusEco - Admissions&quot;,
&quot;Faculty of Education&quot;, &quot;Faculty of Education - Admissions&quot;,
&quot;Faculty of Engineering&quot;, &quot;Faculty of Engineering - Admissions&quot;,
&quot;Faculty of Information Technology&quot;, &quot;Faculty of IT - Admissions&quot;,
&quot;Faculty of Law&quot;, &quot;	Faculty of Law - Admissions&quot;,
&quot;Faculty of Medicine, Nursing and Health Sciences&quot;, &quot;Faculty of MNHS - Admissions&quot;,
&quot;Faculty of Pharmacy and Pharmaceutical Sciences&quot;, &quot;Faculty of Pharmacy - Admissions&quot;,
&quot;Faculty of Science&quot;, &quot;Faculty of Science - Admissions&quot;,
&quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>queueDeveloperName</name>
        <dataType>String</dataType>
        <expression>IF({!Type} == &apos;Genuine Student&apos;, &apos;GenuineStudent&apos; , &apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>subjectDefaultValue</name>
        <dataType>String</dataType>
        <expression>{!Type} + IF(ISBLANK({!CalculatedSubType}), &apos;&apos;, &apos; - &apos; + {!CalculatedSubType})+ &apos;, Applicant: &apos; + {!GetApplicantRecord.Name} + &apos;, &apos; + {!GetACPRecord.Name}</expression>
    </formulas>
    <interviewLabel>SCr - {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Application Course Preference - Create Assessment Tasks</label>
    <processMetadataValues>
        <name>BuilderType</name>
