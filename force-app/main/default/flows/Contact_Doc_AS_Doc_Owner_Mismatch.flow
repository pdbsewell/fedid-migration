            </value>
        </inputParameters>
        <inputParameters>
            <name>tagsString</name>
            <value>
                <stringValue>Admissions,Digitary</stringValue>
            </value>
        </inputParameters>
        <nameSegment>Nebula__FlowRecordLogEntry</nameSegment>
        <offset>0</offset>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Set Application Last Verified Document Received Date so another flow for application can send out email notifications.</description>
        <name>Set_Application_Last_Verified_Document_Received_Date</name>
        <label>Set Application Last Verified Document Received Date</label>
        <locationX>308</locationX>
        <locationY>1247</locationY>
        <assignmentItems>
            <assignToReference>Application.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Application__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Application.Last_Verified_Document_Received_Date__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Application</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Visibility_to_All_User</name>
        <label>Set Visibility to &apos;All User&apos;</label>
        <locationX>528</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>Loop.Visibility</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>AllUsers</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>ContentDocumentLinksToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Visibility_to_Internal_User</name>
        <label>Set Visibility to &apos;Internal User&apos;</label>
        <locationX>264</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>Loop.Visibility</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>InternalUsers</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>ContentDocumentLinksToUpdate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Check value of Document_Owner _Mismatch__c field</description>
        <name>Document_Owner_Mismatch</name>
        <label>Is Document Owner Mismatch</label>
        <locationX>396</locationX>
        <locationY>647</locationY>
        <defaultConnector>
            <targetReference>Set_Visibility_to_All_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>False</defaultConnectorLabel>
        <rules>
            <name>True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Document_Owner_Mismatch__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Visibility_to_Internal_User</targetReference>
            </connector>
            <label>True</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Document_Owner_Mismatch</name>
        <label>Is Document Owner Mismatch</label>
        <locationX>176</locationX>
        <locationY>1139</locationY>
        <defaultConnector>
            <targetReference>Set_Application_Last_Verified_Document_Received_Date</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>False</defaultConnectorLabel>
        <rules>
            <name>Is_True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Document_Owner_Mismatch__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <label>True</label>
        </rules>
    </decisions>
    <description>Update the content document link visibility to &apos;Internal User&apos; for Application, Contact, and Contact Document when the document owner does not match. If the document owner matches, set the visibility to &apos;All User&apos;.</description>
    <environments>Default</environments>
    <interviewLabel>Contact Document : AS : Document Owner Mismatch {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Contact Document : AS : Document Owner Mismatch</label>
    <loops>
        <description>Loop through related content document links to update visibilities</description>
        <name>Loop</name>
        <label>Loop</label>
        <locationX>176</locationX>
        <locationY>539</locationY>
        <collectionReference>Get_Related_Content_Document_Links</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Document_Owner_Mismatch</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Related_Content_Document_Links</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get content document link for this contact document</description>
        <name>Get_Direct_Content_Document_Link</name>
        <label>Get Direct Content Document Link</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Related_Content_Document_Links</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>LinkedEntityId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>ContentDocumentLink</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Get content document links for application, contact and contact document</description>
        <name>Get_Related_Content_Document_Links</name>
        <label>Get Related Content Document Links</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop</targetReference>
        </connector>
        <filterLogic>(1 OR 2 OR 3) AND 4</filterLogic>
        <filters>
            <field>LinkedEntityId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Application__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>LinkedEntityId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Contact__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>LinkedEntityId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>ContentDocumentId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Get_Direct_Content_Document_Link.ContentDocumentId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>ContentDocumentLink</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Application</name>
        <label>Update Application</label>
        <locationX>308</locationX>
        <locationY>1355</locationY>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Failed_to_Update</targetReference>
        </faultConnector>
        <inputReference>Application</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update the content document link visibility to &apos;Internal User&apos; for Application, Contact, and Contact Document when the document owner does not match. If the document owner matches, set the visibility to &apos;All User&apos;.</description>
        <name>Update_Related_Content_Document_Links</name>
        <label>Update Related Content Document Links</label>
        <locationX>176</locationX>
        <locationY>1031</locationY>
        <connector>
            <targetReference>Is_Document_Owner_Mismatch</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Failed_to_Update</targetReference>
        </faultConnector>
        <inputReference>ContentDocumentLinksToUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Direct_Content_Document_Link</targetReference>
        </connector>
        <filterFormula>AND(
  {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
  CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;Contact_Doc_AS_Doc_Owner_Mismatch,&quot;) = False,
  {!$Record.Internal_Only__c} = False,
  ISCHANGED({!$Record.Document_Owner_Mismatch__c})
)</filterFormula>
        <object>Contact_Document__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>Application</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Application__c</objectType>
    </variables>
    <variables>
        <name>ContentDocumentLinksToUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>ContentDocumentLink</objectType>
    </variables>
</Flow>
