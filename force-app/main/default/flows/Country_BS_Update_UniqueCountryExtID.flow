<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign Callista code count into a variable</description>
        <name>Set_Callista_Code_Count</name>
        <label>Set Callista Code Count</label>
        <locationX>176</locationX>
        <locationY>395</locationY>
        <assignmentItems>
            <assignToReference>IntCallistaCodeCount</assignToReference>
            <operator>AssignCount</operator>
            <value>
                <elementReference>Get_All_Records_with_Callista_Code</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Record</targetReference>
        </connector>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>uniqueCountryIDFormula</name>
        <dataType>String</dataType>
        <expression>{!$Record.Callista_Code__c} &amp;&quot;-&quot;&amp; {!$Record.ISO_Alpha_3__c}&amp;&quot;-&quot;&amp;{!$Record.Numeric_Country_Code__c}&amp;&quot;-&quot;&amp;TEXT({!IntCallistaCodeCount})</expression>
    </formulas>
    <interviewLabel>Country : BS : Populate UniqueCountryExternalID {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Country : BS : Populate UniqueCountryExternalID</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get all records matching Callista Code</description>
        <name>Get_All_Records_with_Callista_Code</name>
        <label>Get All Records with Callista Code</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Set_Callista_Code_Count</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Callista_Code__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Callista_Code__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Country_Attribute__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Update uniqueCountryExternalId__c with the value evaluated from the formula</description>
        <name>Update_Record</name>
        <label>Update Record</label>
        <locationX>176</locationX>
        <locationY>503</locationY>
        <inputAssignments>
            <field>uniqueCountryExternalId__c</field>
            <value>
                <elementReference>uniqueCountryIDFormula</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_All_Records_with_Callista_Code</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; NOT(ISBLANK({!$Record.Callista_Code__c})) &amp;&amp; ISBLANK({!$Record.uniqueCountryExternalId__c})</filterFormula>
        <object>Country_Attribute__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>IntCallistaCodeCount</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <scale>2</scale>
    </variables>
</Flow>
