        <label>assign Outcome</label>
        <locationX>854</locationX>
        <locationY>1797</locationY>
        <assignmentItems>
            <assignToReference>getEnquiry.Category_Level_1__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Academic Integrity Breach</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>getEnquiry.Case_Outcome__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Q5</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>getEnquiry.Status</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Solved</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>update_Enquiry</targetReference>
        </connector>
    </assignments>
    <choices>
        <name>c_BreachOfAssessmentConditions</name>
        <choiceText>Breach of assessment conditions</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Breaching conditions or requirements of an assessment</stringValue>
        </value>
    </choices>
    <choices>
        <description>Minor breach - can be managed with a warning and an educative response</description>
        <name>c_Minorbreach</name>
        <choiceText>Minor breach - can be managed with a warning and an educative response</choiceText>
        <dataType>String</dataType>
        <value>
            <stringValue>Minor breach</stringValue>
        </value>
    </choices>
    <choices>
        <description>No, continue the decision-making</description>
        <name>c_Nocontinuethedecisionmaking</name>
