    <screens>
        <name>screen_Misconduct</name>
        <label>screen Misconduct</label>
        <locationX>655</locationX>
        <locationY>1303</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>assign_Alleged_Misconduct</targetReference>
        </connector>
        <fields>
            <name>dtxt_AllgedMisconduct</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Alleged Academic Misconduct&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;This student is in the Academic Integrity Register.&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;This breach will be referred to Student Conduct and Complaints, as an allegation of Academic Misconduct.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p class=&quot;ql-indent-1&quot;&gt;&lt;span style=&quot;color: rgb(23, 43, 77); font-size: 14px; background-color: rgb(255, 255, 255);&quot;&gt;1. &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(23, 43, 77);&quot;&gt;Please add any additional information to support your decision to refer this case as misconduct. This will assist Student Conduct and Complaints with their investigation.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <fieldType>ObjectProvided</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>false</isRequired>
            <objectFieldReference>getEnquiry.Comments</objectFieldReference>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_AllgedMisconduct_b</name>
            <fieldText>&lt;p class=&quot;ql-indent-1&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;2. Use the &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Academic Integrity Breach Outcome - Alleged Misconduct&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; email template to inform the student of the outcome.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Click &lt;/span&gt;&lt;strong style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;&lt;em&gt;Next&lt;/em&gt;&lt;/strong&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to finalise your decision and transfer the case to the Student Conduct and Complaints team.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;You will not have access to the case once it is transferred. After the investigation is complete and a decision has been made, you will be notified of the final outcome.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
