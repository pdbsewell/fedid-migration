            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_new1</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;You’ll need to let the student know this outcome by sending the&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;m an email using&amp;nbsp;the &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;Academic Integrity - Warning Outcome (to Student)&lt;/span&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; template. You may also let the staff member who reported the&amp;nbsp;breach know the outcome by bcc-ing them in the email.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
