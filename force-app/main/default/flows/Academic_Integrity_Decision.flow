            <isRequired>false</isRequired>
            <regionContainerType>SectionWithoutHeader</regionContainerType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dtxt_EduResp</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: rgb(67, 67, 67); font-size: 14px;&quot;&gt;This minor breach stems from poor academic practice and the student should be supported with an educational response. Learn more about the two possible &lt;/span&gt;&lt;a href=&quot;https://learning-teaching.monash.edu/articulateFiles/academic_integrity/academic-integrity-breach-form-resource/content/index.html#/lessons/uCcF2-lazAyLJP6iuQw30aRvdRm9DgLt&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;background-color: transparent; color: rgb(17, 85, 204); font-size: 14px;&quot;&gt;&lt;u&gt;educational responses&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;background-color: transparent; color: rgb(67, 67, 67); font-size: 14px;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Q4</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <elementReference>c_Minorbreach</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>screen_Decision_2_Section2</name>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>screen_Decision_2_Section2_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_Q5</name>
                    <fieldText>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;Q. &lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;Select the outcome of the breach.&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
