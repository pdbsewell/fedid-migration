        </connector>
        <fields>
            <name>dtxt_Dismiss</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Dismiss after investigation&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;This case will be dismissed. Please notify the student of the outcome by sending an email using the &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Academic Integrity - Dismissed Outcome (to Student)&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; email template. You can also BCC the staff member who initiated the investigation to let them know the outcome.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;After the email has been sent, click &lt;/span&gt;&lt;em style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Next&lt;/em&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to finalise your decision and close the case.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                    <operator>NotEqualTo</operator>
                    <rightValue>
                        <stringValue>Inappropriate use of Artificial Intelligence</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_Dismiss_ArtInt</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 109, 174); font-size: 18px;&quot;&gt;Dismiss after investigation&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;This case will be dismissed.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;No further action is required from you. Click &lt;/span&gt;&lt;em style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Finish&lt;/em&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; to finalise your decision and close the case.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
