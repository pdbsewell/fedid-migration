    <textTemplates>
        <name>txt_debugDetails</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;b style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;Oops! We have run into an issue&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;We have run into an issues while updating this record. Please contact your system administrator with the below details for them to investigate the issue.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;-------Debug Start-------&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255);&quot;&gt;Flow:&lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt; Academic Integrity - Breach Review&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255);&quot;&gt;Org Id: &lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;{!$Organization.Id}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255); background-color: rgb(255, 255, 255);&quot;&gt;Date/Time:&lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt; {!$Flow.CurrentDateTime}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255);&quot;&gt;Running User:&lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt; {!$User.Id}({!$Profile.Name})&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 0, 255);&quot;&gt;Interview GUID:&lt;/b&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 0, 255);&quot;&gt; {!$Flow.InterviewGuid}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255);&quot;&gt;Enquiry Id:&lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt; {!getEnquiry.Id}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(0, 0, 255);&quot;&gt;Enquiry Number:&lt;/b&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt; {!getEnquiry.CaseNumber}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b style=&quot;color: rgb(255, 0, 0);&quot;&gt;Error Message:&lt;/b&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt; {!$Flow.FaultMessage}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;-------Debug End-------&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;For any help, questions or support contact:&lt;/p&gt;&lt;p&gt;{!txt_SupportContact}&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>txt_SupportContact</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;b&gt;Academic Integrity Support (UniCRM)&lt;/b&gt;&lt;/p&gt;&lt;p&gt;Name: Servicedesk Online&lt;/p&gt;&lt;p&gt;Email: servicedesk@monash.edu&lt;/p&gt;</text>
    </textTemplates>
