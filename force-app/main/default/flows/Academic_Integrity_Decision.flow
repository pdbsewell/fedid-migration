            <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;Click &lt;/span&gt;&lt;b style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;&lt;i&gt;Next&lt;/i&gt;&lt;/b&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt; to review your decision.&lt;/span&gt;&lt;/p&gt;</fieldText>
