    <decisions>
        <name>decision_Breach_Type</name>
        <label>decision Breach Type</label>
        <locationX>846</locationX>
        <locationY>1519</locationY>
        <defaultConnector>
            <targetReference>assign_Outcome</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>out Minor</defaultConnectorLabel>
        <rules>
            <name>out_Serious</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Q4</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Seriousbreach</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Misconduct_0</targetReference>
            </connector>
            <label>out Serious</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_In_AI_Register</name>
        <label>decision In AI Register</label>
        <locationX>846</locationX>
        <locationY>1070</locationY>
        <defaultConnector>
            <targetReference>screen_Decision_2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>outcome Not in AI Register</defaultConnectorLabel>
        <rules>
            <name>outcome_In_AI_Register</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getList_ContactAIRegister</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Misconduct</targetReference>
            </connector>
            <label>outcome In AI Register</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_Integrity_Decision</name>
        <label>decision Integrity Decision</label>
        <locationX>566</locationX>
        <locationY>590</locationY>
        <defaultConnector>
            <targetReference>getList_ContactAIRegister</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>out_Artificial_Intelligence</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Yes</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Inappropriate use of Artificial Intelligence</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>No</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q3</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>InappropriateUseOfArtificialIntelligence</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Misconduct_1</targetReference>
            </connector>
            <label>out Artificial Intelligence</label>
        </rules>
        <rules>
            <name>out_Change_From_Artificial_Intelligence</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getEnquiry.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Inappropriate use of Artificial Intelligence</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>No</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Q3</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>InappropriateUseOfArtificialIntelligence</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assign_Cat_2</targetReference>
            </connector>
            <label>out Change From Artificial Intelligence</label>
        </rules>
        <rules>
            <name>out_Dismiss_Case</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Q1</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Yes</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Dismiss</targetReference>
            </connector>
            <label>out Dismiss Case</label>
        </rules>
        <rules>
            <name>out_Update_CatLvl2</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Q2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>No</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assign_CatLvl2</targetReference>
            </connector>
            <label>out Update CatLvl2</label>
        </rules>
    </decisions>
    <description>Guided decision making process for AI cases.
Release 21.5.1.2: Time based transfer to SEBS</description>
    <environments>Default</environments>
    <interviewLabel>Academic Integrity - Decision {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Academic Integrity - Decision</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordLookups>
        <name>get_SEBS_QueueId</name>
        <label>get SEBS QueueId</label>
        <locationX>528</locationX>
        <locationY>326</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>screen_Decision</targetReference>
        </connector>
        <faultConnector>
            <targetReference>debug_GetQueue</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Name</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>SEBS - Complaints &amp; Misconduct</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>getEnquiry</name>
        <label>getEnquiry</label>
        <locationX>528</locationX>
        <locationY>206</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>get_SEBS_QueueId</targetReference>
        </connector>
        <faultConnector>
            <targetReference>debug_GetEnquiry</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varEnquiryId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Case</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Check Academic Integrity Register for contact&apos;s enquiries</description>
        <name>getList_ContactAIRegister</name>
        <label>getList ContactAIRegister</label>
        <locationX>854</locationX>
        <locationY>920</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>decision_In_AI_Register</targetReference>
        </connector>
        <faultConnector>
            <targetReference>debug_GetAIRegister</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2 AND (3 OR 4) AND 5 AND (6 OR 7) AND 8</filterLogic>
        <filters>
            <field>RecordType_DeveloperName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Complaint</stringValue>
            </value>
        </filters>
        <filters>
            <field>Enquiry_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Student Misconduct</stringValue>
            </value>
        </filters>
        <filters>
            <field>Category_Level_1__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Academic Integrity Breach</stringValue>
            </value>
        </filters>
        <filters>
            <field>Category_Level_1__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Academic Misconduct</stringValue>
            </value>
        </filters>
        <filters>
            <field>IsClosed</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Case_Outcome__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>upheld</stringValue>
            </value>
        </filters>
        <filters>
            <field>Case_Outcome__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>warning</stringValue>
            </value>
        </filters>
        <filters>
            <field>ContactId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>getEnquiry.ContactId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Case</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
