            </connector>
            <label>Link Enquiry</label>
        </rules>
    </decisions>
    <decisions>
        <name>DecisionEnquiry_RecordType</name>
        <label>DecisionEnquiry RecordType</label>
        <locationX>600</locationX>
        <locationY>539</locationY>
        <defaultConnector>
            <targetReference>DecisionAP_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>MRO</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Enquiry.RecordType_DeveloperName__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MRO</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DecisionEnquiry_Link</targetReference>
            </connector>
            <label>MRO</label>
        </rules>
    </decisions>
    <description>New flow for MRO Action Plan on Create &amp; Update</description>
    <environments>Default</environments>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>IsNew()</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Action Plan After Save ( {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record-Trigger: Action Plan After Save (Monash Research Office)</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
