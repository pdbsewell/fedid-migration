    <decisions>
        <name>Decision_RelatedRecord</name>
        <label>Decision RelatedRecord</label>
        <locationX>1161</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Enquiry</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.TargetId</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>500</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Enquiry</targetReference>
            </connector>
            <label>Enquiry</label>
        </rules>
