    <decisions>
        <name>Decision_ActualStartDate</name>
        <label>Decision ActualStartDate</label>
        <locationX>710</locationX>
        <locationY>1139</locationY>
        <defaultConnector>
            <targetReference>AssignDate_ActualEnd</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ActualStart_IsNull</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ActualStartDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AssignDate_StartDate1</targetReference>
            </connector>
            <label>ActualStart IsNull</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_NewRecord</name>
        <label>Decision NewRecord</label>
        <locationX>182</locationX>
        <locationY>1139</locationY>
        <defaultConnector>
            <targetReference>AssignDate_ActualStart</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>InProgress_IsNew</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>AssignDate_StartDate</targetReference>
            </connector>
            <label>InProgress IsNew</label>
        </rules>
