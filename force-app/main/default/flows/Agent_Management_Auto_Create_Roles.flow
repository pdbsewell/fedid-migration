    <formulas>
        <name>AccountRTFromCustomSetting</name>
        <dataType>String</dataType>
        <expression>{!$Setup.Agent_Onboarding_Settings__c.Account_RT_Developer_Name__c}</expression>
    </formulas>
    <formulas>
        <name>BranchManagerRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Branch Manager&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>CounsellorRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Counsellor&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>FinanceRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Finance&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>KeyCounsellorRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Key Counsellor&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>OtherRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Other&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>PrincipalAgentRoleApplies</name>
        <dataType>Boolean</dataType>
        <expression>IF(
    INCLUDES(
        {!InputContactRecord.Agency_Contact_Roles__c},
        &quot;Principal Agent&quot;
    ),
    true,
    false
)</expression>
    </formulas>
    <formulas>
        <name>RoleRTDeveloperName</name>
        <dataType>String</dataType>
        <expression>{!$Setup.Agent_Onboarding_Settings__c.Role_RT_Developer_Name__c}</expression>
    </formulas>
    <interviewLabel>Agent Management - Auto Create Roles {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Agent Management - Auto Create Roles</label>
    <loops>
        <name>Iterate_Through_Branches</name>
        <label>Iterate Through Branches</label>
        <locationX>685</locationX>
        <locationY>875</locationY>
        <assignNextValueToReference>BranchInLoop</assignNextValueToReference>
        <collectionReference>Branches</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_Role_Rec_Values</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Insert_Branch_Manager</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Insert_Role_Records</name>
        <label>Insert Role Records</label>
        <locationX>1825</locationX>
        <locationY>397</locationY>
        <inputReference>RoleRecordsCollection</inputReference>
    </recordCreates>
    <recordDeletes>
        <name>Delete_Existing_Principal_Roles</name>
        <label>Delete Existing Principal Roles</label>
        <locationX>91</locationX>
        <locationY>1104</locationY>
        <connector>
            <targetReference>Fetch_Account_RT</targetReference>
        </connector>
        <inputReference>ExistingPrincipalsRolesToDelete</inputReference>
    </recordDeletes>
    <recordLookups>
        <name>Fetch_Account_Record</name>
        <label>Fetch Account Record</label>
        <locationX>91</locationX>
        <locationY>621</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Fetch_Existing_Principal</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>InputContactRecord.AccountId</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <outputReference>AgencyRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Principal_Agent__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Fetch_Account_RT</name>
        <label>Fetch Account RT</label>
        <locationX>425</locationX>
        <locationY>1102</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Fetch_Branches</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>AccountRTFromCustomSetting</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Account</stringValue>
            </value>
        </filters>
        <object>RecordType</object>
        <outputReference>AccountRTRec</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Fetch_Branches</name>
        <label>Fetch Branches</label>
        <locationX>425</locationX>
        <locationY>990</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
