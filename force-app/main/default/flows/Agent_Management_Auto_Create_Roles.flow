    <decisions>
        <name>Are_there_branches</name>
        <label>Are there branches?</label>
        <locationX>425</locationX>
        <locationY>877</locationY>
        <defaultConnector>
            <targetReference>Insert_Branch_Manager</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No there aren&apos;t</defaultConnectorLabel>
        <rules>
            <name>Yes_there_are</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Branches</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Iterate_Through_Branches</targetReference>
            </connector>
            <label>Yes there are</label>
        </rules>
    </decisions>
    <decisions>
        <name>Exists</name>
        <label>Existing Principal Exists?</label>
        <locationX>93</locationX>
        <locationY>857</locationY>
        <defaultConnector>
            <targetReference>Fetch_Account_RT</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, Existing Principal Does Not Exist</defaultConnectorLabel>
        <rules>
            <name>YesExistingPrincipalExists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ExistingPrincipalContact</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Fetch_Exsiting_Principal_Roles</targetReference>
            </connector>
            <label>Yes, Existing Principal Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Insert_Branch_Manager</name>
        <label>Insert Branch Manager?</label>
        <locationX>561</locationX>
        <locationY>236</locationY>
        <defaultConnector>
            <targetReference>Insert_Counsellor</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>BranchManagerYes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>BranchManagerRoleApplies</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Role_Record_Field_Values_Branch_Manager</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
