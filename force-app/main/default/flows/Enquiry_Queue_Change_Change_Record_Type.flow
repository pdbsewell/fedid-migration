    <description>This process changes the record type of the enquiry whenever it is assigned to a queue</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
    [Case].RecordTypeId &lt;&gt; null,
	(	CONTAINS(PRIORVALUE([Case].RecordTypeId), &quot;012280000019XJtAAM&quot;) ||
		CONTAINS(PRIORVALUE([Case].RecordTypeId), &quot;012280000019XJt&quot;)),
    [Case].Flag_Owner_is_Queue__c,
	[Case].Owner:Queue.DeveloperName = &quot;OFS_Enquiries&quot;
)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_3</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    {!myVariable_current.RecordTypeId} &lt;&gt; null,
	(	CONTAINS(PRIORVALUE({!myVariable_current.RecordTypeId}), &quot;012280000019XJtAAM&quot;) ||
		CONTAINS(PRIORVALUE({!myVariable_current.RecordTypeId}), &quot;012280000019XJt&quot;)),
    {!myVariable_current.Flag_Owner_is_Queue__c},
	{!myVariable_current.Owner:Queue.DeveloperName} = &quot;OFS_Enquiries&quot;
)</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(
    [Case].RecordTypeId &lt;&gt; null,
	(	CONTAINS(PRIORVALUE([Case].RecordTypeId), &quot;012280000019XJtAAM&quot;) ||
		CONTAINS(PRIORVALUE([Case].RecordTypeId), &quot;012280000019XJt&quot;)),
    [Case].Flag_Owner_is_Queue__c,
	[Case].Owner:Queue.DeveloperName = &quot;OFS_Enquiries&quot;
)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_3_pmetrule</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    {!myVariable_old.RecordTypeId} &lt;&gt; null,
	(	CONTAINS(PRIORVALUE({!myVariable_old.RecordTypeId}), &quot;012280000019XJtAAM&quot;) ||
		CONTAINS(PRIORVALUE({!myVariable_old.RecordTypeId}), &quot;012280000019XJt&quot;)),
    {!myVariable_old.Flag_Owner_is_Queue__c},
	{!myVariable_old.Owner:Queue.DeveloperName} = &quot;OFS_Enquiries&quot;
)</expression>
    </formulas>
