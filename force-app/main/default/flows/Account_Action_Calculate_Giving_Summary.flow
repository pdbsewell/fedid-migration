            </value>
        </inputParameters>
        <nameSegment>AccountActionCalcGivingSummary</nameSegment>
    </actionCalls>
    <apiVersion>51.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Add the recordId to the Ids collection</description>
        <name>Add_recordId_to_Ids_Collection</name>
        <label>Add recordId to Ids Collection</label>
        <locationX>50</locationX>
        <locationY>278</locationY>
        <assignmentItems>
            <assignToReference>ids</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Calculate_Giving_Summary</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>If RecordId is populated, pass it into the generic collection.</description>
        <name>Check_if_recordId_is_populated</name>
        <label>Check if single recordId is populated</label>
        <locationX>182</locationX>
        <locationY>158</locationY>
        <defaultConnector>
            <targetReference>Calculate_Giving_Summary</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>recordId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_recordId_to_Ids_Collection</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Flow to invoke the batch to calculate the giving summary (philanthropic donations) of an account record.</description>
