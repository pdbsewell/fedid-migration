<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Invokes the batch class to kick off the recalculation.</description>
        <name>Calculate_Giving_Summary</name>
