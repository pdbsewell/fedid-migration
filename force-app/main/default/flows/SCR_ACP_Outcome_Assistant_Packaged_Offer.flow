    <collectionProcessors>
        <name>DocumentationStatusPackaged</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>DocumentationStatusPackaged</label>
        <locationX>176</locationX>
        <locationY>350</locationY>
        <assignNextValueToReference>currentItem_DocumentationStatusPackaged</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>LisOfValues</collectionReference>
        <conditionLogic>1 AND (2 OR 3)</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_DocumentationStatusPackaged.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_DOC_STATUS</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_DocumentationStatusPackaged.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>PACK-DOC</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_DocumentationStatusPackaged.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>PACK-DOC-U</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>CustomDocumentChoice</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>OutcomeStatusPackaged</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>OutcomeStatusPackaged</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <assignNextValueToReference>currentItem_OutcomeStatusPackaged</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>LisOfValues</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_OutcomeStatusPackaged.Outcome_Path__c</leftValueReference>
            <operator>Contains</operator>
            <rightValue>
                <stringValue>Packaged Offer</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>CustomOutcomeChoice</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Assign_LOV_Records_Packaged_Offer</name>
        <label>Assign LOV Records Packaged Offer</label>
        <locationX>924</locationX>
        <locationY>890</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Packaged_Offer</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OutcomeStatusPackagedOffer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Status_AssistPackaged</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Packaged_Offer.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OUTCOME_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatAssignPackaged</targetReference>
            </connector>
            <label>OutcomeStatusPackagedOffer</label>
        </rules>
        <rules>
            <name>DocumentationStatusPackagedOffer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Documentation_Status_Packaged</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Packaged_Offer.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_DOC_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DocumentationStatAssignPackaged</targetReference>
            </connector>
            <label>DocumentationStatusPackagedOffer</label>
        </rules>
        <rules>
            <name>EntryQualificationPackagedOffer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>QUALIFIED</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_ENTRY_QUAL_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EntryQualAssignPackaged</targetReference>
            </connector>
            <label>EntryQualificationPackagedOffer</label>
        </rules>
        <rules>
            <name>OfferResponsePackagedOffer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>OfferResponseFullCondOffer</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OfferRespAssignPackaged</targetReference>
            </connector>
            <label>OfferResponsePackagedOffer</label>
        </rules>
        <rules>
            <name>ConditionalOfferPackagedOffer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Conditional_Offer_Status_Packaged</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Packaged_Offer.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Packaged_Offer.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ConditionalOfferAssignPackaged</targetReference>
            </connector>
            <label>ConditionalOfferPackagedOffer</label>
        </rules>
    </decisions>
    <description>Screen Flow for Outcome Path &apos;Packaged Offer&apos;</description>
    <dynamicChoiceSets>
        <name>BasisOfAdmissionType</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
        <object xsi:nil="true"/>
        <picklistField>Basis_For_Adminssion_Type__c</picklistField>
