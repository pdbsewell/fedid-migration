        <displayField>label</displayField>
        <object xsi:nil="true"/>
        <valueField>value</valueField>
    </dynamicChoiceSets>
    <dynamicChoiceSets>
        <name>OutcomeStatusPackagedSet</name>
        <collectionReference>CustomOutcomeChoice</collectionReference>
        <dataType>String</dataType>
        <displayField>label</displayField>
        <object xsi:nil="true"/>
        <valueField>value</valueField>
    </dynamicChoiceSets>
    <environments>Default</environments>
    <formulas>
        <name>LongCommentsPackagedOffer</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!Long_Comments_Packaged}),{!Long_Comments_Packaged_NR}, {!Long_Comments_Packaged})</expression>
    </formulas>
    <formulas>
        <name>OfferDate</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!ACPRecord.Offer_Date__c},TODAY())</expression>
    </formulas>
    <formulas>
        <name>OfferLapseDate</name>
        <dataType>Date</dataType>
        <expression>BLANKVALUE({!ACPRecord.Offer_Response_Date__c},TODAY()+42)</expression>
    </formulas>
    <formulas>
        <name>OfferLapseDateValidation</name>
        <dataType>Boolean</dataType>
        <expression>AND({!Offer_Lapse_Date_Packaged} &gt; {!TodaysDate},{!Offer_Lapse_Date_Packaged}&gt;{!Offer_Date_Packaged})</expression>
    </formulas>
    <formulas>
        <name>OfferResponseFullCondOffer</name>
        <dataType>String</dataType>
        <expression>IF({!ACPRecord.Offer_Response_Status_LOV__r.Value__c} == &apos;DEFERRAL&apos;,{!ACPRecord.Offer_Response_Status_LOV__r.Value__c},&apos;PENDING&apos;)</expression>
    </formulas>
    <formulas>
        <name>TodaysDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>SCR - ACP - Outcome Assistant : Packaged Offer {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - ACP - Outcome Assistant : Packaged Offer</label>
