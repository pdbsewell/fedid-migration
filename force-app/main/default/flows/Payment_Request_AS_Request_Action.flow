    <decisions>
        <name>New_record</name>
        <label>New Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not New Record</defaultConnectorLabel>
        <rules>
            <name>If_New_Record</name>
            <conditionLogic>1</conditionLogic>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_New_Record_Requested_Amount_GST_Fields</targetReference>
            </connector>
            <label>If New Record</label>
        </rules>
    </decisions>
    <decisions>
        <name>Requested_Amount_Ex_GST_Updated</name>
        <label>Requested Amount Ex GST Updated</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Requested_Amount_GST_Override</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Not Requested</defaultConnectorLabel>
        <rules>
            <name>Amount_Ex_GST_Requested</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Requested_Amount_Ex_GST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Requested_Amount_GST_Fields</targetReference>
            </connector>
            <label>Amount Ex GST Requested</label>
        </rules>
    </decisions>
    <decisions>
        <name>Requested_Amount_GST_Override</name>
        <label>Requested Amount GST Override</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>New_record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Is Not Requested</defaultConnectorLabel>
        <rules>
            <name>Amount_GST_Requested</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Requested_Amount_GST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Updated_Requested_Amount</targetReference>
            </connector>
            <label>Amount GST Requested</label>
        </rules>
    </decisions>
    <description>Update of payment request fields</description>
    <environments>Default</environments>
    <formulas>
        <name>CalculateRequestedAmount</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Requested_Amount_Ex_GST__c} + {!$Record.Requested_Amount_GST__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>CalculateRequestGST</name>
        <dataType>Number</dataType>
        <expression>IF({!$Record.GST_Inclusive__c}, {!$Record.Requested_Amount_Ex_GST__c} * 0.1, 0)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>CalculateTotalRequestedAmount</name>
        <dataType>Number</dataType>
        <expression>IF ( {!$Record.GST_Inclusive__c}, {!$Record.Requested_Amount_Ex_GST__c} * 1.1, {!$Record.Requested_Amount_Ex_GST__c} )</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>IsNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <interviewLabel>Payment Request : AS : Request Action {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Payment Request : AS : Request Action</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
