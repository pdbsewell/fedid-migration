                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Existing_External_Lead_Collaborators_Cluster</targetReference>
            </connector>
            <label>Outcome External Cluster</label>
        </rules>
    </decisions>
