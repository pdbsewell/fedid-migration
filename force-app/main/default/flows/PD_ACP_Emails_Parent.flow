    <description>The parent PB for PD ACP emails which directs records to the relevant faculty-specific PBs</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(


OR(

ISNEW(), 


OR(
ISCHANGED([Application_Course_Preference__c].Status__c ),

ISCHANGED([Application_Course_Preference__c].Course_Confirmed__c )
)
),


[Application_Course_Preference__c].Managing_Faculty_Text__c = &apos;Faculty of Business &amp; Economics&apos;,

[Application_Course_Preference__c].Course_Type_Text__c = &apos;Short_Course&apos;

)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>AND(


OR(

ISNEW(), 


OR(
ISCHANGED({!myVariable_current.Status__c} ),

ISCHANGED({!myVariable_current.Course_Confirmed__c} )
)
),


{!myVariable_current.Managing_Faculty_Text__c} = &apos;Faculty of Business &amp; Economics&apos;,

{!myVariable_current.Course_Type_Text__c} = &apos;Short_Course&apos;

)</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(


OR(

ISNEW(), 


OR(
ISCHANGED([Application_Course_Preference__c].Status__c ),

ISCHANGED([Application_Course_Preference__c].Course_Confirmed__c )
)
),


NOT(ISBLANK([Application_Course_Preference__c].Managing_Faculty_Text__c)),

[Application_Course_Preference__c].Course_Type_Text__c = &apos;Short_Course&apos;

)</stringValue>
            </value>
        </processMetadataValues>
