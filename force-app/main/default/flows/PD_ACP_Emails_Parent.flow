        <dataType>Boolean</dataType>
        <expression>AND(


OR(

ISNEW(), 


OR(
ISCHANGED({!myVariable_current.Status__c} ),

ISCHANGED({!myVariable_current.Course_Confirmed__c} )
)
),


NOT(ISBLANK({!myVariable_current.Managing_Faculty_Text__c})),

{!myVariable_current.Course_Type_Text__c} = &apos;Short_Course&apos;

)</expression>
    </formulas>
