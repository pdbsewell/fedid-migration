    <assignments>
        <name>SS_AssignCaseCommentsFields</name>
        <label>Assign Case Comments Fields</label>
        <locationX>314</locationX>
        <locationY>1118</locationY>
        <assignmentItems>
            <assignToReference>SS_CaseCommentsSingleRecord.CommentBody</assignToReference>
