    <decisions>
        <name>SS_HTTPRequestSuccessful</name>
        <label>HTTP Request Successful</label>
        <locationX>182</locationX>
        <locationY>998</locationY>
        <defaultConnector>
            <targetReference>SS_AssignCaseCommentsFields</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SS_STATUSFAILED</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SS_HTTPResponse</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>$Label.SS_ProcessDiscontinuationFailedMessage</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>SS_FaultScreenApex</targetReference>
            </connector>
            <label>STATUS=FAILED</label>
        </rules>
    </decisions>
