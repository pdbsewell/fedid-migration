<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>Invoke  CourseOfferingsService.generateHash method with the parameters</description>
        <name>Generate_Hash</name>
        <label>Generate Hash</label>
        <locationX>176</locationX>
        <locationY>539</locationY>
        <actionName>CourseOfferingsService</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>lstCourseOfferingHashRequest</name>
            <value>
                <elementReference>CourseOfferingHashRequestList</elementReference>
            </value>
        </inputParameters>
        <nameSegment>CourseOfferingsService</nameSegment>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign values to the variables from the triggering record</description>
        <name>Assign_Has_Request</name>
        <label>Assign Has Request</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignmentItems>
            <assignToReference>HashRequestItem.strId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>HashRequestItem.strMixUniqueId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.Mix_Unique_Id__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_Values_to_HashRequest_List</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Prepare  HashRequest List</description>
        <name>Assign_Values_to_HashRequest_List</name>
        <label>Assign Values to HashRequest List</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <assignmentItems>
            <assignToReference>CourseOfferingHashRequestList</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>HashRequestItem</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Generate_Hash</targetReference>
        </connector>
    </assignments>
    <description>To populate Course_Offering_UID__c using hash logic method generateHash from invoking apex class CourseOfferingsService</description>
    <environments>Default</environments>
    <interviewLabel>CourseOffering : AS : Populate COUID {!$Flow.CurrentDateTime}</interviewLabel>
    <label>CourseOffering : AS : Populate COUID</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Assign_Has_Request</targetReference>
        </connector>
        <filterFormula>({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} =false &amp;&amp;  NOT(ISBLANK({!$Record.Mix_Unique_Id__c})) &amp;&amp; ISBLANK({!$Record.Course_Offering_UID__c}) &amp;&amp; ISNEW()) || ({!$Setup.Feature_Switch__c.Force_Course_Offering_UID_update__c} &amp;&amp; NOT(ISNEW()) )</filterFormula>
        <object>Course_Offering__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <description>To populate CourseOfferingHashRequestList</description>
        <name>CourseOfferingHashRequestList</name>
        <apexClass>CourseOfferingHashRequest</apexClass>
        <dataType>Apex</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Input Object to the class</description>
        <name>HashRequestItem</name>
        <apexClass>CourseOfferingHashRequest</apexClass>
        <dataType>Apex</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
