    <decisions>
        <name>Conga_Generation_required</name>
        <label>Conga Generation required ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ISCA_Contract_Preview</name>
            <conditionLogic>1 AND 2 AND (3 OR 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Preview Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Offer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Online Offer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Generate_ISCA_Preview_Outbound_message</targetReference>
            </connector>
            <label>ISCA Contract Preview</label>
        </rules>
        <rules>
            <name>ISCA_Contract</name>
            <conditionLogic>1 AND 2 AND (3 OR 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Details completed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Published</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Offer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Online Offer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contract_Generation_Requested_Date</targetReference>
            </connector>
            <label>ISCA Contract</label>
        </rules>
        <rules>
            <name>Domestic_Contract</name>
            <conditionLogic>1 AND 2 AND 3 AND ( 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Preview Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Template_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic Coursework Australia</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic Offer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Generate_Domestic_Contract</targetReference>
            </connector>
            <label>Domestic Contract</label>
        </rules>
        <rules>
            <name>Manual_ISCA</name>
            <conditionLogic>1 AND 2 AND 3 AND (4 OR 5 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Manual_ISCA_Edit_Required__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Preview Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Offer</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Offer_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Online Offer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Generate_Manual_ISCA_Outbound_message</targetReference>
            </connector>
            <label>Manual ISCA</label>
        </rules>
        <rules>
            <name>Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Agent_Email__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Published</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Offer_Cancelled_email</targetReference>
            </connector>
            <label>Cancelled</label>
        </rules>
        <rules>
            <name>Expired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Agent_Email__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Expired</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Published</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Offer_Expired_email</targetReference>
            </connector>
            <label>Expired</label>
        </rules>
    </decisions>
    <description>Migrated from the following 
WF: 
- Generate Manual ISCA Workflow
- Generate Domestic Contract 
- Generate ISCA Contract Workflow  [ Workflow to generate the ISCA contract when the quote status changes to accepted, and only when contract hasn&apos;t been generated before ]
- Generate ISCA Contract Preview Workflow [ Workflow rule description: Workflow to generate the ISCA contract preview when the quote status changes to Generate Preview ]
- Quote Expiry - Scheduled update Status workflow rule [updates Quote status into expired when current date is past quote expires on date ]

PB:
- Email Agent [ Email to be sent to the agent when the Published Offer is Cancelled or Expired ]
- Technical Error for Conga or CPQ APIs process [ Technical Error when Conga or CPQ APIs when not responding ]
- JBSystem_SBQQ_Quote_c_Process [ Invokes a flow ]</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_Cancelled</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!$Record.Agent_Email__c} )),
    ISPICKVAL({!$Record.SBQQ__Status__c}, &apos;Cancelled&apos;),
    ISPICKVAL(PRIORVALUE({!$Record.SBQQ__Status__c}), &apos;Published&apos;)
)</expression>
    </formulas>
    <formulas>
        <name>formula_Error_Logging_Time</name>
        <dataType>DateTime</dataType>
        <expression>NOW() - (45/1440)</expression>
    </formulas>
    <formulas>
        <name>formula_Expired</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!$Record.Agent_Email__c} )),
    ISPICKVAL({!$Record.SBQQ__Status__c}, &apos;Expired&apos;),
    ISPICKVAL(PRIORVALUE({!$Record.SBQQ__Status__c}), &apos;Published&apos;)
)</expression>
    </formulas>
    <interviewLabel>Quote : AS : Handle Quote operations {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Quote : AS : Handle Quote operations</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Conga_Final_Contract_Error</name>
        <label>Conga Final Contract Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CPQ_API_Error</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_the_scenario_Conga_Final_Contract_Error</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Contract requested</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Error_Log__c</field>
            <value>
                <stringValue>&apos;Conga error generating Final Contract. Conga taking more that 15 minutes to generate pdf&apos;</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Conga Error</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
