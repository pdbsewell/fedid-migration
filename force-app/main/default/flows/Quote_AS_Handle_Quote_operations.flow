    <recordUpdates>
        <description>Updates the Update Contract Generation Requested Date in Quote object</description>
        <name>Update_Contract_Generation_Requested_Date</name>
        <label>Update Contract Generation Requested Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Generate_ISCA_Contract_Outbound_Message</targetReference>
        </connector>
        <inputAssignments>
            <field>Contract_Generation_Requested_Date__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_the_start_date_time_for_Error_Tracking</targetReference>
        </connector>
        <filterFormula>AND({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;QuoteASHandleQuoteOperations,&quot;) = false)</filterFormula>
        <object>SBQQ__Quote__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <name>Conga_Error_Logging</name>
            <connector>
                <targetReference>Conga_Preview_Contract</targetReference>
            </connector>
            <label>Conga Error Logging</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Hours</offsetUnit>
            <recordField>Error_Tracking_Start_Date_Time__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <scheduledPaths>
            <name>Quote_Expiry</name>
            <connector>
                <targetReference>Expire_the_Offer</targetReference>
            </connector>
            <label>Quote Expiry</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Days</offsetUnit>
            <recordField>SBQQ__ExpirationDate__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <description>Scenario for logging the error</description>
        <name>txtScenario</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
