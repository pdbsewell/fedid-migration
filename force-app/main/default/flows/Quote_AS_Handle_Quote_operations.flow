    <recordUpdates>
        <name>Expire_the_Offer</name>
        <label>Expire the Offer</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Set_the_scenario_Expire_the_Offer</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
