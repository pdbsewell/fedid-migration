<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Identifies metadata changes in production via the backup git snapshot and notifies in Copado Release Managers chatter group</description>
    <environments>Default</environments>
    <formulas>
        <name>SnapshotCommit_link</name>
        <dataType>String</dataType>
        <expression>{!$Record.copado__View_in_Git__c}</expression>
    </formulas>
    <interviewLabel>Copado Prod Change Detection {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Copado Prod Change Detection</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Feed_Item</name>
        <label>Create Feed Item</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <inputAssignments>
            <field>Body</field>
            <value>
                <elementReference>ChatterPostMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>IsRichText</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>ParentId</field>
            <value>
                <stringValue>0F9Oa00000000XtKAI</stringValue>
            </value>
        </inputAssignments>
        <object>FeedItem</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Feed_Item</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>copado__Git_Backup__c</field>
            <operator>Contains</operator>
            <value>
                <stringValue>aFgOa0000000LE9</stringValue>
            </value>
        </filters>
        <filters>
            <field>copado__Commit_Message__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>copado__Git_Org_Commit__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
    <textTemplates>
        <name>ChatterPostMessage</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi,&lt;/p&gt;&lt;p&gt;New changes were made in Prod. Please &lt;a href=&quot;{!SnapshotCommit_link}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;Review Commit with differences&lt;/a&gt; and back promote them if necessary.&lt;/p&gt;</text>
    </textTemplates>
    <variables>
        <name>recordId</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <objectType>copado__Git_Org_Commit__c</objectType>
    </variables>
</Flow>
