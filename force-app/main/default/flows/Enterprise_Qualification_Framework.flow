    <decisions>
        <name>Assign_Existing_Outcomes</name>
        <label>Assign Existing Outcomes</label>
        <locationX>385</locationX>
        <locationY>783</locationY>
        <defaultConnector>
            <targetReference>loop_ExistingQuestions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>dcn_LQ1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>loop_ExistingQuestions.Unique_Id__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>{!OppID}-LQ1</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assign_LQ1</targetReference>
            </connector>
            <label>dcn LQ1</label>
        </rules>
