    </decisions>
    <decisions>
        <name>Decide_Recommendation</name>
        <label>Decide Recommendation</label>
        <locationX>2982</locationX>
        <locationY>290</locationY>
        <defaultConnector>
            <targetReference>Recommendation_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Pursue with caution</defaultConnectorLabel>
        <rules>
            <name>Do_Not_Pursue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Count_Red</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>2.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Recommend_Do_not_pursue</targetReference>
            </connector>
            <label>Do Not Pursue</label>
        </rules>
        <rules>
            <name>Pursue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Count_Red</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Count_Green</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>3.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Recommend_Pursue</targetReference>
            </connector>
            <label>Pursue</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_to_update_or_insert</name>
        <label>Decision to update or insert</label>
        <locationX>2190</locationX>
        <locationY>455</locationY>
        <defaultConnector>
            <targetReference>Create_Opp_Questions</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Insert Records</defaultConnectorLabel>
        <rules>
            <name>Update_Records</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_Qualification_Questions</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Opp_Questions</targetReference>
            </connector>
            <label>Update Records</label>
        </rules>
    </decisions>
    <decisions>
        <name>Outcome_Answer</name>
        <label>Outcome Answer</label>
        <locationX>2771</locationX>
        <locationY>606</locationY>
        <defaultConnector>
            <targetReference>Calculate_Outcome</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>AMBER Outcome</defaultConnectorLabel>
        <rules>
            <name>RED_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>RED</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Red</targetReference>
            </connector>
            <label>RED Outcome</label>
        </rules>
        <rules>
            <name>GREEN_Outcome</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Calculate_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>GREEN</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_GREEN</targetReference>
            </connector>
            <label>GREEN Outcome</label>
        </rules>
    </decisions>
    <description>ENGAGEIE-156 - Enhancements to Qualification Framework flow</description>
    <dynamicChoiceSets>
        <description>Qualification Outcome Picklist</description>
