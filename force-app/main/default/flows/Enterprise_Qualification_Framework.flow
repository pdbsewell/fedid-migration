    <screens>
        <name>Error_Message_Screen</name>
        <label>Error Message Screen</label>
        <locationX>3076</locationX>
        <locationY>50</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>Error_Message</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt;There were some errors in saving this record. Please contact your system administrator with this error details:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Flow Name:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; Enterprise Qualification Framework&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Current Record:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; {!$Flow.CurrentRecord}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;InterviewGuid:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; {!$Flow.InterviewGuid}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Active Stage: &lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt;{!$Flow.ActiveStages}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Interview Start Time:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; {!$Flow.InterviewStartTime}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Current Stage:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; {!$Flow.CurrentStage}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;color: rgb(163, 0, 0);&quot;&gt;Fault Message:&lt;/b&gt;&lt;span style=&quot;color: rgb(163, 0, 0);&quot;&gt; {!$Flow.FaultMessage&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255); color: rgb(163, 0, 0);&quot;&gt;Current Time:&lt;/b&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(163, 0, 0);&quot;&gt; {!$Flow.CurrentDateTime}&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(12, 0, 253);&quot;&gt;*****************************************&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Opp Id:&lt;/b&gt; {!get_Opportunity.Id}&lt;/p&gt;&lt;p&gt;&lt;b&gt;RecordType Id:&lt;/b&gt; {!QualFramework_RecType}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Opp Ques Id:&lt;/b&gt; {!get_Qualification_Questions}&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(12, 0, 253); background-color: rgb(255, 255, 255);&quot;&gt;*****************************************&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Current Loop Item:&lt;/b&gt; {!loop_ExistingQuestions.Unique_Id__c}&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(12, 0, 253);&quot;&gt;*****************************************&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(179, 14, 14);&quot;&gt;Red Count = {!Count_Red}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(16, 137, 16);&quot;&gt;Green count = {!Count_Green}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>Q1_SCREEN</name>
        <label>Q1 SCREEN</label>
        <locationX>747</locationX>
        <locationY>420</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Response_Q1</targetReference>
        </connector>
        <fields>
            <name>Q1</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;How does the opportunity fit with the Monash&apos;s strategic plan and intentions?&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q1_Detail</name>
            <fieldText>&lt;p&gt;RED: The opportunity is not aligned with the Focus Monash: Enterprise Plan, or the respective faculty’s strategy&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;AMBER: The opportunity is aligned with the respective faculty’s strategy, but not the Focus Monash: Enterprise Plan&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;GREEN: The opportunity is aligned with the respective faculty’s strategy, and with the Focus Monash: Enterprise Plan&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q1_Outcome</name>
            <choiceReferences>RED</choiceReferences>
            <choiceReferences>AMBER</choiceReferences>
            <choiceReferences>GREEN</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Q1 Outcome</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q1_Rationale</name>
            <defaultValue>
                <stringValue>{!var_Rationale_Q1}</stringValue>
            </defaultValue>
            <fieldText>Q1 Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Q1_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Q2_SCREEN</name>
        <label>Q2 SCREEN</label>
        <locationX>1022</locationX>
        <locationY>426</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Response_Q2</targetReference>
        </connector>
        <fields>
            <name>Q2</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;What is the potential value to and impact for the University? (Value should refer to matters beyond financials)&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q2_Detail</name>
            <fieldText>&lt;p&gt;RED: The potential value to Monash is unclear and/or potentially negative.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;AMBER: The potential value to Monash is positive, in terms of (for example) income and meaningful opportunities for the University’s academics. It is unlikely or unclear whether opportunity will to lead to a longer term partnership.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;GREEN: The potential value to Monash is significantly positive, in terms of (for example) income and meaningful opportunities for the University’s academics, students and alumni (i.e., work-integrated learning or mentorships). The opportunity is likely to lead to a longer term partnership.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q2_Outcome</name>
            <choiceReferences>RED</choiceReferences>
            <choiceReferences>AMBER</choiceReferences>
            <choiceReferences>GREEN</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Q2 Outcome</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q2_Rationale</name>
            <defaultValue>
                <stringValue>{!var_Rationale_Q2}</stringValue>
            </defaultValue>
            <fieldText>Q2 Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Q2_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Q3_SCREEN</name>
        <label>Q3 SCREEN</label>
        <locationX>1280</locationX>
        <locationY>430</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Response_Q3</targetReference>
        </connector>
        <fields>
            <name>Q3</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;Can we secure it/win it?&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q3_Detail</name>
            <fieldText>&lt;p&gt;RED: Monash is not a leader in this field and has no competitive advantage. Monash has no connection with a senior decision maker who could be expected to be able to spend over $500,000 per annum on partnerships.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;AMBER: Monash is a domestic leader in this field and has a moderate competitive advantage. Monash has indirect contact with a senior decision maker who could be expected to be able to spend over $500,000 per annum on partnerships.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;GREEN: Monash is an international leader in this field and has a significant competitive advantage. Monash has direct contact with a senior decision maker who could be expected to be able to spend over $500,000 per annum on partnerships.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q3_Outcome</name>
            <choiceReferences>RED</choiceReferences>
            <choiceReferences>AMBER</choiceReferences>
            <choiceReferences>GREEN</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Q3 Outcome</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q3_Rationale</name>
            <defaultValue>
                <stringValue>{!var_Rationale_Q3}</stringValue>
            </defaultValue>
            <fieldText>Q3 Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Q3_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Q4_SCREEN</name>
        <label>Q4 SCREEN</label>
        <locationX>1542</locationX>
        <locationY>428</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Response_Q4</targetReference>
        </connector>
        <fields>
            <name>Q4</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;Can we deliver it? Do we need anyone else?&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q4_Detail</name>
            <fieldText>&lt;p&gt;RED: There are concerns relating to Monash’s ability to deliver this opportunity, considering capability and capacity.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;AMBER: There are no major concerns relating to Monash’s ability to deliver this opportunity, considering capability and capacity. However, project management and delivery responsibilities have not been assigned. Where applicable, additional capability and capacity required to deliver have been identified, but not yet secured.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;GREEN: Monash is well positioned to deliver this opportunity, considering both capability and capacity, and project management and delivery responsibilities have been assigned. Where applicable, additional capability and capacity required to deliver have been identified and secured.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q4_Outcome</name>
            <choiceReferences>RED</choiceReferences>
            <choiceReferences>AMBER</choiceReferences>
            <choiceReferences>GREEN</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Q4 Outcome</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q4_Rationale</name>
            <defaultValue>
                <stringValue>{!var_Rationale_Q4}</stringValue>
            </defaultValue>
            <fieldText>Q4 Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Q4_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Q5_SCREEN</name>
        <label>Q5 SCREEN</label>
        <locationX>1805</locationX>
        <locationY>427</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Response_Q5</targetReference>
        </connector>
        <fields>
            <name>Q5</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 16px;&quot;&gt;Have we undertaken appropriate due diligence on partners, funding sources, and country context?&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q5_Detail</name>
            <fieldText>&lt;p&gt;RED: There concerns relating to partners, funding sources, and/or country context.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;AMBER: There are some concerns relating to partners, funding sources, and/or country context, however, mitigation strategies have been identified.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;GREEN: There no concerns relating to partners, funding sources, or country context.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q5_Outcome</name>
            <choiceReferences>RED</choiceReferences>
            <choiceReferences>AMBER</choiceReferences>
            <choiceReferences>GREEN</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Q5 Outcome</fieldText>
            <fieldType>RadioButtons</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Q5_Rationale</name>
            <defaultValue>
                <stringValue>{!var_Rationale_Q5}</stringValue>
            </defaultValue>
            <fieldText>Q5 Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Q5_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Recommendation_Screen</name>
        <label>Recommendation Screen</label>
        <locationX>3401</locationX>
        <locationY>285</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Assign_Recommendation</targetReference>
        </connector>
        <fields>
            <name>Recommendation_Text</name>
            <fieldText>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;Based on your answers to the Qualification Framework questions, the recommendation is to&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;&lt;b style=&quot;color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;{!Recommendation}&lt;/b&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>pl_Qualification_Outcome</name>
            <choiceReferences>pcs_QualificationOutcome</choiceReferences>
            <choiceReferences>c_OutcomeDefault</choiceReferences>
            <dataType>String</dataType>
            <defaultSelectedChoiceReference>c_OutcomeDefault</defaultSelectedChoiceReference>
            <fieldText>Qualification Outcome</fieldText>
            <fieldType>DropdownBox</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Outcome_Rationale</name>
            <defaultValue>
                <stringValue>{!get_Opportunity.Qualification_Outcome_Rationale__c}</stringValue>
            </defaultValue>
            <fieldText>Outcome Rationale</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>false</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Outcome_Rationale}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Qualification_Outcome</leftValueReference>
                    <operator>NotEqualTo</operator>
                    <rightValue>
                        <elementReference>Recommendation</elementReference>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>Key_Issues_Next_Steps</name>
            <defaultValue>
                <stringValue>{!get_Opportunity.Key_Issues_Next_Steps__c}</stringValue>
            </defaultValue>
            <fieldText>Key Issues &amp; Next Steps</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>false</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Key_Issues_Next_Steps}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Reason_for_caution</name>
            <defaultValue>
                <stringValue>{!get_Opportunity.Reason_for_caution__c}</stringValue>
            </defaultValue>
            <fieldText>Reason for caution</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>false</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Reason_for_caution}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Qualification_Outcome</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Pursue With Caution</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>Approver</name>
            <extensionName>flowruntime:lookup</extensionName>
            <fieldType>ComponentInstance</fieldType>
            <inputParameters>
                <name>label</name>
                <value>
                    <stringValue>Approver for this outcome</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>objectApiName</name>
                <value>
                    <stringValue>Opportunity</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>fieldApiName</name>
                <value>
                    <stringValue>Approver__c</stringValue>
                </value>
            </inputParameters>
            <isRequired>true</isRequired>
            <storeOutputAutomatically>true</storeOutputAutomatically>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Qualification_Outcome</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Pursue With Caution</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>Approver_Comments</name>
            <defaultValue>
                <stringValue>{!get_Opportunity.Approver_Comments__c}</stringValue>
            </defaultValue>
            <fieldText>Approver Comments</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>false</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;Text needs to be less than 255 characters&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(LEN({!Approver_Comments}) &lt;= 255, TRUE, FALSE)</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Qualification_Outcome</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <stringValue>Pursue With Caution</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
