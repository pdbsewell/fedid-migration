<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Check_Flows_are_Enabled</name>
        <label>Check Flows are Enabled</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Bypass</defaultConnectorLabel>
        <rules>
            <name>Run_Flow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_External_Id_Field_With_ACP_ID_C</targetReference>
            </connector>
            <label>Run Flow</label>
        </rules>
    </decisions>
    <description>Set External_Id__c</description>
    <environments>Default</environments>
    <interviewLabel>ACP : AS : Set External Id {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ACP : AS : Set External Id</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_External_Id_Field_With_ACP_ID_C</name>
        <label>Update External Id Field With ACP_ID__C</label>
        <locationX>50</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>External_Id__c</field>
            <value>
                <elementReference>$Record.ACP_ID__c</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Flows_are_Enabled</targetReference>
        </connector>
        <object>Application_Course_Preference__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
