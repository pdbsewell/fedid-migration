    <actionCalls>
        <name>Quote_is_null_error</name>
        <label>Quote is null error</label>
        <locationX>50</locationX>
        <locationY>242</locationY>
        <actionName>Nebula__FlowLogEntry</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>flowName</name>
            <value>
                <stringValue>SBQQ_Quote_Sub_Send_Error_Message</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>message</name>
