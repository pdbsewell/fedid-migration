    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Emails_to_variable</name>
        <label>Assign Emails to variable</label>
        <locationX>578</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>AdmissionsTeamEmails</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>$Setup.FlowSBQQQuoteAUScheduledDocGen__c.To_Address__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Notify_Admissions_Team</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Added for testing</description>
        <name>Set_email_sent</name>
        <label>Set email sent</label>
        <locationX>578</locationX>
        <locationY>674</locationY>
        <assignmentItems>
            <assignToReference>emailSent</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Set_Error_Message</name>
        <label>Set Error Message</label>
        <locationX>314</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>ErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>No Quote returned for Id +{!QuoteId}</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>Error_for_Flow</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Is_QuoteId_null</name>
        <label>Is QuoteId null</label>
        <locationX>248</locationX>
        <locationY>134</locationY>
        <defaultConnector>
            <targetReference>Get_Quote</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Quote_is_null_outcome</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>QuoteId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>QuoteId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Quote_is_null_error</targetReference>
            </connector>
            <label>Quote is null</label>
        </rules>
    </decisions>
    <decisions>
        <name>No_Quote_Found</name>
        <label>No Quote Found</label>
        <locationX>446</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Assign_Emails_to_variable</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No_Quote_Retrieved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Quote</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Error_Message</targetReference>
            </connector>
            <label>No Quote Retrieved</label>
        </rules>
    </decisions>
    <description>Sends a mail message for errors with quote document generation</description>
    <environments>Default</environments>
    <formulas>
        <name>quoteURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_590}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_590}))+{!Get_Quote.Id}</expression>
    </formulas>
    <interviewLabel>SBQQ Quote {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SBQQ Quote : Sub : Send Error Message</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get quote from Id</description>
        <name>Get_Quote</name>
        <label>Get Quote</label>
        <locationX>446</locationX>
        <locationY>242</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>No_Quote_Found</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Error_for_Flow</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>QuoteId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>SBQQ__Quote__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <start>
        <locationX>122</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Is_QuoteId_null</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>QuoteDocumentGenerationErrorEmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;An error has occurred generating a document for &lt;a href=&quot;{!quoteURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!Get_Quote.Name}&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Status: {!Get_Quote.SBQQ__Status__c}&lt;/p&gt;&lt;p&gt;Sub Status: {!Get_Quote.Sub_Status__c}&lt;/p&gt;&lt;p&gt;Latest Preview Generated Date: {!Get_Quote.Latest_Preview_Generated_Date__c}&lt;/p&gt;&lt;p&gt;Preview Requested Timestamp: {!Get_Quote.Preview_Requested_TimeStamp__c}&lt;/p&gt;&lt;p&gt;Document Generated Timestamp: {!Get_Quote.Document_Generated_TimeStamp__c}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>QuoteDocumentGenerationSubject</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Error Generating Document for - {!Get_Quote.Name}</text>
    </textTemplates>
    <variables>
        <name>AdmissionsTeamEmails</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>emailSent</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>ErrorMessage</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <elementReference>$Flow.FaultMessage</elementReference>
        </value>
    </variables>
    <variables>
        <name>QuoteId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>startDateTime</name>
        <dataType>DateTime</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
