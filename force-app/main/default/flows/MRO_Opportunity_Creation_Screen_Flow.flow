    <formulas>
        <name>createAccountURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_500}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_500})) &amp; &apos;lightning/o/Account/new&apos;</expression>
    </formulas>
    <formulas>
        <name>FAS_Opportunity_Name_Formula</name>
        <dataType>String</dataType>
        <expression>{!FAS_Pure_Application_Id}+ &apos; - &apos;+{!FAS_AccountName.recordName}</expression>
    </formulas>
    <formulas>
        <name>Opportunity_Name_Formula</name>
        <dataType>String</dataType>
        <expression>{!Search_Pure_Application_Id}+ &apos; - &apos;+{!AccountName.recordName}</expression>
    </formulas>
    <formulas>
        <name>vPureAppIdMonashSystemId</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!vPureApplicationId}), {!vMonashSystemId}, {!vPureApplicationId})</expression>
    </formulas>
