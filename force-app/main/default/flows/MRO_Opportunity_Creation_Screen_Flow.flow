        </connector>
        <fields>
            <name>FAS_DisplayText12</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;u&gt;Opportunity Information&lt;/u&gt;&lt;/strong&gt;&lt;strong style=&quot;color: rgb(195, 51, 51);&quot;&gt;﻿&lt;/strong&gt;&lt;/p&gt;</fieldText>
