        <fields>
            <name>dtxt_Instructions_3A</name>
            <fieldText>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(0, 109, 174); font-size: 20px;&quot;&gt;Offer Conditions&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;Please enter conditions for this offer&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>txt_Condition</name>
            <defaultValue>
                <stringValue>{!thisACP.Offer_Condition__c}</stringValue>
            </defaultValue>
            <fieldText>Offer Conditions</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;span style=&quot;color: rgb(255, 0, 0);&quot;&gt;If conditional offer status is Waived or Satisfied, please enter the date this was met.&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>IF(
AND (
ISNULL({!dt_Conditional_Offer_Satisfied_Date}),
OR(
{!pl_Conditional_Offer_Status}=&quot;SATISFIED (Conditions pertaining to offer satisfied)&quot;,
{!pl_Conditional_Offer_Status}=&quot;WAIVED (Conditions pertaining to offer waived)&quot;
)
),FALSE, TRUE)</formulaExpression>
            </validationRule>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Outcome</leftValueReference>
                    <operator>NotEqualTo</operator>
                    <rightValue>
                        <stringValue>OFFER-PROV</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>pl_Conditional_Offer_Status</name>
            <choiceReferences>rcsLOVR_CondStatus</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Conditional Offer Status</fieldText>
            <fieldType>DropdownBox</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>checkbox_Conditions_Must_Be_Satisfied</name>
            <dataType>Boolean</dataType>
            <defaultValue>
                <elementReference>thisACP.Conditions_Must_Be_Satisfied__c</elementReference>
            </defaultValue>
            <fieldText>Conditions Must Be Satisfied</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>dt_Conditional_Offer_Satisfied_Date</name>
            <dataType>Date</dataType>
            <defaultValue>
                <elementReference>thisACP.Conditional_Offer_Satisfied_Date__c</elementReference>
            </defaultValue>
            <fieldText>Conditional Offer Satisfied Date</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>or</conditionLogic>
                <conditions>
                    <leftValueReference>pl_Conditional_Offer_Status</leftValueReference>
                    <operator>Contains</operator>
                    <rightValue>
                        <stringValue>SATISFIED</stringValue>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>pl_Conditional_Offer_Status</leftValueReference>
                    <operator>Contains</operator>
                    <rightValue>
                        <stringValue>WAIVED</stringValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>dtxt_Information_3A</name>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
