    <subflows>
        <name>sub_Soft_Outcome_LOV_values</name>
        <label>Soft Outcome LOV values</label>
        <locationX>732</locationX>
        <locationY>168</locationY>
        <connector>
            <targetReference>a_Update_Outcome</targetReference>
        </connector>
        <flowName>Soft_Outcome_LOV_values</flowName>
        <inputAssignments>
            <name>varOutcome</name>
            <value>
                <elementReference>opt_Outcome</elementReference>
            </value>
        </inputAssignments>
        <outputAssignments>
            <assignToReference>varLOV_DefermentId</assignToReference>
            <name>varLOV_DefermentId</name>
