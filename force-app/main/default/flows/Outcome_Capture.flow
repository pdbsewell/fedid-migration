    <decisions>
        <description>Additional Tasks Required</description>
        <name>d_Additional_Tasks</name>
        <label>Additional Tasks</label>
        <locationX>1375</locationX>
        <locationY>365</locationY>
        <defaultConnector>
            <targetReference>Outcome_Capture_3</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Finalised Outcome</defaultConnectorLabel>
        <rules>
            <name>do_Soft_Outcome</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>pl_Specialist_Selection</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Required</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Credit_Assessment</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Required</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_DSS</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Required</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_GTE</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Required</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Specialist_Selection_1</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Required</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Specialist_Selection</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_InProgress</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Specialist_Selection_1</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_InProgress</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Credit_Assessment</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_InProgress</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_DSS</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_InProgress</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_GTE</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_InProgress</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Specialist_Selection</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WaitDocs</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Specialist_Selection_1</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WaitDocs</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Credit_Assessment</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WaitDocs</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_DSS</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WaitDocs</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_GTE</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WaitDocs</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateACP</targetReference>
