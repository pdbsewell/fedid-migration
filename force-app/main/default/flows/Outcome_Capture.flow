            <label>Soft Outcome</label>
        </rules>
    </decisions>
    <decisions>
        <description>Capture conditions for Offer? Conditional Offer &amp; packaged Offers</description>
        <name>d_Capture_Conditions</name>
        <label>Capture Conditions?</label>
        <locationX>1826</locationX>
        <locationY>360</locationY>
        <defaultConnector>
            <targetReference>Outcome_Capture_4</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Conditions</defaultConnectorLabel>
        <rules>
            <name>do_Conditions</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_COND_OFFER</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_OFFR_PCK</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outcome_Capture_3A</targetReference>
            </connector>
            <label>Conditions</label>
        </rules>
    </decisions>
    <decisions>
        <description>Path to drive flow for final outcome</description>
        <name>d_Final_Outcome_Type</name>
        <label>Final Outcome Type</label>
        <locationX>1681</locationX>
        <locationY>549</locationY>
        <defaultConnector>
            <targetReference>Outcome_Capture_5</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>do_Reject</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_REJECTED</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>a_Update_Rejected</targetReference>
            </connector>
            <label>Reject</label>
        </rules>
    </decisions>
    <decisions>
        <description>Type of outcome</description>
        <name>d_Outcome_Type</name>
        <label>Outcome Type</label>
        <locationX>971</locationX>
        <locationY>170</locationY>
        <defaultConnector>
            <targetReference>d_Additional_Tasks</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default</defaultConnectorLabel>
        <rules>
            <name>do_Rejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_REJECTED</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>thisACP.Task_Course_Entry_Check__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outcome_Capture_2A</targetReference>
            </connector>
            <label>Rejected</label>
        </rules>
        <rules>
            <name>do_Offer</name>
            <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_COND_OFFER</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_OFFR_PCK</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>opt_Outcome</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_OFFER</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>thisACP.Task_Course_Entry_Check__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>do_DSS_GTECheck</targetReference>
            </connector>
            <label>Offer</label>
        </rules>
    </decisions>
    <decisions>
        <description>Update requirement satisfied to Admissions if blank and precedent id is populated</description>
        <name>d_Update_Requirement_Satisfied</name>
        <label>Update Requirement Satisfied</label>
        <locationX>1383</locationX>
        <locationY>907</locationY>
        <defaultConnector>
            <targetReference>UpdateACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default</defaultConnectorLabel>
        <rules>
            <name>do_Update_Req_Satisfied</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nbr_Precedent_Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>pl_Requirement_Satisfied</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>c_NullValue</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>a_Update_Req_Satisifed_Null</targetReference>
            </connector>
            <label>Update Req Satisfied</label>
        </rules>
    </decisions>
    <description>ACP assessment outcome capture (version 1.3)

Change:
SFTLG-237 - Error while trying to send full OFFER update to Callista, with Offer Response Status
SFTLG-225 - Enhancement on the ACP outcome wizard for rejection</description>
