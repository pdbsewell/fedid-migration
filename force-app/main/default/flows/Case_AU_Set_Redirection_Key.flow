        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False &amp;&amp; OR({!$Record.RecordType.DeveloperName} = &apos;MRO&apos;, {!$Record.RecordType.DeveloperName} = &apos;Faculty_Graduate_Research&apos;, {!$Record.RecordType.DeveloperName} = &apos;MGE_Enquiry&apos;)</filterFormula>
