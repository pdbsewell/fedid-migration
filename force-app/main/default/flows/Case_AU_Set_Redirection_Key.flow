    <decisions>
        <name>Check_Record_Type</name>
        <label>Check Record Type</label>
        <locationX>644</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>MRO</name>
            <conditionLogic>1 AND ((2 OR 3) OR (4 AND (5 OR 6)))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>0124a0000004SPRAA2</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Group__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Redirection_Key__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Group__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>MRO_Level_of_detail</targetReference>
            </connector>
            <label>MRO</label>
        </rules>
        <rules>
            <name>Faculty_Graduate_Research</name>
            <conditionLogic>1 AND ((2 OR 3) OR (4 AND (5 OR 6)))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>012Oa000000zENpIAM</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Faculty__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.School__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Redirection_Key__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Faculty__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.School__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Faculty_Level_of_Detail</targetReference>
            </connector>
            <label>Faculty Graduate Research</label>
        </rules>
    </decisions>
    <decisions>
        <name>Faculty_Level_of_Detail</name>
        <label>Faculty Level of Detail</label>
        <locationX>710</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Assign_Faculty</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Faculty</defaultConnectorLabel>
        <rules>
            <name>Faculty_and_School</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Faculty__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MNHS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Faculty__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Science</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Faculty_and_School</targetReference>
            </connector>
            <label>Faculty and School</label>
        </rules>
    </decisions>
    <decisions>
        <name>MRO_Level_of_detail</name>
        <label>MRO Level of detail</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Assign_Enquiry_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Enquiry Type</defaultConnectorLabel>
        <rules>
            <name>Enquiry_Type_and_Group</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Research Development</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Enquiry_Type_and_Group</targetReference>
            </connector>
            <label>Enquiry Type and Group</label>
        </rules>
    </decisions>
