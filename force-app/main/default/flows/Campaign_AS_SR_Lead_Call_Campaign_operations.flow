        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Whats_the_status_of_the_Campaign</targetReference>
        </connector>
        <filterFormula>   {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp;
   {!$Record.RecordType.DeveloperName} = &apos;SR_Campaign&apos; &amp;&amp;
   (
      TEXT({!$Record.Type}) = &apos;Domestic Post App&apos; ||
      TEXT({!$Record.Type}) = &apos;International Post App&apos; ||
      TEXT({!$Record.Type}) = &apos;International Pre App&apos;
   ) 
   &amp;&amp; 
   (
      TEXT({!$Record.Status}) = &apos;In Progress&apos; ||
      TEXT({!$Record.Status}) = &apos;Aborted&apos; ||
      TEXT({!$Record.Status}) = &apos;Completed&apos; 
   )</filterFormula>
        <object>Campaign</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
