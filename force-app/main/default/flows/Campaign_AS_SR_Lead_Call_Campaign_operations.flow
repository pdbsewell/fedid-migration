    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Whats_the_status_of_the_Campaign</name>
        <label>Whats the status of the Campaign ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>In_Progress</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_to_create_list_view_on_SR_Lead_Call_object</targetReference>
            </connector>
            <label>In Progress</label>
        </rules>
        <rules>
            <name>Ended</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Aborted</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Notify_to_delete_list_view_on_SR_Lead_Call_object</targetReference>
            </connector>
            <label>Ended</label>
        </rules>
    </decisions>
    <description>Migrated from the following WF Rules: 
- SR Lead Call Campaign Created - Create List View 
- SR Lead Call Campaign Ended - Delete List View</description>
    <environments>Default</environments>
    <interviewLabel>Campaign : AS : SR Lead Call Campaign operations {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Campaign : AS : SR Lead Call Campaign operations</label>
    <migratedFromWorkflowRuleName>SR Lead Call Campaign Created - Create List View</migratedFromWorkflowRuleName>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
