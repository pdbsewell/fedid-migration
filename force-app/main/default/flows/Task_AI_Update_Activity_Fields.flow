    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Validate_Running_User</name>
        <label>Validate Running User</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Running User Invalid</defaultConnectorLabel>
        <rules>
            <name>Running_User_Valid</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$UserRole.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Monash Connect</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Copy_User_Values_to_Activity</targetReference>
            </connector>
            <label>Running User Valid</label>
        </rules>
    </decisions>
    <description>Copy user info to activities at creation</description>
    <environments>Default</environments>
    <formulas>
        <name>Task_Copy_Location_to_Activity</name>
        <dataType>String</dataType>
        <expression>IF( AND (TEXT({!$User.Location__c}) !=  &apos;Not Set&apos; , TEXT({!$User.Location__c}) !=  &apos;&apos;), TEXT({!$User.Location__c}), &apos;&apos;)</expression>
    </formulas>
    <formulas>
        <name>Task_Copy_Queue_data_to_Activity</name>
        <dataType>String</dataType>
        <expression>IF( AND (TEXT({!$User.Queue__c}) !=  &apos;Not Set&apos; , TEXT({!$User.Queue__c}) !=  &apos;&apos;), TEXT({!$User.Queue__c}), &apos;&apos;)</expression>
    </formulas>
    <interviewLabel>Task : AI : {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Task : AI : Update Activity Fields</label>
    <processMetadataValues>
        <name>BuilderType</name>
