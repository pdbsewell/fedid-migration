<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Error_Notification</name>
        <label>Error Notification</label>
        <locationX>172</locationX>
        <locationY>860</locationY>
        <actionName>customNotificationAction</actionName>
        <actionType>customNotificationAction</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>customNotifTypeId</name>
            <value>
                <elementReference>Get_Notification_ID.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>body</name>
            <value>
                <elementReference>Notification</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>title</name>
            <value>
                <stringValue>Session Gift Email Notification Failed</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>recipientIds</name>
            <value>
                <elementReference>ErrorRecipients</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>targetId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <nameSegment>customNotificationAction</nameSegment>
    </actionCalls>
    <apiVersion>54.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Add_Temp_Payment_to_Collection_to_Update</name>
        <label>Add Temp Payment to Collection to Update</label>
        <locationX>604</locationX>
        <locationY>249</locationY>
        <assignmentItems>
            <assignToReference>Payments_To_Update</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Temp_Payment</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Iterate_Payments</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Add_User_as_Error_Recipient</name>
        <label>Add User as Error Recipient</label>
        <locationX>175</locationX>
        <locationY>724</locationY>
        <assignmentItems>
            <assignToReference>ErrorRecipients</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Error_Notification</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Set the Conga Trigger field to true for each payment in the list</description>
        <name>Set_Conga_Trigger_to_True</name>
        <label>Set Conga Trigger to True</label>
        <locationX>786</locationX>
        <locationY>376</locationY>
        <assignmentItems>
            <assignToReference>Temp_Payment.Generate_Conga_Receipt__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Temp_Payment.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Iterate_Payments.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Add_Temp_Payment_to_Collection_to_Update</targetReference>
        </connector>
    </assignments>
    <description>Send email receipts upon Session Approval</description>
    <environments>Default</environments>
    <formulas>
        <description>Notification Body</description>
        <name>Notification</name>
        <dataType>String</dataType>
        <expression>&quot;One or more gifts in this session failed to generate an email receipt.  Please review the gifts and manually process any gifts which do not show an Acknowledgement Status of &apos;Acknowledged&apos;&quot;</expression>
    </formulas>
    <interviewLabel>Session Approval Email Receipts {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Session Approval Email Receipts</label>
    <loops>
        <description>Iterate the list of payments gathered in the previous step</description>
        <name>Iterate_Payments</name>
        <label>Iterate Payments</label>
        <locationX>408</locationX>
        <locationY>375</locationY>
        <collectionReference>Get_Payments</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_Conga_Trigger_to_True</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Payments</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>FREE_FORM_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_Notification_ID</name>
        <label>Get Notification ID</label>
        <locationX>176</locationX>
        <locationY>573</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Add_User_as_Error_Recipient</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Bulk_Notification_Trigger_Failed</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>CustomNotificationType</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Get all payments which are not acknowledged and do not have restrictions on acknowledging or acknowledgement type</description>
        <name>Get_Payments</name>
        <label>Get Payments</label>
        <locationX>176</locationX>
        <locationY>375</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Iterate_Payments</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Get_Notification_ID</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>ucinn_ascendv2__Session__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Receipt_Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Receipted</stringValue>
            </value>
        </filters>
        <filters>
            <field>ucinn_ascendv2__External_System_ID__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Receipt_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Email</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>ucinn_ascendv2__Payment__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <description>Update all payment records</description>
        <name>Update_Payments</name>
        <label>Update Payments</label>
        <locationX>408</locationX>
        <locationY>585</locationY>
        <faultConnector>
            <targetReference>Get_Notification_ID</targetReference>
        </faultConnector>
        <inputReference>Payments_To_Update</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>49</locationY>
        <connector>
            <targetReference>Get_Payments</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>{!$Record.ucinn_ascendv2__Is_Ready_for_G_L__c} = True &amp;&amp; {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False</filterFormula>
        <object>ucinn_ascendv2__Session__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>ErrorRecipients</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>Payments_To_Update</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>ucinn_ascendv2__Payment__c</objectType>
    </variables>
    <variables>
        <name>Temp_Payment</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>ucinn_ascendv2__Payment__c</objectType>
    </variables>
</Flow>
