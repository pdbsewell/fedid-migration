    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Application_Course</name>
        <label>Application Course</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>ApplicationCoursePreference</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>GetApplicationCoursePreference</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Validate_Course_Status</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Validate_Course_Status</name>
        <label>Validate Course Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>None of the above</defaultConnectorLabel>
        <rules>
            <name>Completed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Confirmed__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Confirmation_Email_Action</targetReference>
            </connector>
            <label>Completed</label>
        </rules>
        <rules>
            <name>Accepted</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Invoice not processed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Invoiced</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - CCFund</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Acceptance_Email_Action</targetReference>
            </connector>
            <label>Accepted</label>
        </rules>
        <rules>
            <name>Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Cancellation_Email_Action</targetReference>
            </connector>
            <label>Cancelled</label>
        </rules>
        <rules>
            <name>EOI</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - EOI Only</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_EOI_Thank_You_Email_Action</targetReference>
            </connector>
            <label>EOI</label>
        </rules>
        <rules>
            <name>Waitlisted</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Waitlisted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Waitlisted_Email_Action</targetReference>
            </connector>
            <label>Waitlisted</label>
        </rules>
        <rules>
            <name>Withdrawn</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Withdrawn</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Withdrawn_Email_Action</targetReference>
            </connector>
            <label>Withdrawn</label>
        </rules>
        <rules>
            <name>Selective_Pending</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Pending Approval</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Selective_Thank_You_Email_Action</targetReference>
            </connector>
            <label>Selective Pending</label>
        </rules>
        <rules>
            <name>Selective_Approved_no_invoice</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Offering__r.Pay_by_Invoice__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Selective_Approved_Email_Action</targetReference>
            </connector>
            <label>Selective Approved (no invoice)</label>
        </rules>
        <rules>
            <name>Selective_Approved_invoice</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Registered - Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ApplicationCoursePreference.Course_Offering__r.Pay_by_Invoice__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PD_Invoice_Selective_Approved_Email_Action</targetReference>
            </connector>
            <label>Selective Approved (invoice)</label>
        </rules>
    </decisions>
    <description>Sends emails for ACP records whose Managing Faculty is not covered by another process</description>
    <environments>Default</environments>
    <interviewLabel>Application Course Preference : AS : PD ACP Emails Faculty Default {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Application Course Preference : AS : PD ACP Emails Faculty Default Flow</label>
