    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Checks the Article&apos;s Record Type</description>
        <name>Check_Record_Type</name>
        <label>Check Record Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>FAQ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Default_URL_Name</targetReference>
            </connector>
            <label>FAQ</label>
        </rules>
        <rules>
            <name>HR_FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>HR FAQ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Validation_Status_HR_FAQ</targetReference>
            </connector>
            <label>HR FAQ</label>
        </rules>
        <rules>
            <name>Research_FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Research FAQ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Validation_Status_Research_FAQ</targetReference>
            </connector>
            <label>Research FAQ</label>
        </rules>
        <rules>
            <name>SR_FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SR FAQ</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Validation_Status_SR_FAQ</targetReference>
            </connector>
            <label>SR FAQ</label>
        </rules>
        <rules>
            <name>Standard_Text</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Standard Text</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Validation_Status_Std_Text</targetReference>
            </connector>
            <label>Standard Text</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Validation_Status</name>
        <label>Check Validation Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Pending_Approval</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending Approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$User.Is_Knowledge_Manager__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Alert_Knowledge_Manager_group</targetReference>
            </connector>
            <label>Pending Approval</label>
        </rules>
        <rules>
            <name>Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Automatically_Publish_On_Approval__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Publish_FAQ_Approved</targetReference>
            </connector>
            <label>Approved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Validation_Status_HR_FAQ</name>
        <label>Check Validation Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
