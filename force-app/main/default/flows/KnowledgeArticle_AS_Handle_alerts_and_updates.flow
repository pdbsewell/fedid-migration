            </connector>
            <label>Approved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Validation_Status_SR_FAQ</name>
        <label>Check Validation Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Pending_Approval_SR_FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending Approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$User.Is_Knowledge_Manager__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Alert_Knowledge_Manager_Group_SR_FAQ</targetReference>
            </connector>
            <label>Pending Approval</label>
        </rules>
        <rules>
            <name>Approved_SR_FAQ</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Automatically_Publish_On_Approval__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Alert_Author_SR_FAQ</targetReference>
            </connector>
            <label>Approved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Validation_Status_Std_Text</name>
        <label>Check Validation Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Validation_Status_to_Published_Standard_Text</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Pending_Approval_Std_Text</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pending Approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$User.Is_Knowledge_Manager__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Alert_Knowledge_Manager_group_Std_Text</targetReference>
            </connector>
            <label>Pending Approval</label>
        </rules>
        <rules>
            <name>Approved_Std_Text</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ValidationStatus</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Automatically_Publish_On_Approval__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Alert_Author_Std_Text</targetReference>
            </connector>
            <label>Approved</label>
        </rules>
    </decisions>
    <description>Migrated from the following WFs:
 - Alert Knowledge Manager group
 - Alert Knowledge SR Manager group
 - Std Article Alert Knowledge Manager group
 - Publish FAQ
 - Publish HR FAQ
 - Publish Standard Text now
 - Publish Research FAQ	
 - Publish Monash College Standard Text
 - SR Publish FAQ
 - Monash College FAQ Remove Leading Zero</description>
    <environments>Default</environments>
    <formulas>
        <description>Migrated from Default Knowledge FAQ Name WF Field update</description>
        <name>formulaURLName</name>
        <dataType>String</dataType>
        <expression>&apos;FAQ-&apos; &amp; TEXT(VALUE({!$Record.ArticleNumber}))</expression>
    </formulas>
    <interviewLabel>KnowledgeArticle : AS : Handle alerts and updates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Knowledge/Article : AS : Handle alerts and updates</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Migrated from Monash College FAQ Remove Leading Zero WF Rule</description>
        <name>Set_Default_URL_Name</name>
        <label>Set Default URL Name</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Validation_Status</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_error_FAQ</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Owning_Org_Unit__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Monash College</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>UrlName</field>
            <value>
                <elementReference>formulaURLName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Migrated from Publish Monash College Standard Text WF Rule</description>
        <name>Set_Validation_Status_to_Published_Standard_Text</name>
        <label>Set Validation Status to Published for Monash College</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Log_the_error_Standard_Text</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Faculty_Business_Unit__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Monash College</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>ValidationStatus</field>
            <value>
                <stringValue>Published</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Record_Type</targetReference>
        </connector>
        <filterFormula>AND(
   {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false,
   CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;KnowledgeArticle_AS_Handle_alerts_and_updates&quot;) = false,
   OR(
         ISNEW(),
         ISCHANGED({!$Record.RecordType.Name}),
         ISCHANGED({!$Record.ValidationStatus}), 
         ISCHANGED({!$Record.Faculty_Business_Unit__c}),
         ISCHANGED({!$Record.Owning_Org_Unit__c}))
)</filterFormula>
        <object>Knowledge_Article__kav</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
