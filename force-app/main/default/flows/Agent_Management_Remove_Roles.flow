<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>49.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Add_Account_to_Collection</name>
        <label>Add Account to Collection</label>
        <locationX>1362</locationX>
        <locationY>899</locationY>
        <assignmentItems>
            <assignToReference>AccountsWithPrincipalNulled</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>AccountRecordInLoop</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Agencies</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Add_Branch_Manager_Role_record_to_collection_for_delete</name>
        <label>Add Branch Manager Role record to collection for delete</label>
        <locationX>773</locationX>
        <locationY>463</locationY>
        <assignmentItems>
            <assignToReference>BranchManagerRoleToDelete</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>RoleRecordInLoop</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>BranchRoleToDeleteCount</assignToReference>
            <operator>Add</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Get_Accounts_to_remove_Branch_Manager_lookup</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Add_to_collection</name>
        <label>Add to collection</label>
        <locationX>1285</locationX>
        <locationY>466</locationY>
        <assignmentItems>
            <assignToReference>AccountsToNullBranchManagerLookup</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>AccountToNullifyBranchManager</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_Accounts</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Add_To_Delete_Collection</name>
        <label>Add To Delete Collection</label>
        <locationX>430</locationX>
        <locationY>336</locationY>
        <assignmentItems>
            <assignToReference>RolesToDelete</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>RoleRecordInLoop</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>RolesToDeleteRecordCount</assignToReference>
            <operator>Add</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Existing_Roles</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Branch_Manager_lookup_field_to_null</name>
        <label>Branch Manager lookup field to null</label>
        <locationX>1117</locationX>
        <locationY>466</locationY>
        <assignmentItems>
            <assignToReference>AccountToNullifyBranchManager.Branch_Manager__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue></stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Add_to_collection</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Null</name>
        <label>Set Null</label>
        <locationX>1152</locationX>
        <locationY>900</locationY>
        <assignmentItems>
            <assignToReference>AccountRecordInLoop.Principal_Agent__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue></stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Add_Account_to_Collection</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Role_Variable</name>
        <label>Set Role Variable</label>
        <locationX>102</locationX>
        <locationY>553</locationY>
        <assignmentItems>
            <assignToReference>RoleValue</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>RoleRecordInLoop.Role__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Delete</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Delete</name>
        <label>Delete?</label>
        <locationX>429</locationX>
        <locationY>554</locationY>
        <defaultConnector>
            <targetReference>Loop_Through_Existing_Roles</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>[Default Outcome]</defaultConnectorLabel>
        <rules>
            <name>DeleteYes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RetainFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RoleRecordInLoop.Role__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Principal Agent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RoleRecordInLoop.Role__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Branch Manager</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_To_Delete_Collection</targetReference>
            </connector>
            <label>Delete Yes (all except Principal or Branch Manager)</label>
        </rules>
        <rules>
            <name>Delete_Principal_Across_Agencies</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RetainFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RoleRecordInLoop.Role__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Principal Agent</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_All_Principal_Role_Records_Across_Agencies</targetReference>
            </connector>
            <label>Delete Principal Across Agencies</label>
        </rules>
        <rules>
            <name>Delete_Branch_Manager</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RetainFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>RoleRecordInLoop.Role__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Branch Manager</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Branch_Manager_Role_record_to_collection_for_delete</targetReference>
            </connector>
            <label>Delete Branch Manager</label>
        </rules>
    </decisions>
    <decisions>
        <name>Rows_To_Delete</name>
        <label>Rows To Delete?</label>
        <locationX>434</locationX>
        <locationY>107</locationY>
        <defaultConnectorLabel>Nothing To Delete</defaultConnectorLabel>
        <rules>
            <name>Yes_Delete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RolesToDeleteRecordCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>RemoveOtherRoles</targetReference>
            </connector>
            <label>Yes Delete</label>
        </rules>
    </decisions>
    <formulas>
        <name>AccountRTDeveloperName</name>
        <dataType>String</dataType>
        <expression>{!$Setup.Agent_Onboarding_Settings__c.Account_RT_Developer_Name__c}</expression>
    </formulas>
    <formulas>
        <name>DebugFormula</name>
        <dataType>Boolean</dataType>
        <expression>IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Principle Agent&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Principle Agent&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Branch Manager&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Branch Manager&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Counsellor&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Counsellor&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Finance&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Finance&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Key Counsellor&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Key Counsellor&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Other&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Other&apos;), true, 
false)))))
)</expression>
    </formulas>
    <formulas>
        <name>DebugIncludes</name>
        <dataType>Boolean</dataType>
        <expression>INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Principle Agent&apos;)</expression>
    </formulas>
    <formulas>
        <name>DebugNotIsBlank</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK({!RoleValue}))</expression>
    </formulas>
    <formulas>
        <name>DebugRoleValueEquals</name>
        <dataType>Boolean</dataType>
        <expression>{!RoleValue} = &apos;Principle Agent&apos;</expression>
    </formulas>
    <formulas>
        <name>RetainFlag</name>
        <dataType>Boolean</dataType>
        <expression>IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Principal Agent&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Principal Agent&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Branch Manager&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Branch Manager&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Counsellor&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Counsellor&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Finance&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Finance&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Key Counsellor&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Key Counsellor&apos;), true,
IF(NOT(ISBLANK({!RoleValue})) &amp;&amp; {!RoleValue} == &apos;Other&apos; &amp;&amp; INCLUDES({!IncomingContactRecord.Agency_Contact_Roles__c}, &apos;Other&apos;), true, 
false)))))
)</expression>
    </formulas>
    <formulas>
        <name>RoleRTDeveloperName</name>
        <dataType>String</dataType>
        <expression>{!$Setup.Agent_Onboarding_Settings__c.Role_RT_Developer_Name__c}</expression>
    </formulas>
    <interviewLabel>Agent Management - Remove Roles {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Agent Management - Remove Roles</label>
    <loops>
        <name>Loop_Through_Agencies</name>
        <label>Loop Through Agencies</label>
        <locationX>1150</locationX>
        <locationY>769</locationY>
        <assignNextValueToReference>AccountRecordInLoop</assignNextValueToReference>
        <collectionReference>AccountsNeedingUpdate</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_Null</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Account</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_Through_Existing_Roles</name>
        <label>Loop Through Existing Roles</label>
        <locationX>102</locationX>
        <locationY>336</locationY>
        <assignNextValueToReference>RoleRecordInLoop</assignNextValueToReference>
        <collectionReference>ExistingRoleRecords</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Set_Role_Variable</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Rows_To_Delete</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processType>AutoLaunchedFlow</processType>
    <recordDeletes>
        <name>Delete_Branch_Manager_Role_Records</name>
        <label>Delete Branch Manager Role Records</label>
        <locationX>1620</locationX>
        <locationY>467</locationY>
        <inputReference>BranchManagerRoleToDelete</inputReference>
    </recordDeletes>
    <recordDeletes>
        <name>Delete_Principal_Role_Across_Agencies</name>
        <label>Delete Principal Role Across Agencies</label>
        <locationX>770</locationX>
        <locationY>640</locationY>
        <connector>
            <targetReference>Get_Account_RT</targetReference>
        </connector>
        <inputReference>PrincipalRoleRecordsAcrossAgenciesToDelete</inputReference>
    </recordDeletes>
    <recordDeletes>
        <name>RemoveOtherRoles</name>
        <label>RemoveOtherRoles</label>
        <locationX>680</locationX>
        <locationY>107</locationY>
        <inputReference>RolesToDelete</inputReference>
    </recordDeletes>
    <recordLookups>
        <name>Get_Account_RT</name>
        <label>Get Account RT</label>
        <locationX>963</locationX>
        <locationY>641</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Agencies_to_Remove_Principal_Lookup</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>AccountRTDeveloperName</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Account</stringValue>
            </value>
        </filters>
        <object>RecordType</object>
        <outputReference>AccountRTRecord</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Accounts_to_remove_Branch_Manager_lookup</name>
        <label>Get Accounts to remove Branch Manager lookup</label>
        <locationX>950</locationX>
        <locationY>465</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Branch_Manager_lookup_field_to_null</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>RoleRecordInLoop.Account__c</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <outputReference>AccountToNullifyBranchManager</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Branch_Manager__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Agencies_to_Remove_Principal_Lookup</name>
        <label>Get Agencies to Remove Principal Lookup</label>
        <locationX>1150</locationX>
        <locationY>640</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Through_Agencies</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Principal_Agent__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>IncomingContactRecord.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>AccountRTRecord.Id</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <outputReference>AccountsNeedingUpdate</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Principal_Agent__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_All_Principal_Role_Records_Across_Agencies</name>
        <label>Get All Principal Role Records Across Agencies</label>
        <locationX>770</locationX>
        <locationY>844</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Delete_Principal_Role_Across_Agencies</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Contact__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>IncomingContactRecord.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>RoleRTRecord.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>Role__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Principal Agent</stringValue>
            </value>
        </filters>
        <object>Roles__c</object>
        <outputReference>PrincipalRoleRecordsAcrossAgenciesToDelete</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Existing_Role_Records</name>
        <label>Get Existing Role Records (Except Principal)</label>
        <locationX>102</locationX>
        <locationY>191</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Through_Existing_Roles</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Account__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>IncomingContactRecord.AccountId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Contact__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>IncomingContactRecord.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>RoleRTRecord.Id</elementReference>
            </value>
        </filters>
        <object>Roles__c</object>
        <outputReference>ExistingRoleRecords</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Account__c</queriedFields>
        <queriedFields>Contact__c</queriedFields>
        <queriedFields>Role__c</queriedFields>
        <queriedFields>RecordTypeId</queriedFields>
        <sortField>Role__c</sortField>
        <sortOrder>Asc</sortOrder>
    </recordLookups>
    <recordLookups>
        <name>Get_Role_RT_Record</name>
        <label>Get Role RT Record</label>
        <locationX>100</locationX>
        <locationY>68</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Existing_Role_Records</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>RoleRTDeveloperName</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Roles__c</stringValue>
            </value>
        </filters>
        <object>RecordType</object>
        <outputReference>RoleRTRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>DeveloperName</queriedFields>
    </recordLookups>
    <recordUpdates>
        <name>Update_Account</name>
        <label>Update Account</label>
        <locationX>1365</locationX>
        <locationY>769</locationY>
        <inputReference>AccountsWithPrincipalNulled</inputReference>
