    &quot;MNHS&quot;, &quot;MNHS - Graduate Research&quot;,
    &quot;MSDI&quot;, &quot;MSDI - Graduate Research&quot;,
    &quot;MUARC&quot;, &quot;MUARC - Graduate Research&quot;,
    &quot;Pharmacy and Pharmaceutical Sciences&quot;, &quot;Pharmacy - Graduate Research&quot;,
    &quot;Science&quot;, &quot;Science - Graduate Research&quot;,
    &quot;&quot;
)</expression>
    </formulas>
