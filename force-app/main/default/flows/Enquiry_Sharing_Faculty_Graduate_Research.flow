    <assignments>
        <name>Add_Faculty_Permission_Set_Id</name>
        <label>Add Faculty Permission Set Id</label>
        <locationX>1898</locationX>
        <locationY>566</locationY>
        <assignmentItems>
            <assignToReference>FacultyPermissionSetIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Extract_Faculty_Permission_Set_Ids.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Extract_Faculty_Permission_Set_Ids</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Faculty_based_on_Permission_Set</name>
        <label>Set Faculty and School based on Permission Set</label>
        <locationX>1678</locationX>
        <locationY>974</locationY>
        <assignmentItems>
            <assignToReference>Get_Enquiry.Faculty__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>PermissionSetToFacultyFormula</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Get_Enquiry.School__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>PermissionSetToSchoolFormula</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Is_School_Faculty</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Faculty_based_on_Queue</name>
        <label>Set Faculty based on Queue</label>
        <locationX>974</locationX>
        <locationY>674</locationY>
        <assignmentItems>
            <assignToReference>Get_Enquiry.Faculty__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>QueueToFacultyFieldFormula</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Get_Enquiry.School__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>QueueToSchoolFormula</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>School_Populated</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Record_Type</name>
        <label>Set Record Type</label>
        <locationX>974</locationX>
        <locationY>566</locationY>
        <assignmentItems>
            <assignToReference>Get_Enquiry.RecordTypeId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Record_Type.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Set_Faculty_based_on_Queue</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Is_Faculty_Permission_Set_Assigned</name>
        <label>Is Faculty Permission Set Assigned?</label>
        <locationX>1810</locationX>
        <locationY>866</locationY>
        <defaultConnector>
            <targetReference>Is_School_Faculty</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Faculty_Permission_Set_Assigned</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Faculty_Permission_Set_assigned_to_User</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Faculty_based_on_Permission_Set</targetReference>
            </connector>
            <label>Faculty Permission Set Assigned</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Owned_by_Queue_or_User</name>
        <label>Is Owned by Queue or User?</label>
        <locationX>1227</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>Get_Faculty_Permission_Sets</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Owned By User</defaultConnectorLabel>
        <rules>
            <name>Owned_By_Queue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Enquiry.Owner:Group.Id</leftValueReference>
                <operator>NotEqualTo</operator>
            </conditions>
            <connector>
                <targetReference>Is_Spam</targetReference>
            </connector>
            <label>Owned by Queue</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_School_Faculty</name>
        <label>Is School Populated?</label>
        <locationX>1810</locationX>
        <locationY>1166</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_Public_Group_based_on_Faculty</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>School_Populated_and_set_as_private</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Enquiry.School__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Enquiry.Private_Enquiry__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Public_Group_based_on_School</targetReference>
            </connector>
            <label>School Populated and set as private?</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_School_Public_Group_Found</name>
        <label>Is School Public Group Found</label>
        <locationX>1546</locationX>
        <locationY>1382</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_Public_Group_based_on_Faculty</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>School_Public_Group_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Public_Group_based_on_School.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Case_Share_for_School_Public_Group</targetReference>
            </connector>
            <label>School Public Group Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Spam</name>
        <label>Is Spam?</label>
        <locationX>644</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Get_Record_Type</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Spam</defaultConnectorLabel>
        <rules>
            <name>Spam</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Enquiry.Owner:Group.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Spam</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Public_Group_based_on_Faculty</targetReference>
            </connector>
            <label>Spam</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if school is populated then share to faculty level even if its owned by a queue</description>
        <name>School_Populated</name>
        <label>School Populated?</label>
        <locationX>974</locationX>
        <locationY>782</locationY>
        <defaultConnector>
            <targetReference>Update_Enquiry</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_1_of_Decision_7</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Enquiry.School__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Get_Public_Group_based_on_Faculty</targetReference>
            </connector>
            <label>Is School Populated?</label>
        </rules>
    </decisions>
    <decisions>
        <name>Was_Public_Group_found</name>
        <label>Was Public Group found?</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Public_Group_found</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Public_Group_based_on_Faculty.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Case_Share_for_Faculty_Public_Group</targetReference>
            </connector>
            <label>Public Group found</label>
        </rules>
    </decisions>
    <description>Flow to control Enquiry Sharing for Graduate Research faculties</description>
    <environments>Default</environments>
    <formulas>
        <name>FacultyToPublicGroupFormula</name>
        <dataType>String</dataType>
        <expression>CASE(
    TEXT({!Get_Enquiry.Faculty__c}),
    &quot;Arts&quot;, &quot;Arts - Graduate Research&quot;,
    &quot;Business and Economics&quot;,  &quot;BusEco - Graduate Research&quot;,
    &quot;Education&quot;, &quot;Education - Graduate Research&quot;,
    &quot;Engineering&quot;, &quot;Engineering - Graduate Research&quot;,
    &quot;Information Technology&quot;, &quot;FIT - Graduate Research&quot;,
    &quot;Law&quot;, &quot;Law - Graduate Research&quot;,
