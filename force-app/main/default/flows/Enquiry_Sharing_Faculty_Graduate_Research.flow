    <interviewLabel>Enquiry Sharing - Faculty Graduate Research {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Sub: Enquiry Sharing (Faculty Graduate Research)</label>
    <loops>
        <name>Extract_Faculty_Permission_Set_Ids</name>
        <label>Extract Faculty Permission Set Ids</label>
        <locationX>1810</locationX>
        <locationY>458</locationY>
        <collectionReference>Get_Faculty_Permission_Sets</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Faculty_Permission_Set_Id</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Faculty_Permission_Set_assigned_to_User</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
