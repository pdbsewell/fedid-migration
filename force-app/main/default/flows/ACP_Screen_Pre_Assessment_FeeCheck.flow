    <recordLookups>
        <name>GetPaymentDetails</name>
        <label>GetPaymentDetails</label>
        <locationX>446</locationX>
        <locationY>134</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Screen_Application_Fee</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varAppId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Application__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Task_Fee__c</queriedFields>
        <queriedFields>Fee_Payment_Mode__c</queriedFields>
        <queriedFields>Fee_Amount__c</queriedFields>
        <queriedFields>Fee_Payment__c</queriedFields>
        <queriedFields>Fee_Waiver_Code__c</queriedFields>
        <queriedFields>Fee_Waiver_Redeemed__c</queriedFields>
        <queriedFields>Transaction_Date__c</queriedFields>
        <queriedFields>Transaction_Amount__c</queriedFields>
        <queriedFields>Transaction_Source__c</queriedFields>
        <queriedFields>Transaction_Reference__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
