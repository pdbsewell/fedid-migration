<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Hold</name>
        <label>Assign Hold</label>
        <locationX>50</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>GetPaymentDetails.Task_Fee__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Waiting for docs</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>UpdatePaymentDetails</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_Paid</name>
        <label>Assign Paid</label>
        <locationX>314</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>GetPaymentDetails.Task_Fee__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>GetPaymentDetails.Fee_Payment__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>UpdatePaymentDetails</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Decision_Navigation</name>
        <label>Decision Navigation</label>
        <locationX>446</locationX>
        <locationY>350</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Hold</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navFee.fire2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Hold</targetReference>
            </connector>
            <label>Outcome Hold</label>
        </rules>
        <rules>
            <name>Outcome_Complete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navFee.fire3</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Paid</targetReference>
            </connector>
            <label>Outcome Complete</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>varViewDocURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_100}, FIND(&apos;/services&apos;, ({!$Api.Enterprise_Server_URL_100})))&amp;&quot;c/DocumentPreviewer.app?cd=&quot;&amp;{!varContactDocumentId}</expression>
    </formulas>
    <interviewLabel>ACP: Screen: Pre-Assessment: FeeCheck {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ACP: Screen: Pre-Assessment: FeeCheck</label>
    <processMetadataValues>
