    <decisions>
        <name>Check_Credit_Card_Payment</name>
        <label>Check Credit Card Payment</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Invoice_Payment</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Credit Card Payment Not Processed</defaultConnectorLabel>
        <rules>
            <name>Credit_Card_Payment_Processed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Processed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Payment_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Credit_Card</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Application_Status_CC</targetReference>
            </connector>
            <label>Credit Card Payment Processed</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Invoice_Payment</name>
        <label>Check Invoice Payment</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Invoice Payment Not Processed</defaultConnectorLabel>
        <rules>
            <name>Invoice_Payment_Processed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Payment_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Processed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Payment_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Invoice</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Application_Status_INV</targetReference>
            </connector>
            <label>Invoice Payment Processed</label>
        </rules>
    </decisions>
    <description>Update Application and ACP when Payment is Processed</description>
    <environments>Default</environments>
    <interviewLabel>Payment : AS : PD Change Application &amp; ACP StatusPayment : AS : PD Change Application &amp; ACP Status {!$Flow.CurrentDateTime}</interviewLabel>
