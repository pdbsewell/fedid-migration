    <recordUpdates>
        <name>Update_Application_Course_Preference_Status_CC</name>
        <label>Update Application Course Preference Status CC</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Updating_Credit_Card_Payment_Details</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Registered - Not paid</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Registered</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Application__r.Application_Course_Preferences__r</inputReference>
    </recordUpdates>
