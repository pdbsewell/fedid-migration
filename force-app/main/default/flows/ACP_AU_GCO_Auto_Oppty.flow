    <decisions>
        <description>Identify whether the Admission category is UG or PG</description>
        <name>Identify_UGPG</name>
        <label>Identify UGPG</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>UnderGraduate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Admission_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>UG-IS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_ACP_for_UG</targetReference>
            </connector>
            <label>UnderGraduate</label>
        </rules>
        <rules>
            <name>PostGraduate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Admission_Category__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PG-IS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_ACP_for_PG</targetReference>
            </connector>
            <label>PostGraduate</label>
        </rules>
    </decisions>
    <description>Triggers the flow on ACP update to create GCO offer</description>
    <environments>Default</environments>
    <formulas>
        <description>Derives Intake period year</description>
        <name>IntakePeriodYear</name>
        <dataType>Number</dataType>
        <expression>VALUE(LEFT(  {!$Record.Intake_Period__c} , FIND(&quot;/&quot;,   {!$Record.Intake_Period__c} ) -1))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Intake period minus one year</description>
        <name>IntakePeriodYearMinusOne</name>
        <dataType>Number</dataType>
        <expression>{!IntakePeriodYear}-1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>IntakePeriodMinusOne</description>
        <name>IntakePeriodYearPlusOne</name>
        <dataType>Number</dataType>
        <expression>{!IntakePeriodYear}+1</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Formula to calculate Offer Response date</description>
        <name>OfferLapseDate</name>
        <dataType>Date</dataType>
        <expression>CASE(RIGHT( {!$Record.Intake_Period__c} ,  LEN( {!$Record.Intake_Period__c})-FIND(&quot;/&quot;,   {!$Record.Intake_Period__c}) ),
 &apos;1&apos;,  {!SEM1OfferLapseDt},
 &apos;2&apos;,  {!SEM2OfferLapseDt},
 &apos;SUM&apos;,  {!SummerOfferLapseDt},
&apos;SPR&apos;,  {!SpringOfferLapseDt},
&apos;W&apos;,  {!WinterOfferLapseDt},
{!$Flow.CurrentDate})</expression>
    </formulas>
    <formulas>
        <description>Determines whether add year check criteria is met</description>
        <name>SEM1AddYearCheck</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c})),{!$Setup.Offer_Setting__c.GCO_SEM1_Add_Year__c}, {!IntakePeriodYear}=={!SEM1ExYear}+1)</expression>
    </formulas>
    <formulas>
        <description>Derive SEM1 Default or exception date</description>
        <name>SEM1DefaultOrEx</name>
        <dataType>String</dataType>
        <expression>IF(
OR(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c}), AND( NOT({!SEM1SameYearCheck}), NOT({!SEM1AddYearCheck}))),
{!$Setup.Offer_Setting__c.GCO_SEM1_Lapse_Date__c},
{!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c})</expression>
    </formulas>
    <formulas>
        <description>Represents SEM1 Exception year</description>
        <name>SEM1ExYear</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c})),
VALUE(RIGHT({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c}, 4)),
{!IntakePeriodYear})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives SEM1 offer lapse date</description>
        <name>SEM1OfferLapseDt</name>
        <dataType>Date</dataType>
        <expression>IF(
OR(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c}), AND( NOT({!SEM1SameYearCheck}), NOT({!SEM1AddYearCheck}))),
 Date( {!SEM1Year} ,VALUE( RIGHT({!SEM1DefaultOrEx}, 2)),VALUE(LEFT({!SEM1DefaultOrEx}, 2))),
Date( {!SEM1Year}, VALUE( MID({!SEM1DefaultOrEx},4, 2)),VALUE(LEFT({!SEM1DefaultOrEx}, 2))))</expression>
    </formulas>
    <formulas>
        <description>Derives whether same year check is met</description>
        <name>SEM1SameYearCheck</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c})), NOT({!$Setup.Offer_Setting__c.GCO_SEM1_Add_Year__c}), {!IntakePeriodYear}=={!SEM1ExYear})</expression>
    </formulas>
    <formulas>
        <description>Represents year for SEM1</description>
        <name>SEM1Year</name>
        <dataType>Number</dataType>
        <expression>IF( ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM1_Lapse_Date__c}),
 {!IntakePeriodYearMinusOne},
IF({!SEM1AddYearCheck}, {!IntakePeriodYearMinusOne},  IF ({!SEM1SameYearCheck},{!IntakePeriodYear} , {!IntakePeriodYearMinusOne}))
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives SEM2 Exception year</description>
        <name>SEM2ExYear</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM2_Lapse_Date__c})),
VALUE(RIGHT({!$Setup.Offer_Setting__c.GCO_Ex_SEM2_Lapse_Date__c}, 4)),
{!IntakePeriodYear})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives SEM2 offer lapse date</description>
        <name>SEM2OfferLapseDt</name>
        <dataType>Date</dataType>
        <expression>IF(
AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_SEM2_Lapse_Date__c})), {!IntakePeriodYear}=={!SEM2ExYear}),
Date( {!IntakePeriodYear}, VALUE( MID({!$Setup.Offer_Setting__c.GCO_Ex_SEM2_Lapse_Date__c},4, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_Ex_SEM2_Lapse_Date__c}, 2))),
 Date( {!IntakePeriodYear} ,VALUE( RIGHT({!$Setup.Offer_Setting__c.GCO_SEM2_Lapse_Date__c}, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_SEM2_Lapse_Date__c}, 2))))</expression>
    </formulas>
    <formulas>
        <description>Derives Spring Exception year</description>
        <name>SpringExYear</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Spring_Lapse_Date__c})),
VALUE(RIGHT({!$Setup.Offer_Setting__c.GCO_Ex_Spring_Lapse_Date__c}, 4)),
{!IntakePeriodYear})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives Spring offer lapse date</description>
        <name>SpringOfferLapseDt</name>
        <dataType>Date</dataType>
        <expression>IF(
AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Spring_Lapse_Date__c})), {!IntakePeriodYear}=={!SpringExYear}),
Date( {!IntakePeriodYear}, VALUE( MID({!$Setup.Offer_Setting__c.GCO_Ex_Spring_Lapse_Date__c},4, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_Ex_Spring_Lapse_Date__c}, 2))),
 Date( {!IntakePeriodYear} ,VALUE( RIGHT({!$Setup.Offer_Setting__c.GCO_Spring_Lapse_Date__c}, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_Spring_Lapse_Date__c}, 2))))</expression>
    </formulas>
    <formulas>
        <description>Determines whether add year check criteria is met</description>
        <name>SummerAddYear</name>
        <dataType>Number</dataType>
        <expression>IF( ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c}),
 {!IntakePeriodYearMinusOne},
IF({!SummerAddYearCheck}, {!IntakePeriodYearMinusOne},  IF ({!SummerSameYearCheck},{!IntakePeriodYear} , {!IntakePeriodYearMinusOne}))
)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives if Add year check is met</description>
        <name>SummerAddYearCheck</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c})),{!$Setup.Offer_Setting__c.GCO_Summer_Add_Year__c}, {!IntakePeriodYear}=={!SummerExYear}+1)</expression>
    </formulas>
    <formulas>
        <description>Determines whether to consider default or Exception lapse date for calculation</description>
        <name>SummerDefaultOrEx</name>
        <dataType>String</dataType>
        <expression>IF(
OR(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c}), AND( NOT({!SummerSameYearCheck}), NOT({!SummerAddYearCheck}))),
{!$Setup.Offer_Setting__c.GCO_Summer_Lapse_Date__c},
{!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c})</expression>
    </formulas>
    <formulas>
        <description>Derives Summer Exception year</description>
        <name>SummerExYear</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c})),
VALUE(RIGHT({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c}, 4)),
{!IntakePeriodYear})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Derives Summer offer lapse date</description>
        <name>SummerOfferLapseDt</name>
        <dataType>Date</dataType>
        <expression>IF(
OR(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c}), AND( NOT({!SummerSameYearCheck}), NOT({!SummerAddYearCheck}))),
 Date( {!SummerAddYear} ,VALUE( RIGHT({!SummerDefaultOrEx}, 2)),VALUE(LEFT({!SummerDefaultOrEx}, 2))),
Date( {!SummerAddYear}, VALUE( MID({!SummerDefaultOrEx},4, 2)),VALUE(LEFT({!SummerDefaultOrEx}, 2))))</expression>
    </formulas>
    <formulas>
        <description>identifies if same year check is met for summer</description>
        <name>SummerSameYearCheck</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Summer_Lapse_Date__c})), NOT({!$Setup.Offer_Setting__c.GCO_Summer_Add_Year__c}), {!IntakePeriodYear}=={!SummerExYear})</expression>
    </formulas>
    <formulas>
        <description>Derives Winter Exception year</description>
        <name>WinterExYear</name>
        <dataType>Number</dataType>
        <expression>IF(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Winter_Lapse_Date__c})),
VALUE(RIGHT({!$Setup.Offer_Setting__c.GCO_Ex_Winter_Lapse_Date__c}, 4)),
{!IntakePeriodYear})</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Determines Offer Lapse date for Winter</description>
        <name>WinterOfferLapseDt</name>
        <dataType>Date</dataType>
        <expression>IF(
AND(NOT(ISNULL({!$Setup.Offer_Setting__c.GCO_Ex_Winter_Lapse_Date__c})), {!IntakePeriodYear}=={!WinterExYear}),
Date( {!IntakePeriodYear}, VALUE( MID({!$Setup.Offer_Setting__c.GCO_Ex_Winter_Lapse_Date__c},4, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_Ex_Winter_Lapse_Date__c}, 2))),
 Date( {!IntakePeriodYear} ,VALUE( RIGHT({!$Setup.Offer_Setting__c.GCO_Winter_Lapse_Date__c}, 2)),VALUE(LEFT({!$Setup.Offer_Setting__c.GCO_Winter_Lapse_Date__c}, 2))))</expression>
    </formulas>
