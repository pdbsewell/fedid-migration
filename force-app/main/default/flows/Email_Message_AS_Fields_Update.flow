                <leftValueReference>$Record.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>myResearch</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Case_When_Received_Email_Case_myResearch</targetReference>
            </connector>
            <label>Received Incoming Email myResearch</label>
        </rules>
        <rules>
            <name>Received_Incoming_Email_Monash_Connect_Enquiry</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash_Connect_Enquiry</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Case_When_Received_Email_Case_Monash_Connect_Enquiry</targetReference>
            </connector>
            <label>Received Incoming Email Monash Connect Enquiry</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_User_Email_Case_Type</name>
        <label>Check User Email Case Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Alumni_Case_Email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>User Email Case Closed</defaultConnectorLabel>
        <rules>
            <name>User_Email_Case_Reopen</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Parent.RecordTypeId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEBS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Reopened</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Email_received_for_a_closed_case_SEBS</targetReference>
            </connector>
            <label>User Email Case Reopen</label>
        </rules>
    </decisions>
