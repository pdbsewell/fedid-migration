    <environments>Default</environments>
    <formulas>
        <description>Check if managing faculties is for assessment</description>
        <name>AllFaculties</name>
        <dataType>Boolean</dataType>
        <expression>OR({!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Business and Economics&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Pharmacy and Pharmaceutical Sciences&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Engineering&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Science&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Arts&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Art, Design and Architecture&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Medicine, Nursing and Health Sciences&apos;, {!ACPRecord.Managing_Faculty__c} == &apos;Faculty of Education&apos;)</expression>
    </formulas>
    <formulas>
        <description>Check if the application course preference course codes is from MNHS and Education</description>
        <name>isMNHSEducationCourses</name>
        <dataType>Boolean</dataType>
        <expression>OR({!ACPRecord.Course_Code__c} == &apos;D0501&apos;, {!ACPRecord.Course_Code__c} == &apos;D0502&apos;)</expression>
    </formulas>
    <formulas>
        <description>check if the application source system is from Agent Portal or My.App</description>
        <name>isSourceSystemAgentPortalAndMyApp</name>
        <dataType>Boolean</dataType>
        <expression>OR({!ACPRecord.Application__r.Source_System__c} == &apos;AgentPortal&apos;, {!ACPRecord.Application__r.Source_System__c} == &apos;my.app&apos;)</expression>
    </formulas>
    <formulas>
        <description>Check if the admission category belong to VTAC</description>
        <name>isVTACCategory</name>
        <dataType>Boolean</dataType>
        <expression>OR({!ACPRecord.Admission_Category__c} == &apos;VTAC-CSP&apos;, {!ACPRecord.Admission_Category__c} == &apos;VTAC-DIP-I&apos;, {!ACPRecord.Admission_Category__c} == &apos;VTAC-HECS&apos;, {!ACPRecord.Admission_Category__c} == &apos;VTAC-IS&apos;,{!ACPRecord.Admission_Category__c} == &apos;VTAC-MC-AU&apos;)</expression>
    </formulas>
    <formulas>
        <description>Check if managing faculties are supported</description>
        <name>ManagingFaculties</name>
        <dataType>Boolean</dataType>
        <expression>OR({!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Information Technology&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Business and Economics&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Law&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Pharmacy and Pharmaceutical Sciences&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Engineering&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Science&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Arts&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Art, Design and Architecture&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Medicine, Nursing and Health Sciences&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Monash College Diplomas&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Monash University Foundation Year MUFY&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Monash University English Language Centre&apos;,{!ACPRecord.Managing_Faculty__c} = &apos;Office of the DVC Education &amp; Senior VP&apos;, {!ACPRecord.Managing_Faculty__c} = &apos;Faculty of Education&apos;)</expression>
    </formulas>
