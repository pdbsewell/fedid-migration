    <decisions>
        <name>Check_Flows_are_Enabled</name>
        <label>Check Flows are Enabled</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Bypass</defaultConnectorLabel>
        <rules>
            <name>Run_Flow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_all_ACPs</targetReference>
            </connector>
            <label>Run Flow</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_ACP_Id_set</name>
        <label>Is ACP Id set?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_1st_ACP_Record</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Get 1st ACP from Application</defaultConnectorLabel>
        <rules>
            <name>Get_ACP</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_ACP_Record</targetReference>
            </connector>
            <label>Get ACP</label>
        </rules>
    </decisions>
    <decisions>
        <name>Is_Tap_Enabled</name>
        <label>Is Tap Enabled?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Tap_Enabled_flag_to_FALSE</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Is_Master_of_Social_Work</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Course_Code__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>M6012</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPCount</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Citizenship_Classification__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tap_Enabled_flag_to_TRUE</targetReference>
            </connector>
            <label>Is Master of Social Work?</label>
        </rules>
        <rules>
            <name>Is_M6030</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Course_Code__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>M6030</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPCount</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>1.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Citizenship_Classification__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Campus_Location__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australia</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tap_Enabled_flag_to_TRUE</targetReference>
            </connector>
            <label>Is M6030?</label>
        </rules>
        <rules>
            <name>is_Managing_Faculty_FIT</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Campus_Location__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australia</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Managing_Faculty__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Faculty of Information Technology</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Setup.Feature_Switch__c.Assessment_Tap_FIT__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Preference_Number__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>1</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tap_Enabled_flag_to_TRUE</targetReference>
            </connector>
            <label>is Managing Faculty FIT?</label>
        </rules>
        <rules>
            <name>Is_Campus_Location_Australia</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Campus_Location__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australia</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Setup.Feature_Switch__c.Assessment_Tap_Australia__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Preference_Number__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>1</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Managing_Faculty__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Type_of_Study__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Coursework</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isMNHSEducationCourses</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isSourceSystemAgentPortalAndMyApp</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isVTACCategory</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Admission_Category__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ManagingFaculties</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Tap_Enabled_flag_to_TRUE</targetReference>
            </connector>
            <label>Is Campus Location Australia?</label>
        </rules>
        <rules>
            <name>Is_Campus_Location_Indonesia</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Campus_Location__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Indonesia</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Setup.Feature_Switch__c.Assessment_Tap_Indonesia__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Preference_Number__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>1</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Application__r.Type_of_Study__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Coursework</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>isSourceSystemAgentPortalAndMyApp</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
