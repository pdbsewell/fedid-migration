        <limit>1</limit>
        <sortOptions>
            <doesPutEmptyStringAndNullFirst>false</doesPutEmptyStringAndNullFirst>
            <sortField>LastModifiedDate</sortField>
            <sortOrder>Desc</sortOrder>
        </sortOptions>
    </collectionProcessors>
    <decisions>
        <name>Check_if_Enquiry_Created_or_not</name>
        <label>Check if Enquiry Created or not</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_ReleaseReason1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Enquiry Updated</defaultConnectorLabel>
        <rules>
            <name>Enquiry_Created</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ReleaseReason</targetReference>
            </connector>
            <label>Enquiry Created</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_Enquiry_Created_or_not1</name>
        <label>Check if Enquiry Created or not</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_ReleaseReason3</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Enquiry Updated</defaultConnectorLabel>
        <rules>
            <name>Enquiry_Created1</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ReleaseReason2</targetReference>
            </connector>
            <label>Enquiry Created</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_In_Progress_ACPs_Exists</name>
        <label>Check if In Progress ACPs Exists</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>In Progress ACPs exists</defaultConnectorLabel>
        <rules>
            <name>No_In_Progress_ACPs</name>
            <conditionLogic>1 AND ((6 AND 2 AND 3) OR (6 AND 4 AND 5) OR (7 AND 8 AND 9 AND 10 AND 11 AND 12 AND 13 AND 14 AND 15 AND 16 AND 17 AND 18 AND 19))</conditionLogic>
            <conditions>
                <leftValueReference>Filter_In_Progress_ACPs</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Application_Course_Preference__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Application_Course_Preference__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Application_Course_Preference__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Web - Agent Portal</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Offer acceptance</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Delegate nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Packaged courses</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Change of Course Preference</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Conditional eCOE</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Withdrawal and Refund</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Release request</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Agent nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Change of Preference</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Filter_Completed_ACPs</targetReference>
            </connector>
            <label>No In Progress ACPs</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Workflow_Status</name>
        <label>Check Workflow Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_On_Hold_ACPs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>On_Hold</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_On_Hold_ACPs.Workflow_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>On Hold</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_if_Enquiry_Created_or_not</targetReference>
            </connector>
            <label>On Hold</label>
        </rules>
        <rules>
            <name>Released</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_On_Hold_ACPs.Workflow_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Released</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_On_Hold_ACPs.Release_Reason__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_if_Enquiry_Created_or_not1</targetReference>
            </connector>
            <label>Released</label>
        </rules>
    </decisions>
    <decisions>
        <name>Validate_Enquiry_Changes</name>
        <label>Validate Enquiry Changes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Filter_In_Progress_ACPs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_New_Email_Received</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Filter_On_Hold_ACPs</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Incoming_Email__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_On_Hold_ACPs</targetReference>
            </connector>
            <label>Is New Email Received?</label>
        </rules>
        <rules>
            <name>Is_Enquiry_Linked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Application_Course_Preference__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Application_Course_Preference__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Filter_On_Hold_ACPs</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Loop_On_Hold_ACPs</targetReference>
            </connector>
            <label>Is Enquiry Linked?</label>
        </rules>
        <rules>
            <name>Is_New_Enquiry_With_ACP_created</name>
            <conditionLogic>1 AND 2 AND 3 AND (4 OR 5 OR 6 OR 7 OR 8 OR 9 OR 10 OR 11 OR 12 OR 13)</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Application_Course_Preference__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Origin</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Web - Agent Portal</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Offer acceptance</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Delegate nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Packaged courses</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Change of Course Preference</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Deferral</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Conditional eCOE</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Withdrawal and Refund</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Release request</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Agent nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Change of Preference</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Loop_On_Hold_ACPs</targetReference>
            </connector>
            <label>Is New Enquiry With ACP created?</label>
        </rules>
    </decisions>
    <description>Update ACP Status when an Enquiry is linked or updated.</description>
    <environments>Default</environments>
    <formulas>
        <description>capture multiple release reasons while application course preference workflow status is still on release</description>
        <name>multipleReleaseReason</name>
        <dataType>String</dataType>
        <expression>If(!ISBLANK({!Loop_On_Hold_ACPs.Release_Reason__c}) &amp;&amp; ISPICKVAL({!Loop_On_Hold_ACPs.Workflow_Status__c}, &apos;Released&apos;), &apos;New Enquiry Received &amp; other reason.&apos;, &apos;New Enquiry Received.&apos;)</expression>
    </formulas>
    <formulas>
        <description>check multiple release reason while application course preference workflow status is released.</description>
        <name>multipleReleaseReasonMUDocs</name>
        <dataType>String</dataType>
        <expression>If(!ISBLANK({!Loop_Completed_Sort.Release_Reason__c}) &amp;&amp; ISPICKVAL({!Loop_Completed_Sort.Workflow_Status__c}, &apos;Released&apos;), &apos;New Enquiry Received &amp; other reason.&apos;, &apos;New Enquiry Received.&apos;)</expression>
    </formulas>
    <interviewLabel>Case : AU : Sync Enquiry with ACP Status {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Case : AU : Sync ACP Status with Enquiry</label>
    <loops>
        <name>Loop_Completed_Sort</name>
        <label>Loop Completed Sort</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Filter_Completed_ACPs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_to_MUDocs</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_ACP_to_Release</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_On_Hold_ACPs</name>
        <label>Loop On Hold ACPs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Filter_On_Hold_ACPs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Check_Workflow_Status</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_ACP_to_Release</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_ACP_Records_Related_to_Application</name>
        <label>Get ACP Records Related to Application</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Filter_On_Hold_ACPs</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Get_ACP_Record_Fault</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Application__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Application_Course_Preference__r.Application__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Application_Course_Preference__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_MUDocs_Queue_Id</name>
        <label>Get MUDocs Queue Id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Completed_Sort</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Type</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Queue</stringValue>
            </value>
        </filters>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>CENTRAL_ADMISSIONS_MUDocs</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_ACP_to_Release</name>
        <label>Update ACP to Release</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Record_Logs_for_Failed_Update</targetReference>
        </faultConnector>
        <inputReference>ACPRecordListForUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_ACP_Records_Related_to_Application</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; {!$Record.RecordType.DeveloperName} = &apos;Admissions&apos;</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>ACPRecordListForUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Application_Course_Preference__c</objectType>
    </variables>
    <variables>
        <name>currentItem_Filter_Completed_ACPs</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Application_Course_Preference__c</objectType>
    </variables>
    <variables>
        <name>currentItem_Filter_In_Progress_ACPs</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Application_Course_Preference__c</objectType>
    </variables>
    <variables>
        <name>currentItem_Filter_On_Hold_ACPs</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Application_Course_Preference__c</objectType>
    </variables>
</Flow>
