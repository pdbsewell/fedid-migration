    <collectionProcessors>
        <name>Filter_Completed_ACPs</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter Completed ACPs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_Completed_ACPs</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_ACP_Records_Related_to_Application</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_Completed_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Completed</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Sort_Completed_ACPs</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Filter_In_Progress_ACPs</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter In Progress ACPs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_In_Progress_ACPs</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_ACP_Records_Related_to_Application</collectionReference>
        <conditionLogic>or</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Pending</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>In Progress</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Released</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>On Hold</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Check_if_In_Progress_ACPs_Exists</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Filter_On_Hold_ACPs</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter On Hold ACPs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_On_Hold_ACPs</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_ACP_Records_Related_to_Application</collectionReference>
        <conditionLogic>or</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_On_Hold_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>On Hold</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_On_Hold_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Released</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Validate_Enquiry_Changes</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Sort_Completed_ACPs</name>
