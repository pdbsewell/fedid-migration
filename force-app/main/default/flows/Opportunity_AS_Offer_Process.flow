        <label>Manually Signed?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>BDP_Completed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>TRUE_Manually_Signed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Applicant_Enrolment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Manual_ISCA_Edit_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Signed by all parties</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Sign_Manual_Quote_Update</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Preview_Ready</name>
        <label>Preview Ready?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Preview_Ready_True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Preview_Ready__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Applicant_Enrolment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Bulk_Gen__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_Owner_ID_to_be_notified</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Publish_Offer</name>
        <label>Publish Offer ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>BDP_Offer_Created</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Publish_Offer_True</name>
            <conditionLogic>(1 OR 6) AND 2 AND 3 AND ( 4 OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Publish</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Applicant_Enrolment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__r.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__r.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Published__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Primary_Quote</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>QA_Required</name>
        <label>QA Required ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Preview_Ready</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>QA_Required_True</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Applicant_Enrolment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Specialist Review</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Primary_Quote_for_review</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Rejected</name>
        <label>Rejected ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Cancelled</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>TRUE_Rejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Applicant_Enrolment</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Closed_Reason__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Rejected</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__PrimaryQuote__r.SBQQ__Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Signed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Reject_Quote_Update</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>Migrated from the - Opportunity Offer Process - process builder
Contains processes for Opportunity Offers</description>
    <environments>Default</environments>
    <formulas>
        <name>formulaAgentEmail</name>
        <dataType>String</dataType>
        <expression>IF({!$Record.Agent_Account__c} = &apos;&apos;, &apos;&apos;, {!$Record.Agent_Account__c.Email__c} )</expression>
    </formulas>
    <formulas>
        <name>formulaNotificationBody</name>
        <dataType>String</dataType>
        <expression>&quot;Click here to view &quot; &amp; {!$Record.PrimaryContact__r.Full_Name__c} &amp; &quot;\&apos;s offer&quot;</expression>
    </formulas>
    <interviewLabel>Opportunity : AS : Offer Process {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity : AS : Offer Process</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Offer_Platform_Event_Creation</name>
        <label>Offer Platform Event Creation</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Bulk_Publish</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Offer_Platform_Event_Creation</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Opportunity_ID__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>Opportunity_Event__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordUpdates>
        <name>Bulk_Publish_Offer</name>
        <label>Bulk Publish Offer</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Publish_Offer</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Bulk_Publish_Offer</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>Publish</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Cancel_Quote_Update</name>
        <label>Cancel Quote Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Deferred</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Cancel_Quote_Update</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Cancelled</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Rejected by Assessor</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Defer_Quote_Update</name>
        <label>Defer Quote Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Deferral_Signed</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Defer_Quote_Update</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Deferred</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue></stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Reject_Quote_Update</name>
        <label>Reject Quote Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Cancelled</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Reject_Quote_Update</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Rejected</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Rejected by Assessor</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Send_Primary_Quote_for_review</name>
        <label>Send Primary Quote for review</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Preview_Ready</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Send_Primary_Quote_for_review</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>In_Technical_Error__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Business request review</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Sign_Manual_Quote_Update</name>
        <label>Sign Manual Quote Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Opportunity_Stage</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Sign_Manual_Quote_Update</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Signed</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Signed and locked</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_BDP_to_Completed</name>
        <label>Update BDP to Completed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Extend_Offer</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Update_BDP_to_Completed</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Bulk_Data_Processing__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_BDP_to_Offer_Created</name>
        <label>Update BDP to Offer Created</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>QA_Required</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Update_BDP_to_Offer_Created</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Status__c</field>
            <value>
                <stringValue>Offer Created</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>isLocked__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Bulk_Data_Processing__r</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Opportunity_Published_Date</name>
        <label>Update Opportunity Published Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>BDP_Offer_Created</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Update_Opportunity_Published_Date</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Published_Date__c</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Opportunity_Stage</name>
        <label>Update Opportunity Stage</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>BDP_Completed</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>Signed</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Primary_Quote</name>
        <label>Update Primary Quote</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Email_Agent_the_Published_Offer</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Set_Scenario_for_Error_logging_Update_Primary_Quote</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Published</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Preview Released</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.SBQQ__PrimaryQuote__r</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Generate_Offer</targetReference>
        </connector>
        <filterFormula>AND({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;Opportunity_AS_Offer_Processing&quot;) = false)</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <description>Collection of Opportunity Owner IDs</description>
        <name>listOwnerIds</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>txtScenario</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
