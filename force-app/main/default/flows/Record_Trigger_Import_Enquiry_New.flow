    <description>RO-426 - Add capability to assign enquiry owners based on Owner Id in Import Enquiry</description>
    <environments>Default</environments>
    <formulas>
        <name>frmBaseURL</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_590}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_590}))</expression>
    </formulas>
    <formulas>
        <name>frmOwnerEnquiry</name>
        <dataType>String</dataType>
        <expression>IF(
ISBLANK({!$Record.Enquiry_Owner__c}), 
{!$Record.OwnerId}, 
{!$Record.Enquiry_Owner__c}
)</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Import Enquiry New {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record-Trigger: Import Enquiry New</label>
