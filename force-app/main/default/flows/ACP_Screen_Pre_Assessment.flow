            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Assessment_Overview_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_PreAssessmentOverview</name>
                    <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;The below shows an overview of the Assessment steps that need to be carried out for this Application at this point in time.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;Fee Check:&lt;/strong&gt;&amp;nbsp;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;{!ttFeesPaidIcon}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;GTE Check:&lt;/strong&gt;&amp;nbsp;{!ttGTEIcon}&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;DSS Check:&lt;/strong&gt;&amp;nbsp;{!ttDSSIcon}&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px; color: var(--slds-g-color-neutral-base-30, var(--lwc-colorTextWeak,rgb(68, 68, 68))); background-color: var(--slds-g-color-neutral-base-100, var(--lwc-colorBackgroundInput,rgb(255, 255, 255)));&quot;&gt;Advanced Standing&lt;/strong&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt; Check&lt;/strong&gt;&lt;strong style=&quot;font-size: 14px; color: var(--slds-g-color-neutral-base-30, var(--lwc-colorTextWeak,rgb(68, 68, 68))); background-color: var(--slds-g-color-neutral-base-100, var(--lwc-colorBackgroundInput,rgb(255, 255, 255)));&quot;&gt;: &lt;/strong&gt;&lt;span style=&quot;font-size: 12px; color: var(--slds-g-color-neutral-base-30, var(--lwc-colorTextWeak,rgb(68, 68, 68))); background-color: var(--slds-g-color-neutral-base-100, var(--lwc-colorBackgroundInput,rgb(255, 255, 255)));&quot;&gt;{!ttCreditIcon}&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
