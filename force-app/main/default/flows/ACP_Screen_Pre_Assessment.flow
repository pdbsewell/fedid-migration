        </fields>
        <fields>
            <name>Section_Genuine_Temporary_Entrant</name>
            <fieldText>Genuine Student (GS) requirement</fieldText>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Genuine_Temporary_Entrant_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_GTE</name>
                    <fieldText>&lt;p&gt;If the applicant are an international student applying for a student visa, in addition to assessing the application against all other&amp;nbsp;&lt;a href=&quot;https://www.monash.edu/admissions/entry-requirements&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;entry requirements&lt;/a&gt;, Monash is obligated to check that the applicant are genuinely seeking temporary entry into Australia for study purposes.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;If we believe they are not a genuine temporary entrant (GTE) – as defined by the&amp;nbsp;&lt;a href=&quot;https://immi.homeaffairs.gov.au/visas/getting-a-visa/visa-listing/student-500/genuine-temporary-entrant&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;Department of Home Affairs’ genuine temporary entrant requirement&lt;/a&gt;&amp;nbsp;for student visa applications – we may:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;refuse to assess your application&lt;/li&gt;&lt;li&gt;withdraw an offer of a place, or&lt;/li&gt;&lt;li&gt;cancel your confirmation of enrolment.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Monash reserves the right to request additional information and conduct a face-to-face interview in relation to a GTE check.&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <fields>
                    <name>navGTE</name>
                    <extensionName>c:navigationButtonFSC</extensionName>
                    <fieldType>ComponentInstance</fieldType>
                    <inputParameters>
                        <name>label</name>
                        <value>
                            <stringValue>Review Genuine Student</stringValue>
                        </value>
                    </inputParameters>
                    <inputParameters>
                        <name>disabledFlag</name>
                        <value>
                            <booleanValue>false</booleanValue>
                        </value>
                    </inputParameters>
                    <inputParameters>
                        <name>variantType</name>
                        <value>
                            <stringValue>brand</stringValue>
                        </value>
                    </inputParameters>
                    <inputParameters>
                        <name>fire</name>
                        <value>
                            <booleanValue>false</booleanValue>
                        </value>
                    </inputParameters>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>true</isRequired>
                    <storeOutputAutomatically>true</storeOutputAutomatically>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>12</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <isRequired>false</isRequired>
