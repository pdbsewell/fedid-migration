                <fields>
                    <name>dtxt_SVP</name>
                    <fieldText>&lt;p&gt;Monash University is a registered institution under the&amp;nbsp;&amp;nbsp;Streamlined Visa Processing (SVP) scheme.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The&amp;nbsp;&lt;a href=&quot;http://www.homeaffairs.gov.au/&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;&lt;u&gt;Department of Home Affairs (HA)&lt;/u&gt;&lt;/a&gt;&amp;nbsp;is responsible for issuing visas for entry to Australia. Students who are planning to study a&amp;nbsp;&lt;a href=&quot;http://cricos.education.gov.au/&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;&lt;u&gt;CRICOS&lt;/u&gt;&lt;/a&gt;&amp;nbsp;registered course are required to obtain a student visa. The HA&amp;nbsp;will assess student visa applications regardless of their country of origin.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;See&amp;nbsp;&lt;a href=&quot;http://www.homeaffairs.gov.au/trav/stud&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;&lt;u&gt;Applying for a student visa&lt;/u&gt;&lt;/a&gt;&amp;nbsp;for information about the application process.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Further information for International students is available here: https://www.monash.edu/study/international&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <fields>
                    <name>navSVP</name>
                    <extensionName>c:navigationButtonFSC</extensionName>
                    <fieldType>ComponentInstance</fieldType>
                    <inputParameters>
                        <name>label</name>
                        <value>
                            <stringValue>Review Visa Questions</stringValue>
                        </value>
                    </inputParameters>
                    <inputParameters>
                        <name>disabledFlag</name>
                        <value>
                            <booleanValue>true</booleanValue>
                        </value>
                    </inputParameters>
                    <inputParameters>
                        <name>variantType</name>
                        <value>
                            <stringValue>brand</stringValue>
                        </value>
                    </inputParameters>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>true</isRequired>
                    <storeOutputAutomatically>true</storeOutputAutomatically>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <inputParameters>
                    <name>width</name>
                    <value>
                        <stringValue>12</stringValue>
                    </value>
                </inputParameters>
                <isRequired>false</isRequired>
            </fields>
            <isRequired>false</isRequired>
            <regionContainerType>SectionWithHeader</regionContainerType>
            <styleProperties>
                <verticalAlignment>
