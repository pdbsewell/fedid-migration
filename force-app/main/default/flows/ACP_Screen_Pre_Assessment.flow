    <decisions>
        <name>Decision_Navigation</name>
        <label>Decision Navigation</label>
        <locationX>578</locationX>
        <locationY>566</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Fee</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NavFee.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACP_Screen_Pre_Assessment_FeeCheck</targetReference>
            </connector>
            <label>Outcome Fee</label>
        </rules>
        <rules>
            <name>Outcome_DSS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NavDSS.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACP_Screen_Pre_Assessment_DSSCheck</targetReference>
            </connector>
            <label>Outcome DSS</label>
        </rules>
        <rules>
            <name>GTE_Check</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navGTE.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACP_Screen_Pre_Assessment_GTECheck</targetReference>
            </connector>
            <label>GTE Check</label>
        </rules>
        <rules>
            <name>Outcome_AdvancedStanding</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navCredit.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ACP_Screen_Pre_Assessment_AdvStandingCheck</targetReference>
            </connector>
            <label>Advanced Standing</label>
        </rules>
    </decisions>
    <description>Version: SMSTA-92 - Advanced Standing Flow (Credit assessments)</description>
    <environments>Default</environments>
    <formulas>
        <name>frmStaticResourceURL</name>
        <dataType>String</dataType>
        <expression>Left({!$Api.Enterprise_Server_URL_100}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_100})) + &quot;resource/1500335404000/GraphicsPackNew/fatcow/farmfresh/32/&quot;</expression>
    </formulas>
    <formulas>
        <name>frmTask_Credit_Icon</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!varTaskCredit}), {!varTaskCredit} , {!frmStaticResourceURL}+CASE({!varTaskCredit}, 
&quot;Not Required&quot;, &quot;flag_green.png&quot;, 
&quot;Completed&quot;, &quot;flag_finish.png&quot;,
&quot;In Progress&quot;, &quot;flag_yellow.png&quot;,
&quot;Failed&quot;, &quot;exclamation.png&quot;,
&quot;Required&quot;, &quot;flag_red.png&quot;,
&quot;Waiting for docs&quot;, &quot;flag_yellow.png&quot;,
&quot;Discontinued&quot;, &quot;flag_green.png&quot;, 
&quot;Internal Input Required&quot;, &quot;flag_yellow.png&quot;,
{!varTaskCredit}))</expression>
    </formulas>
    <formulas>
        <name>frmTask_DSS_Icon</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!varTaskDSS}), {!varTaskDSS} , {!frmStaticResourceURL}+CASE({!varTaskDSS}, 
&quot;Not Required&quot;, &quot;flag_green.png&quot;, 
&quot;Completed&quot;, &quot;flag_finish.png&quot;,
&quot;In Progress&quot;, &quot;flag_yellow.png&quot;,
&quot;Failed&quot;, &quot;exclamation.png&quot;,
&quot;Required&quot;, &quot;flag_red.png&quot;,
&quot;Waiting for docs&quot;, &quot;flag_yellow.png&quot;,
&quot;Discontinued&quot;, &quot;flag_green.png&quot;, 
&quot;Internal Input Required&quot;, &quot;flag_yellow.png&quot;,
{!varTaskDSS}))</expression>
    </formulas>
    <formulas>
        <name>frmTask_Fee_Icon</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!varTaskFee}), {!varTaskFee} , {!frmStaticResourceURL}+CASE({!varTaskFee}, 
&quot;Not Required&quot;, &quot;flag_green.png&quot;, 
&quot;Completed&quot;, &quot;flag_finish.png&quot;,
&quot;In Progress&quot;, &quot;flag_yellow.png&quot;,
&quot;Failed&quot;, &quot;exclamation.png&quot;,
&quot;Required&quot;, &quot;flag_red.png&quot;,
&quot;Waiting for docs&quot;, &quot;flag_yellow.png&quot;,
&quot;Discontinued&quot;, &quot;flag_green.png&quot;, 
&quot;Internal Input Required&quot;, &quot;flag_yellow.png&quot;,
{!varTaskFee}))</expression>
    </formulas>
    <formulas>
        <name>frmTask_GTE_Icon</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!varTaskGTE}), {!varTaskGTE} , {!frmStaticResourceURL}+CASE({!varTaskGTE}, 
&quot;Not Required&quot;, &quot;flag_green.png&quot;, 
&quot;Completed&quot;, &quot;flag_finish.png&quot;,
&quot;In Progress&quot;, &quot;flag_yellow.png&quot;,
&quot;Failed&quot;, &quot;exclamation.png&quot;,
&quot;Required&quot;, &quot;flag_red.png&quot;,
&quot;Waiting for docs&quot;, &quot;flag_yellow.png&quot;,
&quot;Discontinued&quot;, &quot;flag_green.png&quot;, 
&quot;Internal Input Required&quot;, &quot;flag_yellow.png&quot;,
{!varTaskGTE}))</expression>
    </formulas>
    <formulas>
        <name>frmTask_SVP</name>
        <dataType>String</dataType>
        <expression>CASE({!varTaskSVP}, 
&quot;Not Required&quot;, {!ttGreen_SVP}, 
&quot;Completed&quot;, {!ttGreen_SVP},
{!ttRed_SVP})</expression>
    </formulas>
    <formulas>
        <name>frmViewDocumentURL</name>
        <dataType>String</dataType>
        <expression>Left({!$Api.Enterprise_Server_URL_100}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_100})) + &quot;/c/DocumentPreviewer.app?cd=&quot;+{!Get_ContactDocument.Id}</expression>
    </formulas>
