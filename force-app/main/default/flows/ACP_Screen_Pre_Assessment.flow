        <fields>
            <name>Section_Disability_Support</name>
            <fieldText>Disability Support</fieldText>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Disability_Support_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_DSS</name>
                    <fieldText>&lt;p&gt;The applicant has indicated that they have a disability. We have consent from the applicant on providing disability information. We will need to raise a request with the DSS team to review the applicant&apos;s disability and advise if we will be able to cater to their needs.&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <fields>
                    <name>NavDSS</name>
                    <extensionName>c:navigationButtonFSC</extensionName>
                    <fieldType>ComponentInstance</fieldType>
                    <inputParameters>
                        <name>label</name>
