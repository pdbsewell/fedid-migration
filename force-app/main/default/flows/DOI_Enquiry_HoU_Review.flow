                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <nextOrFinishButtonLabel>Review</nextOrFinishButtonLabel>
        <showFooter>false</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Screen_User_Not_Found</name>
        <label>Screen - User Not Found</label>
        <locationX>1942</locationX>
        <locationY>1322</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Skip_Get_User_Retry</targetReference>
        </connector>
        <fields>
            <name>user_not_found_prompt</name>
            <fieldText>&lt;p&gt;&lt;strong&gt;The Faculty/Portfolio Leader email is incorrect&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;No user could be found for {!email_for_user_lookup}. Please enter another email address and click next.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;If you are sure this email address is correct, the user may not be set up correctly for this process.&lt;/p&gt;&lt;p&gt;In this case, please click &quot;Send to HR&quot; for triaging.&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>email_input_retry</name>
            <dataType>String</dataType>
            <fieldType>InputField</fieldType>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>false</isRequired>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>send_hr_button</name>
            <extensionName>c:navigationButtonFSC</extensionName>
            <fieldType>ComponentInstance</fieldType>
            <inputParameters>
                <name>label</name>
                <value>
                    <stringValue>Send to HR</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>variantType</name>
                <value>
                    <stringValue>brand</stringValue>
                </value>
            </inputParameters>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <storeOutputAutomatically>true</storeOutputAutomatically>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>email_input_retry</leftValueReference>
                    <operator>IsNull</operator>
                    <rightValue>
                        <booleanValue>true</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>send_hr_retry_button</name>
            <extensionName>c:navigationButtonFSC</extensionName>
            <fieldType>ComponentInstance</fieldType>
            <inputParameters>
                <name>label</name>
                <value>
                    <stringValue>Send to HR</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>variantType</name>
                <value>
                    <stringValue>brand</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>label2</name>
                <value>
                    <stringValue>Next</stringValue>
                </value>
            </inputParameters>
            <inputParameters>
                <name>variantType2</name>
                <value>
                    <stringValue>brand</stringValue>
                </value>
            </inputParameters>
            <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
            <isRequired>true</isRequired>
            <storeOutputAutomatically>true</storeOutputAutomatically>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>email_input_retry</leftValueReference>
                    <operator>IsNull</operator>
                    <rightValue>
                        <booleanValue>false</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <nextOrFinishButtonLabel>Next</nextOrFinishButtonLabel>
        <showFooter>false</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <start>
        <locationX>3378</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Flow_Access_Check</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>Endorse_Advice</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Endorsement Feedback: [{!$Flow.CurrentDateTime}]-[{!$User.Full_Name__c}] - {!Management_Plan_Endorse_feedback}&lt;br/&gt;
{!getDoIDetails.Endorse_Comments__c}</text>
    </textTemplates>
    <textTemplates>
        <name>Endorse_Reason</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Endorsement Details: [{!$Flow.CurrentDateTime}]-[{!$User.Full_Name__c}] - {!Endorse_comments}&lt;br/&gt;
{!getDoIDetails.Endorse_Comments__c}</text>
    </textTemplates>
    <textTemplates>
        <name>Endorse_Reject</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Reject Details: [{!$Flow.CurrentDateTime}]-[{!$User.Full_Name__c}] - {!Management_Plan_Endorse_feedback}&lt;br/&gt;
{!getDoIDetails.Endorse_Comments__c}</text>
    </textTemplates>
    <textTemplates>
        <name>Escalation_Advice</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Escalation Advice: [{!$Flow.CurrentDateTime}]-[{!$User.Full_Name__c}] - {!Provided_Escalation_Advice}&lt;br/&gt;
{!getDoIDetails.Escalation_Comments__c}</text>
    </textTemplates>
    <textTemplates>
        <name>Escalation_Reason</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Escalation Details: [{!$Flow.CurrentDateTime}]-[{!$User.Full_Name__c}] - {!EscalationReasonMP}&lt;br/&gt;
{!getDoIDetails.Escalation_Comments__c}</text>
    </textTemplates>
    <textTemplates>
        <name>pageseparator</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;hr style=&quot;margin:0&quot;&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Approval_Email_Text</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Your Management Plan:&lt;/p&gt;&lt;p&gt;{!getDoIDetails.Management_Plan__c}&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Approval_Email_Text_With_Comment</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Approval Comment:&lt;br&gt;
{!Approval_Comment_nltobr}
&lt;hr&gt;Your Management Plan:&lt;br&gt;
{!getDoIDetails.Management_Plan__c}</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CaseStatus_open</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;Please review the declaration and assess for actual, potential or perceived conflict or risk. Where conflict is identified you will assess or request a management plan.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Click &lt;a href=&quot;{!frmURL_DoI}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_self&quot;&gt;here&lt;/a&gt; to view the declaration.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CaseStatus_PlanEndorsed</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;This declaration has been reviewed and {!getEnquiry.First_Name_case_corrected__c} has submitted a conflict of interest management plan which has been endorsed.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The agreed plan is pending confirmation by Declarations officer.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <description>Management Plan Not Required</description>
        <name>tt_CaseStatus_PlanNotRequired</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;Based on your review, you have determined that the declared interest does not give rise to an actual, potential or perceived conflict of interest and as a result a COI management plan is not required.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;This case will be closed.&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CaseStatus_PlanReceived</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;A management plan has been submitted by {!getEnquiry.First_Name_case_corrected__c}. You can locate the management plan email from {!getEnquiry.First_Name_case_corrected__c} under the Most Recent Activity panel below.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Click on Review if you are ready to assess and confirm the plan.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CaseStatus_PlanRequested</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;A conflict of interest management plan has been requested from {!getEnquiry.First_Name_case_corrected__c} for this declared interest.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;No action is required until such time the staff member submits this plan, the system will update the status to ‘Open’ and direct you to review when it is time for action.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;We have included a summary of the interest declared below, but if you wish to view the detailed declaration information please click &lt;a href=&quot;{!frmURL_DoI}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;&lt;strong&gt;here&lt;/strong&gt;.&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;{!getEnquiry.Summary__c}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The ‘Most recent activity panel, will display any communication already had with {!getEnquiry.First_Name_case_corrected__c}.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CaseStatus_Referred</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;This declaration and any associated management plan has been referred to an internal party as part of a ‘Request for Support’.&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Once your receive a response to your request, the case status will revert to ‘open’ and enable you to commence review. Detail will be available in the ‘Most Recent Activity Panel’ below.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Category_Group</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-family: -apple-system, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; background-color: rgb(255, 255, 255); color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getEnquiry.Contact.Salutation} {!getEnquiry.Contact.Full_Name__c}&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; has declared an interest with &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.CE_Entity_Name__c}&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; (a group, committee or panel) in &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.CE_Country_of_Ownership__c}&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;. This interest is declared under the category/ies of &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.CE_Management_Plan_Triggers__c}&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Category_Individual_NoRST</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getEnquiry.Contact.Salutation} {!getEnquiry.Contact.Full_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt; has declared an interest with &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Entity_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt; under the category/ies of &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Management_Plan_Triggers__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt;.&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Category_Individual_OnlyRST</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 14px; background-color: rgb(255, 255, 255); font-family: -apple-system, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; color: rgb(200, 0, 143);&quot;&gt;{!getEnquiry.Contact.Salutation} {!getEnquiry.Contact.Full_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt; has declared a close personal relationship with &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;{!getDoIDetails.CE_Entity_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;, and indicated that the individual is a &lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(200, 0, 143);&quot;&gt;{!getDoIDetails.RST_Type__c}&lt;/span&gt;&lt;span style=&quot;font-size: 14px; color: rgb(51, 51, 51);&quot;&gt;. This type of declaration typically gives rise to conflict of interest and you should ensure as suitable management plan is submitted.&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Category_Individual_RST</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-family: -apple-system, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;; color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getEnquiry.Contact.Salutation} {!getEnquiry.Contact.Full_Name__c}&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt; has declared a close personal relationship with &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.CE_Entity_Name__c}&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;, and indicated that the individual is a &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.RST_Type__c}&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;. This individual has also been disclosed as part of another interest category, &lt;/span&gt;&lt;span style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;{!getDoIDetails.CE_Management_Plan_Triggers__c}&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 51); font-size: 14px;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Category_Organisation</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 12px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255); font-family: -apple-system, system-ui, &amp;quot;Segoe UI&amp;quot;, Roboto, Helvetica, Arial, sans-serif, &amp;quot;Apple Color Emoji&amp;quot;, &amp;quot;Segoe UI Emoji&amp;quot;, &amp;quot;Segoe UI Symbol&amp;quot;;&quot;&gt;{!getEnquiry.Contact.Salutation} {!getEnquiry.Contact.Full_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt; has declared an interest with &lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Entity_Name__c}&lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt;, which is a &lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Type_of_Organisation__c}&lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt; in &lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Country_of_Ownership__c}&lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(51, 51, 51); background-color: rgb(255, 255, 255);&quot;&gt;. This interest is declared under the category/ies of &lt;/span&gt;&lt;span style=&quot;font-size: 12px; color: rgb(200, 0, 143); background-color: rgb(255, 255, 255);&quot;&gt;{!getDoIDetails.CE_Management_Plan_Triggers__c}.&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_debug</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;-----&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;----------------------------------------&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Flow:&lt;/strong&gt; DoI - Enquiry - HoU Review&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Current Date/Time:&lt;/strong&gt; {!$Flow.CurrentDateTime}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Case Number: &lt;/strong&gt;{!getEnquiry.CaseNumber}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Case ID: &lt;/strong&gt;{!varID}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;GIUD: &lt;/strong&gt;{!$Flow.InterviewGuid}&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;color: rgb(200, 0, 142);&quot;&gt;Fault Message:&lt;/strong&gt;&lt;span style=&quot;color: rgb(200, 0, 142);&quot;&gt; {!$Flow.FaultMessage}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;---------------------------------------------&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_TaskNotification</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;You have been asked to review this enquiry by {!getEnquiry.Owner:User.Name}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;You have been assigned a Task to collaborate with and/or provide support to the Head of Unit with their staff members Declaration of Interest and associated management plan, or other risks.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;To review the details of the declaration click &lt;a href=&quot;{!frmURL_Case}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;&lt;strong&gt;here&lt;/strong&gt;&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;To see all correspondence on the declaration so far (including any submitted management plan) refer to the ‘Activity Panel’. You can also use that section to correspond or request more information from the HoU by typing @firstname.lastname.&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_UserErrorMessage</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong style=&quot;color: rgb(200, 0, 143); font-size: 16px;&quot;&gt;Something Went Wrong!&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;The flow has run into an issue and can not proceed.&lt;/p&gt;&lt;p&gt;If you need help resolving this, please reach out to the UniCRM admin team via &lt;a href=&quot;mailto:servicedesk@monash.edu?subject=(UniCRM)%20Issue%20with%20DoI%20HoU%20Review%20Flow&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;&lt;strong&gt;Email&lt;/strong&gt;&lt;/a&gt;. You can paste the below information in the email body which can help them debugging the issue.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;{!tt_debug}&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_WhatsNext</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;strong&gt;What next?&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;As there is no further action required on this case, you will need to &lt;a href=&quot;/lightning/r/Case/{!getEnquiry.Id}/view?0.promptId=DeclarationofInterestCloseTab&quot; target=&quot;_self&quot;&gt;close this tab and navigate to the Declaration of Interest Overview&lt;/a&gt;.&lt;/p&gt;</text>
    </textTemplates>
    <variables>
        <name>currentItemFromSourceCollection</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>email_for_user_lookup</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
