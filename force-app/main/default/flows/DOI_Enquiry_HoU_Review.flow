        </rules>
    </decisions>
    <decisions>
        <name>Which_email</name>
        <label>Which email</label>
        <locationX>1942</locationX>
        <locationY>3272</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>getEnquiry</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Escalation_email_to_FPL</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nav_Escalate_To_SME_MP.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_User_for_CTM</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_FPL_Email_Template</targetReference>
            </connector>
            <label>Escalation email to FPL</label>
        </rules>
        <rules>
            <name>Request_more_info_from_submitter</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nav_Request_for_more_information_DoI.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Request_More_Info_Email_Template</targetReference>
            </connector>
            <label>Request more info from submitter</label>
        </rules>
        <rules>
            <name>Management_Plan_Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nav_Approve_Management_Plan.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Management_Plan_Approved_Email_Template</targetReference>
            </connector>
            <label>Management Plan Approved</label>
        </rules>
        <rules>
            <name>Management_Plan_Feedback</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>nav_Request_for_more_information_MP.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Management_Plan_Feedback_Email_Template</targetReference>
            </connector>
            <label>Management Plan Feedback</label>
        </rules>
    </decisions>
    <description>2023 Refresh
new flow-driven email implementation
Shane&apos;s attempt
New Status = Draft holding text
w/ link to new in-app guidance</description>
    <environments>Default</environments>
    <formulas>
        <description>Converts the approval comments newlines to br tags</description>
        <name>Approval_Comment_nltobr</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE( SUBSTITUTE( JSENCODE({!Management_Plan_approval_comment}), &apos;\r\n&apos;, &apos;&lt;br&gt;&apos;), &apos;\n&apos;, &apos;&lt;br&gt;&apos;)</expression>
    </formulas>
    <formulas>
        <name>frm_ChatterPost</name>
        <dataType>String</dataType>
        <expression>{!tt_TaskNotification}</expression>
    </formulas>
    <formulas>
        <name>frm_TaskDueDate</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 14</expression>
    </formulas>
    <formulas>
        <name>frm_TaskReminder</name>
        <dataType>DateTime</dataType>
        <expression>NOW() + (5/1440)</expression>
    </formulas>
    <formulas>
        <name>frmCategory_Text</name>
        <dataType>String</dataType>
        <expression>CASE({!getEnquiry.Category_Level_1__c}, 
&quot;Individual&quot;, IF({!frmOnlyRST}=True, {!tt_Category_Individual_OnlyRST}, IF({!frmContainRST}=True, {!tt_Category_Individual_RST}, {!tt_Category_Individual_NoRST})), 
&quot;Organisation&quot;, {!tt_Category_Organisation},
&quot;Group&quot;, {!tt_Category_Group},
{!tt_Category_Group})</expression>
    </formulas>
    <formulas>
        <description>Management Plan Trigger contains RST</description>
        <name>frmContainRST</name>
        <dataType>Boolean</dataType>
        <expression>CONTAINS({!varPlanTrigger}, &quot;Recruitment, Supervision &amp; Teaching&quot;)</expression>
    </formulas>
    <formulas>
        <description>Management Plan Trigger only RST</description>
        <name>frmOnlyRST</name>
        <dataType>Boolean</dataType>
        <expression>{!varPlanTrigger}=&quot;Recruitment, Supervision &amp; Teaching&quot;</expression>
    </formulas>
    <formulas>
        <name>frmSingleSME</name>
        <dataType>String</dataType>
        <expression>TRIM(
SUBSTITUTE(
LEFT( {!varSelectedSME} , FIND(&quot;;&quot;, {!varSelectedSME} )), 
&quot;;&quot;, 
&quot;&quot;))</expression>
    </formulas>
    <formulas>
        <name>frmStatus_Text</name>
        <dataType>String</dataType>
        <expression>IF(TEXT({!getEnquiry.Enquiry_Type__c}) = &quot;HR DOI Submission&quot;, &quot;No action is required at this time. This is a placeholder record to confirm that &quot; + {!getEnquiry.Contact.Full_Name__c} + &quot; has completed their Declaration of Interest form and has nothing to declare.&quot;, 

CASE({!getEnquiry.Case_Stage__c}, 
&quot;Management Plan Endorsed&quot;, {!tt_CaseStatus_PlanEndorsed},

CASE({!getEnquiry.Status},
&quot;Closed&quot;, &quot;This Declaration of Interest submission has been closed as it has been assessed as: &quot; + TEXT({!getEnquiry.Case_Stage__c}) + &quot;.&quot;,
&quot;Draft&quot;, &quot;This Declaration of Interest submission is still being processed. No action is required at this time. Please check back again shortly.&quot;,
&quot;No action is currently required on this Declaration of Interest submission as it is set to &quot; + TEXT({!getEnquiry.Case_Stage__c})  + &quot;. If you are required to work on this further, the case will reopen and will be included in your lists and digest emails.&quot;
)

)

)</expression>
    </formulas>
    <formulas>
        <name>frmUpdateSelectedSME</name>
        <dataType>String</dataType>
        <expression>TRIM(
SUBSTITUTE( {!varSelectedSME} , {!varSingleSME}+&quot;;&quot; , &quot;&quot; )
)</expression>
    </formulas>
    <formulas>
        <name>frmURL_Case</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_570}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_570}))+&quot;lightning/r/Case/&quot;+{!varID}+&quot;/view&quot;</expression>
    </formulas>
    <formulas>
        <name>frmURL_DoI</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Enterprise_Server_URL_570}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_570}))+&quot;lightning/r/Case_Ext_DoI__c/&quot;+{!getDoIDetails.Id}+&quot;/view&quot;</expression>
    </formulas>
