    <decisions>
        <name>Decision_Navigation</name>
        <label>Decision Navigation</label>
        <locationX>534</locationX>
        <locationY>350</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Adv_Standing_Task</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navAdvStanding.fire2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Admission_Task_RT</targetReference>
            </connector>
            <label>Adv Standing Task</label>
        </rules>
