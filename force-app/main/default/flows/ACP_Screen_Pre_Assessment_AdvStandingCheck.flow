            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navAdvStanding.fire3</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_AdvStanding_Task</targetReference>
            </connector>
            <label>Update Record</label>
        </rules>
    </decisions>
    <description>Version 0.1 - SMSTA-92 - Advanced Standing Flow (Credit assessments)</description>
    <environments>Default</environments>
    <formulas>
        <name>frmShowTaskBtn</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISPICKVAL({!GetAdvStandingDetails.Task_Credit__c},&quot;Required&quot;), False,True)</expression>
    </formulas>
    <formulas>
        <name>frmTaskSubject</name>
        <dataType>String</dataType>
        <expression>&quot;Advance Standing Review: &quot; + &quot; [Applicant: &quot; + {!GetAdvStandingDetails.Applicant__r.Full_Name__c} + &quot;] [Course &amp; Campus: &quot; + {!GetAdvStandingDetails.Name} + &quot;]&quot;</expression>
    </formulas>
    <formulas>
        <name>frmViewDocumentURL</name>
        <dataType>String</dataType>
        <expression>Left({!$Api.Enterprise_Server_URL_100}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_100})) + &quot;/c/DocumentPreviewer.app?cd=&quot;+ {!varContactDocumentId}</expression>
    </formulas>
