    <screens>
        <description>Assessment screen for Advance Standing</description>
        <name>Screen_AdvStanding</name>
        <label>Screen AdvStanding</label>
        <locationX>534</locationX>
        <locationY>242</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Decision_Navigation</targetReference>
        </connector>
        <fields>
            <name>dtxt_AdvStandingScreen</name>
            <fieldText>&lt;p&gt;&lt;strong&gt;Credit for prior learning:&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Credit is the recognition of previous study or learning that can be counted towards a qualification. This can reduce the number of units required to complete a course of study.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>Section_Advance_Standing</name>
            <fieldText>Advance Standing</fieldText>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>Section_Advance_Standing_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>dtxt_AdvStandingDetails</name>
                    <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;u&gt;Applicant Information:&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Full Name:&lt;/strong&gt; {!GetAdvStandingDetails.Applicant__r.Full_Name__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Age:&lt;/strong&gt; {!GetAdvStandingDetails.Age__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Citizenship Country:&lt;/strong&gt; {!GetAdvStandingDetails.Citizenship_Country__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;Study/Location Details:&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong style=&quot;color: rgb(200, 0, 143);&quot;&gt;Credit Intention:&lt;/strong&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt; {!GetAdvStandingDetails.Application__r.Credit_Intention__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Campus:&lt;/strong&gt; {!GetAdvStandingDetails.Location_Description__c}&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Faculty:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetAdvStandingDetails.Managing_Faculty__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Course:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetAdvStandingDetails.Course_Title__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Commencement:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetAdvStandingDetails.Commencement_Period__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Attendance Mode:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetAdvStandingDetails.Attendance_Mode_Description__c}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Attendance Type:&lt;/strong&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt; {!GetAdvStandingDetails.Attendance_Type_Description__c}&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
                    </styleProperties>
                </fields>
                <fields>
                    <fieldType>ObjectProvided</fieldType>
                    <inputsOnNextNavToAssocScrn>UseStoredValues</inputsOnNextNavToAssocScrn>
                    <isRequired>false</isRequired>
                    <objectFieldReference>GetAdvStandingDetails.Task_Credit__c</objectFieldReference>
                    <styleProperties>
                        <verticalAlignment>
