    <decisions>
        <description>Owner is MRO Staff + Cat 1 = Variation/Transfer in/Transfer Out/ Report/ Close out + Enquiry Type = Awards / Majors + Status = In progress, Enquiry contact type is “Known to Monash” and Case reopened = False</description>
        <name>Check_Enquiry_Record</name>
        <label>Check Enquiry Record</label>
        <locationX>446</locationX>
        <locationY>492</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Type_Award_MajorAward</name>
            <conditionLogic>1 AND (2 OR 3) AND 4 AND 5</conditionLogic>
            <conditions>
                <leftValueReference>formula_ClosedEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>ClosedEmailSent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Major Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>General</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Establishment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_For_Awards_Major_Award</targetReference>
            </connector>
            <label>Type=Award-MajorAward</label>
        </rules>
        <rules>
            <name>Type_Application</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_ClosedEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>ClosedEmailSent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_for_Application</targetReference>
            </connector>
            <label>Type=Application</label>
        </rules>
        <rules>
            <name>Type_ApplicationRetrospective</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retrospective</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_ClosedEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>ClosedEmailSent</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_for_Application_Retrospective</targetReference>
            </connector>
            <label>Type=ApplicationRetrospective</label>
        </rules>
    </decisions>
    <decisions>
        <name>CheckEnquiry</name>
        <label>CheckEnquiry</label>
        <locationX>1040</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>EnquiryStatus_Closed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Formula_Field_s</targetReference>
            </connector>
            <label>EnquiryStatus=Closed</label>
        </rules>
    </decisions>
    <description>[RO-404 v1] Email Notification - Scheduled.</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_ClosedEmailSent</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!EnquiryOptionField}),
&quot;ClosedEmailSent;&quot;,
IF(INCLUDES({!$Record.Options__c}, &quot;ClosedEmailSent&quot;),{!EnquiryOptionField},
{!EnquiryOptionField}&amp;&quot;;&quot;&amp;&quot;ClosedEmailSent;&quot;
)
)</expression>
    </formulas>
    <formulas>
        <name>formula_ClosedEmailSentOption</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!EnquiryOptionField}, &quot;ClosedEmailSent&quot;), &quot;ClosedEmailSent&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>senderEmailAddress</name>
        <dataType>String</dataType>
        <expression>&apos;am-noreply@f.e.monash.edu&apos;</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Enquiry After Save (MRO Email Notifications Scheduled) {!$Flow.CurrentDateTime}</interviewLabel>
