    <recordLookups>
        <name>Get_Email_Template</name>
        <label>Get Email Template</label>
        <locationX>446</locationX>
        <locationY>792</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Send_Email</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Create_Log_Record</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>emailTemplateDeveloperName</elementReference>
            </value>
        </filters>
        <filters>
            <field>IsActive</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>EmailTemplate</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Enquiry_Record</name>
        <label>Update Enquiry Record</label>
        <locationX>446</locationX>
        <locationY>1008</locationY>
        <faultConnector>
            <targetReference>Create_Log_Record</targetReference>
        </faultConnector>
        <inputReference>EnquiryRecord</inputReference>
    </recordUpdates>
    <start>
        <locationX>287</locationX>
        <locationY>0</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; {!$Record.RecordType.DeveloperName} = &apos;MRO&apos; &amp;&amp; {!$Record.Reopened__c} = false &amp;&amp; {!$Record.ParentId} = null &amp;&amp;  ISPICKVAL({!$Record.Status}, &apos;Closed&apos;) &amp;&amp; !ISBLANK({!$Record.ContactId}) &amp;&amp; (ISPICKVAL({!$Record.Enquiry_Type__c}, &apos;Award&apos;) || ISPICKVAL({!$Record.Enquiry_Type__c}, &apos;Major Award&apos;) || ISPICKVAL({!$Record.Enquiry_Type__c}, &apos;Application&apos;))</filterFormula>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <name>Scheduled_Path</name>
            <connector>
                <targetReference>CheckEnquiry</targetReference>
            </connector>
            <label>Scheduled Path</label>
            <offsetNumber>60</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <timeSource>RecordTriggerEvent</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
