    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Log_Record</name>
        <label>Create Log Record</label>
        <locationX>1106</locationX>
        <locationY>1116</locationY>
        <inputAssignments>
            <field>Function_Name__c</field>
            <value>
                <stringValue>Record-Trigger: Enquiry After Save (MRO Email Notifications Scheduled) </stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
