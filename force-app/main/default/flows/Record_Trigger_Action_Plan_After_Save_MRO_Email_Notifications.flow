    <recordLookups>
        <description>Get Enquiry Record Details</description>
        <name>Get_Enquiry_Record</name>
        <label>Get Enquiry Record</label>
        <locationX>2162</locationX>
        <locationY>431</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>checkMRORecord</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Create_Log_Record</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.TargetId</elementReference>
            </value>
        </filters>
        <object>Case</object>
        <outputReference>MRO_Enquiry_Record</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>RecordType_DeveloperName__c</queriedFields>
        <queriedFields>Status</queriedFields>
        <queriedFields>Enquiry_Type__c</queriedFields>
        <queriedFields>ContactId</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Template_Id</name>
        <label>Get Template Id</label>
        <locationX>1370</locationX>
        <locationY>1139</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_SenderEmail</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Create_Log_Record</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>EmailTemplateAPIName</elementReference>
            </value>
        </filters>
        <object>EmailTemplate</object>
        <outputReference>oEmailTemplateRecord</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>DeveloperName</queriedFields>
    </recordLookups>
    <start>
        <locationX>2696</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Decision_Target_Record</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; ISCHANGED({!$Record.ActionPlanState} )</filterFormula>
        <object>ActionPlan</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
