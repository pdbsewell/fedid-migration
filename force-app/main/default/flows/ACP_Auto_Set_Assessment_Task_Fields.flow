        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Log_Nebula_Error</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Application__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varAppId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Application_Course_Preference__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Task_Credit__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_ACPs</name>
        <label>Update ACPs</label>
        <locationX>182</locationX>
        <locationY>950</locationY>
        <faultConnector>
            <targetReference>Log_Nebula_Error</targetReference>
        </faultConnector>
        <inputReference>varUpdatedACPs</inputReference>
    </recordUpdates>
    <runInMode>DefaultMode</runInMode>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
