    <apiVersion>60.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_ACP_Tasks</name>
        <label>Assign ACP Tasks</label>
        <locationX>270</locationX>
        <locationY>650</locationY>
        <assignmentItems>
            <assignToReference>Loop_ACP.Task_Credit__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>varTaskCredit</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_ACPs</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_ACPs</name>
        <label>Assign ACPs</label>
        <locationX>270</locationX>
        <locationY>758</locationY>
        <assignmentItems>
            <assignToReference>varUpdatedACPs</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_ACP</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_ACP</targetReference>
        </connector>
    </assignments>
    <assignments>
