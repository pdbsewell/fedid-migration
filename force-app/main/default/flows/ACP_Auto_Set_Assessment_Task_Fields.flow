    <decisions>
        <name>Decision_Credit_Check</name>
        <label>Credit Check</label>
        <locationX>182</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>NotRequired_TaskCredit</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Required</defaultConnectorLabel>
        <rules>
            <name>Outcome_Required</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varCreditIntention</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Required_TaskCredit</targetReference>
            </connector>
            <label>Required</label>
        </rules>
    </decisions>
    <description>Subflow to set Task values on ACP for Applications being assessed in UniCRM</description>
    <environments>Default</environments>
    <interviewLabel>ACP: Auto: Set Assessment Task Fields {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ACP: Auto: Set Assessment Task Fields</label>
    <loops>
        <description>Loop through all ACP</description>
        <name>Loop_ACP</name>
        <label>Loop ACP</label>
        <locationX>182</locationX>
        <locationY>542</locationY>
        <collectionReference>Get_ACP</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_ACP_Tasks</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_ACPs</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
