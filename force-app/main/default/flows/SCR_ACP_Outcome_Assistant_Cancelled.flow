    </dynamicChoiceSets>
    <environments>Default</environments>
    <interviewLabel>SCR - ACP - Outcome Assistant : {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - ACP - Outcome Assistant : Cancelled</label>
    <loops>
        <name>Loop_LOVs_Cancelled</name>
        <label>Loop LOVs Cancelled</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>ListOfValues</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Get_Cancelled_LOV_records</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Outcome_Summary</targetReference>
        </noMoreValuesConnector>
    </loops>
