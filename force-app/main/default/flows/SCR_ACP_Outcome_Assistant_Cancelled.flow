    <collectionProcessors>
        <name>Cancelled_List_of_Values</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Cancelled List of Values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Cancelled_List_of_Values</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>ListOfValues</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Cancelled_List_of_Values.Outcome_Path__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Cancelled</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>OutcomeStatusTransform</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Check_if_previous_Outcome_is_Conditional_Offer_or_Full_Offer</name>
        <label>Check if previous Outcome is Conditional Offer or Full Offer</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Add_currentACP_to_UpdateACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Previous_Outcome_is_Conditional_Offer</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-COND</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-E</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-FY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-MC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Empty_Values_Conditional_Offer</targetReference>
            </connector>
            <label>Previous Outcome is Conditional Offer</label>
        </rules>
        <rules>
            <name>Previous_Outcome_is_Full_Offer</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Empty_Values_Full_Offer</targetReference>
            </connector>
            <label>Previous Outcome is Full Offer</label>
        </rules>
    </decisions>
    <decisions>
        <name>Get_Cancelled_LOV_records</name>
        <label>Get Cancelled LOV records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Cancelled</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Status_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OUTCOME_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Outcome_Status</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatusRecord</targetReference>
            </connector>
            <label>Outcome Status Record</label>
        </rules>
        <rules>
            <name>Entry_Qualification_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_ENTRY_QUAL_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PENDING</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EntryQualificationRecord</targetReference>
            </connector>
            <label>Entry Qualification Record</label>
        </rules>
        <rules>
            <name>Offer_Response_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OfferResponseRecord</targetReference>
            </connector>
            <label>Offer Response Record</label>
        </rules>
        <rules>
            <name>Conditional_Offer_Response_Record</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Cancelled.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ConditionalOfferResponseRecord</targetReference>
            </connector>
            <label>Conditional Offer Response Record</label>
        </rules>
    </decisions>
    <decisions>
        <name>If_nextACP_exists</name>
        <label>If nextACP exists</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Outcome_Confirmation_No_Next_ACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Next ACP doesnt exists</defaultConnectorLabel>
        <rules>
            <name>Next_ACP_exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NextACPChoice</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outcome_Confirmation</targetReference>
            </connector>
            <label>Next ACP exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Next_ACP_Assign_Check</name>
        <label>Next ACP Assign Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_ACP_to_Outcome_values</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Dont assign next ACP</defaultConnectorLabel>
        <rules>
            <name>Assign_next_ACP_to_self</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>How_do_you_want_manage_the_following_ACP</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>No_further_action</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>I_would_like_to</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Assign_the_ACP_to_myself</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_next_ACP_to_list</targetReference>
            </connector>
            <label>Assign next ACP to self</label>
        </rules>
        <rules>
            <name>Assign_next_ACP_to_queue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>How_do_you_want_manage_the_following_ACP</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>No_further_action</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>I_would_like_to</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Route_the_ACP_to_the_queue</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_next_ACP_to_list1</targetReference>
            </connector>
            <label>Assign next ACP to queue</label>
        </rules>
    </decisions>
    <description>Screen Flow for Outcome Path &apos;Cancelled&apos;</description>
    <dynamicChoiceSets>
        <name>ACPListForDecision</name>
