                <elementReference>SingleQuoteRecord</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Through_Files</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assign the number of files uploaded to a count variable to check if there is a file upload done</description>
