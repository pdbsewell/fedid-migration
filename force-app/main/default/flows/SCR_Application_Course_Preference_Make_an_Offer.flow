    <decisions>
        <name>Email_Sent_Successfully</name>
        <label>Email Sent Successfully?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Rollback_Offer_Upload</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Email_Sent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Log_Email_Failure</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Success_Screen</targetReference>
            </connector>
            <label>Email Sent</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if there are files uploaded</description>
        <name>Were_Files_Uploaded</name>
        <label>Were Files Uploaded?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Through_Files</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>No</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>FileCount</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>File_Upload</targetReference>
            </connector>
            <label>No</label>
        </rules>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>FileCount</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Opportunity_Record</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>New opportunity record link</description>
        <name>NewOpportunityLinkFormula</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_260})) &amp; {!newOppRecord}</expression>
    </formulas>
    <formulas>
        <description>Grad Research Opportunity Name</description>
        <name>OpportunityName</name>
        <dataType>String</dataType>
        <expression>{!Get_Customer_User.Contact.FirstName}&amp;&apos; &apos;&amp;{!Get_Customer_User.Contact.LastName}&amp;&apos;-GRCAND-&apos;&amp;TEXT(Today())</expression>
    </formulas>
    <interviewLabel>SCR - Application Course Preference - Make an Offer {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Application Course Preference - Make an Offer</label>
    <loops>
        <description>loop through each of the uploaded files</description>
        <name>Loop_Through_Files</name>
        <label>Loop Through Files</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>contentDocumentIds</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Create_ACP_Content_Document_Link</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Create_Quotes</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordCreates>
        <description>Create the content document link between files and opportunity record</description>
        <name>Create_Content_Document_Link_Records</name>
        <label>Create Content Document Link Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Graduate_Research_Email_Template</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Content_Document_Error</targetReference>
        </faultConnector>
        <inputReference>contentDocumentLinkCollections</inputReference>
    </recordCreates>
    <recordCreates>
        <description>Creates the opportunity record.</description>
        <name>Create_Opportunity_Record</name>
        <label>Create Opportunity Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignRecordIdToReference>newOppRecord</assignRecordIdToReference>
        <connector>
            <targetReference>Loop_Through_Files</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_Failure</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Amount</field>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Application_Course_Preference__c</field>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>CloseDate</field>
            <value>
                <elementReference>$System.OriginDateTime</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Destination_Course_Name__c</field>
            <value>
                <elementReference>Get_Application_Course.Course__r.Title__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Name</field>
            <value>
                <elementReference>OpportunityName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <elementReference>Get_Graduate_Research_Record_Type.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Research_Offer_Type__c</field>
            <value>
                <stringValue>Research Admission</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>Identification</stringValue>
            </value>
        </inputAssignments>
        <object>Opportunity</object>
    </recordCreates>
    <recordCreates>
        <name>Create_Quotes</name>
        <label>Create Quotes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_Content_Document_Link_Records</targetReference>
        </connector>
        <faultConnector>
