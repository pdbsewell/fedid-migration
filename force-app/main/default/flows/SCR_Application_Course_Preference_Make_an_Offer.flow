        </connector>
    </assignments>
    <assignments>
        <name>Assign_Quote_Collection</name>
        <label>Assign Quote Collection</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>SingleQuoteRecord.Contact_Access__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Application_Course.Applicant__c</elementReference>
