    <decisions>
        <description>If the platform event is triggered for document request email</description>
        <name>IsTriggeredForDocumentRequest</name>
        <label>IsTriggeredForDocumentRequest</label>
        <locationX>314</locationX>
        <locationY>170</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>DocReq</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Process_Name__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>GRDocumentRequestEmailController</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DocRequestEmail</targetReference>
            </connector>
            <label>DocReq</label>
        </rules>
        <rules>
            <name>Application_Submission</name>
            <conditionLogic>and</conditionLogic>
