    <collectionProcessors>
        <name>Withdrawn_List_of_Values_Dom</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Withdrawn List of Values Dom</label>
        <locationX>314</locationX>
        <locationY>242</locationY>
        <assignNextValueToReference>currentItem_Withdrawn_List_of_Values_Dom</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>ListOfValues</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Withdrawn_List_of_Values_Dom.Outcome_Path__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Withdrawn</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Withdrawn_List_of_Values_Dom.Value__c</leftValueReference>
            <operator>NotEqualTo</operator>
            <rightValue>
                <stringValue>WTHDRN-GTE</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>ListOfValuesTransformInt</targetReference>
        </connector>
    </collectionProcessors>
