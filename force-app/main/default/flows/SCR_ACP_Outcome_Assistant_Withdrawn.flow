            <operator>Assign</operator>
            <value>
                <elementReference>OutcomeStatusSingleRecord.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>UpdateACP</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>currentACP</elementReference>
            </value>
        </assignmentItems>
    </assignments>
