    </collectionProcessors>
    <decisions>
        <name>Check_Citizenship_Classification</name>
        <label>Check Citizenship Classification</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Withdrawn</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>International_ACP</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Citizenship_Classification__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>International</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outcome_Assistant_Withdrawn_Int</targetReference>
            </connector>
            <label>International ACP</label>
        </rules>
        <rules>
            <name>Domestic_ACP</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Citizenship_Classification__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Domestic</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Outcome_Assistant_Withdrawn_Dom</targetReference>
            </connector>
            <label>Domestic ACP</label>
        </rules>
    </decisions>
    <decisions>
        <name>Get_Outcome_Status_Record_Withdrawn</name>
        <label>Get Outcome Status Record Withdrawn</label>
        <locationX>666</locationX>
        <locationY>974</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Withdrawn</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Outcome_Status_Int</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Status_Description_Withdrawn_Int</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Withdrawn.Value__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatusSingleRec_Withdrawn_Int</targetReference>
            </connector>
            <label>Outcome Status Int</label>
        </rules>
        <rules>
            <name>Outcome_Status_Dom</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Status_Description_Withdrawn_Dom</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Withdrawn.Value__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatusSingleRec_Withdrawn_Dom</targetReference>
            </connector>
            <label>Outcome Status Dom</label>
        </rules>
    </decisions>
