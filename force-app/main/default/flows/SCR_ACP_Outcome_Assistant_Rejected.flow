    <collectionProcessors>
        <name>Documentation_Rejected_List</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Documentation Rejected List</label>
        <locationX>314</locationX>
        <locationY>350</locationY>
        <assignNextValueToReference>currentItem_Documentation_Rejected_List</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>ListOfValues</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Documentation_Rejected_List.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_DOC_STATUS</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Documentation_Rejected_List.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>REJECTED</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>DocumentationStatusTransform</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
