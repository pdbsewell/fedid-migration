            <rightValue>
                <stringValue>Rejected</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>OutcomeStatusTransform</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Assign_LOV_Records_Rejected</name>
        <label>Assign LOV Records Rejected</label>
        <locationX>1062</locationX>
        <locationY>1082</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OutcomeStatusRejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Status_Rejected</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Rejected.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OUTCOME_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatAssignedRejected</targetReference>
            </connector>
            <label>OutcomeStatusRejected</label>
        </rules>
        <rules>
            <name>DocumentationStatusRejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Documentation_Status_Rejected</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_LOVs_Rejected.Value__c</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_DOC_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DocumentationStatAssignedRejected</targetReference>
            </connector>
            <label>DocumentationStatusRejected</label>
        </rules>
        <rules>
            <name>EntryQualificationRejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_ENTRY_QUAL_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-QUAL</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EntryQualificationStatAssignedRejected</targetReference>
            </connector>
            <label>EntryQualificationRejected</label>
        </rules>
        <rules>
            <name>OfferResponseRejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OfferResponseStatAssignedRejected</targetReference>
            </connector>
            <label>OfferResponseRejected</label>
        </rules>
        <rules>
            <name>ConditionalOfferResponseRejected</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Rejected.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ConditionalOfferResponseStatAssignedRejected</targetReference>
            </connector>
            <label>ConditionalOfferResponseRejected</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_other_ACPs_exists</name>
        <label>Check if other ACPs exists</label>
        <locationX>314</locationX>
        <locationY>1574</locationY>
        <defaultConnector>
            <targetReference>Outcome_Summary_Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>ACPs dont exist</defaultConnectorLabel>
        <rules>
            <name>ACPs_exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NextACPChoice</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_NextACPsExists</targetReference>
            </connector>
            <label>ACPs exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_previous_Outcome_Status_is_OFFER_COND</name>
        <label>Check if previous Outcome Status is OFFER-COND</label>
        <locationX>314</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Outcome_Assistant_Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not OFFER-COND</defaultConnectorLabel>
        <rules>
            <name>Is_OFFER_COND</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-COND</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-E</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-FY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_LOV__r.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-MC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_current_ACP_Values</targetReference>
            </connector>
            <label>Is OFFER-COND</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_the_value_is_selected</name>
        <label>Check if the value is selected</label>
        <locationX>534</locationX>
        <locationY>2498</locationY>
        <defaultConnector>
            <targetReference>Add_Unselected_Values_to_different_Choice_List</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Value_exists_in_selected_list</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>SelectedACPValueText</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>Loop_Over_Next_ACP_Choice.label</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ACP_ids_to_get_records</targetReference>
            </connector>
            <label>Value exists in selected list</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_UpdateOtherACPs_is_empty</name>
        <label>Check if UpdateOtherACPs is empty</label>
        <locationX>314</locationX>
        <locationY>2882</locationY>
        <defaultConnector>
            <targetReference>Outcome_Confirmation_Rejected</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>UpdateOtherACPs is Empty</defaultConnectorLabel>
        <rules>
            <name>UpdateOtherACPs_is_not_Empty</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>UpdateOtherACPs</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Other_ACP_Records</targetReference>
            </connector>
            <label>UpdateOtherACPs is not Empty</label>
        </rules>
    </decisions>
    <decisions>
        <name>Next_ACP_Assign_Check</name>
        <label>Next ACP Assign Check</label>
        <locationX>314</locationX>
        <locationY>3590</locationY>
        <defaultConnector>
            <targetReference>Assign_Values_for_Rejected_Current_ACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Dont assign next ACP</defaultConnectorLabel>
        <rules>
            <name>Assign_next_ACP_to_self</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>How_do_you_want_manage_the_following_ACP</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>No_further_action</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>I_would_like_to_Route</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Assign_the_ACP_to_myself</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsAdded</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_next_ACP_to_list</targetReference>
            </connector>
            <label>Assign next ACP to self</label>
        </rules>
        <rules>
            <name>Assign_next_ACP_to_queue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>How_do_you_want_manage_the_following_ACP</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>No_further_action</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>I_would_like_to_Route</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Route_the_ACP_to_the_queue</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsAdded</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Add_next_ACP_to_list1</targetReference>
            </connector>
            <label>Assign next ACP to queue</label>
        </rules>
    </decisions>
