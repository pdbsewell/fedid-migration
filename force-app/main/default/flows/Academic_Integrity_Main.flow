<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>assign_NotParent</name>
        <label>assign NotParent</label>
        <locationX>578</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>varParent</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>False</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>screen_Welcom</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>assign_Parent</name>
        <label>assign Parent</label>
        <locationX>314</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>varParent</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>True</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>screen_Welcom</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>decision_Is_Parent</name>
        <label>decision Is Parent</label>
        <locationX>446</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>assign_NotParent</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>out_IsParent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getListChildEnquiry</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>assign_Parent</targetReference>
            </connector>
            <label>Is Parent</label>
        </rules>
    </decisions>
    <decisions>
        <name>decision_Path</name>
        <label>decision Path</label>
        <locationX>446</locationX>
        <locationY>758</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>out_Review_Case</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>navDefault.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>navParent.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>sub_Review</targetReference>
            </connector>
            <label>Review Case</label>
        </rules>
        <rules>
            <name>Out_Conduct_Interview</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>navDefault.fire2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>sub_Interview</targetReference>
            </connector>
            <label>Conduct Interview</label>
        </rules>
        <rules>
            <name>out_Decision</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>navDefault.fire3</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>navParent.fire2</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>navArtificialIntelligence.fire</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>sub_Decision</targetReference>
            </connector>
            <label>Decision</label>
        </rules>
    </decisions>
    <description>Academic Integrity flow for UniCRM.
Landing page flow, calls other AI subflows.</description>
    <environments>Default</environments>
    <interviewLabel>Academic Integrity - Main {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SCR - Academic Integrity - Main</label>
