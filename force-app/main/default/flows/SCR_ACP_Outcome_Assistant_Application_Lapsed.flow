    <collectionProcessors>
        <name>Get_Conditional_Offer_and_Offer_Response_Not_Applic</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Get Conditional Offer and Offer Response Not Applic</label>
        <locationX>50</locationX>
        <locationY>974</locationY>
        <assignNextValueToReference>currentItem_Get_Conditional_Offer_and_Offer_Response_Not_Applic</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>ListOfValues</collectionReference>
        <conditionLogic>(1 OR 2 )AND 3</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Get_Conditional_Offer_and_Offer_Response_Not_Applic.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Get_Conditional_Offer_and_Offer_Response_Not_Applic.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Get_Conditional_Offer_and_Offer_Response_Not_Applic.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>NOT-APPLIC</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Loop_Not_Applic_Status</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Get_Outcome_Status_App_Lapsed</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Get Outcome Status App Lapsed</label>
        <locationX>182</locationX>
        <locationY>134</locationY>
        <assignNextValueToReference>currentItem_Get_Outcome_Status_App_Lapsed</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>ListOfValues</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Get_Outcome_Status_App_Lapsed.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_OUTCOME_STATUS</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Get_Outcome_Status_App_Lapsed.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>AP-LAPSED</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Loop_Outcome_Status_App_Lapsed</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Check_if_Conditional_Offer_or_Offer_Response</name>
        <label>Check if Conditional Offer or Offer Response</label>
        <locationX>402</locationX>
        <locationY>1190</locationY>
        <defaultConnector>
            <targetReference>Loop_Not_Applic_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Conditional_Offer</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Not_Applic_Status.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Conditional_Offer_Assignment_Not_Applicable</targetReference>
            </connector>
            <label>Conditional Offer</label>
        </rules>
        <rules>
            <name>Offer_Response</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Not_Applic_Status.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Offer_Response_Assignment_Not_Applicable</targetReference>
            </connector>
            <label>Offer Response</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_previous_outcome_is_Conditional_Offer</name>
        <label>Check if previous outcome is Conditional Offer</label>
        <locationX>182</locationX>
        <locationY>866</locationY>
        <defaultConnector>
            <targetReference>Add_currentACP_to_UpdateACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Previous_Outcome_is_Conditional_Offer</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-COND</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-E</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-FY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-MC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Conditional_Offer_and_Offer_Response_Not_Applic</targetReference>
            </connector>
            <label>Previous Outcome is Conditional Offer</label>
        </rules>
    </decisions>
