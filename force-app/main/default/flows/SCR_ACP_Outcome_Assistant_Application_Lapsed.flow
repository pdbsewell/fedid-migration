    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Add_currentACP_to_UpdateACP</name>
        <label>Add currentACP to UpdateACP</label>
        <locationX>182</locationX>
        <locationY>1766</locationY>
        <assignmentItems>
            <assignToReference>UpdateACP</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>currentACP</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_ACP_to_Outcome_values_AppLapsed</name>
        <label>Assign ACP to Outcome values AppLapsed</label>
        <locationX>182</locationX>
        <locationY>758</locationY>
        <assignmentItems>
            <assignToReference>currentACP.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>ACPRecord.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>currentACP.Outcome_Status_LOV__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>OutcomeStatusSingleRecord.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_if_previous_outcome_is_Conditional_Offer</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_Empty_values</name>
        <label>Assign Empty values</label>
        <locationX>50</locationX>
