                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Covaxin (Bharat Biotech)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Covishield (AstraZeneca/Serum Institute of India)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Nuvaxovid (Novavax)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Spikevax (Moderna)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Vaxzevria (AstraZeneca)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Gamaleya Sputnik V</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Vaccination_Brand__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>COVID-19 Vaccine Janssen</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Boosted_Brand_Incoming</targetReference>
            </connector>
            <label>Yes - Boosted Brand Is Custom</label>
        </rules>
    </decisions>
