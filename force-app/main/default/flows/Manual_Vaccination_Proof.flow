    <decisions>
        <name>Boosted_Event_DML</name>
        <label>Boosted Event DML</label>
        <locationX>776</locationX>
        <locationY>1982</locationY>
        <defaultConnector>
            <targetReference>Get_Latest_Vaccination_Event</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Boosted - Record Does Not Exist And No Details Provided</defaultConnectorLabel>
        <rules>
            <name>Boosted_Record_Exists_And_Details_Provided</name>
            <conditionLogic>1 AND (2 OR (3 AND 4) OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrandNewOther</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrand</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrand</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>Other</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Is_Boosted_Date_Provided_0</targetReference>
            </connector>
            <label>Boosted - Record Exists And Details Provided</label>
        </rules>
        <rules>
            <name>Boosted_Record_Exists_And_No_Details_Provided</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrand</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Delete_Boosted_Event</targetReference>
            </connector>
            <label>Boosted - Record Exists And No Details Provided</label>
        </rules>
        <rules>
            <name>Boosted_Record_Does_Not_Exist_And_Details_Provided</name>
            <conditionLogic>1 AND (2 OR (3 AND 4) OR 5)</conditionLogic>
            <conditions>
                <leftValueReference>Get_Boosted_Event.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrandNewOther</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrand</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedBrand</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>Other</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>BoostedDate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
