    <dynamicChoiceSets>
        <name>VaccinationBrands</name>
        <dataType>Picklist</dataType>
        <displayField xsi:nil="true"/>
        <object xsi:nil="true"/>
        <picklistField>Vaccination_Brand__c</picklistField>
        <picklistObject>Event</picklistObject>
    </dynamicChoiceSets>
    <formulas>
        <name>FinalizedBoostedBrand</name>
        <dataType>String</dataType>
        <expression>IF(OR(ISNULL({!BoostedBrand}), {!BoostedBrand} == &apos;Other&apos;), {!BoostedBrandNewOther}, {!BoostedBrand})</expression>
    </formulas>
    <formulas>
        <name>FinalizedFullyVaccinatedBrand</name>
        <dataType>String</dataType>
        <expression>IF(OR(ISNULL({!FullyVaccinatedBrand}), {!FullyVaccinatedBrand} == &apos;Other&apos;), {!FullyVaccinatedBrandNewOther}, {!FullyVaccinatedBrand})</expression>
    </formulas>
