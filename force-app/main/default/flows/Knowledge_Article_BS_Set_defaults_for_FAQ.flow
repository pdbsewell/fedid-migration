<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Update_FAQ_Channel</name>
        <label>Update FAQ Channel</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.IsVisibleInPkb</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.IsVisibleInCsp</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <description>Migrated from the Knowledge Channel process builder
Set defaults for FAQ</description>
    <environments>Default</environments>
    <interviewLabel>Knowledge/Article : BS : Set defaults for FAQ {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Knowledge/Article : BS : Set defaults for FAQ</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_FAQ_Channel</targetReference>
        </connector>
        <filterFormula>AND(
   {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false,
   CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;Knowledge_Article_BS_Set_defaults_for_FAQ,&quot;) = false,
   OR ({!$Record.IsVisibleInCsp} = false,
          {!$Record.IsVisibleInPkb} = false),
   {!$Record.RecordType.DeveloperName} = &apos;FAQ&apos;
)</filterFormula>
        <object>Knowledge_Article__kav</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>KnowledgeArticleRecord</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>KnowledgeArticle</objectType>
    </variables>
</Flow>
