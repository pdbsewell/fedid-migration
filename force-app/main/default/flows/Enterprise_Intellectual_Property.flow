    <screens>
        <name>screen_Enquiry_Details</name>
        <label>screen Enquiry Details</label>
        <locationX>50</locationX>
        <locationY>1982</locationY>
        <allowBack>true</allowBack>
        <allowFinish>false</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>dtxt_EnquiryDetails</name>
            <fieldText>&lt;p&gt;&lt;b style=&quot;font-size: 18px; color: rgb(0, 109, 174);&quot;&gt;An IP approval request is in-progress with Monash Innovation&lt;/b&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 16px;&quot;&gt;Approval Request Reference Number: &lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 255); font-size: 16px;&quot;&gt;{!get_IP_Enquiry.CaseNumber}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;i style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;Please reach out to &lt;/i&gt;&lt;b style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt;&lt;i&gt;Monash Innovation team&lt;/i&gt;&lt;/b&gt;&lt;i style=&quot;color: rgb(200, 0, 143); font-size: 14px;&quot;&gt; for any changes or updates to the above request&lt;/i&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;{!tt_PreviousAns}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
