    <decisions>
        <description>Decision on Create or Edit Opportunity Answers</description>
        <name>dec_Create_or_Edit</name>
        <label>dec Create or Edit</label>
        <locationX>446</locationX>
        <locationY>1862</locationY>
        <defaultConnector>
            <targetReference>screen_Questionnaire_Details</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>decOut Edit Questionnaire</defaultConnectorLabel>
        <rules>
            <name>decOut_Existing_Enquiry</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_IP_Enquiry</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Enquiry_Details</targetReference>
            </connector>
            <label>decOut Existing Enquiry</label>
        </rules>
        <rules>
            <name>decOut_Create_Questionnaire</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>getList_Opportunity_IP_Answers</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_New_IP_Questionnaire</targetReference>
            </connector>
            <label>decOut Create Questionnaire</label>
        </rules>
    </decisions>
    <decisions>
        <description>Decision to check is IP Enquiry required</description>
        <name>dec_IP_Enquiry_Required</name>
        <label>dec IP Enquiry Required</label>
        <locationX>446</locationX>
        <locationY>4262</locationY>
        <defaultConnectorLabel>decOut No IP Enquiry</defaultConnectorLabel>
        <rules>
            <name>decOut_Create_IP_Enquiry</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>varA01.Rationale__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Yes</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varA02.Rationale__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_Yes</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varA03c.Rationale__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_ProvenConcept</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>varA03c.Rationale__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>c_WorkingPrototype</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>flow_Create_IP_Enquiry</targetReference>
            </connector>
            <label>decOut Create IP Enquiry</label>
        </rules>
    </decisions>
