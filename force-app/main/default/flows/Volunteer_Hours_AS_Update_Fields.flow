    <decisions>
        <description>Is End Date Blank?</description>
        <name>Is_End_Date_Blank</name>
        <label>Is End Date Blank</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Is_Planned_Start_Date_Time_Blank</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>End_Date_is_blank</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.End_Date__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_End_Date</targetReference>
            </connector>
            <label>End Date is blank</label>
        </rules>
    </decisions>
    <decisions>
        <description>Is Planned Start Date Time Blank?</description>
