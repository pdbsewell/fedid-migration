<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Check Communication Preference for Phone, Email &amp; Address.</description>
        <name>Check_Communication_Preference</name>
        <label>Check Communication Preference</label>
        <locationX>182</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>UpdateCommPreference</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.ucinn_ascendv2__Phone_1_Type__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue></stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ucinn_ascendv2__Email_1_Type__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue></stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Address_1_Source__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue></stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateEmailSource</targetReference>
            </connector>
            <label>UpdateCommPreference</label>
        </rules>
    </decisions>
    <description>Flow to update communication preference for Alumni Update Your Details Formstack form.</description>
    <environments>Default</environments>
    <formulas>
        <name>EmailFlag</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.Email_Opt_Out__c} = True, False, True)</expression>
    </formulas>
    <formulas>
        <name>MailFlag</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.Direct_Mail_Opt_Out__c} = True, False, True)</expression>
    </formulas>
    <formulas>
        <name>PhoneFlag</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.Call_Opt_Out__c} = True, False, True)</expression>
    </formulas>
    <formulas>
        <name>SMSFlag</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.SMS_Opt_Out__c} = True, False, True)</expression>
    </formulas>
    <interviewLabel>Interim : BS : Set Comm Preference {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Interim : BS : Set Comm Preference</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Update Values for Address received from UYD form.</description>
        <name>UpdateAddressSource</name>
        <label>UpdateAddressSource</label>
        <locationX>50</locationX>
        <locationY>611</locationY>
        <connector>
            <targetReference>UpdateOptInOptOutPref</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>ucinn_ascendv2__Address_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Private</stringValue>
            </value>
        </filters>
        <filters>
            <field>ucinn_ascendv2__Address_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Business</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Address_1_Is_Active__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Address_1_Source__c</field>
            <value>
                <stringValue>Contact Supplied</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update Values for Email received from UYD form.</description>
        <name>UpdateEmailSource</name>
        <label>UpdateEmailSource</label>
        <locationX>50</locationX>
        <locationY>395</locationY>
        <connector>
            <targetReference>UpdatePhoneSource</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>ucinn_ascendv2__Email_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Private</stringValue>
            </value>
        </filters>
        <filters>
            <field>ucinn_ascendv2__Email_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Business</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Email_1_Is_Active__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Email_Source__c</field>
            <value>
                <stringValue>Contact Supplied</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update OptIn/OptOut values received from UYD form.</description>
        <name>UpdateOptInOptOutPref</name>
        <label>UpdateOptInOptOutPref</label>
        <locationX>50</locationX>
        <locationY>719</locationY>
        <inputAssignments>
            <field>Call_Opt_Out__c</field>
            <value>
                <elementReference>PhoneFlag</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Direct_Mail_Opt_Out__c</field>
            <value>
                <elementReference>MailFlag</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Email_Opt_Out__c</field>
            <value>
                <elementReference>EmailFlag</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SMS_Opt_Out__c</field>
            <value>
                <elementReference>SMSFlag</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <description>Update Values for Phone received from UYD form.</description>
        <name>UpdatePhoneSource</name>
        <label>UpdatePhoneSource</label>
        <locationX>50</locationX>
        <locationY>503</locationY>
        <connector>
            <targetReference>UpdateAddressSource</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>ucinn_ascendv2__Phone_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Private</stringValue>
            </value>
        </filters>
        <filters>
            <field>ucinn_ascendv2__Phone_1_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Business</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Phone_1_Is_Active__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Phone_Source__c</field>
            <value>
                <stringValue>Contact Supplied</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Communication_Preference</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false &amp;&amp; {!$Record.RecordType.DeveloperName} = &apos;Update_Your_Details&apos; &amp;&amp; {!$Profile.Id} = &apos;00e0I000002EBdAQAW&apos;</filterFormula>
        <object>ucinn_ascendv2__Interim__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
