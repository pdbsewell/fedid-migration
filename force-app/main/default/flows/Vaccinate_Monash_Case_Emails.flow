    <decisions>
        <name>Email_Selector</name>
        <label>Email Selector</label>
        <locationX>710</locationX>
        <locationY>288</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Email_Confirmation_Students_Fully_Vaccinated</name>
            <conditionLogic>1 AND 2</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Vaccinate Monash - Students</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Outcome__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>COVID-19 Fully Vaccinated</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Email_Student_Fully_Vaccinated</targetReference>
            </connector>
            <label>Email Confirmation - Students Fully Vaccinated</label>
        </rules>
