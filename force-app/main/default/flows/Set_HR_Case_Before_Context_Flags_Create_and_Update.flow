                <rightValue>
                    <stringValue>unityconnection@monash.edu.au</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Case_Channel_Voice_Mail</targetReference>
            </connector>
            <label>Yes - Voice Mail</label>
        </rules>
    </decisions>
    <decisions>
        <name>Set_Escalation_Flags</name>
