    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>IF( CONTAINS([Case].SuppliedEmail, &quot;@monash.edu&quot;), &quot;&quot;,
IF(CONTAINS(LOWER([Case].Subject), &quot;assessments and results&quot;), &quot;Exams, Assessments, &amp; Assignments&quot;,
IF(CONTAINS(LOWER([Case].Subject), &quot;fees&quot;), &quot;Fees &amp; Financial Matters&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;graduations and documents&quot;), &quot;Graduations&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;it support (eSolutions)&quot;), &quot;eSolutions&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;library&quot;), &quot;Library&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;parking and transport&quot;), &quot;Parking &amp; Transport&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;timetables&quot;), &quot;Timetable&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;domestic applicants&quot;), &quot;Course Enquiry&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;international applicants&quot;), &quot;Course Enquiry&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;enrolments and course advice&quot;), &quot;Course Advice&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;enrolments&quot;), &quot;Enrolment - Current Course&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;loans and grants&quot;), &quot;Loans and Grants&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;visa/coe&quot;), &quot;International Visa&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;covid-19&quot;), &quot;Campus Services&quot;, 
IF(CONTAINS(LOWER([Case].Subject), &quot;other&quot;), &quot;&quot;, &quot;General Services&quot; )
)))))))))))))))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_43_myRule_42_A1_4169247467</name>
        <dataType>String</dataType>
        <expression>IF( CONTAINS({!myVariable_current.SuppliedEmail}, &quot;@monash.edu&quot;), &quot;&quot;,
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;assessments and results&quot;), &quot;Exams, Assessments, &amp; Assignments&quot;,
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;fees&quot;), &quot;Fees &amp; Financial Matters&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;graduations and documents&quot;), &quot;Graduations&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;it support (eSolutions)&quot;), &quot;eSolutions&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;library&quot;), &quot;Library&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;parking and transport&quot;), &quot;Parking &amp; Transport&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;timetables&quot;), &quot;Timetable&quot;, 
IF(CONTAINS(LOWER({!myVariable_current.Subject}), &quot;domestic applicants&quot;), &quot;Course Enquiry&quot;, 
