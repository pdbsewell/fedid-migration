<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>The agent hasn&apos;t been notified that the application is accepted by the applicant. Write a log message and link it to the application.</description>
        <name>FailedtoSendEmailtoAgent</name>
        <label>Failed to Send Email to Agent</label>
        <locationX>314</locationX>
        <locationY>863</locationY>
        <actionName>Nebula__FlowRecordLogEntry</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>NotifyGroup</targetReference>
        </connector>
        <dataTypeMappings>
            <typeName>T__record</typeName>
            <typeValue>Application__c</typeValue>
        </dataTypeMappings>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>faultMessage</name>
            <value>
                <elementReference>LogMessageBody</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>flowName</name>
            <value>
                <elementReference>c_Flowname</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>message</name>
            <value>
                <elementReference>LogMessageTitle</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>record</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>saveLog</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>tagsString</name>
            <value>
                <elementReference>c_LogTag</elementReference>
            </value>
        </inputParameters>
        <nameSegment>Nebula__FlowRecordLogEntry</nameSegment>
        <offset>0</offset>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <actionCalls>
        <description>Send an email and log the fact against the application</description>
        <name>SendEmailtoAgent</name>
        <label>Send Email to Agent</label>
        <locationX>50</locationX>
        <locationY>647</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <faultConnector>
            <targetReference>FaultMessage</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>senderType</name>
            <value>
                <stringValue>OrgWideEmailAddress</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderAddress</name>
            <value>
                <elementReference>c_FromAddress</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>relatedRecordId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>recipientId</name>
            <value>
                <elementReference>AgentContactId</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>logEmailOnSend</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailTemplateId</name>
            <value>
                <elementReference>EmailTemplateId</elementReference>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign the flow generated error message</description>
        <name>FaultMessage</name>
        <label>Fault Message</label>
        <locationX>314</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>LogMessageBody</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>LogMessageTitle</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Failed to sent an application status change notification to Agent</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>FailedtoSendEmailtoAgent</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Populate the various error messages</description>
        <name>FaultMessage2</name>
        <label>Fault Message 2</label>
        <locationX>578</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>LogMessageBody</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Check that the Agent user is active and linked to a Contact</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>LogMessageTitle</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>{!AgentName} [{!AgentUserId}] appears to be invalid</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>FailedtoSendEmailtoAgent</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>c_AlertType</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Admissions_Alert</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_CustomNotification</name>
        <dataType>String</dataType>
        <value>
            <stringValue>UniCRM_Alert_Notification</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_EmailTemplateName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>AP_Agent_Notfication</stringValue>
        </value>
    </constants>
    <constants>
        <description>The API name of this flow</description>
        <name>c_Flowname</name>
        <dataType>String</dataType>
        <value>
            <stringValue>ApplicationAUEmailAgent</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_FromAddress</name>
        <dataType>String</dataType>
        <value>
            <stringValue>future@f.e.monash.edu</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_LogTag</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Agent Portal</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_NotificationAlertTyoe</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Admissions_Alert</stringValue>
        </value>
    </constants>
    <constants>
        <name>c_NotificationGroup</name>
        <dataType>String</dataType>
        <value>
            <stringValue>WR_Central_Admissions_Exception</stringValue>
        </value>
    </constants>
    <decisions>
        <description>The application owner must be active and have a linked contact record.</description>
        <name>CheckAgentStatus</name>
        <label>Check Agent Status</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>FaultMessage2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Invalid Agent</defaultConnectorLabel>
        <rules>
            <name>ValidAgent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>AgentIsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>AgentContactId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetEmailTemplate</targetReference>
            </connector>
            <label>Valid Agent</label>
        </rules>
    </decisions>
    <description>Send an email to the agent who owns the application when the applicant approves the application for submission. 
Failures are logged via nebula logger and a custom notification. Successes are logged as activities against the application.</description>
    <environments>Default</environments>
    <interviewLabel>Application : AU : Email Agent {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Application : AU : Email Agent</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get the details of the application owner record. The owner is the Agent we need to email.</description>
        <name>GetAgent</name>
        <label>Get Agent</label>
        <locationX>314</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>CheckAgentStatus</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Owner:User.Id</elementReference>
            </value>
        </filters>
        <object>User</object>
        <outputAssignments>
            <assignToReference>AgentContactId</assignToReference>
            <field>ContactId</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentUserId</assignToReference>
            <field>Id</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentIsActive</assignToReference>
            <field>IsActive</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentName</assignToReference>
            <field>Name</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <name>GetEmailTemplate</name>
        <label>Get Email Template</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>SendEmailtoAgent</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>c_EmailTemplateName</elementReference>
            </value>
        </filters>
        <object>EmailTemplate</object>
        <outputAssignments>
            <assignToReference>EmailTemplateId</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>GetAgent</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;ApplicationAUEmailAgent,&quot;) = false,
ISBLANK( {!$Record.Name}) = False,
{!$Record.Source_System__c}=&apos;AgentPortal&apos;,
TEXT({!$Record.Status__c})=&apos;Applicant Declaration Accepted&apos;)</filterFormula>
        <object>Application__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <description>Make the bell ring for a group of users</description>
        <name>NotifyGroup</name>
        <label>Notify Group</label>
        <locationX>314</locationX>
        <locationY>971</locationY>
        <flowName>SubPushNotification</flowName>
        <inputAssignments>
            <name>CallingFlowName</name>
            <value>
                <elementReference>c_Flowname</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>NotificationAlertType</name>
            <value>
                <elementReference>c_NotificationAlertTyoe</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>NotificationBody</name>
            <value>
                <elementReference>NotificationBody</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>NotificationRecipientGroup</name>
            <value>
                <elementReference>c_NotificationGroup</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>NotificationRecord</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>NotificationTitle</name>
            <value>
                <elementReference>NotificationTitle</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <variables>
        <description>The agent contact record linked to the user</description>
        <name>AgentContactId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Flag that holds the active status of the agent user record</description>
        <name>AgentIsActive</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>AgentName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>AgentUserId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>EmailTemplateId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>The error message to be logged</description>
        <name>LogMessageBody</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>The message to be written to the log entry.</description>
        <name>LogMessageTitle</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>Failed to sent an application status change notification to Agent</stringValue>
        </value>
    </variables>
    <variables>
        <name>NotificationTitle</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>Unable to progress application {!$Record.Name}</stringValue>
        </value>
    </variables>
</Flow>
