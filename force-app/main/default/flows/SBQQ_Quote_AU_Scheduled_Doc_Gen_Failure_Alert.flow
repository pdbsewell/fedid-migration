<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>No point calling the sub flow if document has been generated</description>
        <name>Check_Document_has_been_Generated</name>
        <label>Check Document has been Generated or Error</label>
        <locationX>374</locationX>
        <locationY>276</locationY>
        <defaultConnectorLabel>Document has been generated</defaultConnectorLabel>
        <rules>
            <name>Requested_is_GT_Generated</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Document_Generated_TimeStamp__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>GenerationRequestedDatetime</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Document_Generated_TimeStamp__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Error</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Sub_Status__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>error</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Call_SBQQ_Quote_Sub_Send_Error_Message</targetReference>
            </connector>
            <label>Requested is GT Generated</label>
        </rules>
    </decisions>
    <description>removed &quot;Offer creation/update error&quot; from trigger formula</description>
    <environments>Default</environments>
    <interviewLabel>SBQQ Quote : AU : Scheduled Doc Gen Failure Alert {!$Flow.CurrentDateTime}</interviewLabel>
    <label>SBQQ Quote : AU : Scheduled Doc Gen Failure Alert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c}==FALSE
    &amp;&amp;((( (ISCHANGED({!$Record.Latest_Preview_Generated_Date__c}) || ISCHANGED({!$Record.Document_Generated_TimeStamp__c} ))
&amp;&amp; ({!$Record.Latest_Preview_Generated_Date__c}+10/1440) &gt; {!$Record.Document_Generated_TimeStamp__c}  ||(
ISNULL({!$Record.Latest_Preview_Generated_Date__c})
||{!$Record.Latest_Preview_Generated_Date__c} &lt; {!$Record.Document_Generated_TimeStamp__c} )
) )
|| (ISCHANGED({!$Record.Clauses_Attached_TimeStamp__c}) &amp;&amp; 
(({!$Record.Latest_Preview_Generated_Date__c}+10/1440) &gt; {!$Record.Clauses_Attached_TimeStamp__c}  || ( ISNULL({!$Record.Latest_Preview_Generated_Date__c})
||{!$Record.Latest_Preview_Generated_Date__c} &lt; {!$Record.Clauses_Attached_TimeStamp__c} )
))

||  ((ISCHANGED({!$Record.Sub_Status__c}) &amp;&amp;
                (ISPICKVAL({!$Record.Sub_Status__c}, &quot;DocuSign Error&quot;) || ISPICKVAL({!$Record.Sub_Status__c},&quot;Conga Error&quot;)
|| ISPICKVAL({!$Record.Sub_Status__c}, &quot;APEX Doc. Gen/Save Error&quot;) || ISPICKVAL({!$Record.Sub_Status__c},&quot;Portal doc generation error&quot;) 
|| ISPICKVAL({!$Record.Sub_Status__c},&quot;Offer regeneration Error&quot;) 
))
)
)</filterFormula>
        <object>SBQQ__Quote__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <name>Wait_10_minutes</name>
            <connector>
                <targetReference>Check_Document_has_been_Generated</targetReference>
            </connector>
            <label>Wait 10 minutes after Date Document Generated</label>
            <offsetNumber>10</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <recordField>LastModifiedDate</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <description>Calls Subflow</description>
        <name>Call_SBQQ_Quote_Sub_Send_Error_Message</name>
        <label>Call SBQQ Quote : Sub : Send Error Message</label>
        <locationX>242</locationX>
        <locationY>384</locationY>
        <flowName>SBQQ_Quote_Sub_Send_Error_Message</flowName>
        <inputAssignments>
            <name>QuoteId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
    </subflows>
    <variables>
        <name>AdmissionsTeamEmails</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>GenerationRequestedDatetime</name>
        <dataType>DateTime</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <elementReference>$Record.Preview_Requested_TimeStamp__c</elementReference>
        </value>
    </variables>
</Flow>
