    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Get_RecipientID</name>
        <label>Get RecipientID</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>RecipientID</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>$Record.LastModifiedById</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_Email_Message_Status</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>FlowName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Email Message : AS : Process Messages &amp; Case Management</stringValue>
        </value>
    </constants>
    <decisions>
        <name>Check_Alumni_Case_Email</name>
        <label>Check Alumni Case Email</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Inbound_Email_For_Referred_Case</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Alumni Case Email Closed</defaultConnectorLabel>
        <rules>
            <name>Alumni_Case_Email_Reopened</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Alumni Engagement</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.IsClosed</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_The_Status_From_Closed_Completed_To_Open</targetReference>
            </connector>
            <label>Alumni Case Email Reopened</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Email_Is_Read_myResearch_SEBS</name>
        <label>Check Email Is Read myResearch &amp; SEBS</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Incoming_Email_For_Case_Update</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Email Is Not Read</defaultConnectorLabel>
        <rules>
            <name>Email_Is_Read</name>
            <conditionLogic>1 AND (2 OR 3)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>3</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEBS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEBS Placements</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Incoming_Email_myResearch_SEBS</targetReference>
            </connector>
            <label>Email Is Read</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Email_Message_Open_Status</name>
        <label>Check Email Message Open Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Email_Is_Read_myResearch_SEBS</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Status Is Not Open</defaultConnectorLabel>
        <rules>
            <name>Status_Is_Open</name>
            <conditionLogic>1 AND (2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Referred</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>HR</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Email_Received_For_Open_Status</targetReference>
            </connector>
            <label>Status Is Open</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Email_Message_Status</name>
        <label>Check Email Message Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_If_Enquiry_Is_Valid_To_Reopen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Others</defaultConnectorLabel>
        <rules>
            <name>Email_Message_Approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Is_Approved__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
