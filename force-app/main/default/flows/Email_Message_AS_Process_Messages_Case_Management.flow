                    <stringValue>Referred to Project</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Awaiting approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Quote Sent</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Case_Status_Email_Update_To_Updated_True</targetReference>
            </connector>
            <label>Is Incoming Email</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Incoming_Email_For_Case_Update</name>
        <label>Check Incoming Email For Case Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Get_RecipientID</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Other</defaultConnectorLabel>
        <rules>
            <name>Received_Incoming_Email_Monash_Connect_Enquiry</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Monash_Connect_Enquiry</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Case_When_Received_Email_Case_Monash_Connect_Enquiry</targetReference>
            </connector>
            <label>Received Incoming Email Monash Connect Enquiry</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_User_Email_Case_Type</name>
        <label>Check User Email Case Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Alumni_Case_Email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>User Email Case Closed</defaultConnectorLabel>
        <rules>
            <name>User_Email_Case_Reopen</name>
            <conditionLogic>(1 OR 4) AND 2 AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEBS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.IsClosed</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Incoming</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Parent.RecordType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>SEBS Placements</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Field_Email_Is_Received</targetReference>
            </connector>
            <label>User Email Case Reopen</label>
        </rules>
    </decisions>
    <description>Migrated from: 
- Display Email Icon for Incoming Email and change status to Updated - myResearch, SEBS
- Email Notification on case status
- Notify User for Email received to a closed case 1 SEBS
- Reopen Closed Alumni Case if Email is received
- Unread email alert - OFF
- Unread email alert - ON
- Update a Referred Case When Inbound Email Recieved
- Update the Email Received for an Open Status
- Update Unread Email Message after email is read 2 myResearch, SEBS
- [Standard Enquiry] Email Received - Date/Time
- AA - Email Message Processes
- Email Approval Request Notification
- Incoming Email Reopen Enquiry Process</description>
