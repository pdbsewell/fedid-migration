    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assign field values from GET records</description>
        <name>Assign_values</name>
        <label>Assign values</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>crmApplicationId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Application_Record.Name</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>externalReferenceId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Application_Record.External_Reference_Id__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>crmApplicantId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Get_Applicant_Record.CRM_Id__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Validate_Fields</targetReference>
        </connector>
    </assignments>
    <constants>
        <description>Flow name</description>
        <name>c_FlowAPIName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Delay OES Notification</stringValue>
        </value>
    </constants>
    <constants>
        <description>INFO type constant</description>
        <name>c_INFO</name>
        <dataType>String</dataType>
        <value>
            <stringValue>INFO</stringValue>
        </value>
    </constants>
    <constants>
        <description>Warning type constant</description>
        <name>c_WARN</name>
        <dataType>String</dataType>
        <value>
            <stringValue>WARN</stringValue>
        </value>
    </constants>
    <constants>
        <description>Scenario for the flow</description>
        <name>scenario</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Obd ACP ADM Key Notification</stringValue>
        </value>
    </constants>
    <constants>
        <description>Work flow status constant defaulted to true</description>
        <name>workFlowStatus</name>
        <dataType>String</dataType>
        <value>
            <stringValue>true</stringValue>
        </value>
    </constants>
    <constants>
        <description>work flow type constant</description>
        <name>workFlowType</name>
        <dataType>String</dataType>
        <value>
            <stringValue>ACP ADM Key Generation</stringValue>
        </value>
    </constants>
    <decisions>
        <description>Validate fields before creating Obd ACP Platform event</description>
        <name>Validate_Fields</name>
        <label>Validate Fields</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Invalid_fields</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>crmApplicantId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>crmApplicationId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>externalReferenceId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Warning_Log_Entry</targetReference>
            </connector>
            <label>Invalid fields</label>
        </rules>
        <rules>
            <name>Valid_Fields</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>crmApplicantId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>crmApplicationId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>externalReferenceId</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Obd_ACP_Platform_Event_Create</targetReference>
            </connector>
            <label>Valid Fields</label>
        </rules>
    </decisions>
    <description>Delayed flow to notify OES after ADM Key Generation</description>
    <environments>Default</environments>
    <interviewLabel>ACP: PE : Notify OES On ADM Key Generation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>ACP: PE : Notify OES On ADM Key Generation</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <description>Create Obd ACP Platform Event</description>
        <name>Obd_ACP_Platform_Event_Create</name>
        <label>Obd ACP Platform Event Create</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Info_Log_Entry</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Obd_ACP_Platform_event_create_Fault</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Workflow_Status__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Workflow_Type__c</field>
            <value>
                <stringValue>ACP ADM Key Generation</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>crmApplicantId__c</field>
            <value>
                <elementReference>$Record.Applicant__r.CRM_Id__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>crmApplicationId__c</field>
            <value>
                <elementReference>$Record.Application__r.Name</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>externalReferenceId__c</field>
            <value>
                <elementReference>$Record.Application__r.External_Reference_Id__c</elementReference>
            </value>
        </inputAssignments>
        <object>ObdACP__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <description>Get related Applicant Record</description>
        <name>Get_Applicant_Record</name>
        <label>Get Applicant Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_values</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Get_Applicant_Fault_Path</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Applicant__r.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Contact</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Get related Application Record</description>
        <name>Get_Application_Record</name>
        <label>Get Application Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Applicant_Record</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Get_Application_Fault_Path</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Application__r.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Application__c</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>External_Reference_Id__c</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>AND({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = false,  {!$Record.Application__r.Source_System__c}==&apos;OES&apos;  ,NOT(ISBLANK({!$Record.Callista_Unique_Key_ADM__c})))</filterFormula>
        <object>Application_Course_Preference__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <scheduledPaths>
            <name>Delay_by_10_minutes</name>
            <connector>
                <targetReference>Get_Application_Record</targetReference>
            </connector>
            <label>Delay by 10 minutes</label>
            <maxBatchSize>10</maxBatchSize>
            <offsetNumber>10</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <timeSource>RecordTriggerEvent</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <description>Info template to log Obd ACP PE</description>
        <name>InfoTextTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Platform Event: ObdACP__e             
crmApplicantId__c : {!crmApplicantId}
crmApplicationId__c :  {!crmApplicationId}
externalReferenceId__c :{!externalReferenceId}
Workflow_Type__c :  {!workFlowType}
Workflow_Status__c :{!workFlowStatus}</text>
    </textTemplates>
    <textTemplates>
        <description>Warning template to log when the required fields to create Obd ACP event are not present on the ACP record</description>
        <name>WarnTextTemplate</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Either Application__r.External_Reference_Id__c OR Application__r.Name OR Applicant__r.CRM_Id__c is blank</text>
    </textTemplates>
    <variables>
        <description>Store ApplicantId</description>
        <name>crmApplicantId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>Store Application Id</description>
        <name>crmApplicationId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>Store external Ref Id</description>
        <name>externalReferenceId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>Info Title for the log message</description>
        <name>InfoTitle</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>OES Obd ACP Event Notification for {!crmApplicationId}</stringValue>
        </value>
    </variables>
</Flow>
