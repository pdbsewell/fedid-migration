    <actionCalls>
        <description>Log warning message when one or more fields that are required to create a PE are not present on the record</description>
        <name>Warning_Log_Entry</name>
        <label>Warning Log Entry</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>Nebula__FlowLogEntry</actionName>
        <actionType>apex</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>faultMessage</name>
            <value>
                <elementReference>WarnTextTemplate</elementReference>
            </value>
        </inputParameters>
