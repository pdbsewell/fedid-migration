<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <description>Mark Copado User Story as Ready to Promote when the status field is &apos;Ready for Integration&apos;, &apos;Ready for Regression&apos; or &apos;Ready for Release&apos;</description>
    <environments>Default</environments>
    <interviewLabel>Mark US as Ready to Promote {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Mark US as Ready to Promote</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <description>Mark the User Story as Ready to Promote when the User Story in jira is updated to Ready for Integration or Ready for Regression or Ready for Release</description>
        <name>Mark_User_Story_as_Ready_to_Promote</name>
        <label>Mark User Story as Ready to Promote</label>
        <locationX>176</locationX>
        <locationY>287</locationY>
        <inputAssignments>
            <field>copado__Promote_Change__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Mark_User_Story_as_Ready_to_Promote</targetReference>
        </connector>
        <filterFormula>ISPICKVAL({!$Record.copado__Status__c}, &quot;Ready for Integration&quot;) || ISPICKVAL({!$Record.copado__Status__c}, &quot;Ready for Regression&quot;) || ISPICKVAL({!$Record.copado__Status__c}, &quot;READY FOR RELEASE&quot;)</filterFormula>
        <object>copado__User_Story__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Obsolete</status>
</Flow>
