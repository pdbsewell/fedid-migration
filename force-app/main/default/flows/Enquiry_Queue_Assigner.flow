    <decisions>
        <name>Admissions_Enquiry_Type_check</name>
        <label>Admissions Enquiry Type check</label>
        <locationX>1766</locationX>
        <locationY>395</locationY>
        <defaultConnector>
            <targetReference>Get_SRA_MU_Docs_Queue</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Future_Course</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Future Course</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_SRA_MU_Docs_Queue</targetReference>
            </connector>
            <label>Future Course</label>
        </rules>
    </decisions>
    <decisions>
        <name>Category_Level_1_check</name>
        <label>Category Level 1 check</label>
        <locationX>1766</locationX>
        <locationY>695</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Document_submission</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Document Submission</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Category_Level_2_check</targetReference>
            </connector>
            <label>Document submission</label>
        </rules>
        <rules>
            <name>Request</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Request</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Owner_for_Cat1_Request</targetReference>
            </connector>
            <label>Request</label>
        </rules>
    </decisions>
    <decisions>
        <name>Category_Level_2_check</name>
        <label>Category Level 2 check</label>
        <locationX>1370</locationX>
        <locationY>803</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Agent_Nomination_Or_Delegation_Form</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Agent nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Delegate nomination form</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_SRA_IA_IRS_Fees_owner</targetReference>
            </connector>
            <label>Agent Nomination Or Delegation Form</label>
        </rules>
        <rules>
            <name>Non_Agent_Nomination_and_Delegation_Form</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Agent nomination form</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_2__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Delegate nomination form</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Owner_for_Cat2_Non_Document_Submissions</targetReference>
            </connector>
            <label>Non Agent Nomination and Delegation Form</label>
        </rules>
    </decisions>
    <decisions>
        <name>Enquiry_Type_check</name>
        <label>Enquiry Type check</label>
        <locationX>314</locationX>
        <locationY>395</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Post_Application_Enquiry_Type</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
