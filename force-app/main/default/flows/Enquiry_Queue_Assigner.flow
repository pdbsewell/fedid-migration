        <filterFormula>AND(NOT({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c}), TEXT({!$Record.Origin})=&apos;Web - Agent Portal&apos;)</filterFormula>
        <object>Case</object>
