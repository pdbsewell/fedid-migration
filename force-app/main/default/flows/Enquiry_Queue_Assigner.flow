                <rightValue>
                    <stringValue>Post Application</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Post_Application_Queue</targetReference>
            </connector>
            <label>Post Application Enquiry Type</label>
        </rules>
        <rules>
            <name>Late_Registration_International_Enquiry_Type</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Late Registration - International</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Late_Registration_Queue</targetReference>
            </connector>
            <label>Late Registration - International Enquiry Type</label>
        </rules>
    </decisions>
    <decisions>
        <name>Record_Type_check</name>
        <label>Record Type check</label>
        <locationX>1370</locationX>
        <locationY>287</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Post_Application_Enquiry</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Post_Application_Enquiry</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Enquiry_Type_check</targetReference>
            </connector>
            <label>Post Application Enquiry</label>
        </rules>
        <rules>
            <name>MUM_Admissions</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MUM_Admissions</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_MUM_Admissions_Queue</targetReference>
            </connector>
            <label>MUM Admissions</label>
        </rules>
        <rules>
            <name>Admissions</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Admissions</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Admissions_Enquiry_Type_check</targetReference>
            </connector>
            <label>Admissions</label>
        </rules>
    </decisions>
    <description>Flow that helps with assigning the owner matching various factors for Admissions</description>
    <environments>Default</environments>
    <interviewLabel>E {!$Flow.CurrentDateTime}</interviewLabel>
