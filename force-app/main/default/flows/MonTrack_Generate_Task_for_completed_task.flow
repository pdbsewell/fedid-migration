    <description>This generates new task for Call Attempts which call outcome is No Answer or Voicemail left</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>IF(ISPICKVAL([Task].Call_Attempt__c, &apos;First Attempt&apos;), &apos;Second Attempt&apos;,
IF(ISPICKVAL([Task].Call_Attempt__c, &apos;Second Attempt&apos;), &apos;Third Attempt&apos;,&apos;Fourth Attempt&apos;)
)

 </stringValue>
            </value>
        </processMetadataValues>
        <name>formula_3_myRule_1_A1_9952513355</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!myVariable_current.Call_Attempt__c}, &apos;First Attempt&apos;), &apos;Second Attempt&apos;,
IF(ISPICKVAL({!myVariable_current.Call_Attempt__c}, &apos;Second Attempt&apos;), &apos;Third Attempt&apos;,&apos;Fourth Attempt&apos;)
)</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>IF(CONTAINS(TEXT([Task].Call_Attempt__c),&apos;First&apos;),&apos;Call - Second Attempt&apos;,
IF(CONTAINS(TEXT([Task].Call_Attempt__c),&apos;Second&apos;),&apos;Call - Third Attempt&apos;,
&apos;Call - Fourth Attempt&apos;
)
)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_4_myRule_1_A1_7518576700</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS(TEXT({!myVariable_current.Call_Attempt__c}),&apos;First&apos;),&apos;Call - Second Attempt&apos;,
IF(CONTAINS(TEXT({!myVariable_current.Call_Attempt__c}),&apos;Second&apos;),&apos;Call - Third Attempt&apos;,
&apos;Call - Fourth Attempt&apos;
)
)</expression>
    </formulas>
