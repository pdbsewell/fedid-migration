    <collectionProcessors>
        <name>Filter_Completed_ACPs</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter Completed ACPs</label>
        <locationX>266</locationX>
        <locationY>863</locationY>
        <assignNextValueToReference>currentItem_Filter_Completed_ACPs</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_ACP_Records</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_Completed_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Completed</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Sort_Completed_ACPs</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Filter_In_Progress_ACPs</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter In Progress ACPs</label>
        <locationX>398</locationX>
        <locationY>647</locationY>
        <assignNextValueToReference>currentItem_Filter_In_Progress_ACPs</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_ACP_Records</collectionReference>
        <conditionLogic>or</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Pending</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>In Progress</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>Released</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_In_Progress_ACPs.Workflow_Status__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>On Hold</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Check_if_In_progress_ACPs_exists</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Sort_Completed_ACPs</name>
        <elementSubtype>SortCollectionProcessor</elementSubtype>
        <label>Sort Completed ACPs</label>
        <locationX>266</locationX>
        <locationY>971</locationY>
        <collectionProcessorType>SortCollectionProcessor</collectionProcessorType>
        <collectionReference>Filter_Completed_ACPs</collectionReference>
        <connector>
            <targetReference>Get_MUDocs_Queue_Id</targetReference>
        </connector>
        <limit>1</limit>
        <sortOptions>
            <doesPutEmptyStringAndNullFirst>false</doesPutEmptyStringAndNullFirst>
            <sortField>LastModifiedDate</sortField>
            <sortOrder>Desc</sortOrder>
        </sortOptions>
    </collectionProcessors>
    <decisions>
        <name>Check_if_ACP_records_exists</name>
        <label>Check if ACP records exists</label>
        <locationX>224</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Get_ACP_Records</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>ACP records not found</defaultConnectorLabel>
        <rules>
            <name>ACP_records_found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecordsFetched</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_for_each_ACP</targetReference>
            </connector>
            <label>ACP records found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_if_In_progress_ACPs_exists</name>
        <label>Check if In progress ACPs exists</label>
        <locationX>398</locationX>
        <locationY>755</locationY>
        <defaultConnectorLabel>In Progress ACPs Exists</defaultConnectorLabel>
        <rules>
            <name>No_In_progress_ACPs</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Filter_In_Progress_ACPs</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Filter_Completed_ACPs</targetReference>
            </connector>
            <label>No In progress ACPs</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check if release reason exist</description>
        <name>Check_Workflow_Status</name>
        <label>Check Workflow Status</label>
        <locationX>402</locationX>
        <locationY>647</locationY>
        <defaultConnector>
            <targetReference>Loop_for_each_ACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Release_Reason_Blank</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_for_each_ACP.Workflow_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>On Hold</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ACP_Values_On_Hold</targetReference>
            </connector>
            <label>On Hold</label>
        </rules>
        <rules>
            <name>Released</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_for_each_ACP.Release_Reason__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_for_each_ACP.Workflow_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Released</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_ACP_Values</targetReference>
            </connector>
            <label>Released</label>
        </rules>
    </decisions>
    <description>Flow to release ACPs on hold when Email Message is received.</description>
    <environments>Default</environments>
    <interviewLabel>Email Message : AI : Release ACP On Hold {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Email Message : AI : Release ACP On Hold</label>
    <loops>
        <name>Loop_Completed_Sort</name>
        <label>Loop Completed Sort</label>
        <locationX>266</locationX>
        <locationY>1187</locationY>
        <collectionReference>Filter_Completed_ACPs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_to_MUDocs</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_ACP_to_Release</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_for_each_ACP</name>
        <label>Loop for each ACP</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <collectionReference>ACPRecordsFetched</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Check_Workflow_Status</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_ACP_to_Release</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>ACP records related to Application</description>
        <name>Get_ACP_Records</name>
        <label>Get ACP Records</label>
        <locationX>398</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Filter_In_Progress_ACPs</targetReference>
        </connector>
        <faultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>ACP_Query_Fault</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Application__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Parent.Application_Course_Preference__r.Application__c</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Application_Course_Preference__c</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_ACP_Records_On_Hold</name>
        <label>Get ACP Records On Hold</label>
        <locationX>224</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Check_if_ACP_records_exists</targetReference>
        </connector>
        <faultConnector>
            <targetReference>ACP_Query_Fault</targetReference>
        </faultConnector>
        <filterLogic>1 AND (2 OR 3)</filterLogic>
        <filters>
            <field>Application__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Parent.Application_Course_Preference__r.Application__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Workflow_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>On Hold</stringValue>
            </value>
        </filters>
        <filters>
            <field>Workflow_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Released</stringValue>
            </value>
        </filters>
        <object>Application_Course_Preference__c</object>
        <outputReference>ACPRecordsFetched</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Workflow_Status__c</queriedFields>
        <queriedFields>Release_Reason__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_MUDocs_Queue_Id</name>
        <label>Get MUDocs Queue Id</label>
        <locationX>266</locationX>
        <locationY>1079</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Loop_Completed_Sort</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Type</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Queue</stringValue>
            </value>
        </filters>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>CENTRAL_ADMISSIONS_MUDocs</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_ACP_to_Release</name>
        <label>Update ACP to Release</label>
        <locationX>224</locationX>
        <locationY>1655</locationY>
        <faultConnector>
            <targetReference>ACP_Update_Fault</targetReference>
        </faultConnector>
        <inputReference>ACPRecordListForUpdate</inputReference>
    </recordUpdates>
    <start>
        <locationX>98</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_ACP_Records_On_Hold</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False &amp;&amp; {!$Record.Parent.Application_Course_Preference__r.Application__c} != NULL &amp;&amp; {!$Record.Parent.RecordType.DeveloperName} = &apos;Admissions&apos; &amp;&amp; {!$Record.Incoming}</filterFormula>
        <object>EmailMessage</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>ACPRecordListForUpdate</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
