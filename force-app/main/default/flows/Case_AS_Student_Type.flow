    <decisions>
        <name>checkCitizenship</name>
        <label>checkCitizenship</label>
        <locationX>3746</locationX>
        <locationY>1469</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Domestic_Citizenship</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Contact.Citizenship__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DOMESTIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateDOMSTCitizenship</targetReference>
            </connector>
            <label>Domestic Citizenship</label>
        </rules>
        <rules>
            <name>International_Citizenship</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Contact.Citizenship__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>INTERNATIONAL</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateINTSTCitizenship</targetReference>
            </connector>
            <label>International Citizenship</label>
        </rules>
    </decisions>
    <decisions>
        <name>checkContactProfile</name>
        <label>checkContactProfile</label>
        <locationX>2954</locationX>
        <locationY>971</locationY>
        <defaultConnector>
            <targetReference>checkContactResidencyStatus</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ContactProfileConflict</name>
            <conditionLogic>(1 OR 2 OR 3) AND (4 OR 5 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Future Student (Dom) [FSD]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Current Student (Dom) [CSD]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Future Student (Dom)- Mature [FSD]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Current Student (Int) [CSI]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Future Student (Int) [FSI]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>International Applicant [IA]</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>checkContactResidencyStatus</targetReference>
            </connector>
            <label>ContactProfileConflict</label>
        </rules>
        <rules>
            <name>ContactProfileDomestic</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Future Student (Dom) [FSD]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Current Student (Dom) [CSD]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Current Student (Dom) [CSD]</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateStudentTypeContactProfile</targetReference>
            </connector>
            <label>ContactProfileDomestic</label>
        </rules>
        <rules>
            <name>ContactProfileInternational</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Current Student (Int) [CSI]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Future Student (Int) [FSI]</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>txtContactProfile</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>International Applicant [IA]</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateSTInternational</targetReference>
            </connector>
            <label>ContactProfileInternational</label>
        </rules>
    </decisions>
    <decisions>
        <name>checkContactResidencyStatus</name>
        <label>checkContactResidencyStatus</label>
        <locationX>2954</locationX>
        <locationY>1361</locationY>
        <defaultConnector>
            <targetReference>checkCitizenship</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>ContactResidencyAU</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australian Citizen</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australian Permanent Resident</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New Zealand Citizen</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Australian Permanent Humanitarian</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DOM-AUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DOM-PR</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DOM-NZ</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DOM-HV</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateStudenTypeContactResidency</targetReference>
            </connector>
            <label>ContactResidencyAU</label>
        </rules>
        <rules>
            <name>Residency_INT</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Contact.Residency_Status__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>UpdateStudentTypeToInternational</targetReference>
            </connector>
            <label>Residency=INT</label>
        </rules>
    </decisions>
    <decisions>
        <name>checkEnquiryStatus</name>
        <label>checkEnquiryStatus</label>
        <locationX>4043</locationX>
