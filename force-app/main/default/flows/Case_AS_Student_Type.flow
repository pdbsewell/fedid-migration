    <decisions>
        <name>checkStudentType</name>
        <label>checkStudentType</label>
        <locationX>3020</locationX>
        <locationY>539</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>checkValidRT</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>GetValidRTs</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>checkNationality</targetReference>
            </connector>
            <label>checkValidRT</label>
