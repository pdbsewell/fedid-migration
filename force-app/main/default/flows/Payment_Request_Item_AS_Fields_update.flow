                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Payable_Amount_Field</targetReference>
            </connector>
            <label>Payable Amount GST Updated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Requested_Amount_Ex_GST_Modified</name>
        <label>Requested Amount Ex GST Modified</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Requested_Amount_GST_Modified</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Requested Amount Ex GST Not Updated</defaultConnectorLabel>
        <rules>
            <name>Requested_Amount_Ex_GST_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Requested_Amount_Ex_GST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
