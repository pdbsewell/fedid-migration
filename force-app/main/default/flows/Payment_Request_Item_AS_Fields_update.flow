    <decisions>
        <name>Payable_Amount_Ex_GST_Modified</name>
        <label>Payable Amount Ex GST Modified</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Payable_Amount_GST_Modified</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Payable Amount Ex GST Not Updated</defaultConnectorLabel>
        <rules>
            <name>Payable_Amount_Ex_GST_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Payable_Amount_Ex_GST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Payable_Amount_Fields</targetReference>
            </connector>
            <label>Payable Amount Ex GST Updated</label>
        </rules>
    </decisions>
    <decisions>
        <name>Payable_Amount_GST_Modified</name>
        <label>Payable Amount GST Modified</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Payable Amount GST Not Updated</defaultConnectorLabel>
        <rules>
            <name>Payable_Amount_GST_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Payable_AmountGST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Payable_Amount_Ex_GST__c</leftValueReference>
