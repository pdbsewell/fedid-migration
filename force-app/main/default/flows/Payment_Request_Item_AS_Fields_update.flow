    <description>Calculate &amp; Update the values in Payment Request when there are changes</description>
    <environments>Default</environments>
    <formulas>
        <name>CalculatePayableAmount</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c},{!$Record.Requested_Amount_Ex_GST__c} * 1.1,{!$Record.Requested_Amount_Ex_GST__c})</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>CalculatePayableAmountGST</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c},{!$Record.Requested_Amount_Ex_GST__c} * 0.1,0)</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>CalculateRequestedAmount</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c} ,{!$Record.Requested_Amount_Ex_GST__c} * 1.1,{!$Record.Requested_Amount_Ex_GST__c})</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>CalculateRequestedAmountGST</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c} , {!$Record.Requested_Amount_Ex_GST__c} * 0.1, 0)</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>ChangePayableAmount</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c} ,{!$Record.Payable_Amount_Ex_GST__c} * 1.1,{!$Record.Payable_Amount_Ex_GST__c})</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>ModifyPayableAmountGST</name>
        <dataType>Currency</dataType>
        <expression>IF({!$Record.Invoice_GST_Inclusive__c},{!$Record.Payable_Amount_Ex_GST__c} * 0.1,0)</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>ProcessPayableAmount</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Payable_Amount_Ex_GST__c} + {!$Record.Payable_AmountGST__c}</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>UpdatePayableAmount</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Requested_Amount_Ex_GST__c} + {!$Record.Requested_AmountGST__c}</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>UpdatePayableAmountExGST</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Requested_Amount_Ex_GST__c}</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>UpdatePayableAmountGST</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Requested_AmountGST__c}</expression>
        <scale>18</scale>
    </formulas>
    <formulas>
        <name>UpdateRequestedAmount</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Requested_Amount_Ex_GST__c} + {!$Record.Requested_AmountGST__c}</expression>
        <scale>18</scale>
    </formulas>
    <interviewLabel>Payment Request Item : AS : {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Payment Request Item : AS : Fields update</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Payable_Amount_Field</name>
        <label>Update Payable Amount Field</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Update_Fields_For_Payable_Amount_GST_Changes</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Payable_Amount__c</field>
            <value>
                <elementReference>ProcessPayableAmount</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Payable_Amount_Fields</name>
        <label>Update Payable Amount Fields</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Update_Fields_For_Payable_Amount_Ex_GST_Changes</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Payable_AmountGST__c</field>
