            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Payable_Amount__c</field>
            <value>
                <elementReference>ChangePayableAmount</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Requested_and_Payable_Amount_Field</name>
        <label>Update Requested and Payable Amount Field</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Update_Fields_For_Request_Amount_GST_Changes</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Payable_AmountGST__c</field>
            <value>
                <elementReference>UpdatePayableAmountGST</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Payable_Amount_Ex_GST__c</field>
            <value>
                <elementReference>UpdatePayableAmountExGST</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Payable_Amount__c</field>
            <value>
                <elementReference>UpdatePayableAmount</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Requested_Amount__c</field>
            <value>
                <elementReference>UpdateRequestedAmount</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Requested_and_Payable_Amount_Fields</name>
        <label>Update Requested and Payable Amount Fields</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Error_Update_Fields_For_Request_Amount_Ex_GST_Changes</targetReference>
        </faultConnector>
        <inputAssignments>
            <field>Payable_AmountGST__c</field>
            <value>
                <elementReference>CalculatePayableAmountGST</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Payable_Amount_Ex_GST__c</field>
            <value>
                <elementReference>$Record.Requested_Amount_Ex_GST__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Payable_Amount__c</field>
            <value>
                <elementReference>CalculatePayableAmount</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Requested_AmountGST__c</field>
            <value>
                <elementReference>CalculateRequestedAmountGST</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Requested_Amount__c</field>
            <value>
                <elementReference>CalculateRequestedAmount</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Requested_Amount_Ex_GST_Modified</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False</filterFormula>
        <object>Payment_Request_Item__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
