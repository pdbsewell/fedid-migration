    <decisions>
        <name>Requested_Amount_GST_Modified</name>
        <label>Requested Amount GST Modified</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Payable_Amount_Ex_GST_Modified</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Requested Amount GST Not Updated</defaultConnectorLabel>
        <rules>
            <name>Requested_Amount_GST_Updated</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Requested_AmountGST__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Requested_Amount_Ex_GST__c</leftValueReference>
