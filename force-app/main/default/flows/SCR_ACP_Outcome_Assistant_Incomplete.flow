    <decisions>
        <name>Check_if_previous_Outcome_is_Conditional_Offer_or_Full_Offer</name>
        <label>Check if previous Outcome is Conditional Offer or Full Offer</label>
        <locationX>314</locationX>
        <locationY>950</locationY>
        <defaultConnector>
            <targetReference>Assign_currentACP_to_UpdateACP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Previous_Outcome_is_Conditional_Offer</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-COND</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-E</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-FY</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-C-MC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Empty_values_if_Conditional_Offer</targetReference>
            </connector>
            <label>Previous Outcome is Conditional Offer</label>
        </rules>
        <rules>
            <name>Previous_Outcome_is_Full_Offer</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER-PROV</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>ACPRecord.Outcome_Status_Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>OFFER</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Empty_values_if_Full_Offer</targetReference>
            </connector>
            <label>Previous Outcome is Full Offer</label>
        </rules>
    </decisions>
    <decisions>
        <name>Get_Incomplete_LOV_Records</name>
        <label>Get Incomplete LOV Records</label>
        <locationX>1062</locationX>
        <locationY>242</locationY>
        <defaultConnector>
            <targetReference>Loop_LOVs_Incomplete</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>OutomeStatusRecord_Incomplete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OUTCOME_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>IN-PROGRES</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OutcomeStatusRecordIncomplete</targetReference>
            </connector>
            <label>OutomeStatusRecord_Incomplete</label>
        </rules>
        <rules>
            <name>EntryQualificationRecord_Incomplete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_ENTRY_QUAL_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PENDING</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>EntryQualificationRecordIncomplete</targetReference>
            </connector>
            <label>EntryQualificationRecord_Incomplete</label>
        </rules>
        <rules>
            <name>DocumentationStatusRecord_Incomplete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_DOC_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>INCOMPLETE</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DocumentationSingleRecordIncomnplete</targetReference>
            </connector>
            <label>DocumentationStatusRecord_Incomplete</label>
        </rules>
        <rules>
            <name>OfferResponseStatus_Incomplete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_OFFER_RESP_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>OfferResponseSingleRecordIncomplete</targetReference>
            </connector>
            <label>OfferResponseStatus_Incomplete</label>
        </rules>
        <rules>
            <name>ConditionalOfferStatus_Incomplete</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_LOVs_Incomplete.Value__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NOT-APPLIC</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>ConditionalOfferResponseRecord_Incomplete</targetReference>
            </connector>
            <label>ConditionalOfferStatus_Incomplete</label>
        </rules>
    </decisions>
