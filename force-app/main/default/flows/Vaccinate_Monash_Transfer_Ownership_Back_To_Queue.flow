<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Is_Staff_or_Student</name>
        <label>Is Staff or Student</label>
        <locationX>314</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Staff</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Vaccinate Monash - Staff</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Staff_Queue</targetReference>
            </connector>
            <label>Is Staff</label>
        </rules>
        <rules>
            <name>Is_Student</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Vaccinate Monash - Students</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Student_Queue</targetReference>
            </connector>
            <label>Is Student</label>
        </rules>
    </decisions>
    <interviewLabel>Vaccinate Monash - Transfer Ownership Back To Queue {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Vaccinate Monash - Transfer Ownership Back To Queue</label>
    <processMetadataValues>
        <name>BuilderType</name>
