    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Log_Record</name>
        <label>Create Log Record</label>
        <locationX>1106</locationX>
        <locationY>1121</locationY>
        <inputAssignments>
            <field>Function_Name__c</field>
            <value>
                <stringValue>Record-Trigger: Enquiry After Save (MRO Email Notifications)</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Input__c</field>
            <value>
                <elementReference>senderEmailAddress</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Message__c</field>
