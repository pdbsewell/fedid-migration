    <decisions>
        <description>Owner is MRO Staff + Cat 1 = Variation/Transfer in/Transfer Out/ Report/ Close out + Enquiry Type = Awards / Majors + Status = In progress, Enquiry contact type is “Known to Monash” and Case reopened = False</description>
        <name>Check_Enquiry_Record</name>
        <label>Check Enquiry Record</label>
        <locationX>446</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Setup_Email_Notification</name>
            <conditionLogic>1 AND 2 AND 3 AND (4 OR 5) AND (6 OR 7) AND 8 AND 9 AND 10</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Flag_Owner_is_Queue__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Setup</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Major Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_InitialEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>InitialEmailSent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>bEnquiryCreateDateFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_Name_for_Setup</targetReference>
            </connector>
            <label>Setup Email Notification</label>
        </rules>
        <rules>
            <name>Other_Email_Notification</name>
            <conditionLogic>1 AND 2 AND (3 OR 4) AND (5 OR 6 OR 7 OR 8 OR 9) AND (10 OR 11) AND 12 AND 13 AND 14  AND 15</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Major Award</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Variation</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Transfer In</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Transfer Out</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Reports</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Close Out</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Flag_Owner_is_Queue__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_InitialEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>InitialEmailSent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>bEnquiryCreateDateFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_Name_for_Other</targetReference>
            </connector>
            <label>Other Email Notification</label>
        </rules>
        <rules>
            <name>Setup_Email_Notification_for_Application</name>
            <conditionLogic>1 AND 2 AND 3 AND 4 AND 5 AND 6 AND 7 AND (8 OR 9)  AND 10</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Category_Level_1__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Application</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.ParentId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>In Progress</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Flag_Owner_is_Queue__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Contact.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Student</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>formula_InitialEmailSentOption</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>InitialEmailSent</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>bEnquiryCreateDateFlag</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Template_Name_for_Application</targetReference>
            </connector>
            <label>Setup Email Notification for Application</label>
        </rules>
    </decisions>
    <description>[RO-404] Flow will validate the enquiry record and send email notifications.</description>
    <environments>Default</environments>
    <formulas>
        <name>bEnquiryCreateDateFlag</name>
        <dataType>Boolean</dataType>
        <expression>DATEVALUE({!$Record.CreatedDate}) &gt; DATEVALUE({!$Label.MRO_Notification_Start_Date})</expression>
    </formulas>
    <formulas>
        <name>formula_InitialEmailSent</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!EnquiryOptionField}),
&quot;InitialEmailSent;&quot;,
IF(INCLUDES({!$Record.Options__c}, &quot;InitialEmailSent&quot;),{!EnquiryOptionField},
{!EnquiryOptionField}&amp;&quot;;&quot;&amp;&quot;InitialEmailSent;&quot;
)
)</expression>
    </formulas>
    <formulas>
        <name>formula_InitialEmailSentOption</name>
        <dataType>String</dataType>
        <expression>IF(CONTAINS({!EnquiryOptionField}, &quot;InitialEmailSent&quot;), &quot;InitialEmailSent&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>senderEmailAddress</name>
        <dataType>String</dataType>
        <expression>CASE(TEXT({!$Record.Enquiry_Type__c}), 
&quot;Award&quot;, &quot;mro-awards@f.e.monash.edu&quot;,
&quot;Major Award&quot;, &quot;mro-majorawards@f.e.monash.edu&quot;,
&quot;Application&quot;, &quot;mro-applications@f.e.monash.edu&quot;,
&quot;am-noreply@f.e.monash.edu&quot;)</expression>
    </formulas>
    <interviewLabel>Record-Trigger: Enquiry After Save (MRO Email Notifications) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Record-Trigger: Enquiry After Save (MRO Email Notifications)</label>
    <processMetadataValues>
