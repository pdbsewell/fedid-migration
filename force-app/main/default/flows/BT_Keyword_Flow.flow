<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <environments>Default</environments>
    <formulas>
        <name>uniqueName</name>
        <dataType>String</dataType>
        <expression>IF(ISPICKVAL({!$Record.conference360__Category__c},&quot;&quot;),LOWER({!$Record.Name}), LOWER({!$Record.Name})+&quot;__&quot;+LOWER(TEXT({!$Record.conference360__Category__c})))</expression>
    </formulas>
    <interviewLabel>BT Keyword Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>BT Keyword Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Unique_Keyword_field</name>
        <label>Update Unique Keyword field</label>
        <locationX>176</locationX>
        <locationY>311</locationY>
        <inputAssignments>
            <field>Keyword_Unique_Id__c</field>
            <value>
                <elementReference>uniqueName</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Unique_Keyword_field</targetReference>
        </connector>
        <filterFormula>AND({!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False ,ISBLANK( {!$Record.Name}) = False)</filterFormula>
        <object>conference360__Keyword__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
