    <decisions>
        <name>decision_AutoResponse</name>
        <label>decision Auto Response</label>
        <locationX>446</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>outcome Exit</defaultConnectorLabel>
        <rules>
            <name>outcome_No_Child_Enquiries</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>HR DOI Submission</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No Interests (Auto)</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Email_No_Interests</targetReference>
            </connector>
            <label>outcome No Child Enquiries</label>
        </rules>
        <rules>
            <name>outcome_Plan_Not_Required</name>
            <conditionLogic>1 AND ((2 AND (3 OR 4)) OR (5 AND (6 or 4)))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>HR DOI</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No Conflict (Auto)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Stage__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>No Conflict (Auto)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>No Conflict</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Stage__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>No Conflict</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Email_No_Conflict</targetReference>
            </connector>
            <label>outcome Plan Not Required</label>
        </rules>
        <rules>
            <name>outcome_Plan_Requested</name>
            <conditionLogic>1 AND ((2 AND (3 OR 4)) OR (5 AND (4 OR 6)))</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Enquiry_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>HR DOI</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Management Plan Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Stage__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Management Plan Requested</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Case_Stage__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Management Plan Requested (Auto)</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Case_Stage__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Management Plan Requested (Auto)</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>get_Email_Plan_Required</targetReference>
            </connector>
            <label>outcome Plan Requested</label>
        </rules>
    </decisions>
