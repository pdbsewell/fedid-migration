    <start>
        <locationX>320</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>decision_AutoResponse</targetReference>
        </connector>
        <filterFormula>{!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False
&amp;&amp;
(ISPICKVAL({!$Record.Enquiry_Type__c},&apos;HR DoI Submission&apos;) || ISPICKVAL({!$Record.Enquiry_Type__c},&apos;HR DoI&apos;))
&amp;&amp;
(ISNEW() || ISCHANGED({!$Record.Case_Stage__c}))
&amp;&amp;
(
	ISPICKVAL({!$Record.Case_Stage__c}, &apos;No Conflict&apos;) ||
	ISPICKVAL({!$Record.Case_Stage__c}, &apos;No Conflict (Auto)&apos;) ||
	ISPICKVAL({!$Record.Case_Stage__c}, &apos;No Interests (Auto)&apos;) ||
	ISPICKVAL({!$Record.Case_Stage__c}, &apos;Management Plan Requested&apos;) ||
	ISPICKVAL({!$Record.Case_Stage__c}, &apos;Management Plan Requested (Auto)&apos;)
)
&amp;&amp;
ISPICKVAL({!$Record.Origin}, &apos;Web - Monash Forms&apos;)</filterFormula>
        <object>Case</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
