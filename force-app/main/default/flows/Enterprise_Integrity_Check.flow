        <fields>
            <name>dtxt_Error01</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(255, 0, 0); font-size: 16px;&quot;&gt;Oops, something went wrong!&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Please contact your Enterprise UniCRM team experts with the below information.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;b&gt;Integrity Check (EDIT) on Opportunity&lt;/b&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Current Date/Time: {!$Flow.CurrentDateTime}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Fault Message: {!$Flow.FaultMessage}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Start Time: {!$Flow.InterviewStartTime}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Interview Guid: {!$Flow.InterviewGuid}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Opportunity Id: {!varOppId}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 255);&quot;&gt;Running User: {!$User.Full_Name__c}({!$User.Id})&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;</fieldText>
