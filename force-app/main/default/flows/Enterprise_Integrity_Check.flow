            <fields>
                <name>Edit_Form_Section1_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>Q1_dtxt_e</name>
                    <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 12px; color: rgb(0, 0, 0); background-color: transparent;&quot;&gt;Q1 - Is the opportunity aligned with Monash, your Faculty’s and other relevant strategic plans and intentions?&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 12px; color: rgb(0, 0, 0); background-color: transparent;&quot;&gt;(eg. &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/__data/assets/pdf_file/0009/2680389/Strategic-Plan-2030.pdf&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 12px; color: rgb(5, 99, 193); background-color: rgb(255, 255, 255); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, sans-serif;&quot;&gt;Strategic Plan 2021 - 2030&lt;/a&gt;&lt;span style=&quot;font-size: 12px; color: rgb(0, 0, 0); background-color: transparent;&quot;&gt;, Monash Enterprise Plan, &lt;/span&gt;&lt;a href=&quot; https://www.monash.edu/about/strategic-direction/strategic-plan&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 12px; color: rgb(5, 99, 193); background-color: transparent;&quot;&gt;&lt;u&gt;Impact 2030&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;font-size: 12px; color: rgb(0, 0, 0); background-color: transparent;&quot;&gt;)&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
