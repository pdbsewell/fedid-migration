        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_Contact_Qualifications</collectionReference>
        <conditionLogic>or</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_Contact_Qualification_with_rating_3_4.GTE_Risk_Rating__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>3</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_Filter_Contact_Qualification_with_rating_3_4.GTE_Risk_Rating__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>4</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>GS_Check_Value</targetReference>
        </connector>
    </collectionProcessors>
    <decisions>
        <name>Check_Encumbrance_Errors</name>
        <label>Check Encumbrance Errors</label>
        <locationX>490</locationX>
        <locationY>1706</locationY>
        <defaultConnector>
            <targetReference>Visa_Check_Validation_Check</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Encumbrance Check Success</defaultConnectorLabel>
        <rules>
            <name>Encumbrance_Blocked</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>HasEncumbrance</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsEncumbranceCheckBlocked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Encumbrance_Block_Screen</targetReference>
            </connector>
            <label>Encumbrance Blocked</label>
        </rules>
        <rules>
            <name>Encumbrance_Warning</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>HasEncumbrance</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsEncumbranceCheckBlocked</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Encumbrance_Warn_Screen</targetReference>
            </connector>
            <label>Encumbrance Warning</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Outcome_Control</name>
        <label>Check Outcome Control</label>
        <locationX>1766</locationX>
        <locationY>674</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Offer_Check</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Offer_Conditional_offer</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Incomplete</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Rejected</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Packaged</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Fees_Paid_Check</targetReference>
            </connector>
            <label>Offer Check</label>
        </rules>
        <rules>
            <name>Offer_Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Cancelled</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Application_Cancelled_Path</targetReference>
            </connector>
            <label>Offer Cancelled</label>
        </rules>
        <rules>
            <name>Offer_Withdrawn</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Withdrawn</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Application_Withdrawn_Path</targetReference>
            </connector>
            <label>Offer Withdrawn</label>
        </rules>
        <rules>
            <name>Offer_Application_Lapsed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Application_Lapsed</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Application_Lapsed_Path</targetReference>
            </connector>
            <label>Offer Application Lapsed</label>
