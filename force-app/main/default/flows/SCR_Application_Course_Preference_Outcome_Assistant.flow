    <decisions>
        <name>GS_Check_Value</name>
        <label>GS Check Value</label>
        <locationX>1062</locationX>
        <locationY>998</locationY>
        <defaultConnector>
            <targetReference>Warn_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>GS Check Success</defaultConnectorLabel>
        <rules>
            <name>GS_Check_Failed</name>
            <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>Filter_Contact_Qualification_with_rating_3_4</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Submission_Location_Country__r.GTE_Risk_Rating__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>3</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Submission_Location_Country__r.GTE_Risk_Rating__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>4</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>Incomplete</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>No_Further_Screen</targetReference>
            </connector>
            <label>GS Check Failed</label>
        </rules>
        <rules>
            <name>By_Pass_Incomplete_3_or_4</name>
            <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>Get_Application.Submission_Location_Country__r.GTE_Risk_Rating__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>3</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Submission_Location_Country__r.GTE_Risk_Rating__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>4</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Filter_Contact_Qualification_with_rating_3_4</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Incomplete</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Warn_Screen_Incomplete</targetReference>
            </connector>
            <label>By Pass Incomplete 3 or 4</label>
        </rules>
    </decisions>
    <decisions>
        <name>Outstanding_Task_Check</name>
        <label>Outstanding Task Check</label>
        <locationX>842</locationX>
        <locationY>2690</locationY>
        <defaultConnector>
            <targetReference>Check_Outcome_Path</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Not Packaged or Offer Conditional Path</defaultConnectorLabel>
        <rules>
            <name>Is_Packaged_or_Offer_Conditional_Path</name>
