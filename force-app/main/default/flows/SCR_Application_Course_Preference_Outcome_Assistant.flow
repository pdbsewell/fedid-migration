        <locationX>908</locationX>
        <locationY>3506</locationY>
        <defaultConnector>
            <targetReference>Validation_General_Offer_Error_Screen</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Valid General Offer Error</defaultConnectorLabel>
        <rules>
            <name>Valid_General_Offer_Success</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_ACP.Basis_For_Adminssion_Type__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
