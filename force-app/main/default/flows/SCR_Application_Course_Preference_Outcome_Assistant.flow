    <collectionProcessors>
        <name>ConditionalOfferStatusOffer</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>ConditionalOfferStatusOffer</label>
        <locationX>446</locationX>
        <locationY>3614</locationY>
        <assignNextValueToReference>currentItem_ConditionalOfferStatusOffer</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_List_of_Value</collectionReference>
        <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_ConditionalOfferStatusOffer.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>PENDING</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_ConditionalOfferStatusOffer.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>WAIVED</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_ConditionalOfferStatusOffer.Value__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>SATISFIED</stringValue>
            </rightValue>
        </conditions>
        <conditions>
            <leftValueReference>currentItem_ConditionalOfferStatusOffer.Type__c</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <stringValue>ADM_CNDTNL_OFFER_STATUS</stringValue>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Get_Course_Preference_Qualifications_Education</targetReference>
        </connector>
    </collectionProcessors>
    <collectionProcessors>
        <name>Filter_Contact_Qualification_with_rating_3_4</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter Contact Qualification with rating 3,4</label>
        <locationX>1062</locationX>
