    <decisions>
        <name>Visa_Check_Validation_Check</name>
        <label>Visa Check Validation Check</label>
        <locationX>842</locationX>
        <locationY>2198</locationY>
        <defaultConnector>
            <targetReference>Outstanding_Task_Check</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Rejected Outcome Path</defaultConnectorLabel>
        <rules>
            <name>Not_Rejected_Outcome_Path</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Outcome_Path</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <elementReference>Rejected</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Visa_Check_Validation_Rules</targetReference>
            </connector>
            <label>Not Rejected Outcome Path</label>
        </rules>
    </decisions>
    <decisions>
        <name>Visa_Check_Validation_Rules</name>
        <label>Visa Check Validation Rules</label>
        <locationX>688</locationX>
        <locationY>2306</locationY>
        <defaultConnector>
            <targetReference>Outstanding_Task_Check</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No Value is Yes</defaultConnectorLabel>
        <rules>
            <name>Either_Value_is_Yes</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Application.Refused_entry_visa_to_any_country__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Yes</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Breached_visa_condition__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Yes</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Medical_health_prevent_visa__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Yes</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Protection_visa_in_any_country__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Yes</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Application.Convicted_of_crime_offence__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Yes</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Visa_Check_Validation_Warn_Screen</targetReference>
            </connector>
            <label>Either Value is Yes</label>
        </rules>
    </decisions>
