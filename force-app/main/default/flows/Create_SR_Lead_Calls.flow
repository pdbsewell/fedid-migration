IF( ISPICKVAL([CampaignMember].Campaign.Type, &apos;International Pre App&apos;), &apos;01228000000SjqNAAS&apos;,
IF( ISPICKVAL([CampaignMember].Campaign.Type, &apos;International Post App&apos;), &apos;01228000000SjqMAAS&apos;,
NULL))))</stringValue>
