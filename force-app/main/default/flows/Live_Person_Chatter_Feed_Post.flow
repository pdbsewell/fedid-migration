<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <description>Check if the Flow is to be Bypassed</description>
        <name>Check_Flow_Bypassing</name>
        <label>Check Flow Bypassing</label>
        <locationX>380</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Process_Chatter_Feeds</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Validate_Enquiry_and_Chat_365</targetReference>
            </connector>
            <label>Process Chatter Feeds</label>
        </rules>
    </decisions>
    <decisions>
        <name>Validate_Enquiry_and_Chat_365</name>
        <label>Validate Enquiry and Chat 365</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Missing Field Values</defaultConnectorLabel>
        <rules>
            <name>Validate_Enquiry_and_Chat_365_field_values</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Chat_365_Log__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Enquiry__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Feed_on_Chatter</targetReference>
            </connector>
            <label>Validate Enquiry and Chat 365 field values</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Live Person Chatter Feed POst {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Live Person Chatter Feed Post</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>254</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Flow_Bypassing</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>End_Time__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Live_Person_Chat_Transcript__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Create_Feed_on_Chatter</name>
        <label>Create Feed on Chatter</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <flowName>Case_Feed_Chatter_Post</flowName>
        <inputAssignments>
            <name>VarCaseID</name>
            <value>
                <elementReference>$Record.Enquiry__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>VarChatId</name>
            <value>
                <elementReference>$Record.Chat_Link__c</elementReference>
            </value>
        </inputAssignments>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </subflows>
</Flow>
