    <description>Added logic for Is_enabled_for_APNG__c</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_changed_callista_status</name>
        <dataType>Boolean</dataType>
        <expression>ISCHANGED({!$Record.Callista_Integration_Status__c }) &amp;&amp; 

ISPICKVAL({!$Record.Callista_Integration_Status__c }, &apos;Inserted&apos;)</expression>
    </formulas>
    <formulas>
        <name>formula_changed_record_google_status</name>
        <dataType>Boolean</dataType>
        <expression>(
ISCHANGED({!$Record.Name }) ||
ISCHANGED({!$Record.Monash_AM_Start_Date__c }) ||
ISCHANGED({!$Record.Status__c }) ||
ISCHANGED({!$Record.Phone }) ||
ISCHANGED({!$Record.Monash_AM_Business_Phone__c }) ||
ISCHANGED({!$Record.Monash_AM_Mobile__c }) ||
ISCHANGED({!$Record.Email__c }) ||
ISCHANGED({!$Record.Street__c }) ||  
ISCHANGED({!$Record.City__c }) ||  
ISCHANGED({!$Record.State__c }) ||  
(ISCHANGED({!$Record.Country_Lookup__c }) &amp;&amp; NOT(ISBLANK({!$Record.Country_Lookup__c }) ) ) || 
ISCHANGED({!$Record.Post_Code__c }) 
)</expression>
    </formulas>
    <formulas>
        <name>Formula_firstleft40charactersfromName</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Record.Name }, 40)</expression>
    </formulas>
    <formulas>
        <name>formula_google_status_updated</name>
        <dataType>Boolean</dataType>
        <expression>ISCHANGED({!$Record.Callista_Integration_Status__c}) &amp;&amp;

ISPICKVAL({!$Record.Callista_Integration_Status__c}, &apos;Updated&apos;)</expression>
    </formulas>
    <formulas>
        <name>formula_headquarters</name>
        <dataType>Boolean</dataType>
        <expression>{!$Record.Headquarters__c} = true &amp;&amp; 

(

ISCHANGED({!$Record.Monash_AM_Campus__c }) || 
ISCHANGED({!$Record.Monash_AM_Contract_Issue_Date__c }) ||

ISCHANGED({!$Record.Legal_Entity_Name__c }) || 
ISCHANGED({!$Record.Original_Contract_Start_Date__c }) || 
ISCHANGED({!$Record.Original_Contract_End_Date__c }) || 
ISCHANGED({!$Record.Latest_Contract_Start_Date__c }) || 
ISCHANGED({!$Record.Latest_Contract_End_Date__c }) || 
ISCHANGED({!$Record.Region_of_Recruitment__c }) || 
ISCHANGED({!$Record.Website })

)</expression>
    </formulas>
    <formulas>
        <name>formula_ischanged</name>
        <dataType>Boolean</dataType>
        <expression>( 

ISCHANGED({!$Record.Name}) || 
ISCHANGED({!$Record.Email__c }) || 
ISCHANGED({!$Record.City__c }) 

)</expression>
    </formulas>
    <formulas>
        <name>formula_ischanged_2</name>
        <dataType>Boolean</dataType>
        <expression>(

(ISNEW() &amp;&amp; NOT(ISBLANK({!$Record.Country_Lookup__c }) ) ) || 

ISCHANGED({!$Record.Street__c }) ||  

ISCHANGED({!$Record.City__c }) ||  

ISCHANGED({!$Record.State__c }) ||  

(ISCHANGED({!$Record.Country_Lookup__c }) &amp;&amp; NOT(ISBLANK({!$Record.Country_Lookup__c }) ) ) || 

ISCHANGED({!$Record.Post_Code__c }) 
)</expression>
    </formulas>
    <formulas>
        <description>Flag that indicates that the country on the Account has a regional manager set up</description>
        <name>formula_isCountryHasRegionalManagerSetup</name>
        <dataType>Boolean</dataType>
        <expression>NOT(ISBLANK({!$Record.Country_Lookup__r.Regional_Manager__c}))</expression>
    </formulas>
    <formulas>
        <name>formula_isnew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW() &amp;&amp; 

NOT( ISBLANK( {!$Record.ParentId }) )  &amp;&amp; 

NOT( {!$Record.Headquarters__c })</expression>
    </formulas>
    <formulas>
        <name>formula_isnew_1</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>formula_record_status_changed</name>
        <dataType>Boolean</dataType>
        <expression>(ISCHANGED({!$Record.Status__c}) &amp;&amp;
ISPICKVAL({!$Record.Status__c }, &apos;Contract Terminated&apos;) &amp;&amp;
{!$Record.Headquarters__c = true})</expression>
    </formulas>
    <formulas>
        <name>formula_today</name>
        <dataType>Date</dataType>
        <expression>today()</expression>
    </formulas>
    <formulas>
        <name>formula_today_2</name>
        <dataType>Date</dataType>
        <expression>today()</expression>
    </formulas>
