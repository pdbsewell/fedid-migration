    <decisions>
        <description>When an Agency is activated or deactivated, they are enabled/disabled as Partner</description>
        <name>Is_activated_deactivated_for_APNG</name>
        <label>Is activated/deactivated for APNG ?</label>
        <locationX>182</locationX>
        <locationY>3047</locationY>
        <defaultConnectorLabel>isPartner not changed</defaultConnectorLabel>
        <rules>
            <name>IsPartner_changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.IsPartner</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Agency</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>update_APNG_activation_status</targetReference>
            </connector>
            <label>IsPartner changed?</label>
        </rules>
    </decisions>
