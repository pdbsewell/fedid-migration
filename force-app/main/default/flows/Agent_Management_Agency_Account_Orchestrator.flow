        <flowName>Agent_Management_Copy_Principal_Agent_to_Branch</flowName>
        <inputAssignments>
            <name>BranchAccountRecord</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
