    <description>Process builder for application object</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND
(ISPICKVAL(PRIORVALUE([Application__c].Status__c),&quot;Submission on Hold (Duplicate Contact)&quot;),
ISCHANGED([Application__c].Status__c),
ISPICKVAL([Application__c].Status__c,&quot;Sent for Submission&quot;))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_3</name>
        <dataType>Boolean</dataType>
        <expression>AND
(ISPICKVAL(PRIORVALUE({!myVariable_current.Status__c}),&quot;Submission on Hold (Duplicate Contact)&quot;),
ISCHANGED({!myVariable_current.Status__c}),
ISPICKVAL({!myVariable_current.Status__c},&quot;Sent for Submission&quot;))</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND
(ISPICKVAL(PRIORVALUE([Application__c].Status__c),&quot;Submission on Hold (Duplicate Contact)&quot;),
ISCHANGED([Application__c].Status__c),
ISPICKVAL([Application__c].Status__c,&quot;Sent for Submission&quot;))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_3_pmetrule</name>
        <dataType>Boolean</dataType>
        <expression>AND
(ISPICKVAL(PRIORVALUE({!myVariable_old.Status__c}),&quot;Submission on Hold (Duplicate Contact)&quot;),
ISCHANGED({!myVariable_old.Status__c}),
ISPICKVAL({!myVariable_old.Status__c},&quot;Sent for Submission&quot;))</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND
(ISPICKVAL(PRIORVALUE([Application__c].Status__c),&quot;Draft&quot;),
ISCHANGED([Application__c].Status__c),
ISPICKVAL([Application__c].Status__c,&quot;Cancelled&quot;))</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_8</name>
        <dataType>Boolean</dataType>
        <expression>AND
(ISPICKVAL(PRIORVALUE({!myVariable_current.Status__c}),&quot;Draft&quot;),
ISCHANGED({!myVariable_current.Status__c}),
ISPICKVAL({!myVariable_current.Status__c},&quot;Cancelled&quot;))</expression>
    </formulas>
