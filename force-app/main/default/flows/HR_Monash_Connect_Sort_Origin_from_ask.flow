    <description>Update the origin with the correct value on an enquiry depending if its a HR Enquiry or a Standard Enquiry</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(CONTAINS([Case].SuppliedEmail, &apos;@monash.edu&apos;), ISCHANGED([Case].Origin)) </stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>AND(CONTAINS({!myVariable_current.SuppliedEmail}, &apos;@monash.edu&apos;), ISCHANGED({!myVariable_current.Origin}))</expression>
    </formulas>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(NOT(CONTAINS([Case].SuppliedEmail, &apos;@monash.edu&apos;)), ISCHANGED([Case].Origin)) </stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_3</name>
        <dataType>Boolean</dataType>
        <expression>AND(NOT(CONTAINS({!myVariable_current.SuppliedEmail}, &apos;@monash.edu&apos;)), ISCHANGED({!myVariable_current.Origin}))</expression>
    </formulas>
    <interviewLabel>HR_Monash_Connect_Sort_Origin_from_ask-3_InterviewLabel</interviewLabel>
