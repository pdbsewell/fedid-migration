    <start>
        <locationX>1178</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Flow_Bypassing</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>RecordType_DeveloperName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>MonCon_Support</stringValue>
            </value>
        </filters>
        <filters>
            <field>Enquiry_Type__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Current Course</stringValue>
            </value>
        </filters>
        <filters>
            <field>Category_Level_1__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Enrolment - Current Course</stringValue>
            </value>
        </filters>
        <filters>
            <field>Category_Level_2__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Intermission</stringValue>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Solved</stringValue>
            </value>
        </filters>
        <object>Case</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <name>v_DomesticEmailTempDeveloperName</name>
