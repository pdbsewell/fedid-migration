    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Cancelled_or_Expired</name>
        <label>Cancelled or Expired</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Cancelled</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Agent_Email__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Cancelled</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Published</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Offer_Cancelled_email</targetReference>
            </connector>
            <label>Cancelled</label>
        </rules>
        <rules>
            <name>Expired</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Agent_Email__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Expired</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.SBQQ__Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Published</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Offer_Expired_email</targetReference>
            </connector>
            <label>Expired</label>
        </rules>
    </decisions>
    <description>Migrated from: 
PB: 
- Email Agent
- Technical Error for Conga or CPQ APIs
WF:
- Quote Expiry - Scheduled update Status</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_Cancelled</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!$Record.Agent_Email__c} )),
    ISPICKVAL({!$Record.SBQQ__Status__c}, &apos;Cancelled&apos;),
    ISPICKVAL(PRIORVALUE({!$Record.SBQQ__Status__c}), &apos;Published&apos;)
)</expression>
    </formulas>
    <formulas>
        <name>formula_Error_Logging_Time</name>
        <dataType>DateTime</dataType>
        <expression>NOW() - (45/1440)</expression>
    </formulas>
    <formulas>
        <name>formula_Expired</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!$Record.Agent_Email__c} )),
    ISPICKVAL({!$Record.SBQQ__Status__c}, &apos;Expired&apos;),
    ISPICKVAL(PRIORVALUE({!$Record.SBQQ__Status__c}), &apos;Published&apos;)
)</expression>
    </formulas>
    <interviewLabel>Quote : AS : Error Handler {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Quote : AS : Error Handler</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Conga_Final_Contract_Error</name>
        <label>Conga Final Contract Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>CPQ_API_Error</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_error_Conga_Final_Contract</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Contract requested</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Error_Log__c</field>
            <value>
                <stringValue>&apos;Conga error generating Final Contract. Conga taking more that 15 minutes to generate pdf&apos;</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Conga Error</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Conga_Preview_Contract</name>
        <label>Conga Preview Contract</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Conga_Final_Contract_Error</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_error_Conga_Preview_Contract</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Preview Requested</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Error_Log__c</field>
            <value>
                <stringValue>&apos;Conga error requesting preview pdf. Conga taking more that 15 minutes to generate pdf&apos;</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Conga Error</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>CPQ_API_Error</name>
        <label>CPQ API Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Log_the_error_CPQ_API_Error</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Products Added</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Error_Log__c</field>
            <value>
                <stringValue>&apos;CPQ API error. SF CPQ taking more that 15 minutes to calculate CPQ rules&apos;</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Sub_Status__c</field>
            <value>
                <stringValue>Conga Error</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Expire_the_Offer</name>
        <label>Expire the Offer</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Log_the_error_Expire_the_offer</targetReference>
        </faultConnector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Expired and regenerated</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Expired</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Cancelled</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Deferred</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Rejected</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__Status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Signed</stringValue>
            </value>
        </filters>
        <filters>
            <field>SBQQ__ExpirationDate__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>SBQQ__Status__c</field>
            <value>
                <stringValue>Expired</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Set_the_start_date_time_for_Error_Tracking</name>
        <label>Set the start date time for Error Tracking</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Cancelled_or_Expired</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Log_the_error_Set_the_start_date_time_for_Error_Tracking</targetReference>
        </faultConnector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Preview Requested</stringValue>
            </value>
        </filters>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Contract requested</stringValue>
            </value>
        </filters>
        <filters>
            <field>Sub_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Products Added</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Error_Tracking_Start_Date_Time__c</field>
            <value>
                <elementReference>formula_Error_Logging_Time</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_the_start_date_time_for_Error_Tracking</targetReference>
        </connector>
        <filterFormula>AND(
    {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
    CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;Quote_AS_Error_Handler,&quot;) = false,
    OR(
        ISCHANGED({!$Record.Sub_Status__c}),
        ISCHANGED({!$Record.SBQQ__ExpirationDate__c}),
        ISCHANGED({!$Record.Agent_Email__c}),
        ISCHANGED({!$Record.SBQQ__Status__c})
     )
)</filterFormula>
        <object>SBQQ__Quote__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <name>Conga_Error_Logging</name>
            <connector>
                <targetReference>Conga_Preview_Contract</targetReference>
            </connector>
            <label>Conga Error Logging</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Hours</offsetUnit>
            <recordField>Error_Tracking_Start_Date_Time__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <scheduledPaths>
            <name>Quote_Expiry</name>
            <connector>
                <targetReference>Expire_the_Offer</targetReference>
            </connector>
            <label>Quote Expiry</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Days</offsetUnit>
            <recordField>SBQQ__ExpirationDate__c</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
