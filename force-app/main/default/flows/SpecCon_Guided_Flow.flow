        <locationX>2910</locationX>
        <locationY>1790</locationY>
        <defaultConnector>
            <targetReference>Set_CUA_Status</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Without Exempt</defaultConnectorLabel>
        <rules>
            <name>With_Exempt</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
