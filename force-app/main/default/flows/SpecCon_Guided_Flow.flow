    <screens>
        <name>screen_Confirm_Moodle_Updates_Made</name>
        <label>Confirm Moodle Updates Made</label>
        <locationX>3108</locationX>
        <locationY>2738</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>update_cua_manual_integration</targetReference>
        </connector>
        <fields>
            <name>header_manual_moodle_update</name>
            <fieldText>&lt;p style=&quot;text-align: center;&quot;&gt;&lt;strong style=&quot;font-size: 20px; background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;{!heading_text}&lt;/strong&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>text_manual_moodle_update_error</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;CRM failed to automatically update Moodle due to the following error: {!update_moodle}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
            <visibilityRule>
                <conditionLogic>NOT 1 AND 2</conditionLogic>
                <conditions>
                    <leftValueReference>update_moodle</leftValueReference>
                    <operator>StartsWith</operator>
                    <rightValue>
                        <stringValue>Success</stringValue>
                    </rightValue>
                </conditions>
                <conditions>
                    <leftValueReference>update_moodle</leftValueReference>
                    <operator>IsNull</operator>
                    <rightValue>
                        <booleanValue>false</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>text_update_manually</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;This application requires a manual confirmation of updates made to assessment conditions. If this assessment is:﻿&lt;/span&gt;&lt;/p&gt;&lt;ol&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;a Moodle Lesson activity - manually update the new due date or arrangements in Moodle by using the &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/learning-teaching/TeachHQ/moodle/quiz/how-to/allow-extensions-and-reattempts&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;&lt;u&gt;override function&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;;&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;any other type of Moodle activity - please ensure teaching staff are aware of the new conditions as shown in the Special Consideration Dashboard so that late penalties are not applied;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;approved to be exempted - follow these instructions to &lt;/span&gt;&lt;a href=&quot;https://www.monash.edu/learning-teaching/teachhq/moodle/gradebook/how-to/exclude-grades&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(0, 109, 174);&quot;&gt;&lt;u&gt;exclude the grade&lt;/u&gt;&lt;/a&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt; from Gradebook.&lt;/span&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(200, 0, 143);&quot;&gt;Return to this screen and click the ‘Confirm Updates Made’ button to close this application once the required action is complete.&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <fields>
            <name>screen_Confirm_Moodle_Updates_Made_Section1</name>
            <fieldType>RegionContainer</fieldType>
            <fields>
                <name>screen_Confirm_Moodle_Updates_Made_Section1_Column1</name>
                <fieldType>Region</fieldType>
                <fields>
                    <name>moodle_req_1</name>
                    <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;Unit&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;{!get_cua.Unit_Attempt__r.Unit_Code__c} - &lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 255, 255);&quot;&gt;{!get_cua.Unit_Attempt__r.Title__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;Assessment Name&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;{!get_cua.Assessment_Name__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0);&quot;&gt;Assessment Type&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;{!get_cua.Assessment_Type__c}&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;Outcome&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;{!get_enquiry.Case_Outcome__c}&lt;/span&gt;&lt;/p&gt;</fieldText>
                    <fieldType>DisplayText</fieldType>
                    <styleProperties>
                        <verticalAlignment>
                            <stringValue>top</stringValue>
                        </verticalAlignment>
                        <width>
                            <stringValue>12</stringValue>
                        </width>
