    <decisions>
        <name>Should_Update_Moodle</name>
        <label>Should Update Moodle</label>
        <locationX>2910</locationX>
        <locationY>2414</locationY>
        <defaultConnector>
            <targetReference>send_email_2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>should_update_moodle_yes_assignment</name>
            <conditionLogic>1 AND (2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>can_update_moodle</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>decision_picklist_w_exempt</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>decision_approve</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>decision_picklist</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>decision_approve</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_cua.Assessment_Type__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Assignment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>update_moodle</targetReference>
            </connector>
            <label>Yes - Assignment</label>
        </rules>
        <rules>
            <name>should_update_moodle_yes_quiz</name>
            <conditionLogic>1 AND (2 OR 3) AND 4 AND 5</conditionLogic>
            <conditions>
                <leftValueReference>can_update_moodle</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>decision_picklist_w_exempt</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>decision_approve</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>decision_picklist</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>decision_approve</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_cua.Assessment_Type__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Quiz</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Quiz_Attempts.moodleUnreachable</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Moodle_Quiz</targetReference>
            </connector>
            <label>Yes - Quiz</label>
        </rules>
    </decisions>
    <description>SA-2094 - Guided flow for Chief Examiners and Unit Spec Con contacts.</description>
    <environments>Default</environments>
    <formulas>
        <name>can_update_moodle</name>
        <dataType>Boolean</dataType>
        <expression>!ISBLANK({!get_cua.Moodle_Assessment_ID__c}) &amp;&amp;
(CONTAINS({!get_cua.Assessment_Type__c}, &quot;Assignment&quot;) || CONTAINS({!get_cua.Assessment_Type__c}, &quot;Quiz&quot;))</expression>
    </formulas>
    <formulas>
        <name>complex_assessment_val</name>
        <dataType>String</dataType>
        <expression>IF({!get_cua.Complex_Assignment_Indicator__c}, &quot;Yes&quot;, &quot;No&quot;)</expression>
    </formulas>
    <formulas>
        <name>date_input_error_msg</name>
        <dataType>String</dataType>
        <expression>IF(
  ISPICKVAL({!get_enquiry.Category_Level_1__c}, &quot;Short Extension&quot;),
  /* When Category_Level_1__c equals &apos;Short Extension&apos; */
  IF(
    CONTAINS({!get_cua.Assessment_Type__c}, &quot;Quiz&quot;),
    &quot;Date cannot be less than two days from today.&quot;,
    &quot;Date cannot be less than the short extension minimum of two calendar days (&quot; + TEXT({!get_cua.Assessment_Due_Date_New__c}) + &quot;).&quot;
  ),
  /* When Category_Level_1__c is NOT &apos;Short Extension&apos; */
  IF(
    CONTAINS({!get_cua.Assessment_Type__c}, &quot;Quiz&quot;),
    IF(
      {!default_new_due_date} &gt; {!get_cua.Assessment_Due_Date_New__c},
      &quot;Date cannot be less than two days from today.&quot;,
      &quot;Date cannot be less than the date approved by the Spec con team (&quot; + TEXT({!get_cua.Assessment_Due_Date_New__c}) + &quot;).&quot;
    ),
    &quot;Date cannot be less than the date approved by the Spec con team (&quot; + TEXT({!get_cua.Assessment_Due_Date_New__c}) + &quot;)&quot;
  )
)</expression>
    </formulas>
    <formulas>
        <name>decision_picklists_result</name>
        <dataType>String</dataType>
        <expression>BLANKVALUE({!decision_picklist}, {!decision_picklist_w_exempt})</expression>
    </formulas>
    <formulas>
        <name>default_new_due_date</name>
        <dataType>Date</dataType>
        <expression>IF(
    CONTAINS({!get_cua.Assessment_Type__c}, &apos;Quiz&apos;),
    IF(
        {!get_cua.Assessment_Due_Date_New__c} &gt; (TODAY() + 2),
        {!get_cua.Assessment_Due_Date_New__c},
        TODAY() + 2
    ),
    {!get_cua.Assessment_Due_Date_New__c}
)</expression>
    </formulas>
    <formulas>
        <name>heading_text</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE(TEXT({!get_enquiry.Category_Level_1__c}), &quot;Extension&quot;, &quot;extension&quot;) + 
IF({!get_cua.Complex_Assignment_Indicator__c}, &quot; complex&quot;, &quot;&quot;) + &quot; application&quot;</expression>
    </formulas>
    <formulas>
        <name>is_owner_user</name>
        <dataType>Boolean</dataType>
        <expression>LEFT({!get_enquiry.OwnerId},3) == &apos;005&apos;</expression>
    </formulas>
    <formulas>
        <name>message_2_len</name>
        <dataType>String</dataType>
        <expression>TEXT(LEN({!message_for_student_2}))</expression>
    </formulas>
    <formulas>
        <name>message_len</name>
        <dataType>String</dataType>
        <expression>TEXT(LEN({!message_for_student}))</expression>
    </formulas>
    <formulas>
        <name>new_due_date</name>
        <dataType>Date</dataType>
        <expression>NULLVALUE({!new_due_date_input},{!get_cua.Assessment_Due_Date_New__c})</expression>
    </formulas>
    <formulas>
        <description>Days between Original Due Date and New Due Date</description>
        <name>number_of_extension_days</name>
        <dataType>Number</dataType>
        <expression>{!get_cua.Assessment_Due_Date_New__c} - {!get_cua.Assessment_Due_Date_Original__c}</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>quiz_new_allowable_attempts</name>
        <dataType>Number</dataType>
        <expression>IF(
  {!Get_Quiz_Attempts.attemptsAllowed} &gt; 0 &amp;&amp; {!Get_Quiz_Attempts.attemptsTaken} &gt;= {!Get_Quiz_Attempts.attemptsAllowed},
  {!Get_Quiz_Attempts.attemptsAllowed} + 1, 
  NULL
)</expression>
        <scale>0</scale>
    </formulas>
