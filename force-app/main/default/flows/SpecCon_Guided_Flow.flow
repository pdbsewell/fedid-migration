        <locationX>2206</locationX>
        <locationY>3638</locationY>
        <defaultConnector>
            <targetReference>screen_email_error</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>email_sent_successfully_yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>send_email</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>update_case_solved</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>email_sent_successfully_2</name>
        <label>Email Sent Successfully</label>
        <locationX>3240</locationX>
        <locationY>2630</locationY>
        <defaultConnector>
            <targetReference>email_error_2</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>email_sent_successfully_yes_2</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>send_email_2</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_Confirm_Moodle_Updates_Made</targetReference>
