    </decisions>
    <decisions>
        <name>Has_Attempts_Remaining</name>
        <label>Has Attempts Remaining</label>
        <locationX>2690</locationX>
        <locationY>974</locationY>
        <defaultConnector>
            <targetReference>get_spec_con_queue</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Has_Attempts_Remaining_Yes</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Get_Quiz_Attempts.attemptsAllowed</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>0.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Quiz_Attempts.attemptsAllowed</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Quiz_Attempts.attemptsTaken</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_decision</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
        <rules>
            <name>Has_Attempts_Remaining_Eligibile</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Eligible &amp; Exhausted Attempts</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_decision</targetReference>
            </connector>
            <label>No But Eligible</label>
        </rules>
    </decisions>
    <decisions>
        <name>is_action_required</name>
        <label>Is Action Required</label>
        <locationX>1502</locationX>
        <locationY>866</locationY>
        <defaultConnector>
            <targetReference>screen_already_resolved</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>is_action_required_moodle_and_email</name>
            <conditionLogic>NOT (1 OR 2)</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Moodle_Integration_Status__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Success</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_cua.Emails_Sent__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Should_Update_Moodle</targetReference>
            </connector>
            <label>Moodle Update &amp; Email</label>
        </rules>
        <rules>
            <name>is_action_required_moodle_update</name>
            <conditionLogic>NOT 1</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Moodle_Integration_Status__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Success</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>screen_Confirm_Moodle_Updates_Made</targetReference>
            </connector>
            <label>Moodle Update</label>
        </rules>
        <rules>
            <name>is_action_required_email</name>
            <conditionLogic>NOT 1</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Emails_Sent__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>is_alt_assessment_email</targetReference>
            </connector>
            <label>Email</label>
        </rules>
    </decisions>
    <decisions>
        <name>is_alt_assessment_email</name>
        <label>Is Alt Assessment</label>
        <locationX>1678</locationX>
        <locationY>974</locationY>
        <defaultConnector>
            <targetReference>send_email</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>is_alt_assessment_yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Approved Alternative Assessment</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_email_not_sent_alt_assess</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
