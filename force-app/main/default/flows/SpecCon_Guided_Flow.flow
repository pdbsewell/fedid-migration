                        </width>
                    </styleProperties>
                    <validationRule>
                        <errorMessage>&lt;p&gt;Instructions are too long ({!message_len} characters)&lt;/p&gt;</errorMessage>
                        <formulaExpression>LEN({!message_for_student_2}) &lt; 5000000</formulaExpression>
                    </validationRule>
                </fields>
                <fields>
                    <name>text_email_not_sent_alt_2</name>
