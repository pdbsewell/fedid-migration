    <decisions>
        <name>pre_flow_checks</name>
        <label>Pre Flow Checks</label>
        <locationX>1128</locationX>
        <locationY>350</locationY>
        <defaultConnector>
            <targetReference>Can_Query_Quiz_Info</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Run Flow</defaultConnectorLabel>
        <rules>
            <name>no_flow_access</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Permission.Spec_Con_Guided_Flow</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_no_flow_access</targetReference>
            </connector>
            <label>No Flow Access</label>
        </rules>
        <rules>
            <name>retrieve_error</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>screen_retrieve_error</targetReference>
            </connector>
            <label>Retrieve Error</label>
        </rules>
        <rules>
            <name>user_is_not_owner</name>
            <conditionLogic>NOT 1</conditionLogic>
            <conditions>
                <leftValueReference>get_enquiry.OwnerId</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>$User.Id</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>retrieve_owner</targetReference>
            </connector>
            <label>User Is Not Owner</label>
        </rules>
    </decisions>
    <decisions>
        <name>retrieve_owner</name>
        <label>Retrieve Owner</label>
        <locationX>710</locationX>
        <locationY>458</locationY>
        <defaultConnector>
            <targetReference>screen_not_owner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Group</defaultConnectorLabel>
        <rules>
            <name>retrieve_owner_user</name>
