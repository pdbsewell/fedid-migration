            <targetReference>screen_decision</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Needs_Quiz_Info_Yes</name>
            <conditionLogic>and</conditionLogic>
