    <decisions>
        <name>already_has_outcome</name>
        <label>Already Has Outcome</label>
        <locationX>2206</locationX>
        <locationY>758</locationY>
        <defaultConnector>
            <targetReference>Needs_Quiz_Info</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>has_decision_yes_approved</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Status__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Approved</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>is_action_required</targetReference>
            </connector>
            <label>Yes - Approved</label>
        </rules>
        <rules>
            <name>has_decision_not_approved</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Declined</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_cua.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Withdrawn</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>screen_already_resolved</targetReference>
            </connector>
            <label>Yes - Not Approved</label>
        </rules>
    </decisions>
    <decisions>
        <name>Can_Query_Quiz_Info</name>
        <label>Can Query Quiz Info</label>
        <locationX>2206</locationX>
        <locationY>458</locationY>
        <defaultConnector>
            <targetReference>already_has_outcome</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Query_Quiz_Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>get_cua.Assessment_Type__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Quiz</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>get_cua.Moodle_Assessment_ID__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Quiz_Attempts</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>email_sent_successfully</name>
