            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Result Is Incomplete</label>
        </rules>
    </decisions>
    <decisions>
        <name>Validate_Result_Null</name>
        <label>Validate Result Null</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Result Is Not Null</defaultConnectorLabel>
        <rules>
            <name>Result_Is_Null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>formula_TRUE_myRule_11</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Certificate_To_Empty</targetReference>
            </connector>
            <label>Result Is Null</label>
        </rules>
    </decisions>
    <decisions>
        <name>Validate_Result_Status_Credit_Point</name>
        <label>Validate Result Status Credit Point</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Validate_Result_Fail</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Result Is Not Pass With Credit Points</defaultConnectorLabel>
        <rules>
            <name>Result_Is_Pass_With_Credit_Points</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Course_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Short_Course</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Course_Result__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pass with credit points</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Course_Result_To_Pass_With_Credit_Points</targetReference>
            </connector>
            <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
            <label>Result Is Pass With Credit Points</label>
        </rules>
    </decisions>
    <description>Updates the certificate to be printed field based on the outcome</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_TRUE_myRule_11</name>
        <dataType>Boolean</dataType>
        <expression>AND(
{!$Record.Course_Type__c} = &apos;Short_Course&apos;,
ISPICKVAL( {!$Record.Course_Result__c} ,&quot;&quot;),
NOT(ISPICKVAL(PRIORVALUE({!$Record.Course_Result__c}),&quot;&quot;)))</expression>
    </formulas>
    <interviewLabel>Application Course Preference : AS : Update Certificate Be Printed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Application Course Preference : AS : Update Certificate Be Printed</label>
    <processMetadataValues>
