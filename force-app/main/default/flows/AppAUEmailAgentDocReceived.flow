<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <description>The agent hasn&apos;t been notified that the application is accepted by the applicant. Write a log message and link it to the application.</description>
        <name>FailedtoSendEmailtoAgent</name>
        <label>Failed to Send Email to Agent</label>
        <locationX>314</locationX>
        <locationY>1295</locationY>
        <actionName>Nebula__FlowRecordLogEntry</actionName>
        <actionType>apex</actionType>
        <dataTypeMappings>
            <typeName>T__record</typeName>
            <typeValue>Application__c</typeValue>
        </dataTypeMappings>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>faultMessage</name>
            <value>
                <elementReference>FaultMessageText</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>flowName</name>
            <value>
                <stringValue>AppAUEmailAgentDocReceived</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>message</name>
            <value>
                <elementReference>LogMessageText</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>record</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>saveLog</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>shouldThrowFaultMessageException</name>
            <value>
                <elementReference>IsException</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>tagsString</name>
            <value>
                <elementReference>LogTag</elementReference>
            </value>
        </inputParameters>
        <nameSegment>Nebula__FlowRecordLogEntry</nameSegment>
        <offset>0</offset>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>
    <actionCalls>
        <name>Notify</name>
        <label>Notify</label>
        <locationX>314</locationX>
        <locationY>1187</locationY>
        <actionName>customNotificationAction</actionName>
        <actionType>customNotificationAction</actionType>
        <connector>
            <targetReference>FailedtoSendEmailtoAgent</targetReference>
        </connector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>customNotifTypeId</name>
            <value>
                <elementReference>GetNotification.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>recipientIds</name>
            <value>
                <elementReference>GroupId</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>title</name>
            <value>
                <elementReference>NotificationTitle</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>body</name>
            <value>
                <elementReference>NotificationBody</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>targetId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>targetPageRef</name>
        </inputParameters>
        <nameSegment>customNotificationAction</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <actionCalls>
        <description>Send an email and log the fact against the application</description>
        <name>SendEmailtoAgent</name>
        <label>Send Email to Agent</label>
        <locationX>50</locationX>
        <locationY>647</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <faultConnector>
            <targetReference>Fault_Message_Failed_to_Send_Email</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>senderType</name>
            <value>
                <stringValue>OrgWideEmailAddress</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderAddress</name>
            <value>
                <elementReference>CONST_FromAddress</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>relatedRecordId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>recipientId</name>
            <value>
                <elementReference>AgentContact</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>logEmailOnSend</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailTemplateId</name>
            <value>
                <elementReference>EmailTemplate</elementReference>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>61.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Adds the group id to a text collection</description>
        <name>BuildRecipentList</name>
        <label>Build Recipent List</label>
        <locationX>314</locationX>
        <locationY>1079</locationY>
        <assignmentItems>
            <assignToReference>GroupId</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>GetRecipientGroup.Id</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Notify</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>The error message to be logged</description>
        <name>Fault_Message_Agent_Invalid</name>
        <label>Fault Message - Agent Invalid</label>
        <locationX>578</locationX>
        <locationY>539</locationY>
        <assignmentItems>
            <assignToReference>FaultMessageText</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Check that the Agent user is active and linked to a Contact</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>LogMessageText</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>{!AgentName} [{!AgentUser}] appears to be invalid</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>IsException</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <isGoTo>true</isGoTo>
            <targetReference>GetNotification</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assign the flow generated error message</description>
        <name>Fault_Message_Failed_to_Send_Email</name>
        <label>Fault Message - Failed to Send Email</label>
        <locationX>314</locationX>
        <locationY>755</locationY>
        <assignmentItems>
            <assignToReference>FaultMessageText</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>LogMessageText</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Failed to send progress update to Agent</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>IsException</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>GetNotification</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>CONST_CustomNotification</name>
        <dataType>String</dataType>
        <value>
            <stringValue>UniCRM_Alert_Notification</stringValue>
        </value>
    </constants>
    <constants>
        <name>CONST_EmailTemplateName</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Notify_Verified_Document_Received_To_App_Agent</stringValue>
        </value>
    </constants>
    <constants>
        <name>CONST_FromAddress</name>
        <dataType>String</dataType>
        <value>
            <stringValue>no.reply-future@f.e.monash.edu</stringValue>
        </value>
    </constants>
    <constants>
        <name>CONST_NotificationGroup</name>
        <dataType>String</dataType>
        <value>
            <stringValue>WR_Central_Admissions_Exception</stringValue>
        </value>
    </constants>
    <constants>
        <name>LogTag</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Admissions,Digitary</stringValue>
        </value>
    </constants>
    <decisions>
        <description>The application owner must be active and have a linked contact record.</description>
        <name>CheckAgentStatus</name>
        <label>Check Agent Status</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>Fault_Message_Agent_Invalid</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Invalid Agent</defaultConnectorLabel>
        <rules>
            <name>ValidAgent</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>AgentIsActive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>AgentContact</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>GetEmailTemplate</targetReference>
            </connector>
            <label>Valid Agent</label>
        </rules>
    </decisions>
    <description>Send acknowledgment emails to AP agents upon verified document receipt. Failures are logged with Nebula Logger, while successes are recorded as activities linked to the application.</description>
    <environments>Default</environments>
    <interviewLabel>Application : AU : Email Agent - Document Received {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Application : AU : Email Agent - Document Received</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Get the details of the application owner record. The owner is the Agent we need to email.</description>
        <name>GetAgent</name>
        <label>Get Agent</label>
        <locationX>314</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>CheckAgentStatus</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Owner:User.Id</elementReference>
            </value>
        </filters>
        <object>User</object>
        <outputAssignments>
            <assignToReference>AgentContact</assignToReference>
            <field>ContactId</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentUser</assignToReference>
            <field>Id</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentIsActive</assignToReference>
            <field>IsActive</field>
        </outputAssignments>
        <outputAssignments>
            <assignToReference>AgentName</assignToReference>
            <field>Name</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <name>GetEmailTemplate</name>
        <label>Get Email Template</label>
        <locationX>50</locationX>
        <locationY>539</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>SendEmailtoAgent</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>CONST_EmailTemplateName</elementReference>
            </value>
        </filters>
        <object>EmailTemplate</object>
        <outputAssignments>
            <assignToReference>EmailTemplate</assignToReference>
            <field>Id</field>
        </outputAssignments>
    </recordLookups>
    <recordLookups>
        <description>Lookup the custom notification id</description>
        <name>GetNotification</name>
        <label>Get Notification</label>
        <locationX>314</locationX>
        <locationY>863</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>GetRecipientGroup</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>UniCRM_Alert_Notification</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>CustomNotificationType</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>Look up the public group to send the notifications too</description>
        <name>GetRecipientGroup</name>
        <label>Get Recipient Group</label>
        <locationX>314</locationX>
        <locationY>971</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>BuildRecipentList</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>CONST_NotificationGroup</elementReference>
            </value>
        </filters>
        <filters>
            <field>Type</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Regular</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>GetAgent</targetReference>
        </connector>
        <filterFormula>AND(
    {!$Setup.Bypass_Mute_Request__c.Bypass_All_Flows__c} = False,
    CONTAINS({!$Label.Bypass_Specific_Flow}, &quot;AppAUEmailAgentDocReceived,&quot;) = False,
    {!$Record.Source_System__c}=&apos;AgentPortal&apos;,
    ISBLANK({!$Record.Last_Verified_Document_Received_Date__c}) = False,
    ISCHANGED({!$Record.Last_Verified_Document_Received_Date__c}) = True
)</filterFormula>
        <object>Application__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <variables>
        <description>The agent contact record linked to the user</description>
        <name>AgentContact</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>Flag that holds the active status of the agent user record</description>
        <name>AgentIsActive</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <name>AgentName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>AgentUser</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>EmailTemplate</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>The error message to be logged</description>
        <name>FaultMessageText</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <description>The public group that will receive the notification</description>
        <name>GroupId</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>IsException</name>
        <dataType>Boolean</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
        <value>
            <booleanValue>false</booleanValue>
        </value>
    </variables>
    <variables>
        <description>The message to be written to the log entry.</description>
        <name>LogMessageText</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>NotificationBody</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>The agent (owner) email address may not be valid or accessible</stringValue>
        </value>
    </variables>
    <variables>
        <name>NotificationTitle</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>Unable to progress application {!$Record.Name}</stringValue>
        </value>
    </variables>
</Flow>
